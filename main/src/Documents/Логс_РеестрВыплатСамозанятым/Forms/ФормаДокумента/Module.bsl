&НаКлиенте
Процедура ВыборФайлаCSVЗавершение_Райффайзен(ВыбранныеФайлы, ДополнительныеПараметры) Экспорт
	
	Если ВыбранныеФайлы <> Неопределено Тогда
		ПутьКФайлу = ВыбранныеФайлы[0];
	Иначе
		Возврат;
	КонецЕсли;
	
	Потоки = СформироватьПотокиНаСервере_Райффайзен(Объект.Ссылка);
	
	Для Каждого ДанныеПотока из Потоки Цикл
		Если ДанныеПотока.Заказчик = "" Тогда
			ИмяФайла = ПутьКФайлу;
		Иначе
			ИмяФайла = ?(СтрЗаканчиваетсяНа(ПутьКФайлу, ".csv"),
							Лев(ПутьКФайлу, СтрДлина(ПутьКФайлу)-3) ,ПутьКФайлу) 
					+"("+ДанныеПотока.Заказчик+").csv";
		КонецЕсли;
		Файл = Новый ЗаписьТекста(ИмяФайла, КодировкаТекста.ANSI);
		Файл.ЗаписатьСтроку(ДанныеПотока.Поток);
		Файл.Закрыть();
	КонецЦикла;
	
	//Предупреждение("Файл сохранен");
	ОбщегоНазначенияКлиент.СообщитьПользователю("Файл сохранен");
	
КонецПроцедуры  

&НаСервере
Функция СформироватьПотокиНаСервере_Райффайзен(Реестр)  
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	СотрудникиДополнительныеРеквизиты.Ссылка КАК Сотрудник,
	               |	СотрудникиДополнительныеРеквизиты.Ссылка.ФизическоеЛицо.Наименование КАК Наименование,
	               |	СотрудникиДополнительныеРеквизиты.Ссылка.ФизическоеЛицо КАК ФизическоеЛицо,
	               |	КадроваяИсторияСотрудниковСрезПоследних.Подразделение КАК Подразделение,
	               |	КадроваяИсторияСотрудниковСрезПоследних.Должность КАК Должность
	               |ПОМЕСТИТЬ втКадровыеДанные
	               |ИЗ
	               |	Справочник.Сотрудники.ДополнительныеРеквизиты КАК СотрудникиДополнительныеРеквизиты
	               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КадроваяИсторияСотрудников.СрезПоследних(, ) КАК КадроваяИсторияСотрудниковСрезПоследних
	               |		ПО СотрудникиДополнительныеРеквизиты.Ссылка = КадроваяИсторияСотрудниковСрезПоследних.Сотрудник
	               |			И СотрудникиДополнительныеРеквизиты.Ссылка.ФизическоеЛицо = КадроваяИсторияСотрудниковСрезПоследних.ФизическоеЛицо
	               |ГДЕ
	               |	СотрудникиДополнительныеРеквизиты.Свойство = &Свойство
	               |	И СотрудникиДополнительныеРеквизиты.Значение = &Значение
	               |	И СотрудникиДополнительныеРеквизиты.Ссылка.Логс_Самозанятый
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	Выплаты.НомерСтроки КАК НомерСтроки,
	               |	Выплаты.Контрагент.НаименованиеПолное КАК ФИО,
	               |	Выплаты.Договор.БанковскийСчетКонтрагента.НомерСчета КАК НомерСчета,
	               |	Выплаты.СуммаСНалогом КАК СуммаСНалогом,
	               |	ВЫБОР
	               |		КОГДА Выплаты.Договор.Организация = &ОЛ
	               |			ТОГДА Выплаты.Договор.Логс_ЗаказчикСЗ
	               |		ИНАЧЕ """"
	               |	КОНЕЦ КАК Заказчик,
	               |	0 КАК СуммаУдержаний,
	               |	втКадровыеДанные.ФизическоеЛицо.Фамилия КАК Фамилия,
	               |	втКадровыеДанные.ФизическоеЛицо.Имя КАК Имя,
	               |	втКадровыеДанные.ФизическоеЛицо.Отчество КАК Отчество,
	               |	втКадровыеДанные.Подразделение КАК Подразделение,
	               |	втКадровыеДанные.Должность КАК Должность,
	               |	втКадровыеДанные.ФизическоеЛицо.ДатаРождения КАК ДатаРождения,
	               |	Выплаты.Договор.БанковскийСчетКонтрагента.БИКБанка КАК БИКБанка,
	               |	втКадровыеДанные.Сотрудник.Код КАК ТабельныйНомер
	               |ИЗ
	               |	Документ.Логс_РеестрВыплатСамозанятым.Выплаты КАК Выплаты
	               |		ЛЕВОЕ СОЕДИНЕНИЕ втКадровыеДанные КАК втКадровыеДанные
	               |		ПО Выплаты.Партнер.Наименование = втКадровыеДанные.Наименование
	               |ГДЕ
	               |	Выплаты.Ссылка = &Реестр
	               |	И Выплаты.Договор.БанковскийСчет.Банк = &Банк
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	НомерСтроки";
	Запрос.УстановитьПараметр("ОЛ", Логс_ДополнительныеПроцедурыИФункцииПовтИсп.ОрганизацияЛогсис());
	//Обмен с CRM (Сотрудники) (ПланВидовХарактеристик.ДополнительныеРеквизитыИСведения)
	Запрос.УстановитьПараметр("Свойство", ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.ПолучитьСсылку(Новый УникальныйИдентификатор("dbf78901-85ca-11e9-80b9-000c29f360b4")));
	Запрос.УстановитьПараметр("Значение", Истина);                                                                                
	//Подставим банк из констант
	Запрос.УстановитьПараметр("Банк",Логс_ДополнительныеПроцедурыИФункцииПовтИсп.ПолучитьЗначениеКонстантыЛогс("БанкРайффайзен"));
	Запрос.УстановитьПараметр("Реестр", Реестр);

	Выборка = Запрос.Выполнить().Выбрать();
		
	Заказчик = Неопределено;
	//Поток = "";
	РазделительЗначений = ";";
	РазделительСтрок = Символы.ПС;
	
	Потоки = Новый Массив;
	Индекс = -1;  
	НомерСтрока = 0;
	
	Пока Выборка.Следующий() Цикл
		
		Если Заказчик<>Выборка.Заказчик Тогда
			//Если Заказчик = Неопределено Тогда
			Заказчик = Выборка.Заказчик;
			Потоки.Добавить(Новый Структура("Заказчик, Поток",Заказчик,""));
			Индекс = Индекс+1;
			Первая = Истина;
			Потоки[Индекс].Поток = Потоки[Индекс].Поток + СоздатьЗаголовкиCSV(РазделительЗначений) + РазделительСтрок;
			
		КонецЕсли;
		
		Если НЕ Первая Тогда
			Потоки[Индекс].Поток = Потоки[Индекс].Поток + РазделительСтрок;
		Иначе
			Первая = Ложь;
		КонецЕсли;
		
		Потоки[Индекс].Поток = Потоки[Индекс].Поток + Выборка.ТабельныйНомер + РазделительЗначений;
		
		//ФИО = ФизическиеЛицаКлиентСервер.ЧастиИмени(Выборка.ФИО);
		Потоки[Индекс].Поток = Потоки[Индекс].Поток + Выборка.Фамилия + РазделительЗначений + Выборка.Имя + РазделительЗначений + Выборка.Отчество + РазделительЗначений;
		Потоки[Индекс].Поток = Потоки[Индекс].Поток + Формат(Выборка.ДатаРождения, "ДФ=dd.MM.yyyy") + РазделительЗначений;
		Потоки[Индекс].Поток = Потоки[Индекс].Поток + Выборка.Должность + РазделительЗначений + Выборка.Подразделение + РазделительЗначений;
		
		Потоки[Индекс].Поток = Потоки[Индекс].Поток + Выборка.НомерСчета + РазделительЗначений;
		Потоки[Индекс].Поток = Потоки[Индекс].Поток + Выборка.БикБанка + РазделительЗначений;
		
		Потоки[Индекс].Поток = Потоки[Индекс].Поток + Формат(Выборка.СуммаСНалогом, "ЧДЦ=2; ЧРД=.; ЧН=0.00; ЧГ=") + РазделительЗначений;
		
		//Номер карты
		Потоки[Индекс].Поток = Потоки[Индекс].Поток + "" + РазделительЗначений; 
				
		Потоки[Индекс].Поток = Потоки[Индекс].Поток + Формат(0, "ЧДЦ=2; ЧРД=.; ЧН=0.00; ЧГ=") + РазделительЗначений;
		Потоки[Индекс].Поток = Потоки[Индекс].Поток + Формат(0, "ЧДЦ=2; ЧРД=.; ЧН=0.00; ЧГ=") + РазделительЗначений;
		Потоки[Индекс].Поток = Потоки[Индекс].Поток + Формат(0, "ЧДЦ=2; ЧРД=.; ЧН=0.00; ЧГ=");
						
	КонецЦикла;
	
	Возврат Потоки;
    
КонецФункции     


