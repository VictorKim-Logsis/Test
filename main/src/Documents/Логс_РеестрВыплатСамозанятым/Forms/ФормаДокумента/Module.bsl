#Область ВыгрузитьПоAPI_РайффайзенБанк

&НаСервере
Процедура ВыгрузитьВРайффайзенБанкНаСервере()
	ПроверкаОтправки = Логс_ИнтеграцияРайффайзен.ПроверкаОтправки(Объект.Ссылка);
	Если НЕ ПроверкаОтправки Тогда 
		Если Объект.Выплаты.Количество() = 1 Тогда 
			Логс_ИнтеграцияРайффайзен.ОтправитьДанныеПоАПИРайффайзенОдиночнаяВыплата(Объект.Ссылка);
		Иначе
			//Логс_ИнтеграцияРайффайзен.ОтправитьДанныеПоАПИРайффайзенПакетом(Объект.Ссылка);
		КонецЕсли; 
		
	иначе
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Повторная отправка данных запрещена!"); 
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ВыгрузитьВРайффайзенБанк(Команда)
	Если Модифицированность Тогда 
		Записать();
	КонецЕсли;
	
	ВыгрузитьВРайффайзенБанкНаСервере();
КонецПроцедуры

#КонецОбласти

#Область РазделитьДокументПоЭкселю
//++ Ким Виктор 24.10.2024
//https://jira-sd.logsis.ru/projects/TSLOG/queues/custom/18/TSLOG-14756

&НаКлиенте
Процедура РазделитьПоЭкселю(Команда)
	
	Если Модифицированность Тогда
		Предупреждение("Для разделения реестра необходимо записать документ");
		Возврат;
	КонецЕсли;
	
	Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
	Диалог.Фильтр = "Excel файлы(*.xls;*.xlsx)|*.xls;*.xlsx";
	Диалог.Заголовок = НСтр("Открытие файла");
	ОповещениеЗавершения = Новый ОписаниеОповещения("ВыборФайлаXLSЗаверешение", ЭтотОбъект);
	Диалог.Показать(ОповещениеЗавершения);
		
КонецПроцедуры 

&НаКлиенте
Процедура ВыборФайлаXLSЗаверешение(ВыбранныеФайлы, ДополнительныеПараметры) Экспорт
	
	Если ВыбранныеФайлы <> Неопределено Тогда
		ПутьКФайлу = ВыбранныеФайлы[0];
	Иначе
		Возврат;
	КонецЕсли;   
	
	Оповещение = Новый ОписаниеОповещения("ЗагрузитьЗавершение", ЭтотОбъект);
	НачатьПомещениеФайла(Оповещение,, ПутьКФайлу, Ложь); 
	
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьЗавершение(Результат, Адрес, ПомещаемыйФайл, ДополнительныеПараметры) Экспорт
	
	ЗагрузитьИзЭксельНаСервере(Адрес, ПомещаемыйФайл);	
	ЭтаФорма.Прочитать();
	//ЭтаФорма.ОбновитьОтображениеДанных(); 
			
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьИзЭксельНаСервере(Адрес, ИмяФайла)  
		
	ДвоичныеДанные = ПолучитьИЗВременногоХранилища(Адрес);
	Расширение = ОбщегоНазначенияКлиентСервер.РасширениеБезТочки(ОбщегоНазначенияКлиентСервер.ПолучитьРасширениеИмениФайла(ИмяФайла));
	
	ИмяВременногоФайла = ПолучитьИмяВременногоФайла(Расширение);
	ДвоичныеДанные.Записать(ИмяВременногоФайла);
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.Прочитать(ИмяВременногоФайла, СпособЧтенияЗначенийТабличногоДокумента.Текст); 
	
	УдалитьФайлы(ИмяВременногоФайла);
	
	Построитель = Новый ПостроительОтчета;
	Построитель.ИсточникДанных = Новый ОписаниеИсточникаДанных(ТабличныйДокумент.Область(15, 2, ТабличныйДокумент.ВысотаТаблицы, ТабличныйДокумент.ШиринаТаблицы));
	Построитель.Выполнить();
	РезультатЧтения = Построитель.Результат.Выгрузить();
		
	ТаблицаОшибочных = СоответсвиеФИОКонтрагенту(РезультатЧтения);
		
	ДокОбъект = РеквизитФормыВЗначение("Объект");
	ТаблицаВыплаты = ДокОбъект.Выплаты;
	МассивУдаляемых = Новый Массив;
	КоличествоСтрокДО =  ТаблицаВыплаты.Количество();
	СуммаДо = Объект.СуммаДокумента;
	
	ТаблицаКопия = ТаблицаВыплаты.Выгрузить();
	ТаблицаКопия.Очистить();
	
	ЕстьИзменения = Ложь;
	
	Для Каждого Стр из ТаблицаОшибочных Цикл 
		
		СтрукутраПоиска = Новый Структура;
		СтрукутраПоиска.Вставить("НомерСтроки", Число(Стр.НомерСтроки));
		СтрукутраПоиска.Вставить("Партнер", стр.Партнер); 
		СтрукутраПоиска.Вставить("Контрагент", стр.Контрагент);
		МассивНайденных  = ТаблицаВыплаты.НайтиСтроки(СтрукутраПоиска);
		
		Для Каждого Элем из МассивНайденных Цикл 
			
			Если ТаблицаКопия.Найти(Число(Стр.НомерСтроки), "НомерСтроки") = Неопределено 
				И Элем.НомерСтроки = Число(Стр.НомерСтроки) Тогда
				НоваяСтрока = ТаблицаКопия.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, Элем); 
				
				Если МассивУдаляемых.Найти(Элем) = Неопределено Тогда 
					МассивУдаляемых.Добавить(Элем);
				КонецЕсли;	
			КонецЕсли;
		КонецЦикла;
				
	КонецЦикла;
	
	СоздатьДокументРеестрНаОсновеОшибочных(ТаблицаКопия);
	
	Для Каждого Найденный Из МассивУдаляемых Цикл
		
		Если Не ЕстьИзменения  Тогда 
			ЕстьИзменения = Истина;
		КонецЕсли;
	
		ТаблицаВыплаты.Удалить(Найденный);
	КонецЦикла;
	
	//СуммаПосле = Объект.СуммаДокумента;
	//КоличествоСтрокПосле = ТаблицаВыплаты.Количество();	
	
	ЗначениеВРеквизитФормы(ДокОбъект, "Объект");   
	Объект.Комментарий = "Количество строк до: " + КоличествоСтрокДО + ". " + "Сумма до: " + СуммаДо;
	ЭтаФорма.Записать();     
		
КонецПроцедуры

&НаСервере
Процедура СоздатьДокументРеестрНаОсновеОшибочных(ТаблицаКопия)
	
	РеестрНовый = Документы.Логс_РеестрВыплатСамозанятым.СоздатьДокумент();
	ЗаполнитьЗначенияСвойств(РеестрНовый, Объект,, "Выплаты, Проведен, Номер, СуммаДокумента");
	Для Каждого Стр из ТаблицаКопия Цикл 
		НоваяСтрока = РеестрНовый.Выплаты.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Стр);
	КонецЦикла;
	РеестрНовый.Комментарий = "Создан на основании: " + Объект.Ссылка;
	//РеестрНовый.ПересчитатьНалогВСтроках();
	РеестрНовый.Записать(РежимЗаписиДокумента.Проведение); 
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Создан документ " + РеестрНовый);
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция СоответсвиеФИОКонтрагенту(ТаблицаИзЭкселя)
	
	Запрос = Новый Запрос;
	Запрос.Текст =  ( "ВЫБРАТЬ
	                  |	ТаблицаИзЭкселя.ФИОРаботника КАК ФИОРаботника,
	                  |	ТаблицаИзЭкселя.__ КАК НомерСтроки,
	                  |	ТаблицаИзЭкселя.Сумма_Перевода КАК СуммаПеревода,
	                  |	ТаблицаИзЭкселя._ТекущегоСчетаВРублях_ВИностаннойВалюте КАК _ТекущегоСчетаВРублях_ВИностаннойВалюте,
	                  |	ТаблицаИзЭкселя.ЧекФНС КАК ЧекФНС
	                  |ПОМЕСТИТЬ ТаблицаЭкселя
	                  |ИЗ
	                  |	&ТаблицаИзЭкселя КАК ТаблицаИзЭкселя
	                  |;
	                  |
	                  |////////////////////////////////////////////////////////////////////////////////
	                  |ВЫБРАТЬ
	                  |	ТаблицаЭкселя.ФИОРаботника КАК ФИОРаботника,
	                  |	ТаблицаЭкселя.НомерСтроки КАК НомерСтроки,
	                  |	ТаблицаЭкселя.СуммаПеревода КАК СуммаПеревода,
	                  |	ТаблицаЭкселя._ТекущегоСчетаВРублях_ВИностаннойВалюте КАК _ТекущегоСчетаВРублях_ВИностаннойВалюте,
	                  |	ТаблицаЭкселя.ЧекФНС КАК ЧекФНС,
	                  |	Контрагенты.Ссылка КАК Контрагент,
	                  |	Контрагенты.Партнер КАК Партнер
	                  |ИЗ
	                  |	ТаблицаЭкселя КАК ТаблицаЭкселя
	                  |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Контрагенты
	                  |		ПО ТаблицаЭкселя.ФИОРаботника = Контрагенты.Наименование
	                  |ГДЕ
	                  |	ТаблицаЭкселя.ЧекФНС = ""ОШИБКА""" ) ;
	Запрос.УстановитьПараметр("ТаблицаИзЭкселя", ТаблицаИзЭкселя);
	Возврат Запрос.Выполнить().Выгрузить();
 
