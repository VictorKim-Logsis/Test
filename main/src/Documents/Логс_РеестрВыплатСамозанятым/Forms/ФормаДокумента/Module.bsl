&НаСервере
Функция СоздатьЗаголовкиCSV(разделитель)
    
    Массив = Новый Массив;
	Массив.Добавить("Таб. №");
	Массив.Добавить("Фамилия");
	Массив.Добавить("Имя");
	Массив.Добавить("Отчество");
	Массив.Добавить("Дата рождения");
	Массив.Добавить("Должность");
	Массив.Добавить("Подразделение");
	Массив.Добавить("Счет получателя");
	Массив.Добавить("БИК");
	Массив.Добавить("Сумма средств к зачислению на счет получателя");
	Массив.Добавить("Номер карты");
	Массив.Добавить("% конвертации в USD");
	Массив.Добавить("% конвертации в EUR");
	Массив.Добавить("Удержанная сумма в RUB");
	
    стрКолонки = "";
    Для каждого колонка Из Массив Цикл
        
        Если СтрДлина(стрКолонки)>0 Тогда
            стрКолонки = стрКолонки + разделитель;
        КонецЕсли;    
        
        стрКолонки = стрКолонки + колонка;
        
    КонецЦикла; 
    
    Возврат стрКолонки;
    
КонецФункции

&НаСервере
Функция СформироватьXMLСберБанк(Реестр)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	Логс_РеестрВыплатСамозанятым.Дата КАК Дата,
	               |	Логс_РеестрВыплатСамозанятым.Организация.Наименование КАК НаименованиеОрганизации,
	               |	Логс_РеестрВыплатСамозанятым.Организация.ИНН КАК ИНН,
	               |	isnull(Логс_РеестрВыплатСамозанятым.БанковскийСчет.НомерСчета, """") КАК НомерСчета,
	               |	isnull(Логс_РеестрВыплатСамозанятым.БанковскийСчет.БИКБанка, """") КАК БИК,
	               |	Логс_РеестрВыплатСамозанятым.БанковскийСчет.Логс_НомерДоговора КАК НомерДоговора
	               |ИЗ
	               |	Документ.Логс_РеестрВыплатСамозанятым КАК Логс_РеестрВыплатСамозанятым
	               |ГДЕ
	               |	Логс_РеестрВыплатСамозанятым.Ссылка = &Реестр";     
	Запрос.УстановитьПараметр("Реестр", Реестр);
	
	ВыборкаРеестр = Запрос.Выполнить().Выбрать();  
	Если НЕ ВыборкаРеестр.Следующий() Тогда
		Возврат "";
	КонецЕсли;  
	
	ДатаФормирования 		 = Формат(ТекущаяДата(), "ДФ=yyyy-MM-dd"); 	
	НомерДоговора 	 		 = ВыборкаРеестр.НомерДоговора;
	НаименованиеОрганизации  = ВыборкаРеестр.НаименованиеОрганизации; 	
	ИНН 				     = ВыборкаРеестр.ИНН;
	РасчетныйСчетОрганизации = ВыборкаРеестр.НомерСчета;
	БИК						 = ВыборкаРеестр.БИК;
	ИдПервичногоДокумента	 = Строка(Реестр.УникальныйИдентификатор());
	
	
	Запрос.Текст = "ВЫБРАТЬ
	               |	Выплаты.Контрагент.НаименованиеПолное КАК ФИО,
	               |	Выплаты.Договор.БанковскийСчетКонтрагента.НомерСчета КАК НомерСчета,
	               |	СУММА(Выплаты.СуммаСНалогом) КАК СуммаСНалогом,
	               |	ВЫБОР
	               |		КОГДА Выплаты.Договор.Организация = &ОЛ
	               |			ТОГДА Выплаты.Договор.Логс_ЗаказчикСЗ
	               |		ИНАЧЕ """"
	               |	КОНЕЦ КАК Заказчик,
	               |	0 КАК СуммаУдержаний,
	               |	""0000"" КАК ОтделениеБанка,
	               |	"""" КАК ФилиалОтделенияБанка,
	               |	Выплаты.Договор.Номер КАК НомерИндивидуальногоДоговора,
	               |	Выплаты.Договор.Дата КАК ДатаИндивидуальногоДоговора,
	               |	""21200"" КАК КодВалютнойОперации,
	               |	МИНИМУМ(Выплаты.НомерСтроки) КАК НомерСтроки
	               |ИЗ
	               |	Документ.Логс_РеестрВыплатСамозанятым.Выплаты КАК Выплаты
	               |ГДЕ
	               |	Выплаты.Ссылка = &Реестр
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	Выплаты.Договор.Дата,
	               |	Выплаты.Контрагент.НаименованиеПолное,
	               |	Выплаты.Договор.БанковскийСчетКонтрагента.НомерСчета,
	               |	ВЫБОР
	               |		КОГДА Выплаты.Договор.Организация = &ОЛ
	               |			ТОГДА Выплаты.Договор.Логс_ЗаказчикСЗ
	               |		ИНАЧЕ """"
	               |	КОНЕЦ,
	               |	Выплаты.Договор.Номер";
	Запрос.УстановитьПараметр("ОЛ", Логс_ДополнительныеПроцедурыИФункцииПовтИсп.ОрганизацияЛогсис());

	//ВыборкаВыплаты = Запрос.Выполнить().Выбрать();  
	ТаблицаВыплаты = Запрос.Выполнить().Выгрузить();
	
	ТаблицаДублейВыплаты = ТаблицаВыплаты.Скопировать();
	ТаблицаДублейВыплаты.Очистить();
	ПервыйСотрудникДубль = Неопределено;
	
	Для Каждого Стр из ТаблицаВыплаты Цикл 
		
		СтруктураПоиска = Новый Структура;
		СтруктураПоиска.Вставить("ФИО", 			Стр.ФИО);
		СтруктураПоиска.Вставить("СуммаСНалогом", 	Стр.СуммаСНалогом);
		МассивВыплаты = ТаблицаВыплаты.НайтиСтроки(СтруктураПоиска); 
		Если ПервыйСотрудникДубль <> Стр.ФИО И МассивВыплаты.Количество() > 1 И ТаблицаДублейВыплаты.Найти(Стр.НомерСтроки, "НомерСтроки") = Неопределено Тогда 
			ПервыйСотрудникДубль = Стр.Фио;
			Для каждого Дубль Из МассивВыплаты Цикл
				Если Дубль.НомерСтроки <> Стр.НомерСтроки И ТаблицаДублейВыплаты.Найти(Дубль.НомерСтроки, "НомерСтроки") = Неопределено Тогда
					НоваяСтрока = ТаблицаДублейВыплаты.Добавить();
					ЗаполнитьЗначенияСвойств(НоваяСтрока, Дубль);
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;

	СтруктураЗаголовка = Новый Структура;
	СтруктураЗаголовка.Вставить("ДатаФормирования", 		ДатаФормирования);
	СтруктураЗаголовка.Вставить("НомерДоговора", 			НомерДоговора);
	СтруктураЗаголовка.Вставить("НаименованиеОрганизации", 	НаименованиеОрганизации);
	СтруктураЗаголовка.Вставить("ИНН",						ИНН);
	СтруктураЗаголовка.Вставить("РасчетныйСчетОрганизации", РасчетныйСчетОрганизации);
	СтруктураЗаголовка.Вставить("БИК", 						БИК);
	СтруктураЗаголовка.Вставить("ИдПервичногоДокумента", 	ИдПервичногоДокумента);
	
	СтруктураВозврата = ПолучитьЗаписьХМЛ(СтруктураЗаголовка, ТаблицаВыплаты, ТаблицаДублейВыплаты, "Сбер");
	
	Потоки = Новый Массив;  
	Потоки.Добавить(Новый Структура("Заказчик, Поток", СтруктураВозврата.Заказчик,СтруктураВозврата.ПотокХМЛ));
	
	Для Каждого Стр из ТаблицаДублейВыплаты Цикл 
	
		СтруктураВозврата = ПолучитьЗаписьХМЛ(СтруктураЗаголовка, Стр,  ,"Сбер");
		Потоки.Добавить(Новый Структура("Заказчик, Поток", СтруктураВозврата.Заказчик,СтруктураВозврата.ПотокХМЛ));
				
	КонецЦикла;
	
	Возврат Потоки;
         	
КонецФункции  

&НаКлиенте
Процедура ЭкспортXMLСберБанкНерезиденты(Команда)
	//ЭкспортXMLСберБанкНерезидентыНаСервере();
	
	Если Модифицированность Тогда
		Предупреждение("Для экспорта реестра необходимо записать документ");
		Возврат;
	КонецЕсли; 
	
	Если НЕ Объект.СамозанятыеНерезиденты Тогда  
		Предупреждение("Данный формат используется для выгрузки нерезидентов!");
		Возврат;
	КонецЕсли;
	
		
	Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Сохранение);
	Диалог.Фильтр = "*.xml|*.xml";
	Диалог.Заголовок = НСтр("Сохранение файла");
	ОповещениеЗавершения = Новый ОписаниеОповещения("ВыборФайлаXMLСберЗавершение", ЭтотОбъект);
	Диалог.Показать(ОповещениеЗавершения);
	
КонецПроцедуры  

&НаКлиенте
Процедура ВыборФайлаXMLСберЗавершение(ВыбранныеФайлы, ДополнительныеПараметры) Экспорт

	Если ВыбранныеФайлы <> Неопределено Тогда
		ПутьКФайлу = ВыбранныеФайлы[0];
	Иначе
		Возврат;
	КонецЕсли;
	
	Потоки = СформироватьXMLСберБанк(Объект.Ссылка);
	НомерФайла = 1;
	Для Каждого ДанныеПотока из Потоки Цикл
		Если ДанныеПотока.Заказчик = "" Тогда
			ИмяФайла = ПутьКФайлу;
		Иначе
			ИмяФайла = ?(СтрЗаканчиваетсяНа(ПутьКФайлу, ".xml"),
							Лев(ПутьКФайлу, СтрДлина(ПутьКФайлу)-4) ,ПутьКФайлу) 
					+"("+ДанныеПотока.Заказчик+").xml";
		КонецЕсли;
		
		//++ Ким Виктор 28.06.2024
		//https://jira-sd.logsis.ru/projects/TSLOG/queues/custom/18/TSLOG-13521
		//Формирование хмл на несколько файлов по сумме и фио;
		Если Потоки.Количество() > 1 Тогда 
			ИмяФайла = ?(СтрЗаканчиваетсяНа(ПутьКФайлу, ".xml"),Лев(ПутьКФайлу, СтрДлина(ПутьКФайлу)-4), ПутьКФайлу) + Строка(НомерФайла) + ".xml";
			НомерФайла = НомерФайла + 1;
		КонецЕсли;
		//-- Ким Виктор 28.06.2024
		
		Файл = Новый ЗаписьТекста(ИмяФайла, "windows-1251");
		Файл.ЗаписатьСтроку(ДанныеПотока.Поток);
		Файл.Закрыть();
	КонецЦикла;
	
	//Предупреждение("Файл сохранен");
	ОбщегоНазначенияКлиент.СообщитьПользователю("Файл сохранен");
	
КонецПроцедуры  


	
