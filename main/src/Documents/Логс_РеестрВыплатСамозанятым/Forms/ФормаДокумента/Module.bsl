&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	// Вставить содержимое обработчика.
КонецПроцедуры

&НаСервере
Процедура РассчитыватьНалогПриИзмененииНаСервере()
	тОбъект = РеквизитФормыВЗначение("Объект");
	тОбъект.ПересчитатьНалогВСтроках();
	ЗначениеВРеквизитФормы(тОбъект, "Объект");
	
	Объект.СуммаДокумента = Объект.Выплаты.Итог("СуммаСНалогом");
КонецПроцедуры

&НаКлиенте
Процедура РассчитыватьНалогПриИзменении(Элемент)
	РассчитыватьНалогПриИзмененииНаСервере();
КонецПроцедуры

&НаСервере
Процедура ПодборНаСервере(МассивДоговоров) 
	
		Для Каждого Стр из МассивДоговоров Цикл 
			СтруктураПоиска = Новый Структура;
			СтруктураПоиска.Вставить("Договор", Стр);
			
			МассивНайденных = Объект.Выплаты.НайтиСтроки(СтруктураПоиска);
			
			Если НЕ МассивНайденных.количество() Тогда 
				НоваяСтрока = Объект.Выплаты.Добавить();
				НоваяСтрока.Договор    = Стр;
				НоваяСтрока.Контрагент = Стр.Контрагент;
				НоваяСтрока.Партнер    = Стр.Партнер;
			КонецЕсли;
			
		КонецЦикла; 
		
	
КонецПроцедуры

&НаКлиенте
Процедура Подбор(Команда)

	ПараметрыФормы = Новый Структура("МножественныйВыбор",Истина);
	ПараметрыФормы.Вставить("Логс_ВидКлиентаCRM", ПредопределенноеЗначение("Перечисление.Логс_ВидыКлиентовCRM.СамозанятыйКурьер"));
	
	ОткрытьФорму("Справочник.ДоговорыКонтрагентов.ФормаВыбора", ПараметрыФормы, ЭтотОбъект,,,,, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	
КонецПроцедуры 
 
&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	// Вставить содержимое обработчика.
КонецПроцедуры     

&НаКлиенте
Процедура ОбработкаВыбора(ВыбранноеЗначение, ИсточникВыбора)
	
	Если Не ЗначениеЗаполнено(ВыбранноеЗначение) Тогда
		Возврат;
	КонецЕсли;
	
	Если ВыбранноеЗначение.Количество() Тогда 
		
		ПодборНаСервере(ВыбранноеЗначение);
		Модифицированность = Истина;
		
	КонецЕсли;

КонецПроцедуры



#КонецОбласти


#Область CSV_Sber
&НаКлиенте
Процедура ЭкспортCSV(Команда)
	Если Модифицированность Тогда
		Предупреждение("Для экспорта реестра необходимо записать документ");
		Возврат;
	КонецЕсли;
	
	Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Сохранение);
	Диалог.Фильтр = "*.csv|*.csv";
	Диалог.Заголовок = НСтр("Сохранение файла");
	ОповещениеЗавершения = Новый ОписаниеОповещения("ВыборФайлаCSVЗавершение", ЭтотОбъект);
	Диалог.Показать(ОповещениеЗавершения);
КонецПроцедуры

&НаСервере
Функция СформироватьПотокиНаСервере(Реестр)
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	Выплаты.Контрагент.НаименованиеПолное КАК ФИО,
	               |	Выплаты.Договор.БанковскийСчетКонтрагента.НомерСчета КАК НомерСчета,
	               |	Выбор Когда Выплаты.Договор.Организация = &ОЛ Тогда Выплаты.Договор.Логс_ЗаказчикСЗ Иначе """" Конец КАК Заказчик,
	               |	Выплаты.СуммаСНалогом КАК СуммаСНалогом
	               |ИЗ
	               |	Документ.Логс_РеестрВыплатСамозанятым.Выплаты КАК Выплаты
	               |ГДЕ
	               |	Выплаты.Ссылка = &Реестр
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	Заказчик,
	               |	ФИО";
	Запрос.УстановитьПараметр("Реестр", Реестр);
	Запрос.УстановитьПараметр("ОЛ", Логс_ДополнительныеПроцедурыИФункцииПовтИсп.ОрганизацияЛогсис());
	
	Заказчик = Неопределено;
	//Поток = "";
	РазделительЗначений = ";";
	РазделительСтрок = Символы.ПС;
	
	Потоки = Новый Массив;
	Индекс = -1;
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		Если Заказчик<>Выборка.Заказчик Тогда
			//Если Заказчик = Неопределено Тогда
			Заказчик = Выборка.Заказчик;
			Потоки.Добавить(Новый Структура("Заказчик, Поток",Заказчик,""));
			Индекс = Индекс+1;
			Первая = Истина;
		КонецЕсли;
		
		Если НЕ Первая Тогда
			Потоки[Индекс].Поток = Потоки[Индекс].Поток + РазделительСтрок;
		Иначе
			Первая = Ложь;
		КонецЕсли;
		
		Потоки[Индекс].Поток = Потоки[Индекс].Поток + Выборка.НомерСчета + РазделительЗначений;
		ФИО = ФизическиеЛицаКлиентСервер.ЧастиИмени(Выборка.ФИО);
		Потоки[Индекс].Поток = Потоки[Индекс].Поток + ФИО.Фамилия + РазделительЗначений + ФИО.Имя + РазделительЗначений + ФИО.Отчество + РазделительЗначений;
		Потоки[Индекс].Поток = Потоки[Индекс].Поток + Формат(Выборка.СуммаСНалогом, "ЧДЦ=2; ЧРД=.; ЧН=0.00; ЧГ=") + РазделительЗначений;
		//++ Ким Виктор 25.07.2024
		//https://jira-sd.logsis.ru/projects/TSLOG/queues/custom/18/TSLOG-13992
		Потоки[Индекс].Поток = Потоки[Индекс].Поток + Формат(0, "ЧДЦ=2; ЧРД=.; ЧН=0.00; ЧГ=") + РазделительЗначений;
		Потоки[Индекс].Поток = Потоки[Индекс].Поток + "87";
		//-- Ким Виктор 25.07.2024
	КонецЦикла;
	
	Возврат Потоки;
	
КонецФункции

&НаКлиенте
Процедура ВыборФайлаCSVЗавершение(ВыбранныеФайлы, ДополнительныеПараметры) Экспорт

	Если ВыбранныеФайлы <> Неопределено Тогда
		ПутьКФайлу = ВыбранныеФайлы[0];
	Иначе
		Возврат;
	КонецЕсли;
	
	Потоки = СформироватьПотокиНаСервере(Объект.Ссылка);
	
	Для Каждого ДанныеПотока из Потоки Цикл
		Если ДанныеПотока.Заказчик = "" Тогда
			ИмяФайла = ПутьКФайлу;
		Иначе
			ИмяФайла = ?(СтрЗаканчиваетсяНа(ПутьКФайлу, ".csv"),
							Лев(ПутьКФайлу, СтрДлина(ПутьКФайлу)-3) ,ПутьКФайлу) 
					+"("+ДанныеПотока.Заказчик+").csv";
		КонецЕсли;
		Файл = Новый ЗаписьТекста(ИмяФайла, КодировкаТекста.ANSI);
		Файл.ЗаписатьСтроку(ДанныеПотока.Поток);
		Файл.Закрыть();
	КонецЦикла;
	
	//Предупреждение("Файл сохранен");
	ОбщегоНазначенияКлиент.СообщитьПользователю("Файл сохранен");
	
КонецПроцедуры

#КонецОбласти

&НаКлиенте
Процедура ВыплатыДоговорПриИзменении(Элемент)
	ТД = Элементы.Выплаты.ТекущиеДанные;	
	ТД.Партнер = ОбщегоНазначенияУТВызовСервера.ЗначениеРеквизитаОбъекта(ТД.Договор, "Партнер"); 
	ТД.Контрагент = ОбщегоНазначенияУТВызовСервера.ЗначениеРеквизитаОбъекта(ТД.Договор, "Контрагент"); 
КонецПроцедуры


&НаСервере
Процедура ВыплатыРассчитыватьНалогПриИзмененииНаСервере()
	Документы.Логс_РеестрВыплатСамозанятым.ПересчитатьНалогВСтроке(Элементы.Выплаты.ТекущиеДанные);
КонецПроцедуры

&НаКлиенте
Процедура ВыплатыРассчитыватьНалогПриИзменении(Элемент)
	Строка = Элементы.Выплаты.ТекущиеДанные;
	Строка.СуммаСНалогом = ?(Строка.РассчитыватьНалог, Строка.Сумма/0.94, Строка.Сумма);

КонецПроцедуры

#Область XML_Alfa
&НаКлиенте
Процедура ЭкспортXMLАльфа(Команда)
	Если Модифицированность Тогда
		Предупреждение("Для экспорта реестра необходимо записать документ");
		Возврат;
	КонецЕсли;
	
	Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Сохранение);
	Диалог.Фильтр = "*.xml|*.xml";
	Диалог.Заголовок = НСтр("Сохранение файла");
	ОповещениеЗавершения = Новый ОписаниеОповещения("ВыборФайлаXMLЗавершение", ЭтотОбъект);
	Диалог.Показать(ОповещениеЗавершения);
КонецПроцедуры

&НаКлиенте
Процедура ВыборФайлаXMLЗавершение(ВыбранныеФайлы, ДополнительныеПараметры) Экспорт

	Если ВыбранныеФайлы <> Неопределено Тогда
		ПутьКФайлу = ВыбранныеФайлы[0];
	Иначе
		Возврат;
	КонецЕсли;
	
	Потоки = СформироватьXMLAlfaНаСервереСРазбивкойПоФИО(Объект.Ссылка);
	НомерФайла = 1;
	Для Каждого ДанныеПотока из Потоки Цикл
		Если ДанныеПотока.Заказчик = "" Тогда
			ИмяФайла = ПутьКФайлу;
		Иначе
			ИмяФайла = ?(СтрЗаканчиваетсяНа(ПутьКФайлу, ".xml"),
							Лев(ПутьКФайлу, СтрДлина(ПутьКФайлу)-4) ,ПутьКФайлу) 
					+"("+ДанныеПотока.Заказчик+").xml";
		КонецЕсли;
		
		//++ Ким Виктор 28.06.2024
		//https://jira-sd.logsis.ru/projects/TSLOG/queues/custom/18/TSLOG-13521
		//Формирование хмл на несколько файлов по сумме и фио;
		Если Потоки.Количество() > 1 Тогда 
			ИмяФайла = ?(СтрЗаканчиваетсяНа(ПутьКФайлу, ".xml"),Лев(ПутьКФайлу, СтрДлина(ПутьКФайлу)-4), ПутьКФайлу) + Строка(НомерФайла) + ".xml";
			НомерФайла = НомерФайла + 1;
		КонецЕсли;
		//-- Ким Виктор 28.06.2024
		
		Файл = Новый ЗаписьТекста(ИмяФайла, "windows-1251");
		Файл.ЗаписатьСтроку(ДанныеПотока.Поток);
		Файл.Закрыть();
	КонецЦикла;
	
	//Предупреждение("Файл сохранен");
	ОбщегоНазначенияКлиент.СообщитьПользователю("Файл сохранен");
	
КонецПроцедуры  

&НаКлиенте
Процедура ВыборФайлаXMLЗавершение_старая(ВыбранныеФайлы, ДополнительныеПараметры) Экспорт

	Если ВыбранныеФайлы <> Неопределено Тогда
		ПутьКФайлу = ВыбранныеФайлы[0];
	Иначе
		Возврат;
	КонецЕсли;
	
	Потоки = СформироватьXMLAlfaНаСервере(Объект.Ссылка);
	Для Каждого ДанныеПотока из Потоки Цикл
		Если ДанныеПотока.Заказчик = "" Тогда
			ИмяФайла = ПутьКФайлу;
		Иначе
			ИмяФайла = ?(СтрЗаканчиваетсяНа(ПутьКФайлу, ".xml"),
							Лев(ПутьКФайлу, СтрДлина(ПутьКФайлу)-4) ,ПутьКФайлу) 
					+"("+ДанныеПотока.Заказчик+").xml";
		КонецЕсли;
		
		Файл = Новый ЗаписьТекста(ИмяФайла, "windows-1251");
		Файл.ЗаписатьСтроку(ДанныеПотока.Поток);
		Файл.Закрыть();
	КонецЦикла;
	
	ОбщегоНазначенияКлиент.СообщитьПользователю("Файл сохранен");
	
КонецПроцедуры   

//++ Ким Виктор 27.06.2024
//https://jira-sd.logsis.ru/projects/TSLOG/queues/custom/18/TSLOG-13521
//Формирование хмл на несколько файлов по сумме и фио;
&НаСервере
Функция СформироватьXMLAlfaНаСервереСРазбивкойПоФИО(Реестр)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	Логс_РеестрВыплатСамозанятым.Дата КАК Дата,
	               |	Логс_РеестрВыплатСамозанятым.Организация.Наименование КАК НаименованиеОрганизации,
	               |	Логс_РеестрВыплатСамозанятым.Организация.ИНН КАК ИНН,
	               |	isnull(Логс_РеестрВыплатСамозанятым.БанковскийСчет.НомерСчета, """") КАК НомерСчета,
	               |	isnull(Логс_РеестрВыплатСамозанятым.БанковскийСчет.БИКБанка, """") КАК БИК,
	               |	Логс_РеестрВыплатСамозанятым.БанковскийСчет.Логс_НомерДоговора КАК НомерДоговора
	               |ИЗ
	               |	Документ.Логс_РеестрВыплатСамозанятым КАК Логс_РеестрВыплатСамозанятым
	               |ГДЕ
	               |	Логс_РеестрВыплатСамозанятым.Ссылка = &Реестр";     
	Запрос.УстановитьПараметр("Реестр", Реестр);
	
	ВыборкаРеестр = Запрос.Выполнить().Выбрать();  
	Если НЕ ВыборкаРеестр.Следующий() Тогда
		Возврат "";
	КонецЕсли;  
	
	ДатаФормирования 		 = Формат(ТекущаяДата(), "ДФ=yyyy-MM-dd"); 	
	НомерДоговора 	 		 = ВыборкаРеестр.НомерДоговора;
	НаименованиеОрганизации  = ВыборкаРеестр.НаименованиеОрганизации; 	
	ИНН 				     = ВыборкаРеестр.ИНН;
	РасчетныйСчетОрганизации = ВыборкаРеестр.НомерСчета;
	БИК						 = ВыборкаРеестр.БИК;
	ИдПервичногоДокумента	 = Строка(Реестр.УникальныйИдентификатор());
	
	
	Запрос.Текст = "ВЫБРАТЬ
	               |	Выплаты.НомерСтроки КАК НомерСтроки,
	               |	Выплаты.Контрагент.НаименованиеПолное КАК ФИО,
	               |	Выплаты.Договор.БанковскийСчетКонтрагента.НомерСчета КАК НомерСчета,
	               |	Выплаты.СуммаСНалогом КАК СуммаСНалогом,
	               |	Выбор Когда Выплаты.Договор.Организация = &ОЛ Тогда Выплаты.Договор.Логс_ЗаказчикСЗ Иначе """" Конец КАК Заказчик,
	               |	0 КАК СуммаУдержаний,
	               |	""0000"" КАК ОтделениеБанка,
	               |	"""" КАК ФилиалОтделенияБанка
	               |ИЗ
	               |	Документ.Логс_РеестрВыплатСамозанятым.Выплаты КАК Выплаты
	               |ГДЕ
	               |	Выплаты.Ссылка = &Реестр
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	НомерСтроки";
	Запрос.УстановитьПараметр("ОЛ", Логс_ДополнительныеПроцедурыИФункцииПовтИсп.ОрганизацияЛогсис());

	//ВыборкаВыплаты = Запрос.Выполнить().Выбрать();  
	ТаблицаВыплаты = Запрос.Выполнить().Выгрузить();
	
	ТаблицаДублейВыплаты = ТаблицаВыплаты.Скопировать();
	ТаблицаДублейВыплаты.Очистить();
	ПервыйСотрудникДубль = Неопределено;
	
	Для Каждого Стр из ТаблицаВыплаты Цикл 
		
		СтруктураПоиска = Новый Структура;
		СтруктураПоиска.Вставить("ФИО", 			Стр.ФИО);
		СтруктураПоиска.Вставить("СуммаСНалогом", 	Стр.СуммаСНалогом);
		МассивВыплаты = ТаблицаВыплаты.НайтиСтроки(СтруктураПоиска); 
		Если ПервыйСотрудникДубль <> Стр.ФИО И МассивВыплаты.Количество() > 1 И ТаблицаДублейВыплаты.Найти(Стр.НомерСтроки, "НомерСтроки") = Неопределено Тогда 
			ПервыйСотрудникДубль = Стр.Фио;
			Для каждого Дубль Из МассивВыплаты Цикл
				Если Дубль.НомерСтроки <> Стр.НомерСтроки И ТаблицаДублейВыплаты.Найти(Дубль.НомерСтроки, "НомерСтроки") = Неопределено Тогда
					НоваяСтрока = ТаблицаДублейВыплаты.Добавить();
					ЗаполнитьЗначенияСвойств(НоваяСтрока, Дубль);
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;

	СтруктураЗаголовка = Новый Структура;
	СтруктураЗаголовка.Вставить("ДатаФормирования", 		ДатаФормирования);
	СтруктураЗаголовка.Вставить("НомерДоговора", 			НомерДоговора);
	СтруктураЗаголовка.Вставить("НаименованиеОрганизации", 	НаименованиеОрганизации);
	СтруктураЗаголовка.Вставить("ИНН",						ИНН);
	СтруктураЗаголовка.Вставить("РасчетныйСчетОрганизации", РасчетныйСчетОрганизации);
	СтруктураЗаголовка.Вставить("БИК", 						БИК);
	СтруктураЗаголовка.Вставить("ИдПервичногоДокумента", 	ИдПервичногоДокумента);
	
	СтруктураВозврата = ПолучитьЗаписьХМЛ(СтруктураЗаголовка, ТаблицаВыплаты, ТаблицаДублейВыплаты);
	
	Потоки = Новый Массив;  
	Потоки.Добавить(Новый Структура("Заказчик, Поток", СтруктураВозврата.Заказчик,СтруктураВозврата.ПотокХМЛ));
	
	Для Каждого Стр из ТаблицаДублейВыплаты Цикл 
	
		СтруктураВозврата = ПолучитьЗаписьХМЛ(СтруктураЗаголовка, Стр);
		Потоки.Добавить(Новый Структура("Заказчик, Поток", СтруктураВозврата.Заказчик,СтруктураВозврата.ПотокХМЛ));
				
	КонецЦикла;
	
	Возврат Потоки;
         	
КонецФункции  

&НаСервере
Функция ПолучитьЗаписьХМЛ(Знач СтруктураЗаголовка, Знач ТаблицаВыплаты, ТаблицаДублей = Неопределено, ТипБанка = "Альфа")
		
	Заказчик = Неопределено;
	СуммаИтого = 0;
		
	ЗаписьXML = Новый ЗаписьXML;
	ЗаписьXML.УстановитьСтроку("windows-1251");
	ЗаписьXML.ЗаписатьОбъявлениеXML();
	
	ЗаписьXML.ЗаписатьНачалоЭлемента("СчетаПК");
	ЗаписьXML.ЗаписатьАтрибут("ДатаФормирования", 			СтруктураЗаголовка.ДатаФормирования);
	ЗаписьXML.ЗаписатьАтрибут("НомерДоговора", 				СтруктураЗаголовка.НомерДоговора);
	ЗаписьXML.ЗаписатьАтрибут("НаименованиеОрганизации", 	СтруктураЗаголовка.НаименованиеОрганизации);
	ЗаписьXML.ЗаписатьАтрибут("ИНН", 						СтруктураЗаголовка.ИНН);
	ЗаписьXML.ЗаписатьАтрибут("РасчетныйСчетОрганизации", 	СтруктураЗаголовка.РасчетныйСчетОрганизации);
	ЗаписьXML.ЗаписатьАтрибут("БИК", 						СтруктураЗаголовка.БИК);
	ЗаписьXML.ЗаписатьАтрибут("ИдПервичногоДокумента", 		СтруктураЗаголовка.ИдПервичногоДокумента);
	ЗаписьXML.ЗаписатьНачалоЭлемента("ЗачислениеЗарплаты");          
	
	Если ТипЗнч(ТаблицаВыплаты) = Тип("СтрокаТаблицыЗначений") Тогда 
		СтрТаблицаВыплаты = ТаблицаВыплаты;
		ТаблицаВыплаты = Новый Массив;
		ТаблицаВыплаты.Добавить(СтрТаблицаВыплаты);
	КонецЕсли;
	
	НомерСтроки = 0;
		
	Для Каждого Стр из ТаблицаВыплаты Цикл 
		
		Если ТаблицаДублей <> Неопределено И ТаблицаДублей.Найти(Стр.НомерСтроки, "НомерСтроки") <> Неопределено Тогда 
			Продолжить;
		КонецЕсли;
		
		ВыборкаВыплаты = Стр; 
		
		Если Заказчик<>ВыборкаВыплаты.Заказчик Тогда
			Заказчик = ВыборкаВыплаты.Заказчик;
		КонецЕсли;   
		
		ЗаписьXML.ЗаписатьНачалоЭлемента("Сотрудник");
		НомерСтроки = НомерСтроки + 1;
		//ЗаписьXML.ЗаписатьАтрибут("НПП", Формат(ВыборкаВыплаты.Номерстроки, "ЧРД=.; ЧГ="));
		ЗаписьXML.ЗаписатьАтрибут("НПП", Формат(Номерстроки, "ЧРД=.; ЧГ="));

			ФИО = ФизическиеЛицаКлиентСервер.ЧастиИмени(ВыборкаВыплаты.ФИО);
			ЗаписьXML.ЗаписатьНачалоЭлемента("Фамилия");
				ЗаписьXML.ЗаписатьТекст(ФИО.Фамилия);
				ЗаписьXML.ЗаписатьКонецЭлемента();

			ЗаписьXML.ЗаписатьНачалоЭлемента("Имя");
				ЗаписьXML.ЗаписатьТекст(ФИО.Имя);
				ЗаписьXML.ЗаписатьКонецЭлемента();

			ЗаписьXML.ЗаписатьНачалоЭлемента("Отчество");
				ЗаписьXML.ЗаписатьТекст(?(ФИО.Отчество=Неопределено, "", ФИО.Отчество));
				ЗаписьXML.ЗаписатьКонецЭлемента();

			ЗаписьXML.ЗаписатьНачалоЭлемента("ОтделениеБанка");
				ЗаписьXML.ЗаписатьТекст(ВыборкаВыплаты.ОтделениеБанка);
				ЗаписьXML.ЗаписатьКонецЭлемента();

			ЗаписьXML.ЗаписатьНачалоЭлемента("ФилиалОтделенияБанка");
				ЗаписьXML.ЗаписатьТекст(ВыборкаВыплаты.ФилиалОтделенияБанка);
				ЗаписьXML.ЗаписатьКонецЭлемента();

			ЗаписьXML.ЗаписатьНачалоЭлемента("ЛицевойСчет");
				ЗаписьXML.ЗаписатьТекст(ВыборкаВыплаты.НомерСчета);
				ЗаписьXML.ЗаписатьКонецЭлемента();

			ЗаписьXML.ЗаписатьНачалоЭлемента("Сумма");
				ЗаписьXML.ЗаписатьТекст(Формат(ВыборкаВыплаты.СуммаСНалогом, "ЧРД=.; ЧГ="));
				ЗаписьXML.ЗаписатьКонецЭлемента();   
			СуммаИтого = СуммаИтого + ВыборкаВыплаты.СуммаСНалогом;

			ЗаписьXML.ЗаписатьНачалоЭлемента("ОбщаяСуммаУдержаний");
				ЗаписьXML.ЗаписатьТекст(Формат(ВыборкаВыплаты.СуммаУдержаний, "ЧРД=.; ЧГ="));
				ЗаписьXML.ЗаписатьКонецЭлемента();
		
		//++ Ким Виктор 16.05.2025
		//https://jira-sd.logsis.ru/projects/TSLOG/queues/custom/18/TSLOG-16481
		Если ТипБанка = "Сбер" Тогда 
			ЗаписьXML.ЗаписатьНачалоЭлемента("КодВалютнойОперации");
			ЗаписьXML.ЗаписатьТекст(ВыборкаВыплаты.КодВалютнойОперации);
			ЗаписьXML.ЗаписатьКонецЭлемента();
			
			ЗаписьXML.ЗаписатьНачалоЭлемента("НомерИндивидуальногоДоговора");
			ЗаписьXML.ЗаписатьТекст(Формат(ВыборкаВыплаты.НомерИндивидуальногоДоговора, "ЧДЦ=0; ЧГ="));
			ЗаписьXML.ЗаписатьКонецЭлемента();
			
			ЗаписьXML.ЗаписатьНачалоЭлемента("ДатаИндивидуальногоДоговора");
			ЗаписьXML.ЗаписатьТекст(Формат(ВыборкаВыплаты.ДатаИндивидуальногоДоговора, "ДФ=dd.MM.yyyy"));
			ЗаписьXML.ЗаписатьКонецЭлемента();
		КонецЕсли;
		
		ЗаписьXML.ЗаписатьКонецЭлемента();   //СОТР 
		//-- Ким Виктор 16.05.2025
		
	КонецЦикла;
	
	ЗаписьXML.ЗаписатьКонецЭлемента();   //ЗачислениеЗарплаты
	
	ЗаписьXML.ЗаписатьНачалоЭлемента("КонтрольныеСуммы");          

		ЗаписьXML.ЗаписатьНачалоЭлемента("КоличествоЗаписей"); 
		Если ТаблицаДублей <> Неопределено Тогда 
			ЗаписьXML.ЗаписатьТекст(Формат(ТаблицаВыплаты.Количество() - ТаблицаДублей.Количество(), "ЧРД=.; ЧГ="));
		Иначе
			ЗаписьXML.ЗаписатьТекст(Формат(ТаблицаВыплаты.Количество(), "ЧРД=.; ЧГ="));
		КонецЕсли;
		
		
		ЗаписьXML.ЗаписатьКонецЭлемента();    
		
		ЗаписьXML.ЗаписатьНачалоЭлемента("СуммаИтого");
		ЗаписьXML.ЗаписатьТекст(Формат(СуммаИтого, "ЧРД=.; ЧГ="));
		ЗаписьXML.ЗаписатьКонецЭлемента();
	
	ЗаписьXML.ЗаписатьКонецЭлемента();   //КонтрольныеСуммы

	ЗаписьXML.ЗаписатьКонецЭлемента();   //СчетаПК
	
	СтруктураВозврата = Новый Структура;
	СтруктураВозврата.Вставить("Заказчик", Заказчик);
	СтруктураВозврата.Вставить("ПотокХМЛ", ЗаписьXML.Закрыть()); 
	
	Возврат СтруктураВозврата;
	
КонецФункции
//-- Ким Виктор 27.06.2024

&НаСервере
Функция СформироватьXMLAlfaНаСервере(Реестр)    
	
	ЗаписьXML = Новый ЗаписьXML;
	
	ЗаписьXML.УстановитьСтроку("windows-1251");
	ЗаписьXML.ЗаписатьОбъявлениеXML();
	///получение данных   
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	Логс_РеестрВыплатСамозанятым.Дата КАК Дата,
	               |	Логс_РеестрВыплатСамозанятым.Организация.Наименование КАК НаименованиеОрганизации,
	               |	Логс_РеестрВыплатСамозанятым.Организация.ИНН КАК ИНН,
	               |	isnull(Логс_РеестрВыплатСамозанятым.БанковскийСчет.НомерСчета, """") КАК НомерСчета,
	               |	isnull(Логс_РеестрВыплатСамозанятым.БанковскийСчет.БИКБанка, """") КАК БИК,
	               |	Логс_РеестрВыплатСамозанятым.БанковскийСчет.Логс_НомерДоговора КАК НомерДоговора
	               |ИЗ
	               |	Документ.Логс_РеестрВыплатСамозанятым КАК Логс_РеестрВыплатСамозанятым
	               |ГДЕ
	               |	Логс_РеестрВыплатСамозанятым.Ссылка = &Реестр";     
	Запрос.УстановитьПараметр("Реестр", Реестр);
	
	ВыборкаРеестр = Запрос.Выполнить().Выбрать();  
	Если НЕ ВыборкаРеестр.Следующий() Тогда
		Возврат "";
	КонецЕсли;
	
	ЗаписьXML.ЗаписатьНачалоЭлемента("СчетаПК");
	ЗаписьXML.ЗаписатьАтрибут("ДатаФормирования", Формат(ТекущаяДата(), "ДФ=yyyy-MM-dd"));//Формат(ВыборкаРеестр.Дата, "ДФ=yyyy-MM-dd"));
	ЗаписьXML.ЗаписатьАтрибут("НомерДоговора", ВыборкаРеестр.НомерДоговора);
	ЗаписьXML.ЗаписатьАтрибут("НаименованиеОрганизации", ВыборкаРеестр.НаименованиеОрганизации);
	ЗаписьXML.ЗаписатьАтрибут("ИНН", ВыборкаРеестр.ИНН);
	ЗаписьXML.ЗаписатьАтрибут("РасчетныйСчетОрганизации", ВыборкаРеестр.НомерСчета);
	ЗаписьXML.ЗаписатьАтрибут("БИК", ВыборкаРеестр.БИК);
	ЗаписьXML.ЗаписатьАтрибут("ИдПервичногоДокумента", Строка(Реестр.УникальныйИдентификатор()));

	////получение данных 2
	ЗаписьXML.ЗаписатьНачалоЭлемента("ЗачислениеЗарплаты");          
	Запрос.Текст = "ВЫБРАТЬ
	               |	Выплаты.НомерСтроки КАК НомерСтроки,
	               |	Выплаты.Контрагент.НаименованиеПолное КАК ФИО,
	               |	Выплаты.Договор.БанковскийСчетКонтрагента.НомерСчета КАК НомерСчета,
	               |	Выплаты.СуммаСНалогом КАК СуммаСНалогом,
	               |	Выбор Когда Выплаты.Договор.Организация = &ОЛ Тогда Выплаты.Договор.Логс_ЗаказчикСЗ Иначе """" Конец КАК Заказчик,
	               |	0 КАК СуммаУдержаний,
	               |	""0000"" КАК ОтделениеБанка,
	               |	"""" КАК ФилиалОтделенияБанка
	               |ИЗ
	               |	Документ.Логс_РеестрВыплатСамозанятым.Выплаты КАК Выплаты
	               |ГДЕ
	               |	Выплаты.Ссылка = &Реестр
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	НомерСтроки";
	Запрос.УстановитьПараметр("ОЛ", Логс_ДополнительныеПроцедурыИФункцииПовтИсп.ОрганизацияЛогсис());

	ВыборкаВыплаты = Запрос.Выполнить().Выбрать();  
	
	Заказчик = Неопределено;
	СуммаИтого = 0;  
	
	//цикл 
	Пока ВыборкаВыплаты.Следующий() Цикл
		Если Заказчик<>ВыборкаВыплаты.Заказчик Тогда
			Заказчик = ВыборкаВыплаты.Заказчик;
		КонецЕсли;   
		
		ЗаписьXML.ЗаписатьНачалоЭлемента("Сотрудник");
		ЗаписьXML.ЗаписатьАтрибут("НПП", Формат(ВыборкаВыплаты.Номерстроки, "ЧРД=.; ЧГ="));

			ФИО = ФизическиеЛицаКлиентСервер.ЧастиИмени(ВыборкаВыплаты.ФИО);
			ЗаписьXML.ЗаписатьНачалоЭлемента("Фамилия");
				ЗаписьXML.ЗаписатьТекст(ФИО.Фамилия);
				ЗаписьXML.ЗаписатьКонецЭлемента();

			ЗаписьXML.ЗаписатьНачалоЭлемента("Имя");
				ЗаписьXML.ЗаписатьТекст(ФИО.Имя);
				ЗаписьXML.ЗаписатьКонецЭлемента();

			ЗаписьXML.ЗаписатьНачалоЭлемента("Отчество");
				ЗаписьXML.ЗаписатьТекст(?(ФИО.Отчество=Неопределено, "", ФИО.Отчество));
				ЗаписьXML.ЗаписатьКонецЭлемента();

			ЗаписьXML.ЗаписатьНачалоЭлемента("ОтделениеБанка");
				ЗаписьXML.ЗаписатьТекст(ВыборкаВыплаты.ОтделениеБанка);
				ЗаписьXML.ЗаписатьКонецЭлемента();

			ЗаписьXML.ЗаписатьНачалоЭлемента("ФилиалОтделенияБанка");
				ЗаписьXML.ЗаписатьТекст(ВыборкаВыплаты.ФилиалОтделенияБанка);
				ЗаписьXML.ЗаписатьКонецЭлемента();

			ЗаписьXML.ЗаписатьНачалоЭлемента("ЛицевойСчет");
				ЗаписьXML.ЗаписатьТекст(ВыборкаВыплаты.НомерСчета);
				ЗаписьXML.ЗаписатьКонецЭлемента();

			ЗаписьXML.ЗаписатьНачалоЭлемента("Сумма");
				ЗаписьXML.ЗаписатьТекст(Формат(ВыборкаВыплаты.СуммаСНалогом, "ЧРД=.; ЧГ="));
				ЗаписьXML.ЗаписатьКонецЭлемента();   
			СуммаИтого = СуммаИтого + ВыборкаВыплаты.СуммаСНалогом;

			ЗаписьXML.ЗаписатьНачалоЭлемента("ОбщаяСуммаУдержаний");
				ЗаписьXML.ЗаписатьТекст(Формат(ВыборкаВыплаты.СуммаУдержаний, "ЧРД=.; ЧГ="));
				ЗаписьXML.ЗаписатьКонецЭлемента();
		ЗаписьXML.ЗаписатьКонецЭлемента();   //СОТР 
	КонецЦикла;
	//конеццикла
	
	
	ЗаписьXML.ЗаписатьКонецЭлемента();   //ЗачислениеЗарплаты
	
	ЗаписьXML.ЗаписатьНачалоЭлемента("КонтрольныеСуммы");          

		ЗаписьXML.ЗаписатьНачалоЭлемента("КоличествоЗаписей");
		ЗаписьXML.ЗаписатьТекст(Формат(ВыборкаВыплаты.Количество(), "ЧРД=.; ЧГ="));
		ЗаписьXML.ЗаписатьКонецЭлемента();    
		
		ЗаписьXML.ЗаписатьНачалоЭлемента("СуммаИтого");
		ЗаписьXML.ЗаписатьТекст(Формат(СуммаИтого, "ЧРД=.; ЧГ="));
		ЗаписьXML.ЗаписатьКонецЭлемента();
	
	ЗаписьXML.ЗаписатьКонецЭлемента();   //КонтрольныеСуммы

	ЗаписьXML.ЗаписатьКонецЭлемента();   //СчетаПК
	
	ПотокХМЛ = ЗаписьXML.Закрыть();
	
	Потоки = Новый Массив;  
	Потоки.Добавить(Новый Структура("Заказчик, Поток",Заказчик,ПотокХМЛ));

	Возврат Потоки;
	
КонецФункции

