&НаСервере
Функция ПолучитьСтруктуруПотокаНовый()
	
	СтруктураПотока = Новый Структура;
	СтруктураПотока.Вставить("ИНН");
	СтруктураПотока.Вставить("Фамилия");
	СтруктураПотока.Вставить("ФИО");
	//СтруктураПотока.Вставить("Имя");
	//СтруктураПотока.Вставить("Отчество");
	//СтруктураПотока.Вставить("НомерСчета");
	//СтруктураПотока.Вставить("Отчество");
	СтруктураПотока.Вставить("Сумма");
	СтруктураПотока.Вставить("ДатаСоздания");
	СтруктураПотока.Вставить("ДатаНачала");
	СтруктураПотока.Вставить("ДатаОкончания");
	
	Возврат СтруктураПотока;
	
КонецФункции


&НаСервере
Функция ЭкспортКонсольПроНаСервере(Реестр)
	
	
	Запрос = новый Запрос;
	Запрос.Текст =  ("ВЫБРАТЬ
	                 |	МИНИМУМ(Логс_РеестрВыплатСамозанятымВыплаты.НомерСтроки) КАК НомерСтроки,
	                 |	Логс_РеестрВыплатСамозанятымВыплаты.Контрагент.НаименованиеПолное КАК ФИО,
	                 |	Логс_РеестрВыплатСамозанятымВыплаты.Договор.БанковскийСчетКонтрагента.НомерСчета КАК НомерСчета,
	                 |	СУММА(Логс_РеестрВыплатСамозанятымВыплаты.СуммаСНалогом) КАК Сумма,
	                 |	Логс_РеестрВыплатСамозанятымВыплаты.Договор.БанковскийСчетКонтрагента.Банк КАК БанкКонтрагента,
	                 |	Логс_РеестрВыплатСамозанятымВыплаты.Договор.Номер КАК ДоговорНомер,
	                 |	Логс_РеестрВыплатСамозанятымВыплаты.Договор.Дата КАК ДоговорДата,
	                 |	Логс_РеестрВыплатСамозанятымВыплаты.ДатаОказанияУслуг КАК ДатаОказанияУслуг,
	                 |	Логс_РеестрВыплатСамозанятымВыплаты.Контрагент.ИНН КАК ИНН
	                 |ИЗ
	                 |	Документ.Логс_РеестрВыплатСамозанятым.Выплаты КАК Логс_РеестрВыплатСамозанятымВыплаты
	                 |ГДЕ
	                 |	Логс_РеестрВыплатСамозанятымВыплаты.Ссылка = &Ссылка
	                 |
	                 |СГРУППИРОВАТЬ ПО
	                 |	Логс_РеестрВыплатСамозанятымВыплаты.Договор.БанковскийСчетКонтрагента.НомерСчета,
	                 |	Логс_РеестрВыплатСамозанятымВыплаты.Контрагент.НаименованиеПолное,
	                 |	Логс_РеестрВыплатСамозанятымВыплаты.Договор.БанковскийСчетКонтрагента.Банк,
	                 |	Логс_РеестрВыплатСамозанятымВыплаты.Договор.Номер,
	                 |	Логс_РеестрВыплатСамозанятымВыплаты.Договор.Дата,
	                 |	Логс_РеестрВыплатСамозанятымВыплаты.ДатаОказанияУслуг,
	                 |	Логс_РеестрВыплатСамозанятымВыплаты.Контрагент.ИНН
	                 |
	                 |УПОРЯДОЧИТЬ ПО
	                 |	НомерСтроки") ;
	Запрос.УстановитьПараметр("Ссылка", Реестр);
	Выборка = Запрос.Выполнить().Выбрать();
	
	ТабДок = Новый ТабличныйДокумент;
	ОбъектДокумент =  РеквизитФормыВЗначение("Объект"); 
	Макет = ОбъектДокумент.ПолучитьМакет("МакетВыгрузкиКонсольПро");
	ОбластьЗаголовок = Макет.ПолучитьОбласть("ОбластьЗаголовок");
	ТабДок.Вывести(ОбластьЗаголовок);
	Номерстроки = 0;
	Пока Выборка.Следующий() Цикл 
		НомерСтроки = Номерстроки + 1;
		СтруктураПотока = ПолучитьСтруктуруПотокаНовый();
		//ФИО = ФизическиеЛицаКлиентСервер.ЧастиИмени(Выборка.ФИО);
		ЗаполнитьЗначенияСвойств(СтруктураПотока, Выборка);
		//ЗаполнитьЗначенияСвойств(СтруктураПотока, ФИО, "Фамилия, Имя, Отчество");
		СтруктураПотока.Сумма 			= Формат(СтруктураПотока.Сумма, "ЧЦ=15; ЧДЦ=2; ЧРД=.");
		СтруктураПотока.ДатаСоздания 	= Формат(Выборка.ДатаОказанияУслуг, "ДФ=dd.MM.yyyy");
		СтруктураПотока.ДатаНачала 		= Формат(Выборка.ДатаОказанияУслуг, "ДФ=dd.MM.yyyy");
		СтруктураПотока.ДатаОкончания 	= Формат(Выборка.ДатаОказанияУслуг, "ДФ=dd.MM.yyyy");
		ОбластьСтрока = Макет.ПолучитьОбласть("ОбластьСтрока");
		ОбластьСтрока.Параметры.Заполнить(СтруктураПотока);
		ТабДок.Вывести(ОбластьСтрока);
		      	
	КонецЦикла;
	
	Возврат ТабДок;
		
КонецФункции

&НаКлиенте
Процедура ЭкспортКонсольПро(Команда)
	
	Если Модифицированность Тогда
		Предупреждение("Для экспорта реестра необходимо записать документ");
		Возврат;
	КонецЕсли; 
	    	
	Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Сохранение);
	Диалог.Фильтр = "*.xlsx|*.xlsx";
	Диалог.Заголовок = НСтр("Сохранение файла");
	ОповещениеЗавершения = Новый ОписаниеОповещения("ВыборФайлаНовыйЗавершение", ЭтотОбъект);
	Диалог.Показать(ОповещениеЗавершения);
	
КонецПроцедуры
 
&НаКлиенте
Процедура ВыборФайлаНовыйЗавершение(ВыбранныеФайлы, ДополнительныеПараметры) Экспорт

	Если ВыбранныеФайлы <> Неопределено Тогда
		ПутьКФайлу = ВыбранныеФайлы[0];
	Иначе
		Возврат;
	КонецЕсли;
	
	ТабДок = ЭкспортКонсольПроНаСервере(Объект.Ссылка);
	ТабДок.Записать(ПутьКФайлу,ТипФайлаТабличногоДокумента.XLSX);
	
	ОбщегоНазначенияКлиент.СообщитьПользователю("Файл сохранен");
	
	
КонецПроцедуры  

//++Щурихин Д.С. 16.12.2025
&НаКлиенте
Процедура ЭкспортXLSСберБанкНерезиденты(Команда)
	
	Если Модифицированность Тогда
		Предупреждение("Для экспорта реестра необходимо записать документ");
		Возврат;
	КонецЕсли;
	
	Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Сохранение);
	Диалог.Фильтр			= "Документ Excel (*.xlsx)|*.xlsx";
	Диалог.Расширение		= "xlsx";
	Диалог.Заголовок 		= НСтр("Сохранение файла");
	
	Если Диалог.Выбрать() Тогда
		ПутьКФайлу = Диалог.ПолноеИмяФайла;
		ТабДок = СформироватьРеестрСбербанкНерезидентыXLSнаСервере(Объект.Ссылка);
		ТабДок.Записать(ПутьКФайлу,ТипФайлаТабличногоДокумента.XLSX);
		ОбщегоНазначенияКлиент.СообщитьПользователю("Файл сохранен");
	КонецЕсли;
	


КонецПроцедуры 

&НаСервере
Функция СформироватьРеестрСбербанкНерезидентыXLSнаСервере(Реестр)
	
	ТабДок 			= Новый ТабличныйДокумент;
	ОбъектДокумент 	= РеквизитФормыВЗначение("Объект"); 
	Макет 			= ОбъектДокумент.ПолучитьМакет("РеестрСбербанкНерезидентыXLS");
	ОбластьШапки  	= Макет.ПолучитьОбласть("Шапка");
	
	
	//Обход по группировкам
	РезультатЗапроса = ПолучитьДанныеДляДокументов(Реестр); 
	
	ВыборкаДокСсылка = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока ВыборкаДокСсылка.Следующий() Цикл

		//ТабДок.ВывестиГоризонтальныйРазделительСтраниц();		
		ТабДок.Вывести(ОбластьШапки);

		ВыборкаДетальныеЗаписи = ВыборкаДокСсылка.Выбрать(); 
		
		Сч = 1;
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл   
			
			//++ Ким Виктор 02.03.2026
			//https://logit.okdesk.ru/issues/1052#! 
			
			ТабЧасть	 	= Макет.ПолучитьОбласть("ТабЧасть"); 
			
			Если СЧ = 1 Тогда 
				
				ЗаполнитьЗначенияСвойств(ТабЧасть.Параметры, ВыборкаДетальныеЗаписи); 
				
			Иначе  
				//Исключаем заполнение этих полей для  номера строки > 1
				//БИК	
				//ВидЗачисления	
				//ДатаДокумента	
				//ОрганизацияИНН	
				//ИтогСумма	
				//КодВидаВалютнойОперации	
				//КодВидаДохода	
				//КолСотрудников	
				//НаименованиеОрганизации	
				//ДоговорБанковскогоСчета	
				//НомерДокумента	
				//СчетОрганизации
				
				ЗаполнитьЗначенияСвойств(ТабЧасть.Параметры, ВыборкаДетальныеЗаписи,, "БИК, ВидЗачисления,	
				| ДатаДокумента, ОрганизацияИНН, КодВидаВалютнойОперации, КодВидаДохода, 
				| НаименованиеОрганизации,	ДоговорБанковскогоСчета, НомерДокумента, СчетОрганизации, ИтогСумма");
				
			КонецЕсли; 
			
			//-- Ким Виктор 02.03.2026
			
			//Результат = Новый Структура("Фамилия, Имя, Отчество"); 
			//ФизическиеЛицаКлиентСервер.ЧастиИмени(
			//ФизическиеЛицаКлиентСерверЛокализация.ПриОпределенииЧастейПолногоИмени(ВыборкаДетальныеЗаписи.ПартнерФИО,, Результат);    
			Результат = ФизическиеЛицаКлиентСервер.ЧастиИмени(ВыборкаДетальныеЗаписи.ПартнерФИО);
           	ТабЧасть.Параметры.Фамилия 			= Результат.Фамилия;
			ТабЧасть.Параметры.Имя				= Результат.Имя;
			ТабЧасть.Параметры.Отчество			= Результат.Отчество;
			ТабЧасть.Параметры.СуммаКВыплате 	= ВыборкаДетальныеЗаписи.ИтогСумма;   //Здесь группировка по сотруднику
			
			//++ Ким Виктор 02.03.2026
			//https://logit.okdesk.ru/issues/1052#!

			Если СЧ = 1 Тогда 
				ТабЧасть.Параметры.ИтогСумма		= ВыборкаДокСсылка.ИтогСумма;         //Здесь итоги по документы      
				ТабЧасть.Параметры.КолСотрудников 	= ВыборкаДетальныеЗаписи.Количество();//Количество сотрудников равно количеству Детальных записей 
			КонецЕсли; 
			
			//-- Ким Виктор 02.03.2026

			ТабЧасть.Параметры.НомерПП 			= Сч;
					
			ТабДок.Вывести(ТабЧасть);
			
			Сч = Сч + 1;
			
		КонецЦикла; 
		
	//НомерСтрокиНачало = ТабДок.ВысотаТаблицы + 1;
	//УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабДок,НомерСтрокиНачало,ОбъектыПечати,ВыборкаДокСсылка.Ссылка); 	
		
	КонецЦикла;
		
	Возврат ТабДок;
	
КонецФункции  

&НаСервере
Функция ПолучитьДанныеДляДокументов(МассивОбъектов) 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Логс_РеестрВыплатСамозанятымВыплаты.Ссылка.БанковскийСчет.БИКБанка КАК БИК,
		|	Логс_РеестрВыплатСамозанятымВыплаты.Ссылка.Дата КАК ДатаДокумента,
		|	Логс_РеестрВыплатСамозанятымВыплаты.Ссылка.Организация.ИНН КАК ОрганизацияИНН,
		|	СУММА(Логс_РеестрВыплатСамозанятымВыплаты.Сумма) КАК ИтогСумма,
		|	Логс_РеестрВыплатСамозанятымВыплаты.Ссылка.Организация.Наименование КАК НаименованиеОрганизации,
		|	Логс_РеестрВыплатСамозанятымВыплаты.Договор.Номер КАК НомерДоговора,
		|	Логс_РеестрВыплатСамозанятымВыплаты.Ссылка.Номер КАК НомерДокумента,
		|	Логс_РеестрВыплатСамозанятымВыплаты.Ссылка.БанковскийСчет.НомерСчета КАК СчетОрганизации,
		|	Логс_РеестрВыплатСамозанятымВыплаты.Договор.Дата КАК ДатаДоговора,
		|	Логс_РеестрВыплатСамозанятымВыплаты.Ссылка КАК Ссылка,
		|	Логс_РеестрВыплатСамозанятымВыплаты.Партнер.Представление КАК ПартнерФИО,
		|	Логс_РеестрВыплатСамозанятымВыплаты.Договор.БанковскийСчетКонтрагента.НомерСчета КАК СчетЗачисления,
		|	""38215845"" КАК ДоговорБанковскогоСчета,
		|	""87"" КАК ВидЗачисления,
		|	""1"" КАК КодВидаДохода,
		|	""21200"" КАК КодВидаВалютнойОперации
		|ИЗ
		|	Документ.Логс_РеестрВыплатСамозанятым.Выплаты КАК Логс_РеестрВыплатСамозанятымВыплаты
		|ГДЕ
		|	Логс_РеестрВыплатСамозанятымВыплаты.Ссылка В(&МассивОбъектов)
		|
		|СГРУППИРОВАТЬ ПО
		|	Логс_РеестрВыплатСамозанятымВыплаты.Ссылка.БанковскийСчет.БИКБанка,
		|	Логс_РеестрВыплатСамозанятымВыплаты.Ссылка.Дата,
		|	Логс_РеестрВыплатСамозанятымВыплаты.Ссылка.Организация.ИНН,
		|	Логс_РеестрВыплатСамозанятымВыплаты.Ссылка.Организация.Наименование,
		|	Логс_РеестрВыплатСамозанятымВыплаты.Договор.Номер,
		|	Логс_РеестрВыплатСамозанятымВыплаты.Ссылка.Номер,
		|	Логс_РеестрВыплатСамозанятымВыплаты.Ссылка.БанковскийСчет.НомерСчета,
		|	Логс_РеестрВыплатСамозанятымВыплаты.Договор.Дата,
		|	Логс_РеестрВыплатСамозанятымВыплаты.Ссылка,
		|	Логс_РеестрВыплатСамозанятымВыплаты.Партнер.Представление,
		|	Логс_РеестрВыплатСамозанятымВыплаты.Договор.БанковскийСчетКонтрагента.НомерСчета
		|ИТОГИ
		|	СУММА(ИтогСумма)
		|ПО
		|	Ссылка КАК ДокСсылка";
	
	Запрос.УстановитьПараметр("МассивОбъектов", МассивОбъектов);
	
	РезультатЗапроса = Запрос.Выполнить();    //Обход результата по Группировкам
	
	Возврат РезультатЗапроса;
	
КонецФункции


