	|	МИНИМУМ(РеализацияТоваровУслуг.Ссылка) КАК ДокументРеализации
	|ПОМЕСТИТЬ ДокументыРеализации
	|ИЗ
	|	Данные КАК Данные
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
	|		ПО Данные.Организация = РеализацияТоваровУслуг.Организация
	|			И Данные.Партнер = РеализацияТоваровУслуг.Партнер
	|			И Данные.Контрагент = РеализацияТоваровУслуг.Контрагент
	|			И Данные.Договор = РеализацияТоваровУслуг.Договор
	|			И Данные.ДокументОснование = РеализацияТоваровУслуг.Логс_ДокументОснование
	|			И (НАЧАЛОПЕРИОДА(РеализацияТоваровУслуг.Дата, ДЕНЬ) = &Период)
	|			И (РеализацияТоваровУслуг.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.РеализацияКлиенту))
	|			И (НЕ РеализацияТоваровУслуг.ПометкаУдаления)
	|
	|СГРУППИРОВАТЬ ПО
	|	Данные.Организация,
	|	Данные.Партнер,
	|	Данные.Контрагент,
	|	Данные.Договор,
	|	Данные.ДокументОснование
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Организация,
	|	Партнер,
	|	Контрагент,
	|	Договор,
	|	ДокументОснование
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Данные.Дата КАК Дата,
	|	Данные.Организация КАК Организация,
	|	Данные.Партнер КАК Партнер,
	|	Данные.Контрагент КАК Контрагент,
	|	Данные.Подразделение КАК Подразделение,
	|	Данные.Договор КАК Договор,
	|	Данные.НалогообложениеНДС КАК НалогообложениеНДС,
	|	Данные.ЦенаВключаетНДС КАК ЦенаВключаетНДС,
	|	Данные.Валюта КАК Валюта,
	|	Данные.БанковскийСчетОрганизации КАК БанковскийСчетОрганизации,
	|	ДоговорыКонтрагентов.БанковскийСчетКонтрагента КАК БанковскийСчетКонтрагента,
	|	ДоговорыКонтрагентов.ВалютаВзаиморасчетов КАК ВалютаВзаиморасчетов,
	|	ДоговорыКонтрагентов.ПорядокРасчетов КАК ПорядокРасчетов,
	|	ДоговорыКонтрагентов.Ссылка КАК Основание,
	|	ДоговорыКонтрагентов.Дата КАК ОснованиеДата,
	|	ДоговорыКонтрагентов.Номер КАК ОснованиеНомер,
	|	Данные.ДокументОснование КАК ДокументОснование,
	|	Данные.Комитент КАК Комитент,
	|	Данные.ДоговорКомитента КАК ДоговорКомитента,
	|	Данные.Номенклатура КАК Номенклатура,
	|	Данные.Характеристика КАК Характеристика,
	|	Данные.Склад КАК Склад,
	|	Данные.СводЗаявок КАК СводЗаявок,
	|	Данные.СуммаИтог КАК СуммаИтог,
	|	Данные.Сумма КАК Сумма,
	|	ЕСТЬNULL(ДокументыРеализации.ДокументРеализации, НЕОПРЕДЕЛЕНО) КАК РеализацияТоваровУслугСсылка
	|ИЗ
	|	Данные КАК Данные
	|		ЛЕВОЕ СОЕДИНЕНИЕ ДокументыРеализации КАК ДокументыРеализации
	|		ПО Данные.Организация = ДокументыРеализации.Организация
	|			И Данные.Партнер = ДокументыРеализации.Партнер
	|			И Данные.Контрагент = ДокументыРеализации.Контрагент
	|			И Данные.Договор = ДокументыРеализации.Договор
	|			И Данные.ДокументОснование = ДокументыРеализации.ДокументОснование
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
	|		ПО Данные.Договор = ДоговорыКонтрагентов.Ссылка
	|
	|УПОРЯДОЧИТЬ ПО
	|	ДокументОснование,
	|	ВЫБОР
	|		КОГДА Данные.Партнер = ЗНАЧЕНИЕ(Справочник.Партнеры.РозничныйПокупатель)
	|			ТОГДА 0
	|		ИНАЧЕ 1
	|	КОНЕЦ
	|ИТОГИ
	|	МИНИМУМ(Дата),
	|	МАКСИМУМ(Подразделение),
	|	МАКСИМУМ(НалогообложениеНДС),
	|	МАКСИМУМ(ЦенаВключаетНДС),
	|	МАКСИМУМ(БанковскийСчетОрганизации),
	|	МАКСИМУМ(БанковскийСчетКонтрагента),
	|	МАКСИМУМ(ВалютаВзаиморасчетов),
	|	МАКСИМУМ(ПорядокРасчетов),
	|	МАКСИМУМ(Основание),
	|	МАКСИМУМ(ОснованиеДата),
	|	МАКСИМУМ(ОснованиеНомер),
	|	МАКСИМУМ(Комитент),
	|	МАКСИМУМ(ДоговорКомитента),
	|	МАКСИМУМ(Склад),
	|	МАКСИМУМ(СуммаИтог),
	|	СУММА(Сумма),
	|	МАКСИМУМ(РеализацияТоваровУслугСсылка)
	|ПО
	|	ДокументОснование,
	|	Организация,
	|	Партнер,
	|	Контрагент,
	|	Договор,
	|	Валюта";
	
	ВыборкаОснования = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Менеджер = Пользователи.ТекущийПользователь();
	
	ТабКорр = Новый ТаблицаЗначений;
	ТабКорр.Колонки.Добавить("ДокументОснование");
	ТабКорр.Колонки.Добавить("Характеристика");
	ТабКорр.Колонки.Добавить("Сумма");
	ТабКорр.Колонки.Добавить("СуммаИтог");
	
	Пока ВыборкаОснования.Следующий() Цикл
		
		// Найдём строку в таблице созданных документов, в которую будем добавлять реализации.
		СтрокаСозданныхДокументов = ТаблицаСозданныхДокументов.НайтиСтроки(
			Новый Структура("Партнер,Договор",
				ВыборкаОснования.Комитент,
				ВыборкаОснования.ДоговорКомитента))[0];
		СтрокаПриемаНаКомиссию = СтрокаСозданныхДокументов.ДокументыПриемаНаКомиссию.Найти(ВыборкаОснования.ДокументОснование, "Ссылка");
		
		ВыборкаОрганизации = ВыборкаОснования.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаОрганизации.Следующий() Цикл
			
			Если УчетнаяПолитикаПереопределяемый.ПрименяетсяУСН(ВыборкаОрганизации.Организация, Параметры.НачалоПериода) Тогда
				НалогообложениеНДС = перечисления.ТипыНалогообложенияНДС.ПродажаНеОблагаетсяНДС;
			Иначе
				НалогообложениеНДС = перечисления.ТипыНалогообложенияНДС.ПродажаОблагаетсяНДС;
			КонецЕсли;
			
			//#TODO Костыль для УСН Орион - НДС нужен.
			Если ВыборкаОрганизации.Организация = ОрионОрганизация Тогда
				НалогообложениеНДС = перечисления.ТипыНалогообложенияНДС.ПродажаОблагаетсяНДС;
			КонецЕсли;
			
			
			ВыборкаПартнеры = ВыборкаОрганизации.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока ВыборкаПартнеры.Следующий() Цикл
				ВыборкаКонтрагенты = ВыборкаПартнеры.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
				Пока ВыборкаКонтрагенты.Следующий() Цикл
					ВыборкаДоговоры = ВыборкаКонтрагенты.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
					Пока ВыборкаДоговоры.Следующий() Цикл
						ВыборкаВалюты = ВыборкаДоговоры.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
						Пока ВыборкаВалюты.Следующий() Цикл
							
							Склад = ВыборкаВалюты.Склад;
							
							СтруктураОтветственного = ЗакупкиСервер.ПолучитьОтветственногоПоСкладу(Склад, Менеджер);
							Если СтруктураОтветственного <> Неопределено Тогда
								Отпустил = СтруктураОтветственного.Ответственный;
								ОтпустилДолжность = СтруктураОтветственного.ОтветственныйДолжность;
							КонецЕсли;
							
							Если ЗначениеЗаполнено(ВыборкаВалюты.РеализацияТоваровУслугСсылка) Тогда
								
								Если Параметры.ТолькоСоздаватьНовые Тогда
									Продолжить;
								КонецЕсли; 
								
								РеализацияТоваровУслуг = ВыборкаВалюты.РеализацияТоваровУслугСсылка.ПолучитьОбъект();
								                                
								РеализацияТоваровУслуг.Товары.Очистить();
								РеализацияТоваровУслуг.ЭтапыГрафикаОплаты.Очистить();
								
							Иначе
								
								РеализацияТоваровУслуг = Документы.РеализацияТоваровУслуг.СоздатьДокумент();
								РеализацияТоваровУслуг.Дата = ВыборкаВалюты.Дата;
								РеализацияТоваровУслуг.Организация = ВыборкаВалюты.Организация;
								РеализацияТоваровУслуг.Партнер = ВыборкаВалюты.Партнер;
								РеализацияТоваровУслуг.Контрагент = ВыборкаВалюты.Контрагент;
								РеализацияТоваровУслуг.Договор = ВыборкаВалюты.Договор;
								РеализацияТоваровУслуг.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.РеализацияКлиенту;
								
								РеализацияТоваровУслуг.УстановитьНовыйНомер();
								
							КонецЕсли; 
							
							РеализацияТоваровУслуг.Логс_ДокументОснование = ВыборкаВалюты.ДокументОснование;
							РеализацияТоваровУслуг.БанковскийСчетОрганизации = ВыборкаВалюты.БанковскийСчетОрганизации;
							РеализацияТоваровУслуг.БанковскийСчетКонтрагента = ВыборкаВалюты.БанковскийСчетКонтрагента;
							РеализацияТоваровУслуг.Валюта = ВыборкаВалюты.Валюта;
							//РеализацияТоваровУслуг.ДатаРаспоряжения = КонецДня(РеализацияТоваровУслуг.Дата);
							РеализацияТоваровУслуг.Менеджер = Менеджер;
							РеализацияТоваровУслуг.Склад = Склад;
							РеализацияТоваровУслуг.Отпустил = Отпустил;
							РеализацияТоваровУслуг.ОтпустилДолжность = ОтпустилДолжность;
							РеализацияТоваровУслуг.Статус = Перечисления.СтатусыРеализацийТоваровУслуг.Отгружено;
							РеализацияТоваровУслуг.Автор = Менеджер;
							РеализацияТоваровУслуг.СпособДоставки = Перечисления.СпособыДоставки.Самовывоз;
							РеализацияТоваровУслуг.ВариантОформленияПродажи = Перечисления.ВариантыОформленияПродажи.РеализацияТоваровУслуг;
							РеализацияТоваровУслуг.КурсЧислитель = 1;
							//РеализацияТоваровУслуг.Курс = 1;
							//РеализацияТоваровУслуг.Кратность = 1;
							РеализацияТоваровУслуг.Согласован = Истина;
							РеализацияТоваровУслуг.ПорядокРасчетов = ВыборкаВалюты.ПорядокРасчетов;
							РеализацияТоваровУслуг.НалогообложениеНДС = НалогообложениеНДС;
							РеализацияТоваровУслуг.ЦенаВключаетНДС = ВыборкаВалюты.ЦенаВключаетНДС;
							РеализацияТоваровУслуг.ВалютаВзаиморасчетов = ВыборкаВалюты.ВалютаВзаиморасчетов;
							РеализацияТоваровУслуг.Подразделение = ВыборкаВалюты.Подразделение;
							РеализацияТоваровУслуг.Основание = ВыборкаВалюты.Основание;
							РеализацияТоваровУслуг.ОснованиеНомер = ВыборкаВалюты.ОснованиеНомер;
							РеализацияТоваровУслуг.ОснованиеДата = ВыборкаВалюты.ОснованиеДата;
							РеализацияТоваровУслуг.Склад = ВыборкаВалюты.Склад;
		
							ОтветственныеЛицаСервер.ПриИзмененииСвязанныхРеквизитовДокумента(РеализацияТоваровУслуг);
							
							Выборка = ВыборкаВалюты.Выбрать();
							Пока Выборка.Следующий() Цикл
								
								Поиск = Новый Структура("ДокументОснование, Характеристика", Выборка.ДокументОснование, Выборка.Характеристика);
								СтрПоиск = ТабКорр.НайтиСтроки(Поиск);
								Если СтрПоиск.Количество() = 0 Тогда
									Строка = ТабКорр.Добавить();
									ЗаполнитьЗначенияСвойств(Строка, Выборка);
								Иначе
									Строка = СтрПоиск[0];
									Строка.Сумма = Строка.Сумма + Выборка.Сумма;
								КонецЕсли;	
								
								Разница = Строка.СуммаИтог - Строка.Сумма;
								РазницаКорр = 0;
								Если Разница = 0.01 ИЛИ Разница = -0.01 Тогда
									РазницаКорр = Разница;
								КонецЕсли;	
								
								НоваяСтрока = РеализацияТоваровУслуг.Товары.Добавить();
								НоваяСтрока.Номенклатура = Выборка.Номенклатура;
								НоваяСтрока.Характеристика = Выборка.Характеристика;
								НоваяСтрока.КоличествоУпаковок = Выборка.Сумма + РазницаКорр;
								НоваяСтрока.Количество = Выборка.Сумма + РазницаКорр;
								НоваяСтрока.Цена = 1;
								НоваяСтрока.Сумма = Выборка.Сумма + РазницаКорр;    
								//#TODO Костыль для УСН Орион - НДС нужен.
								Если РеализацияТоваровУслуг.Организация = ОрионОрганизация И РеализацияТоваровУслуг.Дата < Дата("20260101") Тогда
									НоваяСтрока.СтавкаНДС = СтавкаНДС5;  
								ИначеЕсли (РеализацияТоваровУслуг.Организация = ЛогсисОрганизация ИЛИ РеализацияТоваровУслуг.Организация = ОрионОрганизация) И РеализацияТоваровУслуг.Дата >= Дата("20260101") Тогда  
									НоваяСтрока.СтавкаНДС =
									?(РеализацияТоваровУслуг.НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.ПродажаОблагаетсяНДС,
									СтавкаНДС22, СтавкаБезНДС
									);  
                              	Иначе								
									НоваяСтрока.СтавкаНДС =
									?(РеализацияТоваровУслуг.НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.ПродажаОблагаетсяНДС,
									СтавкаНДС20, СтавкаБезНДС
									);  
								КонецЕсли;  
															
								//НоваяСтрока.СтавкаНДС =
								//	?(РеализацияТоваровУслуг.НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.ПродажаОблагаетсяНДС,
								//		//Перечисления.СтавкиНДС.НДС20,
								//		//Перечисления.СтавкиНДС.БезНДС);
								//		СтавкаНДС20, СтавкаБезНДС);  
								
								//НоваяСтрока.СуммаНДС = УчетНДСУПКлиентСервер.РассчитатьСуммуНДС(НоваяСтрока.Сумма,
								//	УчетНДСУПКлиентСервер.ПолучитьСтавкуНДС(НоваяСтрока.СтавкаНДС),
								//	РеализацияТоваровУслуг.ЦенаВключаетНДС, РеализацияТоваровУслуг.НалогообложениеНДС);
								НоваяСтрока.СуммаНДС = УчетНДСУПКлиентСервер.РассчитатьСуммуНДС(НоваяСтрока.Сумма,
									УчетНДСУПВызовСервера.ЗначениеСтавкиНДС(НоваяСтрока.СтавкаНДС),
									РеализацияТоваровУслуг.ЦенаВключаетНДС, РеализацияТоваровУслуг.НалогообложениеНДС);
								НоваяСтрока.СуммаСНДС = НоваяСтрока.Сумма;
								НоваяСтрока.Склад = Выборка.Склад;
								НоваяСтрока.Логс_СводЗаявокНаДоставку = Выборка.СводЗаявок;

							КонецЦикла;
							
							ЭтапОплаты = РеализацияТоваровУслуг.ЭтапыГрафикаОплаты.Добавить();
							ЭтапОплаты.ВариантОплаты = Перечисления.ВариантыКонтроляОплатыКлиентом.КредитПослеОтгрузки;
							ЭтапОплаты.ДатаПлатежа = НачалоДня(РеализацияТоваровУслуг.Дата);
							ЭтапОплаты.СуммаПлатежа = РеализацияТоваровУслуг.Товары.Итог("СуммаСНДС");
							ЭтапОплаты.ПроцентПлатежа = 100;
							ЭтапОплаты.ПроцентЗалогаЗаТару = 100;
							ЭтапОплаты.СуммаВзаиморасчетов = ЭтапОплаты.СуммаПлатежа;
							ЭтапОплаты.ВариантОтсчета = Перечисления.ВариантыОтсчетаДатыПлатежа.ОтДатыОтгрузки;
							
							Если РеализацияТоваровУслуг.Ссылка.Пустая() Тогда
								РеализацияТоваровУслуг.Записать(РежимЗаписиДокумента.Запись);
							КонецЕсли; 
							
							Попытка
								РеализацияТоваровУслуг.Записать(РежимЗаписиДокумента.Проведение);
							Исключение
								РеализацияТоваровУслуг.Записать(РежимЗаписиДокумента.Запись);
								ОписаниеОшибки = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
								ТекстСообщения = СтрШаблон(
									НСтр("ru='Произошла ошибка при записи реализации товаров агента № %1 от %2: %3'"),
									РеализацияТоваровУслуг.Номер, Формат(РеализацияТоваровУслуг.Дата, "ДФ=dd.MM.yyyy"),
									ОписаниеОшибки);
								ЗаписьЖурналаРегистрации("УУ Создание регламентированных документов. Создание реализации товаров агента",
									УровеньЖурналаРегистрации.Ошибка,,, ТекстСообщения);
								СписокОшибок.Вставить(РеализацияТоваровУслуг.Ссылка, ОписаниеОшибки);
							КонецПопытки;
							
							СтрокаПриемаНаКомиссию.ДокументыРеализации.Добавить(РеализацияТоваровУслуг.Ссылка);
						
						КонецЦикла; // Валюты
					КонецЦикла; // Договоры
				КонецЦикла; // Контрагенты
			КонецЦикла; // Партнеры
		КонецЦикла; // Организации
	КонецЦикла; // Основания
	
	Запрос.Текст =
	"УНИЧТОЖИТЬ ТаблицаТовары
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ Данные
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ДокументыРеализации";
	Запрос.Выполнить();
	
КонецПроцедуры 

Процедура СоздатьДокументыОтчетКомитенту(Параметры, ТаблицаСозданныхДокументов, СписокОшибок)
	
	Если Не Параметры.Создавать.СоздаватьОтчетыКомитента Тогда
		Возврат;
	КонецЕсли;
	
	ДокументыРеализации = ПолучитьДокументыРеализацииИзТаблицыСозданныхДокументов(ТаблицаСозданныхДокументов);
	Если ДокументыРеализации.Количество() = 0 Тогда
		Возврат;
	КонецЕсли; 
	
	СтавкаНДС20 = Константы.Логс_СтавкаНДС20.Получить();
	СтавкаБезНДС = Справочники.СтавкиНДС.БезНДС;  
	СтавкаНДС5 = Справочники.СтавкиНДС.НайтиПоНаименованию("5%");  
	СтавкаНДС22 = Справочники.СтавкиНДС.НайтиПоНаименованию("22%");
	ЛогсисОрганизация = Справочники.Организации.НайтиПоРеквизиту("ИНН", "9725007793");
	ОрионОрганизация = Справочники.Организации.НайтиПоРеквизиту("ИНН", "9728051543");

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Период", НачалоДня(Параметры.ДатаФормирования));
	Запрос.УстановитьПараметр("НачалоПериода", НачалоДня(Параметры.НачалоПериода));
	Запрос.УстановитьПараметр("КонецПериода", КонецДня(Параметры.КонецПериода));
	Запрос.УстановитьПараметр("ДокументыРеализации", ДокументыРеализации);
	Запрос.УстановитьПараметр("Организация", Параметры.Организация);
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ПриобретениеТоваровУслуг.Ссылка КАК ДокументОснование,
	|	ПриобретениеТоваровУслуг.Организация КАК Организация,
	|	ПриобретениеТоваровУслуг.Партнер КАК Партнер,
	|	ПриобретениеТоваровУслуг.Контрагент КАК Контрагент,
	|	ПриобретениеТоваровУслуг.Договор КАК Договор,
	|	ДОБАВИТЬКДАТЕ(РеализацияТоваровУслуг.Дата, СЕКУНДА, 1) КАК Дата,
	|	ПриобретениеТоваровУслуг.НалогообложениеНДС КАК НалогообложениеНДС,
	|	ПриобретениеТоваровУслуг.Подразделение КАК Подразделение,
	|	ПриобретениеТоваровУслуг.ЦенаВключаетНДС КАК ЦенаВключаетНДС,
	|	ПриобретениеТоваровУслуг.ФормаОплаты КАК ФормаОплаты,
	|	ПриобретениеТоваровУслуг.ПорядокРасчетов КАК ПорядокРасчетов,
	|	ПриобретениеТоваровУслуг.БанковскийСчетОрганизации КАК БанковскийСчет,
	|	РеализацияТоваровУслуг.Контрагент КАК Покупатель,
	|	ТаблицаТовары.Номенклатура КАК Номенклатура,
	|	ТаблицаТовары.Характеристика КАК Характеристика,
	|	ТаблицаТовары.Сумма КАК СуммаПродажи,
	|	ЕСТЬNULL(ДанныеСводов.ПолнаяСтоимостьВсего, 0) КАК СуммаВознаграждения,
	|	ТаблицаТовары.Склад КАК Склад,
	|	ТаблицаТовары.Логс_СводЗаявокНаДоставку КАК СводЗаявок,
	|	ДанныеСводов.Номер КАК НомерСвода,
	|	ДанныеСводов.Дата КАК ДатаСвода,
	|	ЛОЖЬ КАК УдержатьВознаграждение,
	|	ВЗ_ДанныеСводовНДС.НДС КАК СуммаНДСВознаграждения
	|ПОМЕСТИТЬ ТаблицаТовары	
	|ИЗ
	|	Документ.РеализацияТоваровУслуг.Товары КАК ТаблицаТовары
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПриобретениеТоваровУслуг КАК ПриобретениеТоваровУслуг
	|			ПО РеализацияТоваровУслуг.Логс_ДокументОснование = ПриобретениеТоваровУслуг.Ссылка
	|		ПО ТаблицаТовары.Ссылка = РеализацияТоваровУслуг.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.Логс_СводЗаявокНаДоставку КАК ДанныеСводов
	|		ПО ТаблицаТовары.Логс_СводЗаявокНаДоставку = ДанныеСводов.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			Логс_СводЗаявокНаДоставкуЗаявки.Ссылка КАК Ссылка,
	|			СУММА(Логс_СводЗаявокНаДоставкуЗаявки.ПолнаяСтоимостьНДС) КАК НДС
	|		ИЗ
	|			Документ.Логс_СводЗаявокНаДоставку.Заявки КАК Логс_СводЗаявокНаДоставкуЗаявки
	|		
	|		СГРУППИРОВАТЬ ПО
	|			Логс_СводЗаявокНаДоставкуЗаявки.Ссылка) КАК ВЗ_ДанныеСводовНДС
	|		ПО ТаблицаТовары.Логс_СводЗаявокНаДоставку = ВЗ_ДанныеСводовНДС.Ссылка
	
	|ГДЕ
	|	ТаблицаТовары.Ссылка В(&ДокументыРеализации)
	|;
