Функция СоздатьДокументыВзаимозачетыСКСПоТМС(Параметры, СписокОшибок = Неопределено) 
		
	Перем Партнер;
	
	Если СписокОшибок = Неопределено Тогда
		СписокОшибок = Новый Массив;
	КонецЕсли; 
	
	МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	
	Параметры.Свойство("Партнер", Партнер);
	
	СписокОшибокДляОтчета = Новый Соответствие;
	
	СозданныеДокументы = Новый ТаблицаЗначений;
	СозданныеДокументы.Колонки.Добавить("Партнер", Новый ОписаниеТипов("СправочникСсылка.Партнеры"));
	СозданныеДокументы.Колонки.Добавить("Договор", Новый ОписаниеТипов("СправочникСсылка.ДоговорыКонтрагентов"));
	СозданныеДокументы.Колонки.Добавить("ДокументыПриемаНаКомиссию", Новый ОписаниеТипов("ТаблицаЗначений"));
	СозданныеДокументы.Колонки.Добавить("ДокументыОтчетовКомитентам", Новый ОписаниеТипов("Массив"));
	СозданныеДокументы.Колонки.Добавить("ДокументыАктовВыполненныхРабот", Новый ОписаниеТипов("Массив"));
	СозданныеДокументы.Колонки.Добавить("ДокументыПриобретенияУслугСКС", Новый ОписаниеТипов("Массив"));
	СозданныеДокументы.Индексы.Добавить("Партнер,Договор");
	
	СоздатьДокументВзаимозачетЗадолженностиСКСТМС(Параметры, МенеджерВременныхТаблиц, СозданныеДокументы, СписокОшибокДляОтчета);
	
	Для каждого КлючИЗначение Из СписокОшибокДляОтчета Цикл
		СписокОшибок.Добавить(Новый Структура("ТекстОшибки,КлючДанных",
		КлючИЗначение.Значение, КлючИЗначение.Ключ));
	КонецЦикла;
	
	Если Параметры.ПоказатьОтчетПоЗавершении Тогда
		ТабличныйДокумент = СформироватьОтчетОСозданныхДокументахДвиженияДС(Параметры, СозданныеДокументы, СписокОшибокДляОтчета);
	Иначе
		ТабличныйДокумент = Неопределено;
	КонецЕсли; 
	
	Возврат ТабличныйДокумент;
		
КонецФункции   

Процедура СоздатьДокументВзаимозачетЗадолженностиСКСТМС(Параметры, МенеджерВременныхТаблиц, СозданныеДокументы, СписокОшибокДляОтчета)   
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("Дата", НачалоДня(Параметры.ДатаФормирования));
	Запрос.УстановитьПараметр("НачалоПериода", НачалоДня(Параметры.НачалоПериода));
	Запрос.УстановитьПараметр("КонецПериода", КонецДня(Параметры.КонецПериода));
	
	Партнер = Неопределено;
	Параметры.Свойство("Партнер", Партнер);
	Запрос.УстановитьПараметр("Партнер", Партнер);
	Запрос.УстановитьПараметр("ПартнерЗаполнен", ЗначениеЗаполнено(Партнер));
	 
	Запрос.Текст = ( "ВЫБРАТЬ
	                 |	Логс_СводМаршрутов.Ссылка КАК ДокументСводовМаршрутов,
	                 |	Логс_СводМаршрутов.ДоговорСКС.Организация КАК Организация,
	                 |	Логс_СводМаршрутов.КонтрагентСКС КАК КонтрагентСКС,
	                 |	Логс_СводМаршрутов.ПартнерСКС КАК ПартнерСКС,
	                 |	Логс_СводМаршрутов.ДоговорСКС КАК ДоговорСКС
	                 |ПОМЕСТИТЬ втСводыМаршрутов
	                 |ИЗ
	                 |	Документ.Логс_СводМаршрутов КАК Логс_СводМаршрутов
	                 |ГДЕ
	                 |	Логс_СводМаршрутов.Ссылка.Проведен
	                 |	И Логс_СводМаршрутов.Дата МЕЖДУ &НачалоПериода И &КонецПериода
	                 |	И ВЫБОР
	                 |			КОГДА &ПартнерЗаполнен
	                 |				ТОГДА Логс_СводМаршрутов.ПартнерСКС = &Партнер
	                 |			ИНАЧЕ ИСТИНА
	                 |		КОНЕЦ
	                 |;
	                 |
	                 |////////////////////////////////////////////////////////////////////////////////
	                 |ВЫБРАТЬ
	                 |	МАКСИМУМ(ПриобретениеУслугПрочихАктивовРасходы.Ссылка) КАК ДокументПриобретениеУслуг,
	                 |	ПриобретениеУслугПрочихАктивовРасходы.Ссылка.Договор КАК Договор,
	                 |	ПриобретениеУслугПрочихАктивовРасходы.Логс_СводМаршрутов КАК СводМаршрутов
	                 |ПОМЕСТИТЬ втДокументПриобретениеУслуг
	                 |ИЗ
	                 |	втСводыМаршрутов КАК втСводыМаршрутов
	                 |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПриобретениеУслугПрочихАктивов.Расходы КАК ПриобретениеУслугПрочихАктивовРасходы
	                 |		ПО втСводыМаршрутов.ДоговорСКС = ПриобретениеУслугПрочихАктивовРасходы.Ссылка.Договор
	                 |			И втСводыМаршрутов.ДокументСводовМаршрутов = ПриобретениеУслугПрочихАктивовРасходы.Логс_СводМаршрутов
	                 |ГДЕ
	                 |	НЕ ПриобретениеУслугПрочихАктивовРасходы.Ссылка.ПометкаУдаления
	                 |	И ПриобретениеУслугПрочихАктивовРасходы.Ссылка.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ЗакупкаУПоставщика)
	                 |
	                 |СГРУППИРОВАТЬ ПО
	                 |	ПриобретениеУслугПрочихАктивовРасходы.Ссылка.Договор,
	                 |	ПриобретениеУслугПрочихАктивовРасходы.Логс_СводМаршрутов
	                 |;
	                 |
	                 |////////////////////////////////////////////////////////////////////////////////
	                 |ВЫБРАТЬ
	                 |	втДокументПриобретениеУслуг.ДокументПриобретениеУслуг КАК ДокументПриобретениеУслуг,
	                 |	втДокументПриобретениеУслуг.СводМаршрутов КАК СводМаршрутов,
	                 |	МАКСИМУМ(ЕСТЬNULL(ВзаимозачетЗадолженности.Ссылка, НЕОПРЕДЕЛЕНО)) КАК Взаимозачет,
	                 |	втДокументПриобретениеУслуг.СводМаршрутов.КонтрагентСКС КАК КонтрагентСКС,
	                 |	втДокументПриобретениеУслуг.СводМаршрутов.ПартнерСКС КАК ПартнерСКС,
	                 |	втДокументПриобретениеУслуг.СводМаршрутов.Организация КАК Организация,
	                 |	втДокументПриобретениеУслуг.СводМаршрутов.ДоговорСКС КАК ДоговорСКС,
	                 |	втДокументПриобретениеУслуг.СводМаршрутов.ДоговорСКС.ВалютаВзаиморасчетов КАК ВалютаВзаиморасчетов,
	                 |	втДокументПриобретениеУслуг.ДокументПриобретениеУслуг.СуммаДокумента КАК СуммаДокумента,
	                 |	втДокументПриобретениеУслуг.ДокументПриобретениеУслуг.Подразделение КАК Подразделение
	                 |ИЗ
	                 |	втДокументПриобретениеУслуг КАК втДокументПриобретениеУслуг
	                 |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ВзаимозачетЗадолженности КАК ВзаимозачетЗадолженности
	                 |		ПО втДокументПриобретениеУслуг.ДокументПриобретениеУслуг = ВзаимозачетЗадолженности.ДокументОснование
	                 |			И (НЕ ВзаимозачетЗадолженности.ПометкаУдаления)
	                 |
	                 |СГРУППИРОВАТЬ ПО
	                 |	втДокументПриобретениеУслуг.ДокументПриобретениеУслуг,
	                 |	втДокументПриобретениеУслуг.СводМаршрутов,
	                 |	втДокументПриобретениеУслуг.СводМаршрутов.КонтрагентСКС,
	                 |	втДокументПриобретениеУслуг.СводМаршрутов.ПартнерСКС,
	                 |	втДокументПриобретениеУслуг.СводМаршрутов.Организация,
	                 |	втДокументПриобретениеУслуг.СводМаршрутов.ДоговорСКС,
	                 |	втДокументПриобретениеУслуг.СводМаршрутов.ДоговорСКС.ВалютаВзаиморасчетов,
	                 |	втДокументПриобретениеУслуг.ДокументПриобретениеУслуг.СуммаДокумента") ; 
					 
	Результат = Запрос.Выполнить();
	
	Выборка = Результат.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		ПриобретениеУслугПрочихАктивов = Выборка.ДокументПриобретениеУслуг;
		Организация = Выборка.Организация;
		Партнер = Выборка.ПартнерСКС;
		Контрагент = Выборка.КонтрагентСКС;
		Подразделение = Выборка.Подразделение;
		Договор = Выборка.ДоговорСКС; 
		ВалютаВзаиморасчетов = Выборка.ВалютаВзаиморасчетов;
		СуммаВсего = Выборка.СуммаДокумента;
		ВзаимозачетЗадолженности = Выборка.Взаимозачет;  
		
		СтрокиСозданныхДокументов = СозданныеДокументы.НайтиСтроки(
		Новый Структура("Партнер,Договор",
		Партнер,
		Договор));
		Если СтрокиСозданныхДокументов.Количество() = 0 Тогда
			СтрокаСозданныхДокументов = СозданныеДокументы.Добавить();
			СтрокаСозданныхДокументов.Партнер = Партнер;
			СтрокаСозданныхДокументов.Договор = Договор;
		Иначе
			СтрокаСозданныхДокументов = СтрокиСозданныхДокументов[0];
		КонецЕсли;    
		
		ДоговорСПокупателем = ПолучитьДоговорСПокупателем(Контрагент, Договор);
		
		ОбъектРасчетовСПокупателем = ПолучитьОбъектовРасчетов(ДоговорСПокупателем, Перечисления.ТипыРасчетовСПартнерами.РасчетыСКлиентом); 
		ОбъектРасчетовСПоставщиком = ПолучитьОбъектовРасчетов(Договор, Перечисления.ТипыРасчетовСПартнерами.РасчетыСПоставщиком); 
					 		
		ВзаимозачетСсылка = СоздатьИзменитьДокументВзаимозачетЗадолженностиСКСТМС(Параметры.ДатаФормирования,
		Организация, Партнер, Контрагент, Подразделение,
		ОбъектРасчетовСПоставщиком, ОбъектРасчетовСПокупателем, ВалютаВзаиморасчетов,
		ПриобретениеУслугПрочихАктивов, СуммаВсего,
		ВзаимозачетЗадолженности, СписокОшибокДляОтчета);
		
		СтрокаСозданныхДокументов.ДокументыПриобретенияУслугСКС.Добавить(Новый Структура("Ссылка,Взаимозачет",
		ПриобретениеУслугПрочихАктивов, ВзаимозачетСсылка));	
		
	КонецЦикла;
	
	Запрос.Текст =
	"УНИЧТОЖИТЬ втСводыМаршрутов
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ втДокументПриобретениеУслуг";
	Запрос.Выполнить();

	
КонецПроцедуры     

Функция ПолучитьДоговорСПокупателем(Контрагент, Договор) 
	
	ДоговорСПокупателем = Неопределено;
	
	НомерДоговораБезДефиса = СтрЗаменить(Договор.Номер, "-", "");
	
	Запрос = Новый Запрос;
	Запрос.Текст =  ( "ВЫБРАТЬ
	                  |	ДоговорыКонтрагентов.Ссылка КАК ДоговорСПокупателем
	                  |ИЗ
	                  |	Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
	                  |ГДЕ
	                  |	ДоговорыКонтрагентов.Контрагент = &Контрагент
	                  |	И ДоговорыКонтрагентов.Номер = &Номер
	                  |	И ДоговорыКонтрагентов.ТипДоговора = ЗНАЧЕНИЕ(Перечисление.ТипыДоговоров.СПокупателем)
	                  |	И НЕ ДоговорыКонтрагентов.ПометкаУдаления");
	Запрос.УстановитьПараметр("Контрагент", Контрагент);  
	Запрос.УстановитьПараметр("Номер", НомерДоговораБезДефиса);
	
	Результат = Запрос.Выполнить();
	
	Если НЕ Результат.Пустой() Тогда 
		
		Выборка = Результат.Выбрать();
		Выборка.Следующий();
		
		ДоговорСПокупателем = Выборка.ДоговорСПокупателем;
				
	КонецЕсли;
	
	Возврат ДоговорСПокупателем;

КонецФункции

Функция ПолучитьОбъектовРасчетов(Договор, ТипРасчетов) 
	
	Возврат ОбъектыРасчетовСервер.ПолучитьОбъектРасчетовПоСсылке(Договор, Договор.Организация, ТипРасчетов);
	
КонецФункции


Функция СоздатьИзменитьДокументВзаимозачетЗадолженностиСКСТМС(Дата, Организация, Партнер, Контрагент, Подразделение, Договор, ДоговорСПокупателем,
	ВалютаВзаиморасчетов, ДокументОснование, СуммаВзаимозачета, ДокументСсылка, СписокОшибок)
	
	Если ЗначениеЗаполнено(ДокументСсылка) Тогда
		ВзаимозачетЗадолженности = ДокументСсылка.ПолучитьОбъект();
		
		ВзаимозачетЗадолженности.ДебиторскаяЗадолженность.Очистить();
		ВзаимозачетЗадолженности.КредиторскаяЗадолженность.Очистить();
	Иначе
		ВзаимозачетЗадолженности = Документы.ВзаимозачетЗадолженности.СоздатьДокумент();
		ВзаимозачетЗадолженности.Дата = Дата;
		ВзаимозачетЗадолженности.Организация = Организация;
		ВзаимозачетЗадолженности.КонтрагентДебитор = Контрагент;
		ВзаимозачетЗадолженности.КонтрагентКредитор = Контрагент;
		ВзаимозачетЗадолженности.ТипДебитора = Перечисления.ТипыУчастниковВзаимозачета.Клиент;
		ВзаимозачетЗадолженности.ТипКредитора = Перечисления.ТипыУчастниковВзаимозачета.Поставщик;
		ВзаимозачетЗадолженности.ДокументОснование = ДокументОснование;
		ВзаимозачетЗадолженности.Ответственный = Пользователи.ТекущийПользователь();
		
		ВзаимозачетЗадолженности.УстановитьНовыйНомер();
	КонецЕсли; 
	
	ВзаимозачетЗадолженности.Подразделение = Подразделение;
	ВзаимозачетЗадолженности.ВидОперации = Перечисления.ВидыОперацийВзаимозачетаЗадолженности.Бартер;
	ВзаимозачетЗадолженности.СуммаРегл = СуммаВзаимозачета;
	ВзаимозачетЗадолженности.СуммаУпр = СуммаВзаимозачета;
	ВзаимозачетЗадолженности.Логс_ФормироватьДвиженияПоУпрУчету = Истина;

	ОтветственныеЛицаСервер.ПриИзмененииСвязанныхРеквизитовДокумента(ВзаимозачетЗадолженности);
	
	СтрокаЗадолженность = ВзаимозачетЗадолженности.ДебиторскаяЗадолженность.Добавить();
	СтрокаЗадолженность.ТипРасчетов = Перечисления.ТипыРасчетовСПартнерами.РасчетыСКлиентом;
	СтрокаЗадолженность.Партнер = Партнер;
	//СтрокаЗадолженность.Заказ = ДоговорСПокупателем;
	СтрокаЗадолженность.ОбъектРасчетов = ДоговорСПокупателем;
	СтрокаЗадолженность.ВалютаВзаиморасчетов = ВалютаВзаиморасчетов;
	СтрокаЗадолженность.Организация = Организация;
	СтрокаЗадолженность.СуммаВзаиморасчетов = СуммаВзаимозачета;
	СтрокаЗадолженность.СуммаРегл = СуммаВзаимозачета;
	СтрокаЗадолженность.СуммаУпр = СуммаВзаимозачета;
	
	СтрокаЗадолженность = ВзаимозачетЗадолженности.КредиторскаяЗадолженность.Добавить();
	СтрокаЗадолженность.ТипРасчетов = Перечисления.ТипыРасчетовСПартнерами.РасчетыСПоставщиком;
	СтрокаЗадолженность.Партнер = Партнер;
	//СтрокаЗадолженность.Заказ = Договор;
	СтрокаЗадолженность.ОбъектРасчетов = Договор;
	СтрокаЗадолженность.ВалютаВзаиморасчетов = ВалютаВзаиморасчетов;
	СтрокаЗадолженность.Организация = Организация;
	СтрокаЗадолженность.СуммаВзаиморасчетов = СуммаВзаимозачета;
	СтрокаЗадолженность.СуммаРегл = СуммаВзаимозачета;
	СтрокаЗадолженность.СуммаУпр = СуммаВзаимозачета;
	
	Если ВзаимозачетЗадолженности.Ссылка.Пустая() Тогда
		ВзаимозачетЗадолженности.Записать(РежимЗаписиДокумента.Запись);
	КонецЕсли; 
	
	Попытка
		ВзаимозачетЗадолженности.Записать(РежимЗаписиДокумента.Проведение);
	Исключение
		ОписаниеОшибки = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		ТекстСообщения = СтрШаблон(
			НСтр("ru='Произошла ошибка при записи взаимозачета задолженности № %1 от %2: %3'"),
			ВзаимозачетЗадолженности.Номер, Формат(ВзаимозачетЗадолженности.Дата, "ДФ=dd.MM.yyyy"),
			ОписаниеОшибки);
		ЗаписьЖурналаРегистрации("УУ Создание регламентированных документов. Создание взаимозачета задолженности СКС ТМС",
			УровеньЖурналаРегистрации.Ошибка,,, ТекстСообщения);
		СписокОшибок.Вставить(ВзаимозачетЗадолженности.Ссылка, ОписаниеОшибки);
	КонецПопытки; 

	Возврат ВзаимозачетЗадолженности.Ссылка;
	
КонецФункции 
 
