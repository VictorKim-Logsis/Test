	|		ТаблицаТовары.ПорядокРасчетов КАК ПорядокРасчетов,
	|		ТаблицаТовары.БанковскийСчет КАК БанковскийСчет,
	|		ТаблицаТовары.Дата КАК Дата,
	|		ТаблицаТовары.Покупатель КАК Покупатель,
	|		ТаблицаТовары.Склад КАК Склад,
	|		ТаблицаТовары.СводЗаявок КАК СводЗаявок,
	|		ТаблицаТовары.НомерСвода КАК НомерСвода,
	|		ТаблицаТовары.ДатаСвода КАК ДатаСвода,
	|		ТаблицаТовары.УдержатьВознаграждение КАК УдержатьВознаграждение,
	|		ТаблицаТовары.Номенклатура КАК Номенклатура,
	|		ТаблицаТовары.Характеристика КАК Характеристика,
	|		ТаблицаТовары.СуммаПродажи КАК СуммаПродажи,
	|		ВЫРАЗИТЬ(ТаблицаТовары.СуммаВознаграждения * ТаблицаТовары.СуммаПродажи / ВЫБОР
	|				КОГДА СуммыПродажДляРаспределенияВознаграждения.СуммаПродажи = 0
	|					ТОГДА 0
	|				ИНАЧЕ СуммыПродажДляРаспределенияВознаграждения.СуммаПродажи
	|			КОНЕЦ КАК ЧИСЛО(15, 2)) КАК СуммаВознаграждения,
	|		ВЫРАЗИТЬ(ТаблицаТовары.СуммаНДСВознаграждения * ТаблицаТовары.СуммаПродажи / ВЫБОР
	|				КОГДА СуммыПродажДляРаспределенияВознаграждения.СуммаПродажи = 0
	|					ТОГДА 0
	|				ИНАЧЕ СуммыПродажДляРаспределенияВознаграждения.СуммаПродажи
	|			КОНЕЦ КАК ЧИСЛО(15, 2)) КАК СуммаНДСВознаграждения	
	|	ИЗ
	|		ТаблицаТовары КАК ТаблицаТовары
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ СуммыПродажДляРаспределенияВознаграждения КАК СуммыПродажДляРаспределенияВознаграждения
	|			ПО ТаблицаТовары.СводЗаявок = СуммыПродажДляРаспределенияВознаграждения.СводЗаявок
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		ТаблицаВознаграждения.ДокументОснование,
	|		ТаблицаВознаграждения.Организация,
	|		ТаблицаВознаграждения.Партнер,
	|		ТаблицаВознаграждения.Контрагент,
	|		ТаблицаВознаграждения.Договор,
	|		ТаблицаВознаграждения.НалогообложениеНДС,
	|		ТаблицаВознаграждения.Подразделение,
	|		ТаблицаВознаграждения.ЦенаВключаетНДС,
	|		ТаблицаВознаграждения.ФормаОплаты,
	|		ТаблицаВознаграждения.ПорядокРасчетов,
	|		ТаблицаВознаграждения.БанковскийСчет,
	|		ТаблицаВознаграждения.Дата,
	|		ЗНАЧЕНИЕ(Справочник.Контрагенты.РозничныйПокупатель),
	|		ТаблицаВознаграждения.Склад,
	|		ТаблицаВознаграждения.СводЗаявок,
	|		ТаблицаВознаграждения.НомерСвода,
	|		ТаблицаВознаграждения.ДатаСвода,
	|		ТаблицаВознаграждения.УдержатьВознаграждение,
	|		НЕОПРЕДЕЛЕНО,
	|		НЕОПРЕДЕЛЕНО,
	|		0,
	|		ТаблицаВознаграждения.Сумма,
	|		ТаблицаВознаграждения.НДС
	|	ИЗ
	|		ТаблицаВознаграждения КАК ТаблицаВознаграждения) КАК ВложенныйЗапрос
	|		ЛЕВОЕ СОЕДИНЕНИЕ СуществующиеДокументы КАК СуществующиеДокументы
	|		ПО ВложенныйЗапрос.ДокументОснование = СуществующиеДокументы.ДокументОснование
	|
	|УПОРЯДОЧИТЬ ПО
	|	Организация,
	|	Партнер,
	|	Договор,
	|	НомерСвода
	|ИТОГИ
	|	МАКСИМУМ(НалогообложениеНДС),
	|	МАКСИМУМ(Подразделение),
	|	МАКСИМУМ(ЦенаВключаетНДС),
	|	МАКСИМУМ(ФормаОплаты),
	|	МАКСИМУМ(ПорядокРасчетов),
	|	МАКСИМУМ(БанковскийСчет),
	|	МИНИМУМ(Дата),
	|	МАКСИМУМ(УдержатьВознаграждение),
	|	СУММА(СуммаПродажи),
	|	СУММА(СуммаВознаграждения),
	|	СУММА(СуммаНДСВознаграждения),
	|	МИНИМУМ(ОтчетКомитентуСсылка),
	|	МИНИМУМ(СчетФактураСсылка)
	|ПО
	|	Организация,
	|	Партнер,
	|	Контрагент,
	|	Договор,
	|	ДокументОснование
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ СуществующиеДокументы
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ СуммыПродажДляРаспределенияВознаграждения
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВложенныйЗапрос.Организация КАК Организация,
	|	ВложенныйЗапрос.Партнер КАК Партнер,
	|	ВложенныйЗапрос.Контрагент КАК Контрагент,
	|	ВложенныйЗапрос.Договор КАК Договор,
	|	СУММА(ВложенныйЗапрос.СуммаВознаграждения) КАК Сумма,
	|	СУММА(ВложенныйЗапрос.СуммаНДСВознаграждения) КАК НДС
	|ИЗ
	|	(ВЫБРАТЬ
	|		ВложенныйЗапрос.Организация КАК Организация,
	|		ВложенныйЗапрос.Партнер КАК Партнер,
	|		ВложенныйЗапрос.Контрагент КАК Контрагент,
	|		ВложенныйЗапрос.Договор КАК Договор,
	|		ВложенныйЗапрос.СуммаВознаграждения КАК СуммаВознаграждения,
	|		ВложенныйЗапрос.СуммаНДСВознаграждения КАК СуммаНДСВознаграждения
	|	ИЗ
	|		(ВЫБРАТЬ
	|			ТаблицаТовары.Организация КАК Организация,
	|			ТаблицаТовары.Партнер КАК Партнер,
	|			ТаблицаТовары.Контрагент КАК Контрагент,
	|			ТаблицаТовары.Договор КАК Договор,
	|			ТаблицаТовары.СводЗаявок КАК СводЗаявок,
	|			МАКСИМУМ(ТаблицаТовары.СуммаВознаграждения) КАК СуммаВознаграждения,
	|			МАКСИМУМ(ТаблицаТовары.СуммаНДСВознаграждения) КАК СуммаНДСВознаграждения
	|		ИЗ
	|			ТаблицаТовары КАК ТаблицаТовары
	|		
	|		СГРУППИРОВАТЬ ПО
	|			ТаблицаТовары.Организация,
	|			ТаблицаТовары.Партнер,
	|			ТаблицаТовары.Контрагент,
	|			ТаблицаТовары.Договор,
	|			ТаблицаТовары.СводЗаявок) КАК ВложенныйЗапрос
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		ТаблицаВознаграждения.Организация,
	|		ТаблицаВознаграждения.Партнер,
	|		ТаблицаВознаграждения.Контрагент,
	|		ТаблицаВознаграждения.Договор,
	|		ТаблицаВознаграждения.Сумма,
	|		ТаблицаВознаграждения.НДС
	|	ИЗ
	|		ТаблицаВознаграждения КАК ТаблицаВознаграждения) КАК ВложенныйЗапрос
	|
	|СГРУППИРОВАТЬ ПО
	|	ВложенныйЗапрос.Организация,
	|	ВложенныйЗапрос.Партнер,
	|	ВложенныйЗапрос.Контрагент,
	|	ВложенныйЗапрос.Договор";
				
	Менеджер = Пользователи.ТекущийПользователь();
	ВалютаДокумента = Константы.ВалютаРегламентированногоУчета.Получить();
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	СуммыВознагражденияОбщие = РезультатЗапроса[9].Выбрать();
	
	СтруктураПоиска = Новый Структура("Организация,Партнер,Контрагент,Договор");
	
	ВыборкаОрганизации = РезультатЗапроса[6].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаОрганизации.Следующий() Цикл
		
		
		Если УчетнаяПолитикаПереопределяемый.ПрименяетсяУСН(ВыборкаОрганизации.Организация, Параметры.НачалоПериода) Тогда
			НалогообложениеНДС = перечисления.ТипыНалогообложенияНДС.ПродажаНеОблагаетсяНДС;
		Иначе
			НалогообложениеНДС = перечисления.ТипыНалогообложенияНДС.ПродажаОблагаетсяНДС;
		КонецЕсли;
		
		//#TODO Костыль для УСН Орион - НДС нужен.
		Если ВыборкаОрганизации.Организация = ОрионОрганизация Тогда
			НалогообложениеНДС = перечисления.ТипыНалогообложенияНДС.ПродажаОблагаетсяНДС;
		КонецЕсли;
	
		ВыборкаПартнеры = ВыборкаОрганизации.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаПартнеры.Следующий() Цикл
			ВыборкаКонтрагенты = ВыборкаПартнеры.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока ВыборкаКонтрагенты.Следующий() Цикл
				ВыборкаДоговоры = ВыборкаКонтрагенты.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
				Пока ВыборкаДоговоры.Следующий() Цикл
					
					// Найдём строку в таблице созданных документов, в которую будем добавлять отчеты комитенту.
					СтрокаСозданныхДокументов = ТаблицаСозданныхДокументов.НайтиСтроки(
						Новый Структура("Партнер,Договор",
							ВыборкаДоговоры.Партнер,
							ВыборкаДоговоры.Договор))[0];
					
					ВыборкаОснования = ВыборкаДоговоры.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
					Пока ВыборкаОснования.Следующий() Цикл
						
						Если ЗначениеЗаполнено(ВыборкаОснования.ОтчетКомитентуСсылка) Тогда
							
							Если Параметры.ТолькоСоздаватьНовые Тогда
								Продолжить;
							КонецЕсли; 
							
							ОтчетКомитенту = ВыборкаОснования.ОтчетКомитентуСсылка.ПолучитьОбъект();
							
							ОтчетКомитенту.Товары.Очистить();
							ОтчетКомитенту.ЭтапыГрафикаОплаты.Очистить();
							
						Иначе
							
							ОтчетКомитенту = Документы.ОтчетКомитенту.СоздатьДокумент();
							ОтчетКомитенту.Дата = ВыборкаОснования.Дата;
							ОтчетКомитенту.Организация = ВыборкаОснования.Организация;
							ОтчетКомитенту.Партнер = ВыборкаОснования.Партнер;
							ОтчетКомитенту.Контрагент = ВыборкаОснования.Контрагент;
							ОтчетКомитенту.Договор = ВыборкаОснования.Договор;
							ОтчетКомитенту.Логс_ДокументОснование = ВыборкаОснования.ДокументОснование;
							
						КонецЕсли; 
						
						СуммаПродаж = ВыборкаОснования.СуммаПродажи;
					
						СуммыВознагражденияОбщие.Сбросить();
						ЗаполнитьЗначенияСвойств(СтруктураПоиска, ВыборкаОснования);
						
						Если СуммыВознагражденияОбщие.НайтиСледующий(СтруктураПоиска) Тогда
							СуммаВознагражденияВсего = СуммыВознагражденияОбщие.Сумма;
							СуммаНДСВсего = СуммыВознагражденияОбщие.НДС;
						Иначе
							СуммаВознагражденияВсего = 0;
							СуммаНДСВсего = 0;
						КонецЕсли;							
						
						ОтчетКомитенту.НалогообложениеНДС = НалогообложениеНДС;
						ОтчетКомитенту.Валюта = ВалютаДокумента;
						ОтчетКомитенту.Подразделение = ВыборкаОснования.Подразделение;
						ОтчетКомитенту.Менеджер = Менеджер;
						ОтчетКомитенту.ЦенаВключаетНДС = ВыборкаОснования.ЦенаВключаетНДС;
						ОтчетКомитенту.СпособРасчетаВознаграждения = Перечисления.СпособыРасчетаКомиссионногоВознаграждения.ПроцентОтСуммыПродажи;
						ОтчетКомитенту.ФормаОплаты = ВыборкаОснования.ФормаОплаты;
						ОтчетКомитенту.БанковскийСчет = ВыборкаОснования.БанковскийСчет;
						ОтчетКомитенту.ДатаПлатежа = НачалоДня(ОтчетКомитенту.Дата);
						ОтчетКомитенту.НачалоПериода = Параметры.НачалоПериода;
						ОтчетКомитенту.КонецПериода = Параметры.КонецПериода;
						ОтчетКомитенту.ПорядокРасчетов = ВыборкаОснования.ПорядокРасчетов;
						ОтчетКомитенту.УдержатьВознаграждение = ВыборкаОснования.УдержатьВознаграждение;
						
						ОтчетКомитенту.Услуга = Логс_ДополнительныеПроцедурыИФункцииПовтИсп.УслугаДоставка();
						ОтчетКомитенту.СуммаВознаграждения = СуммаВознагражденияВсего;
						ОтчетКомитенту.ПроцентВознаграждения = ?(СуммаПродаж = 0, 0, СуммаВознагражденияВсего / СуммаПродаж * 100); 
						//#TODO Костыль для УСН Орион - НДС нужен.
						Если ОтчетКомитенту.Организация = ОрионОрганизация И ОтчетКомитенту.Дата < Дата("20260101") Тогда
							ОтчетКомитенту.СтавкаНДСВознаграждения = СтавкаНДС5; 
						ИначеЕсли (ОтчетКомитенту.Организация = ЛогсисОрганизация ИЛИ ОтчетКомитенту.Организация = ОрионОрганизация)
							И ОтчетКомитенту.Дата >= Дата("20260101") Тогда  
						  	ОтчетКомитенту.СтавкаНДСВознаграждения =
							?(ОтчетКомитенту.НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.ПродажаОблагаетсяНДС,
							  СтавкаНДС22, СтавкаБезНДС
							);
                    	Иначе								
							
							ОтчетКомитенту.СтавкаНДСВознаграждения =
							?(ОтчетКомитенту.НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.ПродажаОблагаетсяНДС,
								//Перечисления.СтавкиНДС.НДС20,
								//Перечисления.СтавкиНДС.БезНДС
								СтавкаНДС20, СтавкаБезНДС
							);
						КонецЕсли;

						//ОтчетКомитенту.СтавкаНДСВознаграждения =
						//	?(ОтчетКомитенту.НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.ПродажаОблагаетсяНДС,
						//		//Перечисления.СтавкиНДС.НДС20,
						//		//Перечисления.СтавкиНДС.БезНДС
						//		СтавкаНДС20, СтавкаБезНДС
						//	);
							
						//ПроцентНДС = УчетНДСУПКлиентСервер.ПолучитьСтавкуНДС(ОтчетКомитенту.СтавкаНДСВознаграждения);
						ПроцентНДС = УчетНДСУПВызовСервера.ЗначениеСтавкиНДС(ОтчетКомитенту.СтавкаНДСВознаграждения);
						ОтчетКомитенту.СуммаНДСВознаграждения = СуммаНДСВсего;
	
						ОтветственныеЛицаСервер.ПриИзмененииСвязанныхРеквизитовДокумента(ОтчетКомитенту);
						
						Выборка = ВыборкаОснования.Выбрать();
						Пока Выборка.Следующий() Цикл
							НоваяСтрока = ОтчетКомитенту.Товары.Добавить();
							Если Выборка.Номенклатура = Неопределено Тогда
								НоваяСтрока.Номенклатура = Логс_ДополнительныеПроцедурыИФункцииПовтИсп.ТоварАгента();
								НоваяСтрока.Характеристика = Логс_ДополнительныеПроцедурыИФункции.ПолучитьХарактеристикуНоменклатурыАгента(
									НоваяСтрока.Номенклатура, ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Выборка.СводЗаявок, "Номер"));
							Иначе
								НоваяСтрока.Номенклатура = Выборка.Номенклатура;
								НоваяСтрока.Характеристика = Выборка.Характеристика;
							КонецЕсли; 
							НоваяСтрока.Количество = Выборка.СуммаПродажи;
							НоваяСтрока.КоличествоУпаковок = Выборка.СуммаПродажи;
							НоваяСтрока.СуммаСНДС = Выборка.СуммаПродажи; 
							
							//#TODO Костыль по Ориону
							Если ОтчетКомитенту.СтавкаНДСВознаграждения = СтавкаНДС5 Тогда
							НоваяСтрока.СтавкаНДС = ?(Выборка.СуммаНДСВознаграждения <> 0,
														//Перечисления.СтавкиНДС.НДС20,
														//Перечисления.СтавкиНДС.БезНДС
														СтавкаНДС5, СтавкаБезНДС
													);
							ИначеЕсли ОтчетКомитенту.СтавкаНДСВознаграждения = СтавкаНДС22 Тогда 
							НоваяСтрока.СтавкаНДС = ?(Выборка.СуммаНДСВознаграждения <> 0,
														СтавкаНДС22, СтавкаБезНДС);
												
							Иначе
							НоваяСтрока.СтавкаНДС = ?(Выборка.СуммаНДСВознаграждения <> 0,
														//Перечисления.СтавкиНДС.НДС20,
														//Перечисления.СтавкиНДС.БезНДС
														СтавкаНДС20, СтавкаБезНДС
													); 
							КонецЕсли;
							НоваяСтрока.СуммаНДС = Выборка.СуммаНДСВознаграждения;							
							//НоваяСтрока.СуммаНДС = УчетНДСУПКлиентСервер.РассчитатьСуммуНДС(НоваяСтрока.Сумма,
							//							УчетНДСУПКлиентСервер.ПолучитьСтавкуНДС(НоваяСтрока.СтавкаНДС),
							//							ОтчетКомитенту.ЦенаВключаетНДС, ОтчетКомитенту.НалогообложениеНДС);
							НоваяСтрока.Сумма = НоваяСтрока.СуммаСНДС - ?(ОтчетКомитенту.ЦенаВключаетНДС, 0, НоваяСтрока.СуммаНДС);
							НоваяСтрока.Цена = 1;
							НоваяСтрока.ЦенаПродажи = 1;
							НоваяСтрока.СуммаПродажи = НоваяСтрока.СуммаСНДС;
							НоваяСтрока.Покупатель = Выборка.Покупатель;
							НоваяСтрока.Логс_СводЗаявокНаДоставку = Выборка.СводЗаявок;
							//НоваяСтрока.СуммаВознаграждения = СуммаВознагражденияВсего * ?(СуммаПродаж = 0, 0, Выборка.Сумма / СуммаПродаж);
							НоваяСтрока.СуммаВознаграждения = Выборка.СуммаВознаграждения;
							НоваяСтрока.СуммаНДСВознаграждения = Выборка.СуммаНДСВознаграждения;
						КонецЦикла;
						
						// В результате распределения суммы вознаграждения по строкам табличной части из-за округления
						// могла возникнуть разница в копейках. В таком случае скорректируем последнюю строку.
						// ABS 26.12.2019 Архипкин Р.В. переносим корректировку с первой строки на последнюю
						ТабТовары = ОтчетКомитенту.Товары.Выгрузить();
						ТабТовары.Свернуть("Логс_СводЗаявокНаДоставку", "СуммаВознаграждения");
						Для каждого СтрокаСвод Из ТабТовары Цикл
							
							Разница = СтрокаСвод.Логс_СводЗаявокНаДоставку.ПолнаяСтоимостьВсего - СтрокаСвод.СуммаВознаграждения;								
							Если Разница <> 0 Тогда
								МассивСтроки = ОтчетКомитенту.Товары.НайтиСтроки(Новый Структура("Логс_СводЗаявокНаДоставку", СтрокаСвод.Логс_СводЗаявокНаДоставку));
								Строка = МассивСтроки[0];
								Строка.СуммаВознаграждения = Строка.СуммаВознаграждения + Разница;
							КонецЕсли;						
						КонецЦикла;
						
						ПараметрыДляДобавления = ЭтапыОплатыКлиентСервер.ПараметрыДляДобавленияЭтапаПоУмолчанию();
						ПараметрыДляДобавления.Объект = ОтчетКомитенту;
						ПараметрыДляДобавления.ВариантОплаты = Перечисления.ВариантыКонтроляОплатыПоставщику.КредитСдвиг;
						ПараметрыДляДобавления.ЖелаемаяДата = НачалоДня(ОтчетКомитенту.Дата);
						ПараметрыДляДобавления.ДатаСеанса = ТекущаяДатаСеанса();
						ПараметрыДляДобавления.СуммаОплатыПоДокументу = СуммаПродаж;
						
						ЭтапыОплатыКлиентСервер.ДобавитьЭтапОплатыПоУмолчанию(ПараметрыДляДобавления);
						ОтчетКомитенту.ЭтапыГрафикаОплаты[0].ВариантОтсчета = Перечисления.ВариантыОтсчетаДатыПлатежа.ОтДатыОтгрузки;
						
						Если ОтчетКомитенту.Ссылка.Пустая() Тогда
							ОтчетКомитенту.Записать(РежимЗаписиДокумента.Запись);
						КонецЕсли; 
						
						Попытка
							ОтчетКомитенту.Записать(РежимЗаписиДокумента.Проведение);
						Исключение
							ОтчетКомитенту.Записать(РежимЗаписиДокумента.Запись);
							ОписаниеОшибки = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
							ТекстСообщения = СтрШаблон(
								НСтр("ru='Произошла ошибка при записи отчета комитенту № %1 от %2: %3'"),
								ОтчетКомитенту.Номер, Формат(ОтчетКомитенту.Дата, "ДФ=dd.MM.yyyy"),
								ОписаниеОшибки);
							ЗаписьЖурналаРегистрации("УУ Создание регламентированных документов. Создание отчета комитенту",
								УровеньЖурналаРегистрации.Ошибка,,, ТекстСообщения);
							СписокОшибок.Вставить(ОтчетКомитенту.Ссылка, ОписаниеОшибки);
						КонецПопытки;
				
						СтрокаСозданныхДокументов.ДокументыОтчетовКомитентам.Добавить(
							Новый Структура("Ссылка,Номер,Дата,Организация,Контрагент,СчетФактура",
								ОтчетКомитенту.Ссылка,
								ОтчетКомитенту.Номер,
								ОтчетКомитенту.Дата + 1,
								ОтчетКомитенту.Организация,
								ОтчетКомитенту.Контрагент,
								ВыборкаОснования.СчетФактураСсылка
							));
						
					КонецЦикла; // Основания
				КонецЦикла; // Договоры
				
			КонецЦикла; // Контрагенты
		КонецЦикла; // Партнеры
	КонецЦикла; // Организации
	
КонецПроцедуры 

Процедура СоздатьДокументыАктВыполненныхРабот(Параметры, МенеджерВременныхТаблиц, ТаблицаСозданныхДокументов, СписокОшибок)
	
	Если Не Параметры.Создавать.СоздаватьАктыВыполненныхРабот Тогда
		Возврат;
	КонецЕсли;	
	
	СтавкаНДС20 = Константы.Логс_СтавкаНДС20.Получить();
	СтавкаБезНДС = Справочники.СтавкиНДС.БезНДС;
	СтавкаНДС5  = Справочники.СтавкиНДС.НайтиПоНаименованию("5%"); 
	СтавкаНДС22 = Справочники.СтавкиНДС.НайтиПоНаименованию("22%");
	ЛогсисОрганизация = Справочники.Организации.НайтиПоРеквизиту("ИНН", "9725007793");
    ОрионОрганизация = Справочники.Организации.НайтиПоРеквизиту("ИНН", "9728051543");
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("Дата", НачалоДня(Параметры.ДатаФормирования));
	Запрос.УстановитьПараметр("НачалоПериода", НачалоДня(Параметры.НачалоПериода));
	Запрос.УстановитьПараметр("КонецПериода", КонецДня(Параметры.КонецПериода));
	Запрос.УстановитьПараметр("Организация", Параметры.Организация);
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	СводЗаявокНаДоставку.Организация КАК Организация,
	|	СводЗаявокНаДоставку.Партнер КАК Партнер,
	|	СводЗаявокНаДоставку.Контрагент КАК Контрагент,
	|	СводЗаявокНаДоставку.Договор КАК Договор
	|ПОМЕСТИТЬ СводЗаявокТолькоУслуги
	|ИЗ
	|	Документ.Логс_СводЗаявокНаДоставку КАК СводЗаявокНаДоставку
	|ГДЕ
	|	СводЗаявокНаДоставку.Дата МЕЖДУ &НачалоПериода И &КонецПериода
	|	И СводЗаявокНаДоставку.ВидКлиента <> ЗНАЧЕНИЕ(Перечисление.Логс_ВидыКлиентовCRM.СКС)
	|	И СводЗаявокНаДоставку.Договор В
	|			(ВЫБРАТЬ
	|				СписокДоговоров.Договор
	|			ИЗ
	|				СписокДоговоров)
	|	И СводЗаявокНаДоставку.Проведен
	|
	|СГРУППИРОВАТЬ ПО
	|	СводЗаявокНаДоставку.Организация,
	|	СводЗаявокНаДоставку.Партнер,
	|	СводЗаявокНаДоставку.Контрагент,
	|	СводЗаявокНаДоставку.Договор
	|
	|ИМЕЮЩИЕ
	|	СУММА(СводЗаявокНаДоставку.НаложенныйПлатежВсего) = 0 И
	|	СУММА(СводЗаявокНаДоставку.ПолнаяСтоимостьВсего) > 0
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Организация,
	|	Партнер,
	|	Контрагент,
	|	Договор
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СводЗаявокНаДоставку.Ссылка КАК Ссылка,
	|	СводЗаявокНаДоставку.Номер КАК Номер,
	|	СводЗаявокНаДоставку.Дата КАК Дата,
	|	СводЗаявокНаДоставку.Организация КАК Организация,
	|	СводЗаявокНаДоставку.Партнер КАК Партнер,
	|	СводЗаявокНаДоставку.Контрагент КАК Контрагент,
	|	СводЗаявокНаДоставку.Договор КАК Договор,
	|	СводЗаявокНаДоставку.НалогообложениеНДС КАК НалогообложениеНДС,
	|	СводЗаявокНаДоставку.Валюта КАК Валюта,
	|	СводЗаявокНаДоставку.ФормаОплаты КАК ФормаОплаты,
	|	СписокДоговоров.Подразделение КАК Подразделение,
	|	СписокДоговоров.БанковскийСчет КАК БанковскийСчет,
	|	СписокДоговоров.БанковскийСчетКонтрагента КАК БанковскийСчетКонтрагента,
	|	СписокДоговоров.ПорядокРасчетов КАК ПорядокРасчетов,
	|	СписокДоговоров.ВалютаВзаиморасчетов КАК ВалютаВзаиморасчетов,
	|	СписокДоговоров.Основание КАК Основание,
	|	СписокДоговоров.ОснованиеДата КАК ОснованиеДата,
	|	СписокДоговоров.ОснованиеНомер КАК ОснованиеНомер,
	|	СписокДоговоров.ДоговорНаОказаниеУслуг КАК ДоговорНаОказаниеУслуг,
	|	СводЗаявокНаДоставку.ПолнаяСтоимостьВсего КАК СуммаУслуг,
	|	ВЗ_СводЗаявокНаДоставкуНДС.НДС КАК НДС
	|ПОМЕСТИТЬ СводЗаявокОбщий
	|ИЗ
	|	Документ.Логс_СводЗаявокНаДоставку КАК СводЗаявокНаДоставку
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ СписокДоговоров КАК СписокДоговоров
	|		ПО СводЗаявокНаДоставку.Договор = СписокДоговоров.Договор
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			Логс_СводЗаявокНаДоставкуЗаявки.Ссылка КАК Ссылка,
	|			СУММА(Логс_СводЗаявокНаДоставкуЗаявки.ПолнаяСтоимостьНДС) КАК НДС
	|		ИЗ
	|			Документ.Логс_СводЗаявокНаДоставку.Заявки КАК Логс_СводЗаявокНаДоставкуЗаявки
	|		
	|		СГРУППИРОВАТЬ ПО
	|			Логс_СводЗаявокНаДоставкуЗаявки.Ссылка) КАК ВЗ_СводЗаявокНаДоставкуНДС
	|		ПО СводЗаявокНаДоставку.Ссылка = ВЗ_СводЗаявокНаДоставкуНДС.Ссылка
	|ГДЕ
	|	СводЗаявокНаДоставку.Дата МЕЖДУ &НачалоПериода И &КонецПериода
	|	И СводЗаявокНаДоставку.НаложенныйПлатежВсего = 0
	|	И СводЗаявокНаДоставку.ПолнаяСтоимостьВсего > 0
	|	И СводЗаявокНаДоставку.ВидКлиента <> ЗНАЧЕНИЕ(Перечисление.Логс_ВидыКлиентовCRM.СКС)
	|	И (СводЗаявокНаДоставку.Организация, СводЗаявокНаДоставку.Партнер, СводЗаявокНаДоставку.Контрагент, СводЗаявокНаДоставку.Договор) В
	|			(ВЫБРАТЬ
	|				СводЗаявокТолькоУслуги.Организация,
	|				СводЗаявокТолькоУслуги.Партнер,
	|				СводЗаявокТолькоУслуги.Контрагент,
	|				СводЗаявокТолькоУслуги.Договор
	|			ИЗ
	|				СводЗаявокТолькоУслуги)
	|	И СводЗаявокНаДоставку.Проведен
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	АктВыполненныхРаботУслуги.Логс_СводЗаявокНаДоставку КАК СводЗаявок
	|ПОМЕСТИТЬ СуществующиеАкты
	|ИЗ
	|	Документ.АктВыполненныхРабот.Услуги КАК АктВыполненныхРаботУслуги
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.АктВыполненныхРабот КАК АктВыполненныхРабот
	|		ПО АктВыполненныхРаботУслуги.Ссылка = АктВыполненныхРабот.Ссылка
	|ГДЕ
	|	АктВыполненныхРаботУслуги.Логс_СводЗаявокНаДоставку В
	|			(ВЫБРАТЬ
	|				СводЗаявокОбщий.Ссылка
	|			ИЗ
	|				СводЗаявокОбщий)
	|	И НАЧАЛОПЕРИОДА(АктВыполненныхРабот.Дата, ДЕНЬ) <> &Дата
	|	И АктВыполненныхРабот.Проведен
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СводЗаявок.Ссылка КАК Ссылка,
	|	СводЗаявок.Номер КАК Номер,
	|	СводЗаявок.Дата КАК Дата,
	|	СводЗаявок.Организация КАК Организация,
	|	СводЗаявок.Партнер КАК Партнер,
	|	СводЗаявок.Контрагент КАК Контрагент,
	|	СводЗаявок.Договор КАК Договор,
	|	СводЗаявок.НалогообложениеНДС КАК НалогообложениеНДС,
	|	СводЗаявок.Валюта КАК Валюта,
	|	СводЗаявок.ФормаОплаты КАК ФормаОплаты,
	|	СводЗаявок.Подразделение КАК Подразделение,
	|	СводЗаявок.БанковскийСчет КАК БанковскийСчет,
	|	СводЗаявок.БанковскийСчетКонтрагента КАК БанковскийСчетКонтрагента,
	|	СводЗаявок.ПорядокРасчетов КАК ПорядокРасчетов,
	|	СводЗаявок.ВалютаВзаиморасчетов КАК ВалютаВзаиморасчетов,
	|	СводЗаявок.Основание КАК Основание,
	|	СводЗаявок.ОснованиеДата КАК ОснованиеДата,
	|	СводЗаявок.ОснованиеНомер КАК ОснованиеНомер,
	|	СводЗаявок.ДоговорНаОказаниеУслуг КАК ДоговорНаОказаниеУслуг,
	|	СводЗаявок.СуммаУслуг КАК СуммаУслуг,
	|	СводЗаявок.НДС КАК НДС
	|ПОМЕСТИТЬ Данные
	|ИЗ
	|	СводЗаявокОбщий КАК СводЗаявок
	|ГДЕ
	|	НЕ СводЗаявок.Ссылка В
	|				(ВЫБРАТЬ
	|					СуществующиеАкты.СводЗаявок
	|				ИЗ
	|					СуществующиеАкты)
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ СводЗаявокОбщий
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ СуществующиеАкты
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Данные.Организация КАК Организация,
	|	Данные.Партнер КАК Партнер,
	|	Данные.Контрагент КАК Контрагент,
	|	Данные.Договор КАК Договор
	|ПОМЕСТИТЬ ДанныеДляПоискаАктов
	|ИЗ
	|	Данные КАК Данные
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Данные.Организация КАК Организация,
	|	Данные.Партнер КАК Партнер,
	|	Данные.Контрагент КАК Контрагент,
	|	Данные.Договор КАК Договор,
	|	МИНИМУМ(АктВыполненныхРабот.Ссылка) КАК Ссылка,
	|	МИНИМУМ(ЕСТЬNULL(СчетФактураВыданныйДокументыОснования.Ссылка, НЕОПРЕДЕЛЕНО)) КАК СчетФактураСсылка
	|ПОМЕСТИТЬ АктыВыполненныхРабот
	|ИЗ
	|	ДанныеДляПоискаАктов КАК Данные
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.АктВыполненныхРабот КАК АктВыполненныхРабот
	|			ЛЕВОЕ СОЕДИНЕНИЕ Документ.СчетФактураВыданный.ДокументыОснования КАК СчетФактураВыданныйДокументыОснования
	|			ПО АктВыполненныхРабот.Ссылка = СчетФактураВыданныйДокументыОснования.ДокументОснование
	|				И (НЕ СчетФактураВыданныйДокументыОснования.Ссылка.ПометкаУдаления)
	|		ПО Данные.Организация = АктВыполненныхРабот.Организация
	|			И Данные.Партнер = АктВыполненныхРабот.Партнер
	|			И Данные.Контрагент = АктВыполненныхРабот.Контрагент
	|			И Данные.Договор = АктВыполненныхРабот.Договор
	|			И (НАЧАЛОПЕРИОДА(АктВыполненныхРабот.Дата, ДЕНЬ) = &Дата)
	|			И (НЕ АктВыполненныхРабот.ПометкаУдаления)
	|
	|СГРУППИРОВАТЬ ПО
	|	Данные.Организация,
	|	Данные.Партнер,
	|	Данные.Контрагент,
	|	Данные.Договор
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Организация,
	|	Партнер,
	|	Контрагент,
	|	Договор
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Данные.Ссылка КАК Ссылка,
	|	Данные.Номер КАК Номер,
	|	Данные.Дата КАК Дата,
	|	Данные.Организация КАК Организация,
	|	Данные.Партнер КАК Партнер,
	|	Данные.Контрагент КАК Контрагент,
	|	Данные.Договор КАК Договор,
	|	Данные.НалогообложениеНДС КАК НалогообложениеНДС,
	|	Данные.Валюта КАК Валюта,
	|	Данные.Подразделение КАК Подразделение,
	|	Данные.БанковскийСчет КАК БанковскийСчет,
	|	Данные.БанковскийСчетКонтрагента КАК БанковскийСчетКонтрагента,
	|	Данные.ПорядокРасчетов КАК ПорядокРасчетов,
	|	Данные.ВалютаВзаиморасчетов КАК ВалютаВзаиморасчетов,
	|	Данные.Основание КАК Основание,
	|	Данные.ОснованиеДата КАК ОснованиеДата,
	|	Данные.ОснованиеНомер КАК ОснованиеНомер,
	|	Данные.ДоговорНаОказаниеУслуг КАК ДоговорНаОказаниеУслуг,
	|	Данные.СуммаУслуг КАК Сумма,
	|	ЕСТЬNULL(АктыВыполненныхРабот.Ссылка, НЕОПРЕДЕЛЕНО) КАК АктВыполненныхРаботСсылка,
	|	ЕСТЬNULL(АктыВыполненныхРабот.СчетФактураСсылка, НЕОПРЕДЕЛЕНО) КАК СчетФактураСсылка,
	|	Данные.НДС КАК НДС
	|ИЗ
	|	Данные КАК Данные
	|		ЛЕВОЕ СОЕДИНЕНИЕ АктыВыполненныхРабот КАК АктыВыполненныхРабот
	|		ПО Данные.Организация = АктыВыполненныхРабот.Организация
	|			И Данные.Партнер = АктыВыполненныхРабот.Партнер
	|			И Данные.Контрагент = АктыВыполненныхРабот.Контрагент
	|			И Данные.Договор = АктыВыполненныхРабот.Договор
	|ИТОГИ
	|	МАКСИМУМ(Подразделение),
	|	МАКСИМУМ(БанковскийСчет),
	|	МАКСИМУМ(БанковскийСчетКонтрагента),
	|	МАКСИМУМ(ПорядокРасчетов),
	|	МАКСИМУМ(ВалютаВзаиморасчетов),
	|	МАКСИМУМ(Основание),
	|	МАКСИМУМ(ОснованиеДата),
	|	МАКСИМУМ(ОснованиеНомер),
	|	МАКСИМУМ(ДоговорНаОказаниеУслуг),
	|	МАКСИМУМ(АктВыполненныхРаботСсылка),
	|	МАКСИМУМ(СчетФактураСсылка)
	|ПО
	|	Организация,
	|	Партнер,
	|	Контрагент,
	|	Договор,
	|	НалогообложениеНДС,
	|	Валюта";
	
	ВыборкаОрганизации = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаОрганизации.Следующий() Цикл
		
		Если УчетнаяПолитикаПереопределяемый.ПрименяетсяУСН(ВыборкаОрганизации.Организация, Параметры.НачалоПериода) Тогда
			НалогообложениеНДС = перечисления.ТипыНалогообложенияНДС.ПродажаНеОблагаетсяНДС;
		Иначе
			НалогообложениеНДС = перечисления.ТипыНалогообложенияНДС.ПродажаОблагаетсяНДС;
		КонецЕсли;
		
		//#TODO Костыль для УСН Орион - НДС нужен.
		Если ВыборкаОрганизации.Организация = ОрионОрганизация Тогда
			НалогообложениеНДС = перечисления.ТипыНалогообложенияНДС.ПродажаОблагаетсяНДС;
		КонецЕсли;
		         	
		ВыборкаПартнеры = ВыборкаОрганизации.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаПартнеры.Следующий() Цикл
			ВыборкаКонтрагенты = ВыборкаПартнеры.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока ВыборкаКонтрагенты.Следующий() Цикл
				ВыборкаДоговоры = ВыборкаКонтрагенты.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
				Пока ВыборкаДоговоры.Следующий() Цикл
					
					// Найдём строку в таблице созданных документов, в которую будем добавлять акты выполненных работ.
					СтрокиСозданныхДокументов = ТаблицаСозданныхДокументов.НайтиСтроки(
						Новый Структура("Партнер,Договор",
							ВыборкаДоговоры.Партнер,
							ВыборкаДоговоры.Договор));
					Если СтрокиСозданныхДокументов.Количество() = 0 Тогда
						СтрокаСозданныхДокументов = ТаблицаСозданныхДокументов.Добавить();
						СтрокаСозданныхДокументов.Партнер = ВыборкаДоговоры.Партнер;
						СтрокаСозданныхДокументов.Договор = ВыборкаДоговоры.Договор;
					Иначе
						СтрокаСозданныхДокументов = СтрокиСозданныхДокументов[0];
					КонецЕсли; 
							
					ВыборкаНалогообложение = ВыборкаДоговоры.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
					Пока ВыборкаНалогообложение.Следующий() Цикл
						ВыборкаВалюты = ВыборкаНалогообложение.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
						Пока ВыборкаВалюты.Следующий() Цикл
							
							Если ЗначениеЗаполнено(ВыборкаВалюты.АктВыполненныхРаботСсылка) Тогда
								
								Если Параметры.ТолькоСоздаватьНовые Тогда
									Продолжить;
								КонецЕсли; 
								
								АктВыполненныхРабот = ВыборкаВалюты.АктВыполненныхРаботСсылка.ПолучитьОбъект();
								
								АктВыполненныхРабот.Услуги.Очистить();
								АктВыполненныхРабот.ЭтапыГрафикаОплаты.Очистить();
								
							Иначе
								
								АктВыполненныхРабот = Документы.АктВыполненныхРабот.СоздатьДокумент();
								АктВыполненныхРабот.Дата = НачалоДня(Параметры.ДатаФормирования) + 43203;
								АктВыполненныхРабот.Организация = ВыборкаВалюты.Организация;
								АктВыполненныхРабот.Партнер = ВыборкаВалюты.Партнер;
								АктВыполненныхРабот.Контрагент = ВыборкаВалюты.Контрагент;
								АктВыполненныхРабот.Договор = ВыборкаВалюты.Договор;
								АктВыполненныхРабот.НалогообложениеНДС = НалогообложениеНДС;
								АктВыполненныхРабот.Валюта = ВыборкаВалюты.Валюта;
								//АктВыполненныхРабот.Логс_ДокументОснование = ?(ОтчетКомитенту = Неопределено, Неопределено, ОтчетКомитенту.Ссылка);
								
								АктВыполненныхРабот.УстановитьНовыйНомер();
								
							КонецЕсли; 
							
							АктВыполненныхРабот.Подразделение = ВыборкаВалюты.Подразделение;
							АктВыполненныхРабот.БанковскийСчетОрганизации = ВыборкаВалюты.БанковскийСчет;
							АктВыполненныхРабот.БанковскийСчетКонтрагента = ВыборкаВалюты.БанковскийСчетКонтрагента;
							АктВыполненныхРабот.ВалютаВзаиморасчетов = ВыборкаВалюты.ВалютаВзаиморасчетов;
							АктВыполненныхРабот.ПорядокРасчетов = ВыборкаВалюты.ПорядокРасчетов;
							АктВыполненныхРабот.Основание = ВыборкаВалюты.Основание;
							АктВыполненныхРабот.ОснованиеНомер = ВыборкаВалюты.ОснованиеНомер;
							АктВыполненныхРабот.ОснованиеДата = ВыборкаВалюты.ОснованиеДата;
							АктВыполненныхРабот.Менеджер = Пользователи.ТекущийПользователь();
							АктВыполненныхРабот.Автор = Пользователи.ТекущийПользователь();
							АктВыполненныхРабот.Согласован = Истина;
							АктВыполненныхРабот.ЦенаВключаетНДС = Истина;
							АктВыполненныхРабот.КурсЧислитель = 1;
							//АктВыполненныхРабот.Курс = 1;
							//АктВыполненныхРабот.Кратность = 1;
							
							ОтветственныеЛицаСервер.ПриИзмененииСвязанныхРеквизитовДокумента(АктВыполненныхРабот);
							
							Выборка = ВыборкаВалюты.Выбрать();
							Пока Выборка.Следующий() Цикл
								
								Если Выборка.ДоговорНаОказаниеУслуг Тогда
									ДатаНачалаУчета = Дата(2019, 6, 27);
									НачалоПериода = Макс(
										ДатаНачалаУчета,
										?(День(Выборка.Дата) <= 15,
											НачалоМесяца(Выборка.Дата),
											Дата(Год(Выборка.Дата), Месяц(Выборка.Дата), 16)
										));
									КонецПериода = Выборка.Дата;
									ДополнениеКСодержанию = СтрШаблон(НСтр("ru=' по %1 за период с %2 по %3'"),
										Выборка.Основание, День(НачалоПериода), Формат(КонецПериода, "ДЛФ=DD"));
								Иначе
									ДополнениеКСодержанию = "";
								КонецЕсли; 
								
								НоваяСтрока = АктВыполненныхРабот.Услуги.Добавить();
								НоваяСтрока.Номенклатура = Логс_ДополнительныеПроцедурыИФункцииПовтИсп.УслугаДоставка();
								НоваяСтрока.Содержание = Логс_ДополнительныеПроцедурыИФункции.СформироватьНаименованиеУслугНаДоставкуПоСводу(Выборка.Ссылка) +
															ДополнениеКСодержанию;
								НоваяСтрока.Количество = 1;
								НоваяСтрока.Цена = Выборка.Сумма;
								НоваяСтрока.Сумма = Выборка.Сумма;
								
								
								//#TODO Костыль для УСН Орион - НДС нужен.
								Если АктВыполненныхРабот.Организация = ОрионОрганизация  И АктВыполненныхРабот.Дата < Дата("20260101") Тогда
									НоваяСтрока.СтавкаНДС = СтавкаНДС5; 
									
								ИначеЕсли (АктВыполненныхРабот.Организация = ЛогсисОрганизация ИЛИ АктВыполненныхРабот.Организация = ОрионОрганизация)
									И АктВыполненныхРабот.Дата >= Дата("20260101") Тогда 
									НоваяСтрока.СтавкаНДС =
									?(АктВыполненныхРабот.НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.ПродажаОблагаетсяНДС,
									СтавкаНДС22, СтавкаБезНДС
									);
	                            Иначе								
									
									НоваяСтрока.СтавкаНДС =
									?(АктВыполненныхРабот.НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.ПродажаОблагаетсяНДС,
										//Перечисления.СтавкиНДС.НДС20,
										//Перечисления.СтавкиНДС.БезНДС
										СтавкаНДС20, СтавкаБезНДС
									);
								КонецЕсли;
								
								//НоваяСтрока.СтавкаНДС =
								//	?(АктВыполненныхРабот.НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.ПродажаОблагаетсяНДС,
								//		//Перечисления.СтавкиНДС.НДС20,
								//		//Перечисления.СтавкиНДС.БезНДС
								//		СтавкаНДС20, СтавкаБезНДС
								//	);          
									
								//НоваяСтрока.СуммаНДС = УчетНДСУПКлиентСервер.РассчитатьСуммуНДС(НоваяСтрока.Сумма,
								//	УчетНДСУПКлиентСервер.ПолучитьСтавкуНДС(НоваяСтрока.СтавкаНДС),
								//	АктВыполненныхРабот.ЦенаВключаетНДС, АктВыполненныхРабот.НалогообложениеНДС);
								НоваяСтрока.СуммаНДС = Выборка.НДС;
								НоваяСтрока.СуммаСНДС = НоваяСтрока.Сумма;
								НоваяСтрока.Логс_СводЗаявокНаДоставку = Выборка.Ссылка;
								НоваяСтрока.Подразделение = Выборка.Подразделение;
								
							КонецЦикла; 
							
							ЭтапОплаты = АктВыполненныхРабот.ЭтапыГрафикаОплаты.Добавить();
							ЭтапОплаты.ВариантОплаты = Перечисления.ВариантыКонтроляОплатыКлиентом.КредитПослеОтгрузки;
							ЭтапОплаты.ДатаПлатежа = НачалоДня(АктВыполненныхРабот.Дата);
							ЭтапОплаты.СуммаПлатежа = АктВыполненныхРабот.Услуги.Итог("СуммаСНДС");
							ЭтапОплаты.ПроцентПлатежа = 100;
							ЭтапОплаты.СуммаВзаиморасчетов = ЭтапОплаты.СуммаПлатежа;
							ЭтапОплаты.ВариантОтсчета = Перечисления.ВариантыОтсчетаДатыПлатежа.ОтДатыОтгрузки;
							
							Если АктВыполненныхРабот.Ссылка.Пустая() Тогда
								АктВыполненныхРабот.Записать(РежимЗаписиДокумента.Запись);
							КонецЕсли; 
							
							Попытка
								АктВыполненныхРабот.Записать(РежимЗаписиДокумента.Проведение);
							Исключение
								ОписаниеОшибки = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
								ТекстСообщения = СтрШаблон(
									НСтр("ru='Произошла ошибка при записи акта выполненных работ № %1 от %2: %3'"),
									АктВыполненныхРабот.Номер, Формат(АктВыполненныхРабот.Дата, "ДФ=dd.MM.yyyy"),
									ОписаниеОшибки);
								ЗаписьЖурналаРегистрации("УУ Создание регламентированных документов. Создание актов выполненных работ",
									УровеньЖурналаРегистрации.Ошибка,,, ТекстСообщения);
								СписокОшибок.Вставить(АктВыполненныхРабот.Ссылка, ОписаниеОшибки);
							КонецПопытки;
							
							СтрокаСозданныхДокументов.ДокументыАктовВыполненныхРабот.Добавить(
								Новый Структура("Ссылка,Номер,Дата,Организация,Контрагент,СчетФактура",
									АктВыполненныхРабот.Ссылка,
									АктВыполненныхРабот.Номер,
									АктВыполненныхРабот.Дата + 1,
									АктВыполненныхРабот.Организация,
									АктВыполненныхРабот.Контрагент,
									ВыборкаВалюты.СчетФактураСсылка
								));
							
						КонецЦикла; // Валюты
					КонецЦикла; // Налогообложение НДС
				КонецЦикла; // Договоры
			КонецЦикла; // Контрагенты
		КонецЦикла; // Партнеры
	КонецЦикла; // Организации
	
	Запрос.Текст =
	"УНИЧТОЖИТЬ Данные
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ДанныеДляПоискаАктов
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ АктыВыполненныхРабот";
	Запрос.Выполнить();
	
КонецПроцедуры 

Процедура СоздатьДокументыДвиженияДенежныхСредствПоСКС(Параметры, МенеджерВременныхТаблиц, ТаблицаСозданныхДокументов, СписокОшибок)
	
	//++ Ким Виктор 22.01.2025
	//https://jira-sd.logsis.ru/projects/TSLOG/queues/custom/18/TSLOG-15412
	//Разделение функционала СКС стандарт от СКС ТМС;
	Если Не Параметры.Создавать.СоздаватьПоступления Тогда
		Возврат;
	КонецЕсли;		
	//-- Ким Виктор 22.01.2025
	
	СтавкаНДС20 = Константы.Логс_СтавкаНДС20.Получить();
	СтавкаБезНДС = Справочники.СтавкиНДС.БезНДС;  
	СтавкаНДС5 = Справочники.СтавкиНДС.НайтиПоНаименованию("5%");
	СтавкаНДС22 = Справочники.СтавкиНДС.НайтиПоНаименованию("22%");
	ЛогсисОрганизация = Справочники.Организации.НайтиПоРеквизиту("ИНН", "9725007793");
    ОрионОрганизация = Справочники.Организации.НайтиПоРеквизиту("ИНН", "9728051543");

	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("Дата", НачалоДня(Параметры.ДатаФормирования));
	Запрос.УстановитьПараметр("НачалоПериода", НачалоДня(Параметры.НачалоПериода));
	Запрос.УстановитьПараметр("КонецПериода", КонецДня(Параметры.КонецПериода));
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	СводЗаявокНаДоставку.Ссылка КАК Ссылка,
	|	СводЗаявокНаДоставку.Номер КАК Номер,
	|	СводЗаявокНаДоставку.Организация КАК Организация,
	|	СводЗаявокНаДоставку.Партнер КАК Партнер,
	|	СводЗаявокНаДоставку.Контрагент КАК Контрагент,
	|	СводЗаявокНаДоставку.Договор КАК Договор,
	|	СводЗаявокНаДоставку.НалогообложениеНДС КАК НалогообложениеНДС,
	|	СводЗаявокНаДоставку.Валюта КАК Валюта,
	|	СписокДоговоров.Подразделение КАК Подразделение,
	|	СписокДоговоров.ВалютаВзаиморасчетов КАК ВалютаВзаиморасчетов,
	|	СписокДоговоров.БанковскийСчет КАК БанковскийСчет,
	|	СписокДоговоров.БанковскийСчетКонтрагента КАК БанковскийСчетКонтрагента,
	|	СписокДоговоров.СтатьяДвиженияДенежныхСредств КАК СтатьяДвиженияДенежныхСредств,
	|	СписокДоговоров.ПорядокРасчетов КАК ПорядокРасчетов,
	|	СписокДоговоров.ЦенаВключаетНДС КАК ЦенаВключаетНДС,
	|	СписокДоговоров.ФормаОплатыУслуг КАК ФормаОплатыУслуг,
	|	ПроцентыСтоимостиУслугСКС.Договор КАК ДоговорСПокупателем,
	|	СводЗаявокНаДоставку.ПолнаяСтоимостьВсего КАК Сумма
	|ПОМЕСТИТЬ СводЗаявок
	|ИЗ
	|	Документ.Логс_СводЗаявокНаДоставку КАК СводЗаявокНаДоставку
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ СписокДоговоров КАК СписокДоговоров
	|		ПО СводЗаявокНаДоставку.Договор = СписокДоговоров.Договор
	|		ЛЕВОЕ СОЕДИНЕНИЕ ПроцентыСтоимостиУслугСКС КАК ПроцентыСтоимостиУслугСКС
	|		ПО СводЗаявокНаДоставку.Организация = ПроцентыСтоимостиУслугСКС.Организация
	|			И СводЗаявокНаДоставку.Партнер = ПроцентыСтоимостиУслугСКС.Партнер
	|			И СводЗаявокНаДоставку.Контрагент = ПроцентыСтоимостиУслугСКС.Контрагент
	|ГДЕ
	|	СводЗаявокНаДоставку.Дата МЕЖДУ &НачалоПериода И &КонецПериода
	|	И СводЗаявокНаДоставку.ПолнаяСтоимостьВсего > 0
	|	И СводЗаявокНаДоставку.ВидКлиента = ЗНАЧЕНИЕ(Перечисление.Логс_ВидыКлиентовCRM.СКС)
	|	И СводЗаявокНаДоставку.Проведен
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПриобретениеУслугПрочихАктивов.Договор КАК Договор,
	|	МАКСИМУМ(ПриобретениеУслугПрочихАктивов.Ссылка) КАК ПриобретениеУслуг,
	|	МАКСИМУМ(ЕСТЬNULL(ВзаимозачетЗадолженности.Ссылка, НЕОПРЕДЕЛЕНО)) КАК ВзаимозачетЗадолженности
	|ПОМЕСТИТЬ ДокументыПриобретенияУслуг
	|ИЗ
	|	Документ.ПриобретениеУслугПрочихАктивов КАК ПриобретениеУслугПрочихАктивов
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ВзаимозачетЗадолженности КАК ВзаимозачетЗадолженности
	|		ПО ПриобретениеУслугПрочихАктивов.Ссылка = ВзаимозачетЗадолженности.ДокументОснование
	|			И (НЕ ВзаимозачетЗадолженности.ПометкаУдаления)
	|ГДЕ
	|	НАЧАЛОПЕРИОДА(ПриобретениеУслугПрочихАктивов.Дата, ДЕНЬ) = &Дата
	|	И ПриобретениеУслугПрочихАктивов.Договор В
	|			(ВЫБРАТЬ
	|				СписокДоговоров.Договор
	|			ИЗ
	|				СписокДоговоров)
	|	И ПриобретениеУслугПрочихАктивов.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ЗакупкаУПоставщика)
	|	И НЕ ПриобретениеУслугПрочихАктивов.ПометкаУдаления
	|
	|СГРУППИРОВАТЬ ПО
	|	ПриобретениеУслугПрочихАктивов.Договор
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Договор
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СводЗаявок.Ссылка КАК Ссылка,
	|	СводЗаявок.Номер КАК Номер,
	|	СводЗаявок.Организация КАК Организация,
	|	СводЗаявок.Партнер КАК Партнер,
	|	СводЗаявок.Контрагент КАК Контрагент,
	|	СводЗаявок.Договор КАК Договор,
	|	СводЗаявок.НалогообложениеНДС КАК НалогообложениеНДС,
	|	СводЗаявок.Валюта КАК Валюта,
	|	СводЗаявок.Подразделение КАК Подразделение,
	|	СводЗаявок.ВалютаВзаиморасчетов КАК ВалютаВзаиморасчетов,
	|	СводЗаявок.БанковскийСчет КАК БанковскийСчет,
	|	СводЗаявок.БанковскийСчетКонтрагента КАК БанковскийСчетКонтрагента,
	|	СводЗаявок.СтатьяДвиженияДенежныхСредств КАК СтатьяДвиженияДенежныхСредств,
	|	СводЗаявок.ПорядокРасчетов КАК ПорядокРасчетов,
	|	СводЗаявок.ЦенаВключаетНДС КАК ЦенаВключаетНДС,
	|	СводЗаявок.ФормаОплатыУслуг КАК ФормаОплатыУслуг,
	|	СводЗаявок.ДоговорСПокупателем КАК ДоговорСПокупателем,
	|	СводЗаявок.Сумма КАК Сумма,
	|	ЕСТЬNULL(ДокументыПриобретенияУслуг.ПриобретениеУслуг, НЕОПРЕДЕЛЕНО) КАК ПриобретениеУслуг,
	|	ЕСТЬNULL(ДокументыПриобретенияУслуг.ВзаимозачетЗадолженности, НЕОПРЕДЕЛЕНО) КАК ВзаимозачетЗадолженности
	|ИЗ
	|	СводЗаявок КАК СводЗаявок
	|		ЛЕВОЕ СОЕДИНЕНИЕ ДокументыПриобретенияУслуг КАК ДокументыПриобретенияУслуг
	|		ПО СводЗаявок.Договор = ДокументыПриобретенияУслуг.Договор
	|ИТОГИ
	|	МАКСИМУМ(Подразделение),
	|	МАКСИМУМ(ВалютаВзаиморасчетов),
	|	МАКСИМУМ(БанковскийСчет),
	|	МАКСИМУМ(БанковскийСчетКонтрагента),
	|	МАКСИМУМ(ПорядокРасчетов),
	|	МАКСИМУМ(ЦенаВключаетНДС),
	|	МАКСИМУМ(ФормаОплатыУслуг),
	|	МАКСИМУМ(ДоговорСПокупателем),
	|	МАКСИМУМ(ПриобретениеУслуг),
	|	МАКСИМУМ(ВзаимозачетЗадолженности)
	|ПО
	|	Организация,
	|	Партнер,
	|	Контрагент,
	|	Договор,
	|	НалогообложениеНДС,
	|	Валюта";
	
	Менеджер = Пользователи.ТекущийПользователь();
	СтатьяРасходов = Константы.Логс_СтатьяРасходовУслугСКС.Получить();
	АналитикаРасходов = Константы.Логс_АналитикаРасходовУслугСКС.Получить();
	
	ВыборкаОрганизации = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаОрганизации.Следующий() Цикл
		ВыборкаПартнеры = ВыборкаОрганизации.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		
		Если УчетнаяПолитикаПереопределяемый.ПрименяетсяУСН(ВыборкаОрганизации.Организация, Параметры.НачалоПериода) Тогда
			НалогообложениеНДС = перечисления.ТипыНалогообложенияНДС.ПродажаНеОблагаетсяНДС;
		Иначе
			НалогообложениеНДС = перечисления.ТипыНалогообложенияНДС.ПродажаОблагаетсяНДС;
		КонецЕсли;	
		
		//#TODO Костыль для УСН Орион - НДС нужен.
		Если ВыборкаОрганизации.Организация = ОрионОрганизация Тогда
			НалогообложениеНДС = перечисления.ТипыНалогообложенияНДС.ПродажаОблагаетсяНДС;
		КонецЕсли;

		
		Пока ВыборкаПартнеры.Следующий() Цикл
			ВыборкаКонтрагенты = ВыборкаПартнеры.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока ВыборкаКонтрагенты.Следующий() Цикл
				ВыборкаДоговоры = ВыборкаКонтрагенты.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
				Пока ВыборкаДоговоры.Следующий() Цикл
					
					// Найдём строку в таблице созданных документов, в которую будем добавлять приобретения услуг.
					СтрокиСозданныхДокументов = ТаблицаСозданныхДокументов.НайтиСтроки(
						Новый Структура("Партнер,Договор",
							ВыборкаДоговоры.Партнер,
							ВыборкаДоговоры.Договор));
					Если СтрокиСозданныхДокументов.Количество() = 0 Тогда
						СтрокаСозданныхДокументов = ТаблицаСозданныхДокументов.Добавить();
						СтрокаСозданныхДокументов.Партнер = ВыборкаДоговоры.Партнер;
						СтрокаСозданныхДокументов.Договор = ВыборкаДоговоры.Договор;
					Иначе
						СтрокаСозданныхДокументов = СтрокиСозданныхДокументов[0];
					КонецЕсли; 
					
					ВыборкаНалогообложение = ВыборкаДоговоры.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
					Пока ВыборкаНалогообложение.Следующий() Цикл
						ВыборкаВалюты = ВыборкаНалогообложение.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
						Пока ВыборкаВалюты.Следующий() Цикл
							
							Если ЗначениеЗаполнено(ВыборкаВалюты.ПриобретениеУслуг) Тогда
								ПриобретениеУслугПрочихАктивов = ВыборкаВалюты.ПриобретениеУслуг.ПолучитьОбъект();
								
								ПриобретениеУслугПрочихАктивов.Расходы.Очистить();
								ПриобретениеУслугПрочихАктивов.РасшифровкаПлатежа.Очистить();
							Иначе
								ПриобретениеУслугПрочихАктивов = Документы.ПриобретениеУслугПрочихАктивов.СоздатьДокумент();
								ПриобретениеУслугПрочихАктивов.Дата = НачалоДня(Параметры.ДатаФормирования) + 43210;
								ПриобретениеУслугПрочихАктивов.Организация = ВыборкаВалюты.Организация;
								ПриобретениеУслугПрочихАктивов.Партнер = ВыборкаВалюты.Партнер;
								ПриобретениеУслугПрочихАктивов.Контрагент = ВыборкаВалюты.Контрагент;
								ПриобретениеУслугПрочихАктивов.Договор = ВыборкаВалюты.Договор;
								ПриобретениеУслугПрочихАктивов.Менеджер = Менеджер;
								
								ПриобретениеУслугПрочихАктивов.УстановитьНовыйНомер();
							КонецЕсли;
	
							ПриобретениеУслугПрочихАктивов.Подразделение = ВыборкаВалюты.Подразделение;
							ПриобретениеУслугПрочихАктивов.Валюта = ВыборкаВалюты.ВалютаВзаиморасчетов;
							ПриобретениеУслугПрочихАктивов.ВалютаВзаиморасчетов = ВыборкаВалюты.ВалютаВзаиморасчетов;
							ПриобретениеУслугПрочихАктивов.ЦенаВключаетНДС = ВыборкаВалюты.ЦенаВключаетНДС;
							ПриобретениеУслугПрочихАктивов.ДатаПлатежа = НачалоДня(ПриобретениеУслугПрочихАктивов.Дата);
							ПриобретениеУслугПрочихАктивов.НалогообложениеНДС = НалогообложениеНДС;
							ПриобретениеУслугПрочихАктивов.БанковскийСчетОрганизации = ВыборкаВалюты.БанковскийСчет;
							ПриобретениеУслугПрочихАктивов.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ЗакупкаУПоставщика;
							ПриобретениеУслугПрочихАктивов.БанковскийСчетКонтрагента = ВыборкаВалюты.БанковскийСчетКонтрагента;
							ПриобретениеУслугПрочихАктивов.ЗакупкаПодДеятельность = ВыборкаВалюты.НалогообложениеНДС;
							ПриобретениеУслугПрочихАктивов.ПорядокРасчетов = ВыборкаВалюты.ПорядокРасчетов;
							ПриобретениеУслугПрочихАктивов.СтатьяДвиженияДенежныхСредств = ВыборкаВалюты.СтатьяДвиженияДенежныхСредств;
							ПриобретениеУслугПрочихАктивов.КурсЧислитель = 1;
							//ПриобретениеУслугПрочихАктивов.Курс = 1;
							//ПриобретениеУслугПрочихАктивов.Кратность = 1;

							ОтветственныеЛицаСервер.ПриИзмененииСвязанныхРеквизитовДокумента(ПриобретениеУслугПрочихАктивов);
							
							Выборка = ВыборкаВалюты.Выбрать();
							Пока Выборка.Следующий() Цикл
								СтрокаУслуга = ПриобретениеУслугПрочихАктивов.Расходы.Добавить();
								СтрокаУслуга.Содержание = Логс_ДополнительныеПроцедурыИФункции.СформироватьНаименованиеУслугНаДоставкуПоСводу(Выборка.Ссылка);
								СтрокаУслуга.Количество = 1;
								СтрокаУслуга.Цена = Выборка.Сумма;
								СтрокаУслуга.Сумма = Выборка.Сумма; 
								
								//#TODO Костыль для УСН Орион - НДС нужен.
								Если ПриобретениеУслугПрочихАктивов.Организация = ОрионОрганизация И ПриобретениеУслугПрочихАктивов.Дата < Дата("20260101") Тогда
									СтрокаУслуга.СтавкаНДС = СтавкаНДС5;  
									
								ИначеЕсли (ПриобретениеУслугПрочихАктивов.Организация = ЛогсисОрганизация ИЛИ ПриобретениеУслугПрочихАктивов.Организация = ОрионОрганизация)
									И ПриобретениеУслугПрочихАктивов.Дата >= Дата("20260101") Тогда 
									СтрокаУслуга.СтавкаНДС =
									?(ПриобретениеУслугПрочихАктивов.НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.ПродажаОблагаетсяНДС,
									СтавкаНДС22, СтавкаБезНДС
									);
	                          	Иначе								
									СтрокаУслуга.СтавкаНДС =
									?(ПриобретениеУслугПрочихАктивов.НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.ПродажаОблагаетсяНДС,
										//Перечисления.СтавкиНДС.НДС20,
										//Перечисления.СтавкиНДС.БезНДС
										СтавкаНДС20, СтавкаБезНДС
									);
								КонецЕсли;

								//СтрокаУслуга.СтавкаНДС =
								//	?(ПриобретениеУслугПрочихАктивов.НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.ПродажаОблагаетсяНДС,
								//		//Перечисления.СтавкиНДС.НДС20,
								//		//Перечисления.СтавкиНДС.БезНДС
								//		СтавкаНДС20, СтавкаБезНДС
								//	);      
								
								//СтрокаУслуга.СуммаНДС = УчетНДСУПКлиентСервер.РассчитатьСуммуНДС(СтрокаУслуга.Сумма,
								//	УчетНДСУПКлиентСервер.ПолучитьСтавкуНДС(СтрокаУслуга.СтавкаНДС),
								//	ПриобретениеУслугПрочихАктивов.ЦенаВключаетНДС,
								//	ПриобретениеУслугПрочихАктивов.НалогообложениеНДС);
								СтрокаУслуга.СуммаНДС = УчетНДСУПКлиентСервер.РассчитатьСуммуНДС(СтрокаУслуга.Сумма,
									УчетНДСУПВызовСервера.ЗначениеСтавкиНДС(СтрокаУслуга.СтавкаНДС),
									ПриобретениеУслугПрочихАктивов.ЦенаВключаетНДС,
									ПриобретениеУслугПрочихАктивов.НалогообложениеНДС);
								СтрокаУслуга.СуммаСНДС = Выборка.Сумма;
								СтрокаУслуга.СтатьяРасходов = СтатьяРасходов;
								СтрокаУслуга.АналитикаРасходов = АналитикаРасходов;
								СтрокаУслуга.Подразделение = ПриобретениеУслугПрочихАктивов.Подразделение;
								СтрокаУслуга.Логс_СводЗаявокНаДоставку = Выборка.Ссылка;
							КонецЦикла; 
							
							СуммаВсего = ПриобретениеУслугПрочихАктивов.Расходы.Итог("СуммаСНДС");
							
							СтрокаПлатежа = ПриобретениеУслугПрочихАктивов.РасшифровкаПлатежа.Добавить();
							СтрокаПлатежа.Сумма = СуммаВсего;
	
							Если ПриобретениеУслугПрочихАктивов.Ссылка.Пустая() Тогда
								ПриобретениеУслугПрочихАктивов.Записать(РежимЗаписиДокумента.Запись);
							КонецЕсли; 
							
							Попытка
								ПриобретениеУслугПрочихАктивов.Записать(РежимЗаписиДокумента.Проведение);
							Исключение
								ОписаниеОшибки = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
								ТекстСообщения = СтрШаблон(
									НСтр("ru='Произошла ошибка при записи приобретения услуг № %1 от %2: %3'"),
									ПриобретениеУслугПрочихАктивов.Номер, Формат(ПриобретениеУслугПрочихАктивов.Дата, "ДФ=dd.MM.yyyy"),
									ОписаниеОшибки);
								ЗаписьЖурналаРегистрации("УУ Создание регламентированных документов. Создание приобретения услуг",
									УровеньЖурналаРегистрации.Ошибка,,, ТекстСообщения);
								СписокОшибок.Вставить(ПриобретениеУслугПрочихАктивов.Ссылка, ОписаниеОшибки);
							КонецПопытки;
							
							Если ВыборкаВалюты.ФормаОплатыУслуг = Перечисления.Логс_ФормыОплатыУслугАгенту.ОплатаЗаВычетом Тогда
								ВзаимозачетСсылка = СоздатьДокументВзаимозачетЗадолженностиСКС(ПриобретениеУслугПрочихАктивов.Дата + 1,
									ВыборкаВалюты.Организация, ВыборкаВалюты.Партнер, ВыборкаВалюты.Контрагент, ВыборкаВалюты.Подразделение,
									ВыборкаВалюты.Договор, ВыборкаВалюты.ДоговорСПокупателем, ВыборкаВалюты.ВалютаВзаиморасчетов,
									ПриобретениеУслугПрочихАктивов.Ссылка, СуммаВсего,
									ВыборкаВалюты.ВзаимозачетЗадолженности, СписокОшибок);
							Иначе
								ВзаимозачетСсылка = Неопределено;
							КонецЕсли; 
							
							СтрокаСозданныхДокументов.ДокументыПриобретенияУслугСКС.Добавить(Новый Структура("Ссылка,Взаимозачет",
								ПриобретениеУслугПрочихАктивов.Ссылка, ВзаимозачетСсылка));
							
						КонецЦикла; // Валюты
					КонецЦикла; // Налогообложение НДС
				КонецЦикла; // Договоры
			КонецЦикла; // Контрагенты
		КонецЦикла; // Партнеры
	КонецЦикла; // Организации
	
	Запрос.Текст =
	"УНИЧТОЖИТЬ СводЗаявок
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ДокументыПриобретенияУслуг";
	Запрос.Выполнить();
	
КонецПроцедуры 

//++ Ким Виктор 17.01.2025
//https://jira-sd.logsis.ru/projects/TSLOG/queues/custom/18/TSLOG-15412
Процедура СоздатьДокументыДвиженияДенежныхСредствПоСКСТМС(Параметры, МенеджерВременныхТаблиц, ТаблицаСозданныхДокументов, СписокОшибок)

	Если Не Параметры.Создавать.СоздаватьПоступленияСКСТМС Тогда
		Возврат;
	КонецЕсли;	
	
	СтавкаНДС20 = Константы.Логс_СтавкаНДС20.Получить();
	СтавкаБезНДС = Справочники.СтавкиНДС.БезНДС; 
	СтавкаНДС5	 = Справочники.СтавкиНДС.НайтиПоНаименованию("5%");
	СтавкаНДС22 = Справочники.СтавкиНДС.НайтиПоНаименованию("22%");
	ЛогсисОрганизация = Справочники.Организации.НайтиПоРеквизиту("ИНН", "9725007793");
	ОрионОрганизация = Справочники.Организации.НайтиПоРеквизиту("ИНН", "9728051543");

	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("Дата", НачалоДня(Параметры.ДатаФормирования));
	Запрос.УстановитьПараметр("НачалоПериода", НачалоДня(Параметры.НачалоПериода));
	Запрос.УстановитьПараметр("КонецПериода", КонецДня(Параметры.КонецПериода));
	
	Партнер = Неопределено;
	Параметры.Свойство("Партнер", Партнер);
	Запрос.УстановитьПараметр("Партнер", Партнер);
	Запрос.УстановитьПараметр("ПартнерЗаполнен", ЗначениеЗаполнено(Партнер));
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Логс_СводМаршрутов.Ссылка КАК ДокументСводовМаршрутов,
	|	Логс_СводМаршрутов.ДоговорСКС.Организация КАК Организация,
	|	Логс_СводМаршрутов.КонтрагентСКС КАК КонтрагентСКС,
	|	Логс_СводМаршрутов.ПартнерСКС КАК ПартнерСКС,
	|	Логс_СводМаршрутов.ДоговорСКС КАК ДоговорСКС,
	|	Логс_ПроцентыСтоимостиУслугСКСTMSСрезПоследних.ДоговорРеализации КАК ДоговорСПокупателем,
	|	Логс_СводМаршрутов.СуммаДокумента КАК СуммаДокумента
	|ПОМЕСТИТЬ втСводыМаршрутов
	|ИЗ
	|	Документ.Логс_СводМаршрутов КАК Логс_СводМаршрутов
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.Логс_ПроцентыСтоимостиУслугСКСTMS.СрезПоследних(&НачалоПериода, ) КАК Логс_ПроцентыСтоимостиУслугСКСTMSСрезПоследних
	|		ПО Логс_СводМаршрутов.КонтрагентСКС = Логс_ПроцентыСтоимостиУслугСКСTMSСрезПоследних.Контрагент
	|			И Логс_СводМаршрутов.ПартнерСКС = Логс_ПроцентыСтоимостиУслугСКСTMSСрезПоследних.Партнер
	|			И Логс_СводМаршрутов.ДоговорСКС = Логс_ПроцентыСтоимостиУслугСКСTMSСрезПоследних.Договор
	|ГДЕ
	|	Логс_СводМаршрутов.Ссылка.Проведен
	|	И Логс_СводМаршрутов.Дата МЕЖДУ &НачалоПериода И &КонецПериода
	|	И ВЫБОР
	|			КОГДА &ПартнерЗаполнен
	|				ТОГДА Логс_СводМаршрутов.ПартнерСКС = &Партнер
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	МАКСИМУМ(ПриобретениеУслугПрочихАктивовРасходы.Ссылка) КАК ДокументПриобретениеУслуг,
	|	ПриобретениеУслугПрочихАктивовРасходы.Ссылка.Договор КАК Договор,
	|	ПриобретениеУслугПрочихАктивовРасходы.Логс_СводМаршрутов КАК СводМаршрутов
	|ПОМЕСТИТЬ втДокументПриобретениеУслуг
	|ИЗ
	|	втСводыМаршрутов КАК втСводыМаршрутов
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПриобретениеУслугПрочихАктивов.Расходы КАК ПриобретениеУслугПрочихАктивовРасходы
	|		ПО втСводыМаршрутов.ДоговорСКС = ПриобретениеУслугПрочихАктивовРасходы.Ссылка.Договор
	|			И втСводыМаршрутов.ДокументСводовМаршрутов = ПриобретениеУслугПрочихАктивовРасходы.Логс_СводМаршрутов
	|ГДЕ
	|	НАЧАЛОПЕРИОДА(ПриобретениеУслугПрочихАктивовРасходы.Ссылка.Дата, ДЕНЬ) = &Дата
	|	И НЕ ПриобретениеУслугПрочихАктивовРасходы.Ссылка.ПометкаУдаления
	|	И ПриобретениеУслугПрочихАктивовРасходы.Ссылка.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ЗакупкаУПоставщика)
	|
	|СГРУППИРОВАТЬ ПО
	|	ПриобретениеУслугПрочихАктивовРасходы.Ссылка.Договор,
	|	ПриобретениеУслугПрочихАктивовРасходы.Логс_СводМаршрутов
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втСводыМаршрутов.ДокументСводовМаршрутов КАК ДокументСводовМаршрутов,
	|	втСводыМаршрутов.Организация КАК Организация,
	|	втСводыМаршрутов.КонтрагентСКС КАК Контрагент,
	|	втСводыМаршрутов.ПартнерСКС КАК Партнер,
	|	втСводыМаршрутов.ДоговорСКС КАК Договор,
	|	ЕСТЬNULL(втДокументПриобретениеУслуг.ДокументПриобретениеУслуг, НЕОПРЕДЕЛЕНО) КАК ПриобретениеУслуг,
	|	втСводыМаршрутов.ДоговорСПокупателем КАК ДоговорСПокупателем,
	|	втСводыМаршрутов.ДоговорСКС.БанковскийСчет КАК БанковскийСчет,
	|	втСводыМаршрутов.ДоговорСКС.БанковскийСчетКонтрагента КАК БанковскийСчетКонтрагента,
	|	втСводыМаршрутов.ДоговорСКС.ВалютаВзаиморасчетов КАК ВалютаВзаиморасчетов,
	|	втСводыМаршрутов.ДоговорСКС.СтатьяДвиженияДенежныхСредств КАК СтатьяДвиженияДенежныхСредств,
	|	втСводыМаршрутов.ДоговорСКС.НаправлениеДеятельности КАК НаправлениеДеятельности,
	|	втСводыМаршрутов.ДоговорСКС.НалогообложениеНДС КАК НалогообложениеНДС,
	|	втСводыМаршрутов.ДоговорСКС.ПорядокРасчетов КАК ПорядокРасчетов,
	|	ИСТИНА КАК ЦенаВключаетНДС,
	|	втСводыМаршрутов.ДоговорСКС.СтавкаНДС КАК СтавкаНДС,
	|	втСводыМаршрутов.ДоговорСКС.Подразделение КАК Подразделение,
	|	втСводыМаршрутов.СуммаДокумента КАК Сумма
	|ИЗ
	|	втСводыМаршрутов КАК втСводыМаршрутов
	|		ЛЕВОЕ СОЕДИНЕНИЕ втДокументПриобретениеУслуг КАК втДокументПриобретениеУслуг
	|		ПО втСводыМаршрутов.ДоговорСКС = втДокументПриобретениеУслуг.Договор
	|			И втСводыМаршрутов.ДокументСводовМаршрутов = втДокументПриобретениеУслуг.СводМаршрутов
	|ИТОГИ
	|	МАКСИМУМ(ПриобретениеУслуг),
	|	МАКСИМУМ(ДоговорСПокупателем),
	|	МАКСИМУМ(БанковскийСчет),
	|	МАКСИМУМ(БанковскийСчетКонтрагента),
	|	МАКСИМУМ(ВалютаВзаиморасчетов),
	|	МАКСИМУМ(ПорядокРасчетов),
	|	МАКСИМУМ(ЦенаВключаетНДС),
	|	МАКСИМУМ(Подразделение)
	|ПО
	|	Организация,
	|	Партнер,
	|	Контрагент,
	|	Договор,
	|	НалогообложениеНДС,
	|	ВалютаВзаиморасчетов,
	|	ДокументСводовМаршрутов";
	
	Менеджер = Пользователи.ТекущийПользователь();
	СтатьяРасходов = Константы.Логс_СтатьяРасходовУслугСКС.Получить();
	АналитикаРасходов = Константы.Логс_АналитикаРасходовУслугСКС.Получить();
	НалогообложениеНДС = Неопределено;
	
	ВыборкаОрганизации = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаОрганизации.Следующий() Цикл 
		
		ВыборкаПартнеры = ВыборкаОрганизации.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		
		Если УчетнаяПолитикаПереопределяемый.ПрименяетсяУСН(ВыборкаОрганизации.Организация, Параметры.НачалоПериода) Тогда
			НалогообложениеНДС = перечисления.ТипыНалогообложенияНДС.ПродажаНеОблагаетсяНДС;
		Иначе
			НалогообложениеНДС = перечисления.ТипыНалогообложенияНДС.ПродажаОблагаетсяНДС;
		КонецЕсли;
		
		//#TODO Костыль для УСН Орион - НДС нужен.
		Если ВыборкаОрганизации.Организация = ОрионОрганизация Тогда
			НалогообложениеНДС = перечисления.ТипыНалогообложенияНДС.ПродажаОблагаетсяНДС;
		КонецЕсли;

		
		Пока ВыборкаПартнеры.Следующий() Цикл
			ВыборкаКонтрагенты = ВыборкаПартнеры.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока ВыборкаКонтрагенты.Следующий() Цикл
				ВыборкаДоговоры = ВыборкаКонтрагенты.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
				Пока ВыборкаДоговоры.Следующий() Цикл  
					
					// Найдём строку в таблице созданных документов, в которую будем добавлять приобретения услуг.
					СтрокиСозданныхДокументов = ТаблицаСозданныхДокументов.НайтиСтроки(
						Новый Структура("Партнер,Договор",
							ВыборкаДоговоры.Партнер,
							ВыборкаДоговоры.Договор));
					Если СтрокиСозданныхДокументов.Количество() = 0 Тогда
						СтрокаСозданныхДокументов = ТаблицаСозданныхДокументов.Добавить();
						СтрокаСозданныхДокументов.Партнер = ВыборкаДоговоры.Партнер;
						СтрокаСозданныхДокументов.Договор = ВыборкаДоговоры.Договор;
					Иначе
						СтрокаСозданныхДокументов = СтрокиСозданныхДокументов[0];
					КонецЕсли; 
					
					ВыборкаНалогообложение = ВыборкаДоговоры.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
					Пока ВыборкаНалогообложение.Следующий() Цикл
						
						ВыборкаВалюты = ВыборкаНалогообложение.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
						Пока ВыборкаВалюты.Следующий() Цикл   
							
							ВыборкаПоСводам = ВыборкаВалюты.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
							
							Пока ВыборкаПоСводам.Следующий() Цикл 
								
								Если ЗначениеЗаполнено(ВыборкаПоСводам.ПриобретениеУслуг) Тогда
									ПриобретениеУслугПрочихАктивов = ВыборкаПоСводам.ПриобретениеУслуг.ПолучитьОбъект();
									
									ПриобретениеУслугПрочихАктивов.Расходы.Очистить();
									ПриобретениеУслугПрочихАктивов.РасшифровкаПлатежа.Очистить();
								Иначе
									ПриобретениеУслугПрочихАктивов = Документы.ПриобретениеУслугПрочихАктивов.СоздатьДокумент();
									ПриобретениеУслугПрочихАктивов.Дата = НачалоДня(Параметры.ДатаФормирования) + 43210;
									ПриобретениеУслугПрочихАктивов.Организация 	= ВыборкаПоСводам.Организация;
									ПриобретениеУслугПрочихАктивов.Партнер 		= ВыборкаПоСводам.Партнер;
									ПриобретениеУслугПрочихАктивов.Контрагент 	= ВыборкаПоСводам.Контрагент;
									ПриобретениеУслугПрочихАктивов.Договор 	    = ВыборкаПоСводам.Договор;
									ПриобретениеУслугПрочихАктивов.Менеджер = Менеджер;
									
									ПриобретениеУслугПрочихАктивов.УстановитьНовыйНомер();
								КонецЕсли;
								
								ПриобретениеУслугПрочихАктивов.Подразделение = ВыборкаПоСводам.Подразделение;
								ПриобретениеУслугПрочихАктивов.Валюта = ВыборкаПоСводам.ВалютаВзаиморасчетов;
								ПриобретениеУслугПрочихАктивов.ВалютаВзаиморасчетов = ВыборкаПоСводам.ВалютаВзаиморасчетов;
								ПриобретениеУслугПрочихАктивов.ЦенаВключаетНДС = ВыборкаПоСводам.ЦенаВключаетНДС;
								ПриобретениеУслугПрочихАктивов.ДатаПлатежа = НачалоДня(ПриобретениеУслугПрочихАктивов.Дата);
								Если Не ЗначениеЗаполнено(ВыборкаПоСводам.НалогообложениеНДС) Тогда 
									ПриобретениеУслугПрочихАктивов.НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.ПродажаНеОблагаетсяНДС;
								Иначе
									ПриобретениеУслугПрочихАктивов.НалогообложениеНДС = ВыборкаПоСводам.НалогообложениеНДС;
								КонецЕсли;
								ПриобретениеУслугПрочихАктивов.БанковскийСчетОрганизации = ВыборкаПоСводам.БанковскийСчет;
								ПриобретениеУслугПрочихАктивов.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ЗакупкаУПоставщика;
								ПриобретениеУслугПрочихАктивов.БанковскийСчетКонтрагента = ВыборкаПоСводам.БанковскийСчетКонтрагента;
								ПриобретениеУслугПрочихАктивов.ЗакупкаПодДеятельность = ПриобретениеУслугПрочихАктивов.НалогообложениеНДС;
								ПриобретениеУслугПрочихАктивов.ПорядокРасчетов = ВыборкаПоСводам.ПорядокРасчетов;
								ПриобретениеУслугПрочихАктивов.СтатьяДвиженияДенежныхСредств = ВыборкаПоСводам.СтатьяДвиженияДенежныхСредств;
								ПриобретениеУслугПрочихАктивов.КурсЧислитель = 1;
								ПриобретениеУслугПрочихАктивов.КурсЗнаменатель = 1; 
								//ПриобретениеУслугПрочихАктивов.Курс = 1;
								//ПриобретениеУслугПрочихАктивов.Кратность = 1;
								
								ОтветственныеЛицаСервер.ПриИзмененииСвязанныхРеквизитовДокумента(ПриобретениеУслугПрочихАктивов);
								
								Выборка = ВыборкаПоСводам.Выбрать();
								
								Пока Выборка.Следующий() Цикл
									СтрокаУслуга = ПриобретениеУслугПрочихАктивов.Расходы.Добавить();
									СтрокаУслуга.Содержание = Логс_ДополнительныеПроцедурыИФункции.СформироватьНаименованиеУслугНаДоставкуПоСводуМаршрутов(Выборка.ДокументСводовМаршрутов);
									СтрокаУслуга.Количество = 1;
									СтрокаУслуга.Цена = Выборка.Сумма;
									СтрокаУслуга.Сумма = Выборка.Сумма;
									
									//#TODO Костыль для УСН Орион - НДС нужен.
									Если ПриобретениеУслугПрочихАктивов.Организация = ОрионОрганизация И ПриобретениеУслугПрочихАктивов.Дата < Дата("20260101") Тогда
