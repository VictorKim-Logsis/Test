					ВыборкаДоговоры = ВыборкаРегион.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
					Пока ВыборкаДоговоры.Следующий() Цикл
						ВыборкаБанковскиеСчета = ВыборкаДоговоры.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
						Пока ВыборкаБанковскиеСчета.Следующий() Цикл
							
							ВыборкаВалюты = ВыборкаБанковскиеСчета.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
							Пока ВыборкаВалюты.Следующий() Цикл
								
								#Область Пофикшено_В_Комбайн
			//					Если ВыборкаВалюты.СрокПлатежаДата Тогда
			//						ДеньПлатежа = ВыборкаВалюты.СрокПлатежа;
			//						                    
			//						//Если ДеньПлатежа = 20 Тогда
			//						Если ВыборкаВалюты.ПереноситьНаСледующийМесяц Тогда
			//							
			//							Если ДеньПлатежа > День(ДатаСчета) Тогда
			//								Если МесяцПлатежа = 12 Тогда
