										//	ДатаПлатежа = НачалоДня(ДатаСчета) + ВыборкаВалюты.СрокПлатежа * 86400;
										//КонецЕсли; 
										//
										//// День платежа должен быть рабочим.
										//НачальныеДаты = Новый Массив;
										//НачальныеДаты.Добавить(ДатаПлатежа);
										//РабочиеДни = КалендарныеГрафики.ДатыБлижайшихРабочихДней(ПроизводственныйКалендарь, НачальныеДаты, Ложь, Ложь, Истина);
										//ДатаПлатежа = РабочиеДни[ДатаПлатежа];
										#КонецОбласти
										
										ДатаПлатежа = Логс_ДатыПовтИсп.РассчитатьСдвигДаты(ДатаСчета, ВыборкаВалюты.СрокПлатежаСсылка);

										
										СчетНаОплату = Документы.СчетНаОплатуКлиенту.СоздатьДокумент();
										СчетНаОплату.Дата = ДатаСчета;
										СчетНаОплату.Организация = ВыборкаВалюты.Организация;
										СчетНаОплату.СуммаДокумента = ВыборкаВалюты.Сумма;
										СчетНаОплату.Валюта = ВыборкаВалюты.Валюта;
										СчетНаОплату.ДокументОснование = ВыборкаВалюты.Договор;
										СчетНаОплату.ФормаОплаты = Перечисления.ФормыОплаты.Безналичная;
										СчетНаОплату.БанковскийСчет = ВыборкаВалюты.БанковскийСчет;
										СчетНаОплату.Менеджер = Пользователи.ТекущийПользователь();
										СчетНаОплату.Партнер = ВыборкаВалюты.Партнер;
										СчетНаОплату.Контрагент = ВыборкаВалюты.Контрагент;
										СчетНаОплату.Договор = ВыборкаВалюты.Договор;
										
										ЭтапОплаты = СчетНаОплату.ЭтапыГрафикаОплаты.Добавить();
										ЭтапОплаты.ДатаПлатежа = ДатаПлатежа;
										ЭтапОплаты.ПроцентПлатежа = 100;
										ЭтапОплаты.СуммаПлатежа = СчетНаОплату.СуммаДокумента;
										
										Выборка = ВыборкаВалюты.Выбрать();
										Пока Выборка.Следующий() Цикл
											СтрокаРаспределения = СчетНаОплату.Логс_РаспределениеПоСводамЗаявокНаДоставку.Добавить();
											СтрокаРаспределения.СводЗаявок = Выборка.СводЗаявок;
											СтрокаРаспределения.Сумма = Выборка.Сумма;
										КонецЦикла; // Своды
										
										СчетНаОплату.УстановитьНовыйНомер();
										
										СчетНаОплату.НазначениеПлатежа = СтрШаблон(НСтр("ru='%1 по %2 по счету %3 от %4'"), 
										ВыборкаВалюты.НаименованиеУслугПоДоставке,
										ВыборкаВалюты.НаименованиеДоговора,
										СчетНаОплату.Номер,
										Формат(СчетНаОплату.Дата, "ДФ=dd.MM.yyyy"));
										
										СчетНаОплату.Записать(РежимЗаписиДокумента.Запись);
										Сообщить(Выборка.СводЗаявок);
										Попытка
											СчетНаОплату.Записать(РежимЗаписиДокумента.Проведение);
										Исключение
											ТекстСообщения = СтрШаблон(
											НСтр("ru='Произошла ошибка при записи счета на оплату № %1 от %2: %3'"),
											СчетНаОплату.Номер, Формат(СчетНаОплату.Дата, "ДФ=dd.MM.yyyy"),
											КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
											ЗаписьЖурналаРегистрации("УУ Создание регламентированных документов. Создание счетов на оплату",
											УровеньЖурналаРегистрации.Ошибка,,, ТекстСообщения);
											СписокОшибок.Добавить(Новый Структура("ТекстОшибки,КлючДанных",
											ТекстСообщения, СчетНаОплату.Ссылка));
										КонецПопытки;
										//Fil
										Если СчетНаОплату.Проведен И Параметры.ОтправлятьПоЭлектроннойПочте Тогда
											Логс_ДополнительныеПроцедурыИФункции.ОтправитьПоПочтеСчетОтчет(СчетНаОплату.Ссылка, "Счет");
										КонецЕсли;
									КонецЦикла;
								КонецЦикла;
							КонецЦикла;
						КонецЦикла;
					КонецЦикла;
				КонецЦикла;
			КонецЦикла;
			
			//}}КОНСТРУКТОР_ЗАПРОСА_С_ОБРАБОТКОЙ_РЕЗУЛЬТАТА]
		КонецЕсли;
	КонецЦикла;
КонецФункции

Функция СоздатьСчетаНаОплату20(Параметры, СписокОшибок = Неопределено)
	
	КонтрагентСпецСвязь = Справочники.Контрагенты.ПолучитьСсылку(Новый УникальныйИдентификатор("1010c9e4-352b-11e9-93f8-005056987d66")); // Спец.связь для печати товаров в формате
	
	Если СписокОшибок = Неопределено Тогда
		СписокОшибок = Новый Массив;
	КонецЕсли; 
			
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Период", Новый Граница(КонецДня(Параметры.Период), ВидГраницы.Включая));
	Запрос.УстановитьПараметр("СрокиВыставленияСчетов", Параметры.СрокиВыставленияСчетов);
	Запрос.УстановитьПараметр("ОрганизацияЛогсис", Логс_ДополнительныеПроцедурыИФункцииПовтИсп.ОрганизацияЛогсис());
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Аналитика.Организация КАК Организация,
	|	Аналитика.Партнер КАК Партнер,
	|	Аналитика.Контрагент КАК Контрагент,
	|	Аналитика.Договор КАК Договор,
	|	Организации.Логс_ОсновнойБанковскийСчет КАК БанковскийСчет,
	|	СчетаПоУслугам100Остатки.СводЗаявок КАК СводЗаявок,
	|	СчетаПоУслугам100Остатки.Валюта КАК Валюта,
	|	-СчетаПоУслугам100Остатки.СуммаОстаток КАК Сумма,
	|	СводЗаявокНаДоставку.МоментВремени КАК Порядок
	|ИЗ
	|	РегистрНакопления.Логс_СчетаПоУслугам100.Остатки(
	|			&Период,
	|			СводЗаявок.ФормаОплаты = ЗНАЧЕНИЕ(Перечисление.Логс_ФормыОплатыУслугАгенту.Оплата100)
	|				И (АналитикаУчетаПоПартнерам.Договор.Логс_СрокВыставленияСчетаЗаУслугиАгента В (&СрокиВыставленияСчетов)
	|					ИЛИ АналитикаУчетаПоПартнерам.Договор.Логс_СрокВыставленияСчетаЗаУслугиАгентаРег В (&СрокиВыставленияСчетов))
	|				И &ТекстОтбораПоПартнеру) КАК СчетаПоУслугам100Остатки
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.АналитикаУчетаПоПартнерам КАК Аналитика
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
	|			ПО Аналитика.Договор = ДоговорыКонтрагентов.Ссылка
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Организации КАК Организации
	|			ПО Аналитика.Организация = Организации.Ссылка
	|		ПО СчетаПоУслугам100Остатки.АналитикаУчетаПоПартнерам = Аналитика.КлючАналитики
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.Логс_СводЗаявокНаДоставку КАК СводЗаявокНаДоставку
	|		ПО СчетаПоУслугам100Остатки.СводЗаявок = СводЗаявокНаДоставку.Ссылка
	|ГДЕ
	|	СчетаПоУслугам100Остатки.СуммаОстаток < 0
	|	И НЕ Аналитика.Организация = &ОрганизацияЛогсис
	|	И НЕ Аналитика.Организация.Логс_НеФормироватьРеглДокументы
	|
	|УПОРЯДОЧИТЬ ПО
	|	Порядок
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Аналитика.Организация КАК Организация,
	|	Аналитика.Партнер КАК Партнер,
	|	Аналитика.Контрагент КАК Контрагент,
	|	Аналитика.Договор КАК Договор,
	|	СчетаПоУслугам100Остатки.СводЗаявок КАК СводЗаявок,
	|	СчетаПоУслугам100Остатки.Валюта КАК Валюта,
	|	ДоговорыКонтрагентов.НаименованиеДляПечати КАК НаименованиеДоговора,
	|	ДоговорыКонтрагентов.Логс_НаименованиеУслугПоДоставке КАК НаименованиеУслугПоДоставке,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(СводЗаявокНаДоставку.РегиональныйСвод, ЛОЖЬ)
	|			ТОГДА ДоговорыКонтрагентов.Логс_СрокПлатежаРег
