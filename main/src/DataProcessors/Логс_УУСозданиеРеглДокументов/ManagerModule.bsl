#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

Процедура СоздатьРеглДокументы(Параметры, АдресХранилища) Экспорт
	Перем ТабличныйДокумент;
	
	УстановитьПривилегированныйРежим(Истина);
	
	СписокОшибок = Новый Массив;
	
	Выполнить("ТабличныйДокумент = " + Параметры.Команда + "(Параметры, СписокОшибок)");
	
	Результат = Новый Структура("Успешно", СписокОшибок.Количество() = 0);
	Если Не Результат.Успешно Тогда
		Результат.Вставить("СписокОшибок", СписокОшибок);
	КонецЕсли; 
	
	Если ТабличныйДокумент <> Неопределено Тогда
		Результат.Вставить("ТабличныйДокумент", ТабличныйДокумент);
	КонецЕсли; 
	
	ПоместитьВоВременноеХранилище(Результат, АдресХранилища);
	
КонецПроцедуры 

#КонецОбласти 

#Область СозданиеДокументов

Функция СоздатьЗаявкиНаРасходованиеДенежныхСредств(Параметры, СписокОшибок = Неопределено)
	Перем КэшированныеЗначения;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Период", КонецДня(Параметры.Период) + 1);
	Запрос.УстановитьПараметр("СрокиПеречисленияНП", Параметры.СрокиПеречисленияНП);
	Запрос.УстановитьПараметр("ДатаНачалаУчета", Дата('20200728'));
	Запрос.УстановитьПараметр("ПустаяОрганизация", Справочники.Организации.ПустаяСсылка());
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Логс_ВзаиморасчетыЗаВычетомОстатки.АналитикаУчетаПоПартнерам КАК АналитикаУчетаПоПартнерам,
	|	Логс_ВзаиморасчетыЗаВычетомОстатки.СводЗаявок КАК СводЗаявок,
	|	Логс_ВзаиморасчетыЗаВычетомОстатки.Валюта КАК Валюта,
	|	ВЫБОР
	|		КОГДА Логс_ВзаиморасчетыЗаВычетомОстатки.СуммаНаложенногоПлатежаОстаток > 0
	|			ТОГДА Логс_ВзаиморасчетыЗаВычетомОстатки.СуммаНаложенногоПлатежаОстаток
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК Сумма,
	|	ВЫБОР
	|		КОГДА Логс_ВзаиморасчетыЗаВычетомОстатки.СуммаКОплатеОстаток < 0
	|			ТОГДА Логс_ВзаиморасчетыЗаВычетомОстатки.СуммаКОплатеОстаток
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК СуммаВозврата,
	|	ВЫБОР
	|		КОГДА Логс_ВзаиморасчетыЗаВычетомОстатки.СуммаКОплатеОстаток < 0
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ЭтоВозврат
	|ПОМЕСТИТЬ РасчетыПоНаложеннымПлатежамОстатки
	|ИЗ
	|	РегистрНакопления.Логс_ВзаиморасчетыЗаВычетом.Остатки(
	|			&Период,
	|			СводЗаявок.ФормаОплаты = ЗНАЧЕНИЕ(Перечисление.Логс_ФормыОплатыУслугАгенту.ОплатаЗаВычетом)
	|				И (АналитикаУчетаПоПартнерам.Договор.Логс_СрокПеречисленияНП В (&СрокиПеречисленияНП)
	|					ИЛИ АналитикаУчетаПоПартнерам.Договор.Логс_СрокПеречисленияНПРег В (&СрокиПеречисленияНП))
	|				И СводЗаявок.Дата <= &Период
	|				И НЕ СводЗаявок.Организация.Логс_НеФормироватьРеглДокументы
	|				И СводЗаявок.ВидКлиента <> ЗНАЧЕНИЕ(Перечисление.Логс_ВидыКлиентовCRM.СКС)
	|				И &ТекстОтбораПоПартнеру) КАК Логс_ВзаиморасчетыЗаВычетомОстатки
	|ГДЕ
	|	(Логс_ВзаиморасчетыЗаВычетомОстатки.СуммаКОплатеОстаток < 0
	|			ИЛИ Логс_ВзаиморасчетыЗаВычетомОстатки.СуммаНаложенногоПлатежаОстаток > 0)
	|	И Логс_ВзаиморасчетыЗаВычетомОстатки.СводЗаявок.Дата >= &ДатаНачалаУчета
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВложенныйЗапрос.АналитикаУчетаПоПартнерам КАК АналитикаУчетаПоПартнерам,
	|	Аналитика.Организация КАК Организация,
	|	Аналитика.Партнер КАК Партнер,
	|	Аналитика.Контрагент КАК Контрагент,
	|	Аналитика.Договор КАК Договор
	|ПОМЕСТИТЬ ИспользуемаяАналитика
	|ИЗ
	|	(ВЫБРАТЬ
	|		РасчетыПоНаложеннымПлатежам.АналитикаУчетаПоПартнерам КАК АналитикаУчетаПоПартнерам
	|	ИЗ
	|		РасчетыПоНаложеннымПлатежамОстатки КАК РасчетыПоНаложеннымПлатежам
	|	
	|	СГРУППИРОВАТЬ ПО
	|		РасчетыПоНаложеннымПлатежам.АналитикаУчетаПоПартнерам
	|	
	|	ИМЕЮЩИЕ
	|		СУММА(РасчетыПоНаложеннымПлатежам.Сумма) > 0) КАК ВложенныйЗапрос
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.АналитикаУчетаПоПартнерам КАК Аналитика
	|		ПО ВложенныйЗапрос.АналитикаУчетаПоПартнерам = Аналитика.КлючАналитики
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	АналитикаУчетаПоПартнерам
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ИспользуемаяАналитика.АналитикаУчетаПоПартнерам КАК АналитикаУчетаПоПартнерам,
	|	МАКСИМУМ(ВЫРАЗИТЬ(Логс_ВзаиморасчетыЗаВычетом.Регистратор КАК Документ.ЗаявкаНаРасходованиеДенежныхСредств).Дата) КАК Дата
	|ПОМЕСТИТЬ ПоследняяПроведеннаяЗаявка
	|ИЗ
	|	ИспользуемаяАналитика КАК ИспользуемаяАналитика
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.Логс_ВзаиморасчетыЗаВычетом КАК Логс_ВзаиморасчетыЗаВычетом
	|		ПО ИспользуемаяАналитика.АналитикаУчетаПоПартнерам = Логс_ВзаиморасчетыЗаВычетом.АналитикаУчетаПоПартнерам
	|ГДЕ
	|	Логс_ВзаиморасчетыЗаВычетом.Регистратор ССЫЛКА Документ.ЗаявкаНаРасходованиеДенежныхСредств
	|	И Логс_ВзаиморасчетыЗаВычетом.Период < &Период
	|
	|СГРУППИРОВАТЬ ПО
	|	ИспользуемаяАналитика.АналитикаУчетаПоПартнерам
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	РасчетыПоНаложеннымПлатежам.СводЗаявок КАК СводЗаявок,
	|	РасчетыПоНаложеннымПлатежам.Валюта КАК Валюта,
	|	Аналитика.Организация КАК Организация,
	|	Аналитика.Партнер КАК Партнер,
	|	Аналитика.Контрагент КАК Контрагент,
	|	Аналитика.Договор КАК Договор,
	|	РасчетыПоНаложеннымПлатежам.Сумма КАК Сумма,
	|	РасчетыПоНаложеннымПлатежам.СуммаВозврата КАК СуммаВозврата,
	|	ЕСТЬNULL(ПоследняяПроведеннаяЗаявка.Дата, ДАТАВРЕМЯ(2010, 1, 1)) КАК ДатаПоследнейЗаявки,
	|	РасчетыПоНаложеннымПлатежам.АналитикаУчетаПоПартнерам КАК АналитикаУчетаПоПартнерам,
	|	РасчетыПоНаложеннымПлатежам.ЭтоВозврат КАК ЭтоВозврат
	|ПОМЕСТИТЬ РасчетыПоНаложеннымПлатежам
	|ИЗ
	|	РасчетыПоНаложеннымПлатежамОстатки КАК РасчетыПоНаложеннымПлатежам
	|		ЛЕВОЕ СОЕДИНЕНИЕ ИспользуемаяАналитика КАК Аналитика
	|		ПО РасчетыПоНаложеннымПлатежам.АналитикаУчетаПоПартнерам = Аналитика.АналитикаУчетаПоПартнерам
	|		ЛЕВОЕ СОЕДИНЕНИЕ ПоследняяПроведеннаяЗаявка КАК ПоследняяПроведеннаяЗаявка
	|		ПО РасчетыПоНаложеннымПлатежам.АналитикаУчетаПоПартнерам = ПоследняяПроведеннаяЗаявка.АналитикаУчетаПоПартнерам
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	СводЗаявок,
	|	Организация
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ РасчетыПоНаложеннымПлатежамОстатки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ИспользуемаяАналитика
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Кассы.Владелец КАК Организация,
	|	МАКСИМУМ(Кассы.Ссылка) КАК Ссылка
	|ПОМЕСТИТЬ Кассы
	|ИЗ
	|	Справочник.Кассы КАК Кассы
	|ГДЕ
	|	Кассы.Владелец В
	|			(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|				РасчетыПоНаложеннымПлатежам.Организация
	|			ИЗ
	|				РасчетыПоНаложеннымПлатежам)
	|	И НЕ Кассы.ПометкаУдаления
	|
	|СГРУППИРОВАТЬ ПО
	|	Кассы.Владелец
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Организация
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	РаспределениеПоСводамЗаявок.СводЗаявок КАК СводЗаявок
	|ПОМЕСТИТЬ СуществующиеЗаявкиНаРасходованиеДС
	|ИЗ
	|	Документ.ЗаявкаНаРасходованиеДенежныхСредств.Логс_РаспределениеПоСводамЗаявокНаДоставку КАК РаспределениеПоСводамЗаявок
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.Логс_ВзаиморасчетыЗаВычетом КАК Логс_ВзаиморасчетыЗаВычетом
	|		ПО РаспределениеПоСводамЗаявок.Ссылка = Логс_ВзаиморасчетыЗаВычетом.Регистратор
	|ГДЕ
	|	РаспределениеПоСводамЗаявок.СводЗаявок В
	|			(ВЫБРАТЬ
	|				РасчетыПоНаложеннымПлатежам.СводЗаявок
	|			ИЗ
	|				РасчетыПоНаложеннымПлатежам)
	|	И РаспределениеПоСводамЗаявок.Ссылка.Проведен
	|	И НЕ РаспределениеПоСводамЗаявок.Ссылка.ПометкаУдаления
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	РаспределениеПоСводамЗаявок.СводЗаявок
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДокСводЗаявок.Дата КАК ДатаСвода,
	|	ДокСводЗаявок.Номер КАК НомерСвода,
	|	ДокСводЗаявок.ФормаОплаты КАК ФормаОплаты,
	|	РасчетыПоНаложеннымПлатежам.Организация КАК Организация,
	|	РасчетыПоНаложеннымПлатежам.Партнер КАК Партнер,
	|	РасчетыПоНаложеннымПлатежам.Контрагент КАК Контрагент,
	|	РасчетыПоНаложеннымПлатежам.Договор КАК Договор,
	|	ДоговорыКонтрагентов.НаименованиеДляПечати КАК НаименованиеДоговора,
	|	ДоговорыКонтрагентов.Логс_ВидКлиентаCRM КАК ВидКлиента,
	|	ВЫБОР
	|		КОГДА ДокСводЗаявок.РегиональныйСвод
	|			ТОГДА ДоговорыКонтрагентов.Логс_СрокПеречисленияНПРег
	|		ИНАЧЕ ДоговорыКонтрагентов.Логс_СрокПеречисленияНП
	|	КОНЕЦ КАК СрокПеречисленияНП,
	|	ВЫБОР
	|		КОГДА ДокСводЗаявок.РегиональныйСвод
	|			ТОГДА ДоговорыКонтрагентов.Логс_ПериодФормированияСводовАгентаРег
	|		ИНАЧЕ ДоговорыКонтрагентов.Логс_ПериодФормированияСводовАгента
	|	КОНЕЦ КАК ПериодФормированияОтчетов,
	|	ВЫБОР
	|		КОГДА РасчетыПоНаложеннымПлатежам.Договор.Логс_ПриоритетныйСчетОплаты = ЗНАЧЕНИЕ(Справочник.БанковскиеСчетаОрганизаций.ПустаяСсылка)
	|			ТОГДА Организации.Логс_ОсновнойБанковскийСчет
	|		ИНАЧЕ РасчетыПоНаложеннымПлатежам.Договор.Логс_ПриоритетныйСчетОплаты
	|	КОНЕЦ КАК БанковскийСчет,
	|	ДоговорыКонтрагентов.БанковскийСчетКонтрагента КАК БанковскийСчетКонтрагента,
	|	ДоговорыКонтрагентов.Подразделение КАК Подразделение,
	|	ДоговорыКонтрагентов.СтатьяДвиженияДенежныхСредств КАК СтатьяДвиженияДенежныхСредств,
	|	ДоговорыКонтрагентов.СтавкаНДС КАК СтавкаНДС,
	|	Кассы.Ссылка КАК Касса,
	|	РасчетыПоНаложеннымПлатежам.СводЗаявок КАК СводЗаявок,
	|	РасчетыПоНаложеннымПлатежам.Валюта КАК Валюта,
	|	РасчетыПоНаложеннымПлатежам.Сумма КАК Сумма,
	|	НЕ СуществующиеЗаявкиНаРасходованиеДС.СводЗаявок ЕСТЬ NULL КАК Доплата,
	|	РасчетыПоНаложеннымПлатежам.СуммаВозврата КАК СуммаВозврата,
	|	РасчетыПоНаложеннымПлатежам.ДатаПоследнейЗаявки КАК ДатаПоследнейЗаявки,
	|	РасчетыПоНаложеннымПлатежам.АналитикаУчетаПоПартнерам КАК АналитикаУчетаПоПартнерам,
	|	РасчетыПоНаложеннымПлатежам.ЭтоВозврат КАК ЭтоВозврат,
	|	ОбъектыРасчетов.Ссылка КАК ОбъектРасчетов
	|ИЗ
	|	РасчетыПоНаложеннымПлатежам КАК РасчетыПоНаложеннымПлатежам
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
	|		ПО РасчетыПоНаложеннымПлатежам.Договор = ДоговорыКонтрагентов.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ОбъектыРасчетов КАК ОбъектыРасчетов
	|		ПО РасчетыПоНаложеннымПлатежам.Договор = ОбъектыРасчетов.Объект
	|		И ОбъектыРасчетов.ТипРасчетов = Значение(Перечисление.ТипыРасчетовСПартнерами.РасчетыСПоставщиком)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Организации КАК Организации
	|		ПО РасчетыПоНаложеннымПлатежам.Организация = Организации.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.Логс_СводЗаявокНаДоставку КАК ДокСводЗаявок
	|		ПО РасчетыПоНаложеннымПлатежам.СводЗаявок = ДокСводЗаявок.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Кассы КАК Кассы
	|		ПО РасчетыПоНаложеннымПлатежам.Организация = Кассы.Организация
	|		ЛЕВОЕ СОЕДИНЕНИЕ СуществующиеЗаявкиНаРасходованиеДС КАК СуществующиеЗаявкиНаРасходованиеДС
	|		ПО РасчетыПоНаложеннымПлатежам.СводЗаявок = СуществующиеЗаявкиНаРасходованиеДС.СводЗаявок
	|ГДЕ
	|	(РасчетыПоНаложеннымПлатежам.Сумма <> 0
	|			ИЛИ РасчетыПоНаложеннымПлатежам.СуммаВозврата <> 0)
	|   И НЕ РасчетыПоНаложеннымПлатежам.Организация = &ПустаяОрганизация
	|УПОРЯДОЧИТЬ ПО
	|	ДатаСвода,
	|	Сумма
	|ИТОГИ ПО
	|	АналитикаУчетаПоПартнерам,
	|	ЭтоВозврат";
	
	Если Параметры.Свойство("Партнер") Тогда
		Запрос.УстановитьПараметр("Партнер", Параметры.Партнер);
		ТекстОтбораПоПартнеру = "АналитикаУчетаПоПартнерам.Партнер = &Партнер";
	Иначе
		ТекстОтбораПоПартнеру = "ИСТИНА";
	КонецЕсли;
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ТекстОтбораПоПартнеру", ТекстОтбораПоПартнеру);
	
	ПриоритетОплаты = Справочники.ПриоритетыОплаты.ПолучитьПриоритетПоУмолчанию(Неопределено);
	ПроизводственныйКалендарь = КалендарныеГрафики.ОсновнойПроизводственныйКалендарь();
							
	СтруктураПересчетаСуммы = Новый Структура;
	СтруктураПересчетаСуммы.Вставить("ЦенаВключаетНДС", Истина);
	
	СтруктураДействий = Новый Структура;
	СтруктураДействий.Вставить("ПересчитатьСуммуНДС", СтруктураПересчетаСуммы);
	
	ТекущаяДата = ТекущаяДатаСеанса();
	ДатаДокумента = ?(НачалоДня(ТекущаяДата) = НачалоДня(Параметры.Период), ТекущаяДата, КонецДня(Параметры.Период));
	
	ВыборкаАналитикаУчетаПоПартнерам = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаАналитикаУчетаПоПартнерам.Следующий() Цикл
		
		ВыборкаВозврат = ВыборкаАналитикаУчетаПоПартнерам.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаВозврат.Следующий() Цикл
			
			ЗаявкаНаРасходованиеДС = Неопределено;
			ПризнакДоплатПоСводам = Новый Соответствие();
			НаименованиеДоговора = "";
			ТекущаяКасса = Неопределено;
			ТекущийБанковскийСчет = Неопределено;
			
			Выборка = ВыборкаВозврат.Выбрать();
			Пока Выборка.Следующий() Цикл
				
				Если ЗаявкаНаРасходованиеДС = Неопределено Тогда
				
					ЗаявкаНаРасходованиеДС = Документы.ЗаявкаНаРасходованиеДенежныхСредств.СоздатьДокумент();
					ЗаявкаНаРасходованиеДС.Дата = ДатаДокумента;
					ЗаявкаНаРасходованиеДС.Организация = Выборка.Организация;
					ЗаявкаНаРасходованиеДС.Статус = Перечисления.СтатусыЗаявокНаРасходованиеДенежныхСредств.НеСогласована;
					Если Выборка.ЭтоВозврат Тогда
						ЗаявкаНаРасходованиеДС.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ВозвратОплатыКлиенту;
					Иначе
						ЗаявкаНаРасходованиеДС.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ОплатаПоставщику;
					КонецЕсли;
					ЗаявкаНаРасходованиеДС.Валюта = Выборка.Валюта;
					ЗаявкаНаРасходованиеДС.ФормаОплатыНаличная = (Выборка.Организация = Логс_ДополнительныеПроцедурыИФункцииПовтИсп.ОрганизацияЛогсис());
					ЗаявкаНаРасходованиеДС.ФормаОплатыБезналичная = Не ЗаявкаНаРасходованиеДС.ФормаОплатыНаличная;
					ЗаявкаНаРасходованиеДС.БанковскийСчет = Выборка.БанковскийСчет;
					ЗаявкаНаРасходованиеДС.Касса = Выборка.Касса;
					ЗаявкаНаРасходованиеДС.Контрагент = Выборка.Контрагент;
					ЗаявкаНаРасходованиеДС.БанковскийСчетКонтрагента = Выборка.БанковскийСчетКонтрагента;
					ЗаявкаНаРасходованиеДС.Подразделение = Выборка.Подразделение;
					ЗаявкаНаРасходованиеДС.КтоЗаявил = Пользователи.ТекущийПользователь();
					ЗаявкаНаРасходованиеДС.Автор = ЗаявкаНаРасходованиеДС.КтоЗаявил;
					ЗаявкаНаРасходованиеДС.СтатьяДвиженияДенежныхСредств = Выборка.СтатьяДвиженияДенежныхСредств;
					ЗаявкаНаРасходованиеДС.ПланированиеСуммы = Перечисления.СпособыПланированияОплатыЗаявок.ВВалютеПлатежа;
					//2,5,7//ЗаявкаНаРасходованиеДС.ВариантОплаты = Перечисления.ВариантыОплатыПоставщику.ПредоплатаДоПоступления;
					ЗаявкаНаРасходованиеДС.ВариантОплаты = Перечисления.ВариантыКонтроляОплатыПоставщику.ПредоплатаДоПоступления;
					ЗаявкаНаРасходованиеДС.ВидПеречисленияВБюджет = Перечисления.ВидыПеречисленийВБюджет.ИнойПлатеж;
					ЗаявкаНаРасходованиеДС.ПриоритетОплаты = ПриоритетОплаты;
					
					ЗаявкаНаРасходованиеДС.ДополнительныеСвойства.Вставить("ДатаПоследнейЗаявки", Выборка.ДатаПоследнейЗаявки);
					ЗаявкаНаРасходованиеДС.ДополнительныеСвойства.Вставить("АналитикаУчетаПоПартнерам", Выборка.АналитикаУчетаПоПартнерам);
					
				КонецЕсли;
				
				НаименованиеДоговора = Выборка.НаименованиеДоговора;
				
				СтрокаРаспределения = ЗаявкаНаРасходованиеДС.Логс_РаспределениеПоСводамЗаявокНаДоставкуДвижения.Добавить();
				СтрокаРаспределения.СводЗаявок = Выборка.СводЗаявок;
				СтрокаРаспределения.ЭтоВозврат = Выборка.ЭтоВозврат;
				СтрокаРаспределения.Сумма = Выборка.Сумма;
				
				ПризнакДоплатПоСводам.Вставить(Выборка.СводЗаявок, Выборка.Доплата);
				
				
				//Правка от 13.05.2021
				//переделываем сроки:
				//3.	Вт/ПТ и Ежедневно+2 раб дня –это +2 рабочих дня от даты свода
				//		СР/ПН-+3 рабочих дня от даты свода
				
				////старая версия:
				//Если Выборка.СрокПеречисленияНП = Перечисления.Логс_СрокиПеречисленияНП.Ежедневно
				//		И Выборка.ПериодФормированияОтчетов = Перечисления.Логс_ПериодыФормированияСводовАгентов.ДваРазаВНеделю Тогда
				//		
				//	лСрокПеречисления = Перечисления.Логс_СрокиПеречисленияНП.ПлатежныйДень;
				//Иначе
				//	лСрокПеречисления = Выборка.СрокПеречисленияНП;
				//КонецЕсли;
				//Если лСрокПеречисления = Перечисления.Логс_СрокиПеречисленияНП.ПлатежныйДень или
				//		лСрокПеречисления = Перечисления.Логс_СрокиПеречисленияНП.ПлатежныйДеньСрПт Тогда
				//		ДатаПлатежа = Логс_ДатыПовтИсп.РассчитатьСдвигДаты(НачалоДня(ТекущаяДата())+24*60*60, лСрокПеречисления);
				//Иначе
				//	ДатаПлатежа = Логс_ДатыПовтИсп.РассчитатьСдвигДаты(Выборка.ДатаСвода, лСрокПеречисления);
				//КонецЕсли;
				
				////новая версия
				Если  Выборка.СрокПеречисленияНП = Перечисления.Логс_СрокиПеречисленияНП.ПлатежныйДень или
					     Выборка.СрокПеречисленияНП = Перечисления.Логс_СрокиПеречисленияНП.Ежедневно или
						 Выборка.СрокПеречисленияНП = Перечисления.Логс_СрокиПеречисленияНП.ПлатежныйДеньСрПт Тогда
						ДатаПлатежа = Логс_ДатыПовтИсп.РассчитатьСдвигДаты(Выборка.ДатаСвода,  Выборка.СрокПеречисленияНП);
				Иначе
					ДатаПлатежа = Логс_ДатыПовтИсп.РассчитатьСдвигДаты(Выборка.ДатаСвода,  Выборка.СрокПеречисленияНП);
				КонецЕсли;
				//конецправки
				
				ЗаявкаНаРасходованиеДС.ДатаПлатежа = ДатаПлатежа;
				ЗаявкаНаРасходованиеДС.ЖелательнаяДатаПлатежа = ДатаПлатежа;
				
				СтрокаПлатежа = ЗаявкаНаРасходованиеДС.РасшифровкаПлатежа.Добавить();
				СтрокаПлатежа.Партнер = Выборка.Партнер;
				СтрокаПлатежа.ОбъектРасчетов = Выборка.ОбъектРасчетов;
				Если Выборка.ЭтоВозврат Тогда
					СтрокаПлатежа.Сумма = Выборка.СуммаВозврата;
				Иначе
					СтрокаПлатежа.Сумма = Выборка.Сумма;
				КонецЕсли;
				
				ЗаявкаНаРасходованиеДС.ДатаПлатежа = Макс(ДатаПлатежа, ЗаявкаНаРасходованиеДС.ДатаПлатежа);
				
				СтрокаПлатежа.ВалютаВзаиморасчетов = Выборка.Валюта;
				СтрокаПлатежа.СтатьяДвиженияДенежныхСредств = Выборка.СтатьяДвиженияДенежныхСредств; 
				СтрокаПлатежа.Организация = Выборка.Организация;
				СтрокаПлатежа.СтавкаНДС = Выборка.СтавкаНДС;
				
				//++ Ким Виктор 10.12.2025
				//Фикс после обновления
				//ОбработкаТабличнойЧастиСервер.ОбработатьСтрокуТЧ(СтрокаПлатежа, СтруктураДействий, КэшированныеЗначения);
				ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьСтрокуТЧ(СтрокаПлатежа, СтруктураДействий, КэшированныеЗначения);
				//-- Ким Виктор 10.12.2025
				
				ТекущаяКасса = Выборка.Касса;
				ТекущийБанковскийСчет =  Выборка.БанковскийСчет;
			КонецЦикла; // Своды
			
			Если ЗаявкаНаРасходованиеДС <> Неопределено Тогда
				
				Если ЗаявкаНаРасходованиеДС.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ВозвратОплатыКлиенту Тогда
					ШаблонНазначенияПлатежа = НСтр("ru='Возврат излишне перечисленных сумм по %1 по : '");
					ШаблонНазначенияПлатежаПоСводу = НСтр("ru='отчет №%1 от %2'");
					
					НазначениеПлатежа = СтрШаблон(ШаблонНазначенияПлатежа, НаименованиеДоговора);
					
					Для каждого СтрокаОстатков Из ЗаявкаНаРасходованиеДС.Логс_РаспределениеПоСводамЗаявокНаДоставкуДвижения Цикл
						НоваяСтрока = ЗаявкаНаРасходованиеДС.Логс_РаспределениеПоСводамЗаявокНаДоставку.Добавить();
						ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаОстатков);
						НазначениеПлатежа = НазначениеПлатежа + СтрШаблон(ШаблонНазначенияПлатежаПоСводу, НоваяСтрока.СводЗаявок.Номер, НоваяСтрока.СводЗаявок.Дата);
					КонецЦикла;
				Иначе
					ЗаполнитьРаспределениеНП_ПоСводам(ЗаявкаНаРасходованиеДС, ПризнакДоплатПоСводам);
				КонецЕсли; 
				
				СтрокаБанковскогоСчета = ЗаявкаНаРасходованиеДС.РаспределениеПоСчетам.Добавить();
				СтрокаБанковскогоСчета.БанковскийСчетКасса = ?(ЗаявкаНаРасходованиеДС.ФормаОплатыНаличная, ТекущаяКасса, ТекущийБанковскийСчет);
				СтрокаБанковскогоСчета.Сумма = ЗаявкаНаРасходованиеДС.Логс_РаспределениеПоСводамЗаявокНаДоставкуДвижения.Итог("Сумма");
				СтрокаБанковскогоСчета.ДатаПлатежа = ЗаявкаНаРасходованиеДС.ДатаПлатежа;
				
				ЗаявкаНаРасходованиеДС.СуммаДокумента = ЗаявкаНаРасходованиеДС.Логс_РаспределениеПоСводамЗаявокНаДоставкуДвижения.Итог("Сумма");
				
				ЗаявкаНаРасходованиеДС.УстановитьНовыйНомер();
				ЗаявкаНаРасходованиеДС.Записать(РежимЗаписиДокумента.Запись);
				
				Попытка
					ЗаявкаНаРасходованиеДС.Записать(РежимЗаписиДокумента.Проведение);
				Исключение
					ТекстСообщения = СтрШаблон(
						НСтр("ru='Произошла ошибка при записи заявки на расходование денежных средств по своду заявок на доставку № %1 от %2: %3'"),
						Выборка.НомерСвода, Формат(Выборка.ДатаСвода, "ДФ=dd.MM.yyyy"),
						КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
					ЗаписьЖурналаРегистрации("УУ Создание регламентированных документов. Создание заявок на расходование ДС",
						УровеньЖурналаРегистрации.Ошибка,,, ТекстСообщения);
					БылиОшибки = Истина;
				КонецПопытки;
				
				ЗаявкаНаРасходованиеДС = Неопределено;
				
			КонецЕсли;
			
		КонецЦикла; // Возврат
	КонецЦикла;
	
КонецФункции

Процедура ЗаполнитьРаспределениеНП_ПоСводам(ЗаявкаНаРасходованиеДС, ПризнакДоплатПоСводам)
	
	АналитикаУчетаПоПартнерам = ЗаявкаНаРасходованиеДС.ДополнительныеСвойства.АналитикаУчетаПоПартнерам;
	Запрос = Новый Запрос("ВЫБРАТЬ
	|	ВложенныйЗапрос.СводЗаявок КАК СводЗаявок,
	|	ВложенныйЗапрос.СуммаНаложенногоПлатежаОборотПоЗаявке + ВложенныйЗапрос.СуммаНаложенногоПлатежаОстаток КАК Сумма
	|ИЗ
	|	(ВЫБРАТЬ
	|		ВЫБОР
	|			КОГДА Логс_ВзаиморасчетыЗаВычетом.СводЗаявок <> Логс_ВзаиморасчетыЗаВычетом.КоррСводЗаявок
	|				ТОГДА Логс_ВзаиморасчетыЗаВычетом.КоррСводЗаявок
	|			ИНАЧЕ Логс_ВзаиморасчетыЗаВычетом.СводЗаявок
	|		КОНЕЦ КАК СводЗаявок,
	|		СУММА(Логс_ВзаиморасчетыЗаВычетом.СуммаНаложенногоПлатежа * ВЫБОР
	|				КОГДА Логс_ВзаиморасчетыЗаВычетом.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
	|					ТОГДА -1
	|				ИНАЧЕ 1
	|			КОНЕЦ) КАК СуммаНаложенногоПлатежаОборотПоЗаявке,
	|		0 КАК СуммаНаложенногоПлатежаОстаток
	|	ИЗ
	|		РегистрНакопления.Логс_ВзаиморасчетыЗаВычетом КАК Логс_ВзаиморасчетыЗаВычетом
	|	ГДЕ
	|		Логс_ВзаиморасчетыЗаВычетом.Период МЕЖДУ &ДатаНачала И &ДатаОкончания
	|		И Логс_ВзаиморасчетыЗаВычетом.АналитикаУчетаПоПартнерам = &АналитикаУчетаПоПартнерам
	|	
	|	СГРУППИРОВАТЬ ПО
	|		Логс_ВзаиморасчетыЗаВычетом.СводЗаявок,
	|		ВЫБОР
	|			КОГДА Логс_ВзаиморасчетыЗаВычетом.СводЗаявок <> Логс_ВзаиморасчетыЗаВычетом.КоррСводЗаявок
	|				ТОГДА Логс_ВзаиморасчетыЗаВычетом.КоррСводЗаявок
	|			ИНАЧЕ Логс_ВзаиморасчетыЗаВычетом.СводЗаявок
	|		КОНЕЦ
	|	
	|	ИМЕЮЩИЕ
	|		СУММА(Логс_ВзаиморасчетыЗаВычетом.СуммаНаложенногоПлатежа * ВЫБОР
	|				КОГДА Логс_ВзаиморасчетыЗаВычетом.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
	|					ТОГДА -1
	|				ИНАЧЕ 1
	|			КОНЕЦ) <> 0
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		Логс_ВзаиморасчетыЗаВычетомОстатки.СводЗаявок,
	|		0,
	|		Логс_ВзаиморасчетыЗаВычетомОстатки.СуммаНаложенногоПлатежаОстаток
	|	ИЗ
	|		РегистрНакопления.Логс_ВзаиморасчетыЗаВычетом.Остатки(&ДатаНачала, АналитикаУчетаПоПартнерам = &АналитикаУчетаПоПартнерам) КАК Логс_ВзаиморасчетыЗаВычетомОстатки
	|	ГДЕ
	|		Логс_ВзаиморасчетыЗаВычетомОстатки.СуммаНаложенногоПлатежаОстаток > 0) КАК ВложенныйЗапрос
	|ГДЕ
	|	ВложенныйЗапрос.СуммаНаложенногоПлатежаОборотПоЗаявке + ВложенныйЗапрос.СуммаНаложенногоПлатежаОстаток <> 0
	|
	|УПОРЯДОЧИТЬ ПО
	|	ВложенныйЗапрос.СводЗаявок.Дата");
	ДатаНачала = ЗаявкаНаРасходованиеДС.ДополнительныеСвойства.ДатаПоследнейЗаявки;
	
	Запрос.УстановитьПараметр("ДатаНачала", ДатаНачала + 1);
	Запрос.УстановитьПараметр("ДатаОкончания", ЗаявкаНаРасходованиеДС.Дата);
	Запрос.УстановитьПараметр("АналитикаУчетаПоПартнерам", АналитикаУчетаПоПартнерам);
	ТаблицаРезультат = Запрос.Выполнить().Выгрузить();
	Для каждого СтрокаРезультата Из ТаблицаРезультат Цикл
		НоваяСтрока = ЗаявкаНаРасходованиеДС.Логс_РаспределениеПоСводамЗаявокНаДоставку.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаРезультата);
	КонецЦикла;
	
	Если АналитикаУчетаПоПартнерам.Договор.Логс_ВидКлиентаCRM = Перечисления.Логс_ВидыКлиентовCRM.Принципал Тогда
		ШаблонНазначенияПлатежа = НСтр("ru='Наложенный платеж за вычетом агентского возн-ния по %1 по:'");
	Иначе
		ШаблонНазначенияПлатежа = НСтр("ru='Наложенный платеж за вычетом субагентского возн-ния по %1 по:'");
	КонецЕсли;
	ШаблонНазначенияПлатежаПоСводу = НСтр("ru=' отчет №%1 от %2'");
	ШаблонНазначенияПлатежаПоСводуДоплата = НСтр("ru=' (доплата) отчет №%1 от %2'");
	
	НазначениеПлатежа = СтрШаблон(ШаблонНазначенияПлатежа, АналитикаУчетаПоПартнерам.Договор.НаименованиеДляПечати);
	
	МассивСводов = ОбщегоНазначенияКлиентСервер.СвернутьМассив(ТаблицаРезультат.ВыгрузитьКолонку("СводЗаявок"));
	
	Для каждого ТекущийСвод Из МассивСводов Цикл
		Отбор = Новый Структура("СводЗаявок", ТекущийСвод);
		Если ПризнакДоплатПоСводам.Получить(ТекущийСвод) <> Неопределено И ПризнакДоплатПоСводам.Получить(ТекущийСвод) Тогда
			ТекущийШаблонПоСводу = ШаблонНазначенияПлатежаПоСводуДоплата;
		ИНаче
			ТекущийШаблонПоСводу = ШаблонНазначенияПлатежаПоСводу;
		КонецЕсли;
		
		МассивСтрок = ТаблицаРезультат.НайтиСтроки(Отбор);
		Для каждого СтрокаТаблицы Из МассивСтрок Цикл
			Если СтрокаТаблицы.Сумма > 0 Тогда
				НазначениеПлатежа = НазначениеПлатежа + СтрШаблон(ТекущийШаблонПоСводу, СтрокаТаблицы.СводЗаявок.Номер, Формат(СтрокаТаблицы.СводЗаявок.Дата, "ДФ=dd.MM.yyyy"));
			Иначе
				НазначениеПлатежа = НазначениеПлатежа + СтрШаблон(НСтр("ru=', кор-ка по отчету %1 от %2'"), СтрокаТаблицы.СводЗаявок.Номер, СтрокаТаблицы.СводЗаявок.Дата);
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
	ЗаявкаНаРасходованиеДС.НазначениеПлатежа = НазначениеПлатежа;
	
КонецПроцедуры
 
Функция СоздатьЗаявкиНаРасходованиеДенежныхСредств20(Параметры, СписокОшибок = Неопределено)
	Перем КэшированныеЗначения;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("Период", КонецДня(Параметры.Период));
	Запрос.УстановитьПараметр("СрокиПеречисленияНП", Параметры.СрокиПеречисленияНП);
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Логс_ЗаявкиНаРасход100Остатки.АналитикаУчетаПоПартнерам КАК АналитикаУчетаПоПартнерам,
	|	Логс_ЗаявкиНаРасход100Остатки.СводЗаявок КАК СводЗаявок,
	|	Логс_ЗаявкиНаРасход100Остатки.Валюта КАК Валюта,
	|	Логс_ЗаявкиНаРасход100Остатки.СуммаОстаток КАК Сумма
	|ПОМЕСТИТЬ РасчетыПоНаложеннымПлатежамОстатки
	|ИЗ
	|	РегистрНакопления.Логс_ЗаявкиНаРасход100.Остатки(
	|			,
	|			СводЗаявок.ФормаОплаты = ЗНАЧЕНИЕ(Перечисление.Логс_ФормыОплатыУслугАгенту.Оплата100)
	|				И (АналитикаУчетаПоПартнерам.Договор.Логс_СрокПеречисленияНП В (&СрокиПеречисленияНП)
	|					ИЛИ АналитикаУчетаПоПартнерам.Договор.Логс_СрокПеречисленияНПРег В (&СрокиПеречисленияНП))
	|				И НЕ СводЗаявок.Организация.Логс_НеФормироватьРеглДокументы
	|				И СводЗаявок.Дата <= &Период
	|				И СводЗаявок.ВидКлиента <> ЗНАЧЕНИЕ(Перечисление.Логс_ВидыКлиентовCRM.СКС)
	|				И &ТекстОтбораПоПартнеру) КАК Логс_ЗаявкиНаРасход100Остатки
	|ГДЕ
	|	Логс_ЗаявкиНаРасход100Остатки.СуммаОстаток <> 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВложенныйЗапрос.АналитикаУчетаПоПартнерам КАК АналитикаУчетаПоПартнерам,
	|	Аналитика.Организация КАК Организация,
	|	Аналитика.Партнер КАК Партнер,
	|	Аналитика.Контрагент КАК Контрагент,
	|	Аналитика.Договор КАК Договор
	|ПОМЕСТИТЬ ИспользуемаяАналитика
	|ИЗ
	|	(ВЫБРАТЬ
	|		РасчетыПоНаложеннымПлатежам.АналитикаУчетаПоПартнерам КАК АналитикаУчетаПоПартнерам
	|	ИЗ
	|		РасчетыПоНаложеннымПлатежамОстатки КАК РасчетыПоНаложеннымПлатежам
	|	
	|	СГРУППИРОВАТЬ ПО
	|		РасчетыПоНаложеннымПлатежам.АналитикаУчетаПоПартнерам
	|	
	|	ИМЕЮЩИЕ
	|		СУММА(РасчетыПоНаложеннымПлатежам.Сумма) <> 0) КАК ВложенныйЗапрос
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.АналитикаУчетаПоПартнерам КАК Аналитика
	|		ПО ВложенныйЗапрос.АналитикаУчетаПоПартнерам = Аналитика.КлючАналитики
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	АналитикаУчетаПоПартнерам
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	РасчетыПоНаложеннымПлатежам.СводЗаявок КАК СводЗаявок,
	|	РасчетыПоНаложеннымПлатежам.Валюта КАК Валюта,
	|	Аналитика.Организация КАК Организация,
	|	Аналитика.Партнер КАК Партнер,
	|	Аналитика.Контрагент КАК Контрагент,
	|	Аналитика.Договор КАК Договор,
	|	РасчетыПоНаложеннымПлатежам.Сумма КАК Сумма
	|ПОМЕСТИТЬ РасчетыПоНаложеннымПлатежам
	|ИЗ
	|	РасчетыПоНаложеннымПлатежамОстатки КАК РасчетыПоНаложеннымПлатежам
	|		ЛЕВОЕ СОЕДИНЕНИЕ ИспользуемаяАналитика КАК Аналитика
	|		ПО РасчетыПоНаложеннымПлатежам.АналитикаУчетаПоПартнерам = Аналитика.АналитикаУчетаПоПартнерам
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	СводЗаявок,
	|	Организация
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ РасчетыПоНаложеннымПлатежамОстатки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ИспользуемаяАналитика
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Кассы.Владелец КАК Организация,
	|	МАКСИМУМ(Кассы.Ссылка) КАК Ссылка
	|ПОМЕСТИТЬ Кассы
	|ИЗ
	|	Справочник.Кассы КАК Кассы
	|ГДЕ
	|	Кассы.Владелец В
	|			(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|				РасчетыПоНаложеннымПлатежам.Организация
	|			ИЗ
	|				РасчетыПоНаложеннымПлатежам)
	|	И НЕ Кассы.ПометкаУдаления
	|
	|СГРУППИРОВАТЬ ПО
	|	Кассы.Владелец
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Организация
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	РаспределениеПоСводамЗаявок.СводЗаявок КАК СводЗаявок
	|ПОМЕСТИТЬ СуществующиеЗаявкиНаРасходованиеДС
	|ИЗ
	|	Документ.ЗаявкаНаРасходованиеДенежныхСредств.Логс_РаспределениеПоСводамЗаявокНаДоставку КАК РаспределениеПоСводамЗаявок
	|ГДЕ
	|	РаспределениеПоСводамЗаявок.СводЗаявок В
	|			(ВЫБРАТЬ
	|				РасчетыПоНаложеннымПлатежам.СводЗаявок
	|			ИЗ
	|				РасчетыПоНаложеннымПлатежам)
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	РаспределениеПоСводамЗаявок.СводЗаявок
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДокСводЗаявок.Дата КАК ДатаСвода,
	|	ДокСводЗаявок.Номер КАК НомерСвода,
	|	ДокСводЗаявок.ФормаОплаты КАК ФормаОплаты,
	|	РасчетыПоНаложеннымПлатежам.Организация КАК Организация,
	|	РасчетыПоНаложеннымПлатежам.Партнер КАК Партнер,
	|	РасчетыПоНаложеннымПлатежам.Контрагент КАК Контрагент,
	|	РасчетыПоНаложеннымПлатежам.Договор КАК Договор,
	|	ДоговорыКонтрагентов.НаименованиеДляПечати КАК НаименованиеДоговора,
	|	ДоговорыКонтрагентов.Логс_ВидКлиентаCRM КАК ВидКлиента,
	|	ВЫБОР
	|		КОГДА ДокСводЗаявок.РегиональныйСвод
	|			ТОГДА ДоговорыКонтрагентов.Логс_СрокПеречисленияНПРег
	|		ИНАЧЕ ДоговорыКонтрагентов.Логс_СрокПеречисленияНП
	|	КОНЕЦ КАК СрокПеречисленияНП,
	|	ВЫБОР
	|		КОГДА ДокСводЗаявок.РегиональныйСвод
	|			ТОГДА ДоговорыКонтрагентов.Логс_ПериодФормированияСводовАгентаРег
	|		ИНАЧЕ ДоговорыКонтрагентов.Логс_ПериодФормированияСводовАгента
	|	КОНЕЦ КАК ПериодФормированияОтчетов,
	|	ВЫБОР
	|		КОГДА ДоговорыКонтрагентов.Ссылка ЕСТЬ NULL
	|				ИЛИ ДоговорыКонтрагентов.Логс_ПриоритетныйСчетОплаты = ЗНАЧЕНИЕ(Справочник.БанковскиеСчетаОрганизаций.ПустаяСсылка)
	|			ТОГДА Организации.Логс_ОсновнойБанковскийСчет
	|		ИНАЧЕ ДоговорыКонтрагентов.Логс_ПриоритетныйСчетОплаты
	|	КОНЕЦ КАК БанковскийСчет,
	|	ДоговорыКонтрагентов.БанковскийСчетКонтрагента КАК БанковскийСчетКонтрагента,
	|	ДоговорыКонтрагентов.Подразделение КАК Подразделение,
	|	ДоговорыКонтрагентов.СтатьяДвиженияДенежныхСредств КАК СтатьяДвиженияДенежныхСредств,
	|	ДоговорыКонтрагентов.СтавкаНДС КАК СтавкаНДС,
	|	Кассы.Ссылка КАК Касса,
	|	РасчетыПоНаложеннымПлатежам.СводЗаявок КАК СводЗаявок,
	|	РасчетыПоНаложеннымПлатежам.Валюта КАК Валюта,
	|	РасчетыПоНаложеннымПлатежам.Сумма КАК Сумма,
	|	НЕ СуществующиеЗаявкиНаРасходованиеДС.СводЗаявок ЕСТЬ NULL КАК Доплата
	|
	|ПОМЕСТИТЬ ВТ_ДанныеДляЗаявок
	|ИЗ
	|	РасчетыПоНаложеннымПлатежам КАК РасчетыПоНаложеннымПлатежам
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
	|		ПО РасчетыПоНаложеннымПлатежам.Договор = ДоговорыКонтрагентов.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Организации КАК Организации
	|		ПО РасчетыПоНаложеннымПлатежам.Организация = Организации.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.Логс_СводЗаявокНаДоставку КАК ДокСводЗаявок
	|		ПО РасчетыПоНаложеннымПлатежам.СводЗаявок = ДокСводЗаявок.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Кассы КАК Кассы
	|		ПО РасчетыПоНаложеннымПлатежам.Организация = Кассы.Организация
	|		ЛЕВОЕ СОЕДИНЕНИЕ СуществующиеЗаявкиНаРасходованиеДС КАК СуществующиеЗаявкиНаРасходованиеДС
	|		ПО РасчетыПоНаложеннымПлатежам.СводЗаявок = СуществующиеЗаявкиНаРасходованиеДС.СводЗаявок
	|;
	|Выбрать Различные
	|	ВТ_ДанныеДляЗаявок.ДатаСвода КАК ДатаСвода,  
	|	ДатаВремя(1,1,1,0,0,0) КАК ДатаПлатежа,  
	|	ВТ_ДанныеДляЗаявок.СрокПеречисленияНП КАК СрокПеречисленияНП  
	|Из ВТ_ДанныеДляЗаявок как ВТ_ДанныеДляЗаявок
	|"; 
	
	Если Параметры.Свойство("Партнер") Тогда
		Запрос.УстановитьПараметр("Партнер", Параметры.Партнер);
		ТекстОтбораПоПартнеру = "АналитикаУчетаПоПартнерам.Партнер = &Партнер";
	Иначе
		ТекстОтбораПоПартнеру = "ИСТИНА";
	КонецЕсли;
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ТекстОтбораПоПартнеру", ТекстОтбораПоПартнеру);
	
	ТаблицаСроковПеречисленияНП = Запрос.Выполнить().Выгрузить();
	Для Каждого Строка из ТаблицаСроковПеречисленияНП Цикл
		Строка.ДатаПлатежа = Логс_ДатыПовтИсп.РассчитатьСдвигДаты(Строка.ДатаСвода,  Строка.СрокПеречисленияНП);
	КонецЦикла;
	
	Запрос.УстановитьПараметр("СрокиПлатежей", ТаблицаСроковПеречисленияНП);
	Запрос.Текст = "
	|Выбрать 
	|	СрокиПлатежей.ДатаСвода КАК ДатаСвода,  
	|	СрокиПлатежей.ДатаПлатежа КАК ДатаПлатежа,  
	|	СрокиПлатежей.СрокПеречисленияНП КАК СрокПеречисленияНП  
	|Поместить ВТ_СрокиПлатежей
	|Из &СрокиПлатежей как СрокиПлатежей
	|;
	|ВЫБРАТЬ
	|	ВТ_ДанныеДляЗаявок.ДатаСвода КАК ДатаСвода,
	|	ВТ_ДанныеДляЗаявок.НомерСвода КАК НомерСвода,
	|	ВТ_ДанныеДляЗаявок.ФормаОплаты КАК ФормаОплаты,
	|	ВТ_ДанныеДляЗаявок.Организация КАК Организация,
	|	ВТ_ДанныеДляЗаявок.Партнер КАК Партнер,
	|	ВТ_ДанныеДляЗаявок.Контрагент КАК Контрагент,
	|	ВТ_ДанныеДляЗаявок.Договор КАК Договор,
	|	ВТ_ДанныеДляЗаявок.НаименованиеДоговора КАК НаименованиеДоговора,
	|	ВТ_ДанныеДляЗаявок.ВидКлиента КАК ВидКлиента,
	|	ВТ_ДанныеДляЗаявок.СрокПеречисленияНП КАК СрокПеречисленияНП,
	|	ВТ_ДанныеДляЗаявок.ПериодФормированияОтчетов КАК ПериодФормированияОтчетов,
	|	ВТ_ДанныеДляЗаявок.БанковскийСчет КАК БанковскийСчет,
	|	ВТ_ДанныеДляЗаявок.БанковскийСчетКонтрагента КАК БанковскийСчетКонтрагента,
	|	ВТ_ДанныеДляЗаявок.Подразделение КАК Подразделение,
	|	ВТ_ДанныеДляЗаявок.СтатьяДвиженияДенежныхСредств КАК СтатьяДвиженияДенежныхСредств,
	|	ВТ_ДанныеДляЗаявок.СтавкаНДС КАК СтавкаНДС,
	|	ВТ_ДанныеДляЗаявок.Касса КАК Касса,
	|	ВТ_ДанныеДляЗаявок.СводЗаявок КАК СводЗаявок,
	|	ВТ_ДанныеДляЗаявок.Валюта КАК Валюта,
	|	ВТ_ДанныеДляЗаявок.Сумма КАК Сумма,
	|	ВТ_ДанныеДляЗаявок.Доплата КАК Доплата,
	|	ВТ_СрокиПлатежей.ДатаПлатежа КАК ДатаПлатежа,  
	|	ВЫБОР
	|		КОГДА ВТ_ДанныеДляЗаявок.Договор.Логс_ГруппироватьСводыВЗаявкахНаОплату
	|			ТОГДА ВТ_СрокиПлатежей.ДатаПлатежа
	|		ИНАЧЕ ВТ_ДанныеДляЗаявок.СводЗаявок
	|	КОНЕЦ КАК СпособГруппировкиЗаявок,
	|	ОбъектыРасчетов.Ссылка КАК ОбъектРасчетов
	|ИЗ
	|	ВТ_ДанныеДляЗаявок КАК ВТ_ДанныеДляЗаявок
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_СрокиПлатежей КАК ВТ_СрокиПлатежей
	|		ПО ВТ_ДанныеДляЗаявок.ДатаСвода = ВТ_СрокиПлатежей.ДатаСвода
	|		и ВТ_ДанныеДляЗаявок.СрокПеречисленияНП = ВТ_СрокиПлатежей.СрокПеречисленияНП
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ОбъектыРасчетов КАК ОбъектыРасчетов
	|		ПО ВТ_ДанныеДляЗаявок.Договор = ОбъектыРасчетов.Объект
	|		И ОбъектыРасчетов.ТипРасчетов = Значение(Перечисление.ТипыРасчетовСПартнерами.РасчетыСПоставщиком)
	|УПОРЯДОЧИТЬ ПО
	|	ДатаСвода,
	|	Сумма
	|ИТОГИ ПО
	|	Организация,
	|	Партнер,
	|	Контрагент, СпособГруппировкиЗаявок,
	|	Договор, 
	|	Валюта";
	
	
	ПриоритетОплаты = Справочники.ПриоритетыОплаты.ПолучитьПриоритетПоУмолчанию(Неопределено);
	ПроизводственныйКалендарь = КалендарныеГрафики.ОсновнойПроизводственныйКалендарь();
							
	СтруктураПересчетаСуммы = Новый Структура;
	СтруктураПересчетаСуммы.Вставить("ЦенаВключаетНДС", Истина);
	
	СтруктураДействий = Новый Структура;
	СтруктураДействий.Вставить("ПересчитатьСуммуНДС", СтруктураПересчетаСуммы);
	
	ТекущаяДата = ТекущаяДатаСеанса();
	ДатаДокумента = ?(НачалоДня(ТекущаяДата) = НачалоДня(Параметры.Период), ТекущаяДата, КонецДня(Параметры.Период));
	
	ВыборкаОрганизации = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаОрганизации.Следующий() Цикл
		ВыборкаПартнеры = ВыборкаОрганизации.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаПартнеры.Следующий() Цикл
			ВыборкаКонтрагенты = ВыборкаПартнеры.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока ВыборкаКонтрагенты.Следующий() Цикл
				ВыборкаДата = ВыборкаКонтрагенты.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам); //СпособГруппировкиЗаявок
				Пока ВыборкаДата.Следующий() Цикл //СпособГруппировкиЗаявок  
					ВыборкаДоговоры = ВыборкаДата.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
					Пока ВыборкаДоговоры.Следующий() Цикл
						ВыборкаВалюты = ВыборкаДоговоры.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
						Пока ВыборкаВалюты.Следующий() Цикл
							
							ЗаявкаНаРасходованиеДС = Неопределено;
							
							Выборка = ВыборкаВалюты.Выбрать();
							Пока Выборка.Следующий() Цикл    //проходим выборку сводов, по окончанию запишем удачный документ
								
								Если ЗаявкаНаРасходованиеДС = Неопределено Тогда   //заполним новый документ (заявка на расходование ДС)
								
									ЗаявкаНаРасходованиеДС = Документы.ЗаявкаНаРасходованиеДенежныхСредств.СоздатьДокумент();
									ЗаявкаНаРасходованиеДС.Дата = ДатаДокумента;
									ЗаявкаНаРасходованиеДС.Организация = Выборка.Организация;
									ЗаявкаНаРасходованиеДС.Статус = Перечисления.СтатусыЗаявокНаРасходованиеДенежныхСредств.НеСогласована;
									ЗаявкаНаРасходованиеДС.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ОплатаПоставщику;
									ЗаявкаНаРасходованиеДС.Валюта = Выборка.Валюта;
									ЗаявкаНаРасходованиеДС.ФормаОплатыНаличная = (Выборка.Организация = Логс_ДополнительныеПроцедурыИФункцииПовтИсп.ОрганизацияЛогсис());
									ЗаявкаНаРасходованиеДС.ФормаОплатыБезналичная = Не ЗаявкаНаРасходованиеДС.ФормаОплатыНаличная;
									ЗаявкаНаРасходованиеДС.БанковскийСчет = Выборка.БанковскийСчет;
									ЗаявкаНаРасходованиеДС.Касса = Выборка.Касса;
									ЗаявкаНаРасходованиеДС.Контрагент = Выборка.Контрагент;
									ЗаявкаНаРасходованиеДС.БанковскийСчетКонтрагента = Выборка.БанковскийСчетКонтрагента;
									ЗаявкаНаРасходованиеДС.Подразделение = Выборка.Подразделение;
									ЗаявкаНаРасходованиеДС.КтоЗаявил = Пользователи.ТекущийПользователь();
									ЗаявкаНаРасходованиеДС.Автор = ЗаявкаНаРасходованиеДС.КтоЗаявил;
									ЗаявкаНаРасходованиеДС.СтатьяДвиженияДенежныхСредств = Выборка.СтатьяДвиженияДенежныхСредств;
									ЗаявкаНаРасходованиеДС.ПланированиеСуммы = Перечисления.СпособыПланированияОплатыЗаявок.ВВалютеПлатежа;
									ЗаявкаНаРасходованиеДС.ВариантОплаты = Перечисления.ВариантыКонтроляОплатыПоставщику.ПредоплатаДоПоступления;
									ЗаявкаНаРасходованиеДС.ВидПеречисленияВБюджет = Перечисления.ВидыПеречисленийВБюджет.ИнойПлатеж;
									ЗаявкаНаРасходованиеДС.ПриоритетОплаты = ПриоритетОплаты;
									ЗаявкаНаРасходованиеДС.ДатаПлатежа = Выборка.ДатаПлатежа;
									ЗаявкаНаРасходованиеДС.ЖелательнаяДатаПлатежа = Выборка.ДатаПлатежа;
									
									Если Выборка.ФормаОплаты = Перечисления.Логс_ФормыОплатыУслугАгенту.Оплата100 Тогда
										ШаблонНазначенияПлатежа = ?(Выборка.Доплата,
											НСтр("ru='Наложенный платеж (доплата) по %1'"),
											НСтр("ru='Наложенный платеж по %1'"));
									ИначеЕсли Выборка.ВидКлиента = Перечисления.Логс_ВидыКлиентовCRM.Принципал Тогда
										ШаблонНазначенияПлатежа = ?(Выборка.Доплата,
											НСтр("ru='Наложенный платеж (доплата) за вычетом агентского возн-ния по %1'"),
											НСтр("ru='Наложенный платеж за вычетом агентского возн-ния по %1'"));
									Иначе
										ШаблонНазначенияПлатежа = ?(Выборка.Доплата,
											НСтр("ru='Наложенный платеж (доплата) за вычетом субагентского возн-ния по %1'"),
											НСтр("ru='Наложенный платеж за вычетом субагентского возн-ния по %1'"));
									КонецЕсли; 
									
									НазначениеПлатежа = СтрШаблон(ШаблонНазначенияПлатежа, Выборка.НаименованиеДоговора);
									НазначениеПлатежаКорректировка = "";
									
									//ТЧ
									СтрокаПлатежа = ЗаявкаНаРасходованиеДС.РасшифровкаПлатежа.Добавить();
									СтрокаПлатежа.Партнер = Выборка.Партнер;
									СтрокаПлатежа.ОбъектРасчетов = Выборка.ОбъектРасчетов;
									СтрокаПлатежа.Сумма = 0;
									СтрокаПлатежа.ВалютаВзаиморасчетов = Выборка.Валюта;
									СтрокаПлатежа.СтатьяДвиженияДенежныхСредств = Выборка.СтатьяДвиженияДенежныхСредств; 
									СтрокаПлатежа.Организация = Выборка.Организация;
									СтрокаПлатежа.СтавкаНДС = Выборка.СтавкаНДС;
									
									СтрокаБанковскогоСчета = ЗаявкаНаРасходованиеДС.РаспределениеПоСчетам.Добавить();
									СтрокаБанковскогоСчета.БанковскийСчетКасса = ?(ЗаявкаНаРасходованиеДС.ФормаОплатыНаличная, Выборка.Касса, Выборка.БанковскийСчет);
									СтрокаБанковскогоСчета.Сумма = 0;
									СтрокаБанковскогоСчета.ДатаПлатежа = ЗаявкаНаРасходованиеДС.ДатаПлатежа;
									
									СуммаВсего = 0;
									
								КонецЕсли; 
								
								СтрокаРаспределения = ЗаявкаНаРасходованиеДС.Логс_РаспределениеПоСводамЗаявокНаДоставку.Добавить();
								СтрокаРаспределения.СводЗаявок = Выборка.СводЗаявок;
								СтрокаРаспределения.Сумма = Выборка.Сумма;
								
								СуммаВсего = СуммаВсего + СтрокаРаспределения.Сумма;
								
								Если СтрокаРаспределения.Сумма >= 0 Тогда
									НазначениеПлатежаКорректировка = НазначениеПлатежаКорректировка +
										СтрШаблон(НСтр("ru=', по отчету %1 от %2'"),
											Выборка.НомерСвода, Формат(Выборка.ДатаСвода, "ДФ='dd.MM.yy""г.""'")
										);
								Иначе
									ДанныеСвода = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(СтрокаРаспределения.СводЗаявок, "Номер,Дата");
									НазначениеПлатежаКорректировка = НазначениеПлатежаКорректировка +
										СтрШаблон(НСтр("ru=', кор-ка по отчету %1 от %2'"),
											Выборка.НомерСвода, Формат(Выборка.ДатаСвода, "ДФ='dd.MM.yy""г.""'")
										);
								КонецЕсли; 
								
							КонецЦикла; //своды	(конец выборки)
							
							Если СуммаВсего > 0 Тогда  //запись заявки на расходование
									
								Если НазначениеПлатежаКорректировка <> "" Тогда
									НазначениеПлатежа = НазначениеПлатежа + НазначениеПлатежаКорректировка;
								КонецЕсли; 	
								
								ЗаявкаНаРасходованиеДС.НазначениеПлатежа = НазначениеПлатежа;
								ЗаявкаНаРасходованиеДС.СуммаДокумента = СуммаВсего;
								
								//СтрокаПлатежа = ЗаявкаНаРасходованиеДС.РасшифровкаПлатежа.Добавить();
								СтрокаПлатежа.Сумма = СуммаВсего;   
								//++ Ким Виктор 10.12.2025
								//Фикс после обновления
								//ОбработкаТабличнойЧастиСервер.ОбработатьСтрокуТЧ(СтрокаПлатежа, СтруктураДействий, КэшированныеЗначения);
								ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьСтрокуТЧ(СтрокаПлатежа, СтруктураДействий, КэшированныеЗначения);
								//-- Ким Виктор 10.12.2025
											
								//СтрокаБанковскогоСчета = ЗаявкаНаРасходованиеДС.РаспределениеПоСчетам.Добавить();
								СтрокаБанковскогоСчета.Сумма = СуммаВсего;
								
								ЗаявкаНаРасходованиеДС.УстановитьНовыйНомер();
								ЗаявкаНаРасходованиеДС.Записать(РежимЗаписиДокумента.Запись);
								
								Попытка
									ЗаявкаНаРасходованиеДС.Записать(РежимЗаписиДокумента.Проведение);
								Исключение
									ТекстСообщения = СтрШаблон(
										НСтр("ru='Произошла ошибка при записи заявки на расходование денежных средств по своду заявок на доставку № %1 от %2: %3'"),
										Выборка.НомерСвода, Формат(Выборка.ДатаСвода, "ДФ=dd.MM.yyyy"),
										КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
									ЗаписьЖурналаРегистрации("УУ Создание регламентированных документов. Создание заявок на расходование ДС",
										УровеньЖурналаРегистрации.Ошибка,,, ТекстСообщения);
									БылиОшибки = Истина;
								КонецПопытки;
								
								ЗаявкаНаРасходованиеДС = Неопределено;
								
							КонецЕсли; 
								
						
						КонецЦикла; // Валюты
					КонецЦикла; // Договоры
				КонецЦикла; // Дата
			КонецЦикла; // Контрагенты
		КонецЦикла; // Партнеры
	КонецЦикла; // Организации
	
	// формируем заявки на расход ДС на возврат переплаты
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Период", КонецДня(Параметры.Период));
	Запрос.УстановитьПараметр("СрокиПеречисленияНП", Параметры.СрокиПеречисленияНП);
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Логс_ВзаиморасчетыПоУслугам100.АналитикаУчетаПоПартнерам КАК АналитикаУчетаПоПартнерам,
	|	Логс_ВзаиморасчетыПоУслугам100.Счет.Дата КАК Дата,
	|	Логс_ВзаиморасчетыПоУслугам100.Счет.Номер КАК Номер,
	|	Логс_ВзаиморасчетыПоУслугам100.Счет КАК Счет,
	|	Логс_ВзаиморасчетыПоУслугам100.Валюта КАК Валюта,
	|	Логс_ВзаиморасчетыПоУслугам100.ПредоплатаОстаток КАК Сумма
	|ПОМЕСТИТЬ РасчетыПоНаложеннымПлатежамОстатки
	|ИЗ
	|	РегистрНакопления.Логс_ВзаиморасчетыПоУслугам100.Остатки(
	|			,
	|			(АналитикаУчетаПоПартнерам.Договор.Логс_СрокПеречисленияНП В (&СрокиПеречисленияНП)
	|					ИЛИ АналитикаУчетаПоПартнерам.Договор.Логс_СрокПеречисленияНПРег В (&СрокиПеречисленияНП))
	|				И НЕ АналитикаУчетаПоПартнерам.Организация.Логс_НеФормироватьРеглДокументы
	|				И Счет.Дата <= &Период
	|				И Счет.Договор.Логс_ВидКлиентаCRM <> ЗНАЧЕНИЕ(Перечисление.Логс_ВидыКлиентовCRM.СКС)
	|				И &ТекстОтбораПоПартнеру) КАК Логс_ВзаиморасчетыПоУслугам100
	|ГДЕ
	|	Логс_ВзаиморасчетыПоУслугам100.ПредоплатаОстаток <> 0
	|;
