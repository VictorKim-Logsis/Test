Функция УстановитьИнформациюОбОшибкеВОтчетеОСозданныхДокументахДвиженияДС(Область, ДокументСсылка, СписокОшибок, НомерКолонки)
	
	ОписаниеОшибки = СписокОшибок[ДокументСсылка];
	
	Если ОписаниеОшибки = Неопределено Тогда
		Область.Область(1, НомерКолонки, 1, НомерКолонки).Картинка = Неопределено;
		Область.Область(1, НомерКолонки, 1, НомерКолонки).Гиперссылка = Ложь;
	Иначе
		Область.Параметры.ОписаниеОшибки = ОписаниеОшибки;
	КонецЕсли; 
	
КонецФункции 

Функция ОрганизацияИспользуетНДС(Организация, КешированныеЗначения)
	ИспользуетсяНДС = КешированныеЗначения[Организация];
	
	Если ИспользуетсяНДС <> Неопределено Тогда
		Возврат ИспользуетсяНДС;
	КонецЕсли; 
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	НастройкиУчетаУСН.ПрименяетсяУСНДоходыМинусРасходы КАК ПрименяетсяУСН
	|ИЗ
	|	РегистрСведений.НастройкиУчетаУСН.СрезПоследних(, Организация = &Организация) КАК НастройкиУчетаУСН");
	Запрос.УстановитьПараметр("Организация", Организация);
	
	Выборка = Запрос.Выполнить().Выбрать();
	ИспользуетсяНДС = ?(Выборка.Следующий(),
		Не Выборка.ПрименяетсяУСН,
		Истина);
		
	КешированныеЗначения.Вставить(Организация, ИспользуетсяНДС);
	
	Возврат ИспользуетсяНДС;
КонецФункции

Процедура СоздатьДокументыСчетФактурыВыданный(Параметры, ТаблицаСозданныхДокументов, СписокОшибок)
	
	ДокументыДляСчетФактур = ПолучитьДокументыДляСчетФактурИзТаблицыСозданныхДокументов(ТаблицаСозданныхДокументов);
	
	КешированныеЗначения = Новый Соответствие;
	
	ОрионОрганизация = Справочники.Организации.НайтиПоРеквизиту("ИНН", "9728051543");
	
	Для каждого Документ Из ДокументыДляСчетФактур Цикл
		
		//#TODO Костыль для УСН Орион - НДС нужен.
		Если Документ.Организация = ОрионОрганизация Тогда
			
		ИначеЕсли Не ОрганизацияИспользуетНДС(Документ.Организация, КешированныеЗначения) Тогда
			Продолжить;
		КонецЕсли; 
		
		Если ЗначениеЗаполнено(Документ.СчетФактура) Тогда
			
			Если Параметры.ТолькоСоздаватьНовые Тогда
				Продолжить;
			КонецЕсли; 			
			
			СчетФактура = Документ.СчетФактура.ПолучитьОбъект();
			СчетФактура.ДокументыОснования.Очистить();
			
		Иначе
			
			СчетФактура = Документы.СчетФактураВыданный.СоздатьДокумент();
			СчетФактура.Дата = Документ.Дата;
			СчетФактура.Номер = Документ.Номер;
			
		КонецЕсли; 
		
		ДанныеЗаполнения = Новый Структура;
		ДанныеЗаполнения.Вставить("ДокументОснование", Документ.Ссылка);
		ДанныеЗаполнения.Вставить("Исправление", Ложь);
		ДанныеЗаполнения.Вставить("Контрагент", Документ.Контрагент);
		ДанныеЗаполнения.Вставить("Корректировочный", Ложь);
		ДанныеЗаполнения.Вставить("Организация", Документ.Организация);
		
		СчетФактура.Заполнить(ДанныеЗаполнения);
		
		Если СчетФактура.Ссылка.Пустая() Тогда
			СчетФактура.Записать(РежимЗаписиДокумента.Запись);
		КонецЕсли; 
		
		Попытка
			СчетФактура.Записать(РежимЗаписиДокумента.Проведение);
		Исключение
			ОписаниеОшибки = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
			ТекстСообщения = СтрШаблон(
				НСтр("ru='Произошла ошибка при записи счет-фактуры № %1 от %2: %3'"),
				СчетФактура.Номер, Формат(СчетФактура.Дата, "ДФ=dd.MM.yyyy"),
				ОписаниеОшибки);
			ЗаписьЖурналаРегистрации("УУ Создание регламентированных документов. Создание счет-фактуры",
				УровеньЖурналаРегистрации.Ошибка,,, ТекстСообщения);
			СписокОшибок.Вставить(СчетФактура.Ссылка, ОписаниеОшибки);
		КонецПопытки;
		
		Документ.СчетФактура = СчетФактура.Ссылка;
		
	КонецЦикла;
	
КонецПроцедуры 

Функция СформироватьОтчетОСозданныхДокументахДвиженияДС(Параметры, СозданныеДокументы, СписокОшибок)
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	
	Макет = ПолучитьМакет("ОтчетОСозданныхДокументахДвиженияДС");
	
	Область = Макет.ПолучитьОбласть("Заголовок");
	Область.Параметры.ДатаФормирования = Формат(Параметры.ДатаФормирования, "ДФ=dd.MM.yyyy");
	Область.Параметры.ПредставлениеПериодаСводов = ПредставлениеПериода(
		НачалоДня(Параметры.НачалоПериода), КонецДня(Параметры.КонецПериода), "ФП=Истина");  
	ТабличныйДокумент.Вывести(Область);
	
	ОбластьПартнер     = Макет.ПолучитьОбласть("Партнер");
	ОбластьСводыЗаявок = Макет.ПолучитьОбласть("СводыЗаявок");
	ОбластьРазделитель = Макет.ПолучитьОбласть("Разделитель");
	
	Для каждого СтрокаТаблицы Из СозданныеДокументы Цикл
		
		ОбластьПартнер.Параметры.Партнер = СтрокаТаблицы.Партнер;
		ОбластьПартнер.Параметры.ПредставлениеПартнера = СтрШаблон(НСтр("ru='%1; %2'"),
			СтрокаТаблицы.Партнер, СтрокаТаблицы.Договор);
		ТабличныйДокумент.Вывести(ОбластьПартнер, 1);
		
		//ОбластьСводыЗаявок.Параметры.КоличествоСводов = СписокСводов.Количество();
		//ОбластьСводыЗаявок.Параметры.СписокСводов = СписокСводов;
		//ТабличныйДокумент.Вывести(ОбластьСводыЗаявок, 1);
		
		ТабличныйДокумент.Вывести(ОбластьРазделитель, 1);
		
		Для каждого СтрокаПоступления Из СтрокаТаблицы.ДокументыПриемаНаКомиссию Цикл
			
			Область = Макет.ПолучитьОбласть("ПриобретениеТоваровУслуг");
			Область.Параметры.ПриобретениеТоваровУслуг = СтрокаПоступления.Ссылка;
			УстановитьИнформациюОбОшибкеВОтчетеОСозданныхДокументахДвиженияДС(Область, СтрокаПоступления.Ссылка, СписокОшибок, 1);
			ТабличныйДокумент.Вывести(Область, 2);
			
			Для каждого ДокументРеализации Из СтрокаПоступления.ДокументыРеализации Цикл
				Область = Макет.ПолучитьОбласть("РеализацияТоваровУслуг");
				Область.Параметры.РеализацияТоваровУслуг = ДокументРеализации;
				УстановитьИнформациюОбОшибкеВОтчетеОСозданныхДокументахДвиженияДС(Область, ДокументРеализации, СписокОшибок, 2);
				ТабличныйДокумент.Вывести(Область, 2);
			КонецЦикла;
			
		КонецЦикла;
		
		Для каждого ОтчетКомитенту Из СтрокаТаблицы.ДокументыОтчетовКомитентам Цикл
			Область = Макет.ПолучитьОбласть("ОтчетКомитенту");
			Область.Параметры.ОтчетКомитенту = ОтчетКомитенту.Ссылка;
			УстановитьИнформациюОбОшибкеВОтчетеОСозданныхДокументахДвиженияДС(Область, ОтчетКомитенту.Ссылка, СписокОшибок, 2);
			ТабличныйДокумент.Вывести(Область, 2);
			
			Если ЗначениеЗаполнено(ОтчетКомитенту.СчетФактура) Тогда
				Область = Макет.ПолучитьОбласть("СчетФактураВыданный");
				Область.Параметры.СчетФактураВыданный = ОтчетКомитенту.СчетФактура;
				УстановитьИнформациюОбОшибкеВОтчетеОСозданныхДокументахДвиженияДС(Область, ОтчетКомитенту.СчетФактура, СписокОшибок, 3);
				ТабличныйДокумент.Вывести(Область, 3);
			КонецЕсли; 
		КонецЦикла;
		
		Для каждого АктВыполненныхРабот Из СтрокаТаблицы.ДокументыАктовВыполненныхРабот Цикл
			Область = Макет.ПолучитьОбласть("АктВыполненныхРабот");
			Область.Параметры.АктВыполненныхРабот = АктВыполненныхРабот.Ссылка;
			УстановитьИнформациюОбОшибкеВОтчетеОСозданныхДокументахДвиженияДС(Область, АктВыполненныхРабот.Ссылка, СписокОшибок, 1);
			ТабличныйДокумент.Вывести(Область, 2);
			
			Если ЗначениеЗаполнено(АктВыполненныхРабот.СчетФактура) Тогда
				Область = Макет.ПолучитьОбласть("СчетФактураВыданный");
				Область.Параметры.СчетФактураВыданный = АктВыполненныхРабот.СчетФактура;
				УстановитьИнформациюОбОшибкеВОтчетеОСозданныхДокументахДвиженияДС(Область, АктВыполненныхРабот.СчетФактура, СписокОшибок, 3);
				ТабличныйДокумент.Вывести(Область, 3);
			КонецЕсли; 
		КонецЦикла;
		
		Для каждого ДокументыПриобретенияУслугСКС Из СтрокаТаблицы.ДокументыПриобретенияУслугСКС Цикл
			Область= Макет.ПолучитьОбласть("ПриобретениеУслугСКС");
			Область.Параметры.ПриобретениеУслуг = ДокументыПриобретенияУслугСКС.Ссылка;
			УстановитьИнформациюОбОшибкеВОтчетеОСозданныхДокументахДвиженияДС(Область, ДокументыПриобретенияУслугСКС.Ссылка, СписокОшибок, 1);
			ТабличныйДокумент.Вывести(Область, 2);
			
			Если ЗначениеЗаполнено(ДокументыПриобретенияУслугСКС.Взаимозачет) Тогда
				Область = Макет.ПолучитьОбласть("ВзаимозачетЗадолженностиСКС");
				Область.Параметры.ВзаимозачетЗадолженности = ДокументыПриобретенияУслугСКС.Взаимозачет;
				УстановитьИнформациюОбОшибкеВОтчетеОСозданныхДокументахДвиженияДС(Область, ДокументыПриобретенияУслугСКС.Взаимозачет, СписокОшибок, 2);
				ТабличныйДокумент.Вывести(Область, 2);
			КонецЕсли; 
		КонецЦикла;
			
	КонецЦикла;
	
	Возврат ТабличныйДокумент;
	
КонецФункции 

#КонецОбласти 

#Область ДокументыПоступленияДенежныхСредств
Функция ПолучитьДанныеПоПоступлениюДенежныхСредств_Архивная(Параметры)
	
	МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("НачалоПериода", НачалоДня(Параметры.НачалоПериода));
	Запрос.УстановитьПараметр("КонецПериода", КонецДня(Параметры.КонецПериода));
	Запрос.УстановитьПараметр("ОрганизацияЛогсис", Логс_ДополнительныеПроцедурыИФункцииПовтИсп.ОрганизацияЛогсис());
	Запрос.УстановитьПараметр("ОрганизацияЛССервис", Справочники.Организации.НайтиПоРеквизиту("ИНН", "7734424084"));
	Запрос.УстановитьПараметр("ОрганизацияНЛ", Справочники.Организации.НайтиПоРеквизиту("ИНН", "9725030344"));
	Запрос.УстановитьПараметр("КонтрагентУпр", Справочники.Контрагенты.НайтиПоРеквизиту("ИНН", "9721047523"));
	Запрос.УстановитьПараметр("СвойствоФормироватьПКОПоНаложеннымПлатежа",
		Логс_ДополнительныеПроцедурыИФункцииПовтИсп.СвойствоОрганизацияФормироватьПКОПоНаложеннымПлатежам());
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	НАЧАЛОПЕРИОДА(ЗаявкаНаДоставку.Дата, ДЕНЬ) КАК Период,
	|	ЗаявкаНаДоставку.Договор КАК Договор,
	|	ЗаявкаНаДоставку.Организация КАК Организация,
	|	ЗаявкаНаДоставку.Хаб КАК Хаб,
	|	ЗаявкаНаДоставку.Курьер КАК Курьер,
	|	ЗаявкаНаДоставку.ОплатаНаличные КАК ОплатаНаличные,
	|	ЗаявкаНаДоставку.ОплатаСБП КАК ОплатаСБП,
	|	СУММА(ЗаявкаНаДоставку.НаложенныйПлатеж) КАК Сумма
	|ПОМЕСТИТЬ ВТ_Заявки
	|ИЗ
	|	Документ.Логс_ЗаявкаНаДоставку КАК ЗаявкаНаДоставку
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Организации.ДополнительныеРеквизиты КАК ДопРеквизитыОрганизации
	|		ПО ЗаявкаНаДоставку.Организация = ДопРеквизитыОрганизации.Ссылка
	|			И (ДопРеквизитыОрганизации.Свойство = &СвойствоФормироватьПКОПоНаложеннымПлатежа)
	|ГДЕ
	|	ЗаявкаНаДоставку.Дата МЕЖДУ &НачалоПериода И &КонецПериода
	|	И НЕ(ЗаявкаНаДоставку.ОплатаНаличные
	|				И ЕСТЬNULL(ДопРеквизитыОрганизации.Свойство, ЛОЖЬ) = ЛОЖЬ)
	|	И ЗаявкаНаДоставку.Проведен
	|	И НЕ ЗаявкаНаДоставку.ТДРегион
	|	И НЕ ЗаявкаНаДоставку.Хаб.ЯвляетсяСКС
	|	И НЕ ЗаявкаНаДоставку.Партнер = ЗНАЧЕНИЕ(Справочник.Партнеры.ПустаяСсылка)
	|	И ЗаявкаНаДоставку.НаложенныйПлатеж > 0
	|	И &ТекстОтбораПоПартнеру
	|
	|СГРУППИРОВАТЬ ПО
	|	ЗаявкаНаДоставку.Организация,
	|	ЗаявкаНаДоставку.Хаб,
	|	ЗаявкаНаДоставку.Курьер,
	|	ЗаявкаНаДоставку.Договор,
	|	ЗаявкаНаДоставку.ОплатаНаличные,
	|	ЗаявкаНаДоставку.ОплатаСБП,
	|	НАЧАЛОПЕРИОДА(ЗаявкаНаДоставку.Дата, ДЕНЬ)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Заявки.Период КАК Период,
	|	Заявки.Договор КАК Договор,
	|	Заявки.ОплатаНаличные КАК ОплатаНаличные,
	|	Заявки.ОплатаСБП КАК ОплатаСБП,
	//|	ЕСТЬNULL(Настройки.ОтражатьРеализациюНаРозничногоПокупателя, ЛОЖЬ) КАК ОтражатьРеализациюНаРозничногоПокупателя,
	//|	ЕСТЬNULL(Настройки.ОтражатьРеализациюЧерезБокс, ЛОЖЬ) КАК ОтражатьРеализациюЧерезБокс,
	|	ЕСТЬNULL(Настройки.МетодПриходования, Значение(Перечисление.Логс_МетодыПриходованияНаложенногоПлатежа.ПустаяСсылка)) КАК МетодПриходования,
	|	ЕСТЬNULL(Настройки.МетодПриходованияСЗ, Значение(Перечисление.Логс_МетодыПриходованияНаложенногоПлатежа.ПустаяСсылка)) КАК МетодПриходованияСЗ
	|ПОМЕСТИТЬ ВТ_ИндивидуальныеНастройкиДоговоров
	|ИЗ
	|	(ВЫБРАТЬ
	|		Заявки.Период КАК Период,
	|		Заявки.ОплатаНаличные КАК ОплатаНаличные,
	|		Заявки.ОплатаСБП КАК ОплатаСБП,
	|		Заявки.Договор КАК Договор,
	|		МАКСИМУМ(Настройки.Период) КАК МаксПериод
	|	ИЗ
	|		(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|			Заявки.Период КАК Период,
	|			Заявки.ОплатаНаличные КАК ОплатаНаличные,
	|			Заявки.ОплатаСБП КАК ОплатаСБП,
	|			Заявки.Договор КАК Договор
	|		ИЗ
	|			ВТ_Заявки КАК Заявки) КАК Заявки
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.Логс_ИндивидуальныеНастройкиДоговоров КАК Настройки
	|			ПО Заявки.Договор = Настройки.Договор
	|				И Заявки.ОплатаНаличные = Настройки.ОплатаНаличные
	|				И Заявки.Период >= Настройки.Период
	|	
	|	СГРУППИРОВАТЬ ПО
	|		Заявки.Период,
	|		Заявки.ОплатаНаличные,
	|		Заявки.ОплатаСБП,
	|		Заявки.Договор) КАК Заявки
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.Логс_ИндивидуальныеНастройкиДоговоров КАК Настройки
	|		ПО Заявки.Договор = Настройки.Договор
	|			И Заявки.ОплатаНаличные = Настройки.ОплатаНаличные
	|			И Заявки.МаксПериод = Настройки.Период
	|;
	|ВЫБРАТЬ
	|	Заявки.Период КАК Период,
	|	Заявки.Организация КАК Организация,
	|	Заявки.ОплатаНаличные КАК ОплатаНаличные,
	|	Заявки.ОплатаСБП КАК ОплатаСБП,
	|	ЕСТЬNULL(Настройки.МетодПриходования, Значение(Перечисление.Логс_МетодыПриходованияНаложенногоПлатежа.Прямой)) КАК МетодПриходования,
	|	ЕСТЬNULL(Настройки.МетодПриходованияСЗ, Значение(Перечисление.Логс_МетодыПриходованияНаложенногоПлатежа.Прямой)) КАК МетодПриходованияСЗ
	|ПОМЕСТИТЬ ВТ_МетодПриходованияНП
	|ИЗ
	|	(ВЫБРАТЬ
	|		Заявки.Период КАК Период,
	|		Заявки.ОплатаНаличные КАК ОплатаНаличные,
	|		Заявки.ОплатаСБП КАК ОплатаСБП,
	|		Заявки.Организация КАК Организация,
	|		МАКСИМУМ(Настройки.Период) КАК МаксПериод
	|	ИЗ
	|		(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|			Заявки.Период КАК Период,
	|			Заявки.ОплатаНаличные КАК ОплатаНаличные,
	|			Заявки.ОплатаСБП КАК ОплатаСБП,
	|			Заявки.Организация КАК Организация
	|		ИЗ
	|			ВТ_Заявки КАК Заявки) КАК Заявки
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.Логс_МетодПриходованияНаложенногоПлатежа КАК Настройки
	|			ПО Заявки.Организация = Настройки.Организация
	|				И Заявки.ОплатаНаличные = Настройки.ОплатаНаличные
	|				И Заявки.Период >= Настройки.Период
	|	
	|	СГРУППИРОВАТЬ ПО
	|		Заявки.Период,
	|		Заявки.ОплатаНаличные,
