								//Иначе
									ВзаимозачетСсылка = Неопределено;
								//КонецЕсли; 
								
								//ТаблицаСозданныхДокументов
								СтрокаСозданныхДокументов.ДокументыПриобретенияУслугСКС.Добавить(Новый Структура("Ссылка,Взаимозачет",
								ПриобретениеУслугПрочихАктивов.Ссылка, ВзаимозачетСсылка));
								
							КонецЦикла;
						КонецЦикла;
					КонецЦикла;
				КонецЦикла;		
			КонецЦикла;
		КонецЦикла;
	КонецЦикла;
	
	Запрос.Текст =
	"УНИЧТОЖИТЬ втСводыМаршрутов
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ втДокументПриобретениеУслуг";
	Запрос.Выполнить();
		
КонецПроцедуры

