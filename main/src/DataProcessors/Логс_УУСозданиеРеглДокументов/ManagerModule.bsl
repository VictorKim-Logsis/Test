										И ПриобретениеУслугПрочихАктивов.Дата >= Дата("20260101") Тогда 
										СтрокаУслуга.СтавкаНДС =
										?(ПриобретениеУслугПрочихАктивов.НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.ПродажаОблагаетсяНДС,
										СтавкаНДС22, СтавкаБезНДС
										);
                                   	Иначе
										
										СтрокаУслуга.СтавкаНДС =
										?(ПриобретениеУслугПрочихАктивов.НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.ПродажаОблагаетсяНДС,
										//Перечисления.СтавкиНДС.НДС20,
										//Перечисления.СтавкиНДС.БезНДС
										СтавкаНДС20, СтавкаБезНДС
										);
									КонецЕсли;

									//СтрокаУслуга.СтавкаНДС =
									//?(ПриобретениеУслугПрочихАктивов.НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.ПродажаОблагаетсяНДС,
									////Перечисления.СтавкиНДС.НДС20,
									////Перечисления.СтавкиНДС.БезНДС
									//СтавкаНДС20, СтавкаБезНДС
									//);
									
									СтрокаУслуга.СуммаНДС = УчетНДСУПКлиентСервер.РассчитатьСуммуНДС(СтрокаУслуга.Сумма,
									УчетНДСУПВызовСервера.ЗначениеСтавкиНДС(СтрокаУслуга.СтавкаНДС),
									ПриобретениеУслугПрочихАктивов.ЦенаВключаетНДС,
									ПриобретениеУслугПрочихАктивов.НалогообложениеНДС);
									СтрокаУслуга.СуммаСНДС = Выборка.Сумма;
									СтрокаУслуга.СтатьяРасходов = СтатьяРасходов;
									//СтрокаУслуга.АналитикаРасходов = АналитикаРасходов;
									СтрокаУслуга.Подразделение = ПриобретениеУслугПрочихАктивов.Подразделение;
									СтрокаУслуга.АналитикаРасходов = СтрокаУслуга.Подразделение;
									СтрокаУслуга.Логс_СводМаршрутов = Выборка.ДокументСводовМаршрутов;
								КонецЦикла; 
								
								СуммаВсего = ПриобретениеУслугПрочихАктивов.Расходы.Итог("СуммаСНДС");
								
