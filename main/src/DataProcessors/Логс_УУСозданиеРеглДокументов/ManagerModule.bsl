	ОрионОрганизация = Справочники.Организации.НайтиПоРеквизиту("ИНН", "9728051543");
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("Дата", НачалоДня(Параметры.ДатаФормирования));
	Запрос.УстановитьПараметр("НачалоПериода", НачалоДня(Параметры.НачалоПериода));
	Запрос.УстановитьПараметр("КонецПериода", КонецДня(Параметры.КонецПериода));
	Запрос.УстановитьПараметр("Организация", Параметры.Организация);
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	СводЗаявокНаДоставку.Ссылка КАК Ссылка,
	|	СводЗаявокНаДоставку.Номер КАК Номер,
	|	СводЗаявокНаДоставку.Организация КАК Организация,
	|	СводЗаявокНаДоставку.Партнер КАК Партнер,
	|	СводЗаявокНаДоставку.Контрагент КАК Контрагент,
	|	СводЗаявокНаДоставку.Договор КАК Договор,
	|	СводЗаявокНаДоставку.НалогообложениеНДС КАК НалогообложениеНДС,
	|	СводЗаявокНаДоставку.Валюта КАК Валюта,
	|	СписокДоговоров.Подразделение КАК Подразделение,
	|	СписокДоговоров.БанковскийСчет КАК БанковскийСчет,
	|	СписокДоговоров.БанковскийСчетКонтрагента КАК БанковскийСчетКонтрагента,
	|	СписокДоговоров.ПорядокРасчетов КАК ПорядокРасчетов,
	|	СписокДоговоров.ВалютаВзаиморасчетов КАК ВалютаВзаиморасчетов,
	|	СписокДоговоров.Склад КАК Склад,
	|	СводЗаявокНаДоставку.НаложенныйПлатежВсего КАК Сумма
	|ПОМЕСТИТЬ СводЗаявок
	|ИЗ
	|	Документ.Логс_СводЗаявокНаДоставку КАК СводЗаявокНаДоставку
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ СписокДоговоров КАК СписокДоговоров
	|		ПО СводЗаявокНаДоставку.Договор = СписокДоговоров.Договор
	|ГДЕ
	|	СводЗаявокНаДоставку.Дата МЕЖДУ &НачалоПериода И &КонецПериода
	|	И СводЗаявокНаДоставку.НаложенныйПлатежВсего > 0
	|	И СводЗаявокНаДоставку.ВидКлиента <> ЗНАЧЕНИЕ(Перечисление.Логс_ВидыКлиентовCRM.СКС)
	|	И СводЗаявокНаДоставку.Проведен  И (СводЗаявокНаДоставку.Организация = &Организация или &Организация = Значение(Справочник.Организации.ПустаяСсылка))
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПриобретениеТоваровУслуг.Договор КАК Договор,
	|	МАКСИМУМ(ПриобретениеТоваровУслуг.Ссылка) КАК ПриемНаКомиссию
	|ПОМЕСТИТЬ ДокументыПриемаНаКомиссию
	|ИЗ
	|	Документ.ПриобретениеТоваровУслуг КАК ПриобретениеТоваровУслуг
	|ГДЕ
	|	НАЧАЛОПЕРИОДА(ПриобретениеТоваровУслуг.Дата, ДЕНЬ) = &Дата
	|	И ПриобретениеТоваровУслуг.Договор В
	|			(ВЫБРАТЬ
	|				СписокДоговоров.Договор
	|			ИЗ
	|				СписокДоговоров)
	|	И ПриобретениеТоваровУслуг.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ПриемНаКомиссию)
	|	И НЕ ПриобретениеТоваровУслуг.ПометкаУдаления
	|
	|СГРУППИРОВАТЬ ПО
	|	ПриобретениеТоваровУслуг.Договор
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Договор
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СводЗаявок.Ссылка КАК Ссылка,
	|	СводЗаявок.Номер КАК Номер,
	|	СводЗаявок.Организация КАК Организация,
	|	СводЗаявок.Партнер КАК Партнер,
	|	СводЗаявок.Контрагент КАК Контрагент,
	|	СводЗаявок.Договор КАК Договор,
	|	СводЗаявок.Склад КАК Склад,
	|	СводЗаявок.НалогообложениеНДС КАК НалогообложениеНДС,
	|	СводЗаявок.Подразделение КАК Подразделение,
	|	СводЗаявок.БанковскийСчет КАК БанковскийСчет,
	|	СводЗаявок.БанковскийСчетКонтрагента КАК БанковскийСчетКонтрагента,
	|	СводЗаявок.ВалютаВзаиморасчетов КАК ВалютаВзаиморасчетов,
	|	СводЗаявок.Валюта КАК Валюта,
	|	СводЗаявок.ПорядокРасчетов КАК ПорядокРасчетов,
	|	СводЗаявок.Сумма КАК Сумма,
	|	ЕСТЬNULL(ДокументыПриемаНаКомиссию.ПриемНаКомиссию, НЕОПРЕДЕЛЕНО) КАК ПриемНаКомиссию
	|ИЗ
	|	СводЗаявок КАК СводЗаявок
	|		ЛЕВОЕ СОЕДИНЕНИЕ ДокументыПриемаНаКомиссию КАК ДокументыПриемаНаКомиссию
	|		ПО СводЗаявок.Договор = ДокументыПриемаНаКомиссию.Договор
	|ИТОГИ
	|	МАКСИМУМ(Склад),
	|	МАКСИМУМ(Подразделение),
	|	МАКСИМУМ(БанковскийСчет),
	|	МАКСИМУМ(БанковскийСчетКонтрагента),
	|	МАКСИМУМ(ВалютаВзаиморасчетов),
	|	МАКСИМУМ(ПорядокРасчетов),
	|	МАКСИМУМ(ПриемНаКомиссию)
	|ПО
	|	Организация,
	|	Партнер,
	|	Контрагент,
	|	Договор,
	|	НалогообложениеНДС,
	|	Валюта";
	
	Менеджер = Пользователи.ТекущийПользователь();
	
	ВыборкаОрганизации = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаОрганизации.Следующий() Цикл
		ВыборкаПартнеры = ВыборкаОрганизации.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		
		Пока ВыборкаПартнеры.Следующий() Цикл
			ВыборкаКонтрагенты = ВыборкаПартнеры.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока ВыборкаКонтрагенты.Следующий() Цикл
				ВыборкаДоговоры = ВыборкаКонтрагенты.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
				Пока ВыборкаДоговоры.Следующий() Цикл
					ВыборкаНалогообложение = ВыборкаДоговоры.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
					Пока ВыборкаНалогообложение.Следующий() Цикл
						ВыборкаВалюты = ВыборкаНалогообложение.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
						Пока ВыборкаВалюты.Следующий() Цикл
							
							Склад = ВыборкаВалюты.Склад;
							
							СтруктураОтветственного = ЗакупкиСервер.ПолучитьОтветственногоПоСкладу(Склад, Менеджер);
							Если СтруктураОтветственного <> Неопределено Тогда
								Принял = СтруктураОтветственного.Ответственный;
								ПринялДолжность = СтруктураОтветственного.ОтветственныйДолжность;
							КонецЕсли;
							
							Если ЗначениеЗаполнено(ВыборкаВалюты.ПриемНаКомиссию) Тогда
								
								Если Параметры.ТолькоСоздаватьНовые Тогда
									Продолжить;
								КонецЕсли; 
		
								ПриобретениеТоваровУслуг = ВыборкаВалюты.ПриемНаКомиссию.ПолучитьОбъект();
								
								ПриобретениеТоваровУслуг.Товары.Очистить();
								ПриобретениеТоваровУслуг.ЭтапыГрафикаОплаты.Очистить();
								
							Иначе
								
								ПриобретениеТоваровУслуг = Документы.ПриобретениеТоваровУслуг.СоздатьДокумент();
								ПриобретениеТоваровУслуг.Дата = НачалоДня(Параметры.ДатаФормирования) + 43200;
								ПриобретениеТоваровУслуг.Организация = ВыборкаВалюты.Организация;
								ПриобретениеТоваровУслуг.Партнер = ВыборкаВалюты.Партнер;
								ПриобретениеТоваровУслуг.Контрагент = ВыборкаВалюты.Контрагент;
								ПриобретениеТоваровУслуг.Договор = ВыборкаВалюты.Договор;
								ПриобретениеТоваровУслуг.НалогообложениеНДС = ВыборкаВалюты.НалогообложениеНДС;
								ПриобретениеТоваровУслуг.Валюта = ВыборкаВалюты.Валюта;
								ПриобретениеТоваровУслуг.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ПриемНаКомиссию;
								
								ПриобретениеТоваровУслуг.УстановитьНовыйНомер();
								
							КонецЕсли; 
							
							ПриобретениеТоваровУслуг.Подразделение = ВыборкаВалюты.Подразделение;
							ПриобретениеТоваровУслуг.Склад = Склад;
							ПриобретениеТоваровУслуг.Менеджер = Менеджер;
							ПриобретениеТоваровУслуг.ЦенаВключаетНДС = Истина;
							ПриобретениеТоваровУслуг.ВалютаВзаиморасчетов = ВыборкаВалюты.ВалютаВзаиморасчетов;
							ПриобретениеТоваровУслуг.Согласован = Истина;
							ПриобретениеТоваровУслуг.БанковскийСчетОрганизации = ВыборкаВалюты.БанковскийСчет;
							ПриобретениеТоваровУслуг.БанковскийСчетКонтрагента = ВыборкаВалюты.БанковскийСчетКонтрагента;
							ПриобретениеТоваровУслуг.Принял = Принял;
							ПриобретениеТоваровУслуг.ПринялДолжность = ПринялДолжность;
							ПриобретениеТоваровУслуг.Автор = Менеджер;
							ПриобретениеТоваровУслуг.ПорядокРасчетов = ВыборкаВалюты.ПорядокРасчетов;
							ПриобретениеТоваровУслуг.СпособДоставки = Перечисления.СпособыДоставки.СиламиПоставщикаДоНашегоСклада;
							ПриобретениеТоваровУслуг.КурсЧислитель = 1;
							//ПриобретениеТоваровУслуг.Курс = 1;
							//ПриобретениеТоваровУслуг.Кратность = 1;
							ПриобретениеТоваровУслуг.ВариантПриемкиТоваров = Перечисления.ВариантыПриемкиТоваров.РазделенаТолькоПоНакладным;
							
							ОтветственныеЛицаСервер.ПриИзмененииСвязанныхРеквизитовДокумента(ПриобретениеТоваровУслуг);
							
							Выборка = ВыборкаВалюты.Выбрать();
							Пока Выборка.Следующий() Цикл
								СтрокаТовар = ПриобретениеТоваровУслуг.Товары.Добавить();
								СтрокаТовар.Номенклатура = Логс_ДополнительныеПроцедурыИФункцииПовтИсп.ТоварАгента();
								СтрокаТовар.Характеристика =
									Логс_ДополнительныеПроцедурыИФункции.ПолучитьХарактеристикуНоменклатурыАгента(
										СтрокаТовар.Номенклатура, Выборка.Номер);
								СтрокаТовар.Количество = Выборка.Сумма;
								СтрокаТовар.КоличествоУпаковок = Выборка.Сумма;
								СтрокаТовар.Цена = 1;
								СтрокаТовар.Сумма = Выборка.Сумма;
								
								//#TODO Костыль для УСН Орион - НДС нужен.
								Если ПриобретениеТоваровУслуг.Организация = ОрионОрганизация И ПриобретениеТоваровУслуг.Дата < Дата("20260101") Тогда
									СтрокаТовар.СтавкаНДС = СтавкаНДС5;   
								ИначеЕсли (ПриобретениеТоваровУслуг.Организация = ЛогсисОрганизация ИЛИ ПриобретениеТоваровУслуг.Организация = ОрионОрганизация) И ПриобретениеТоваровУслуг.Дата >= Дата("20260101") Тогда  
									СтрокаТовар.СтавкаНДС =
									?(ПриобретениеТоваровУслуг.НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.ПродажаОблагаетсяНДС,
									СтавкаНДС22, СтавкаБезНДС
									);  
                             	Иначе								
									СтрокаТовар.СтавкаНДС =
									?(ПриобретениеТоваровУслуг.НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.ПродажаОблагаетсяНДС,
									СтавкаНДС20, СтавкаБезНДС
									);  
								КонецЕсли;

								//СтрокаТовар.СуммаНДС = УчетНДСУПКлиентСервер.РассчитатьСуммуНДС(СтрокаТовар.Сумма,
								//	УчетНДСУПКлиентСервер.ПолучитьСтавкуНДС(СтрокаТовар.СтавкаНДС),
								//	ПриобретениеТоваровУслуг.ЦенаВключаетНДС,
								//	ПриобретениеТоваровУслуг.НалогообложениеНДС);
								СтрокаТовар.СуммаНДС = УчетНДСУПКлиентСервер.РассчитатьСуммуНДС(СтрокаТовар.Сумма,
									УчетНДСУПВызовСервера.ЗначениеСтавкиНДС(СтрокаТовар.СтавкаНДС),
									ПриобретениеТоваровУслуг.ЦенаВключаетНДС,
									ПриобретениеТоваровУслуг.НалогообложениеНДС);
								СтрокаТовар.СуммаСНДС = Выборка.Сумма;
								СтрокаТовар.Склад = ПриобретениеТоваровУслуг.Склад;
								СтрокаТовар.Логс_СводЗаявокНаДоставку = Выборка.Ссылка;
							КонецЦикла; 
	
							Если ПриобретениеТоваровУслуг.Ссылка.Пустая() Тогда
								ПриобретениеТоваровУслуг.Записать(РежимЗаписиДокумента.Запись);
							КонецЕсли; 
							
							Попытка
								ПриобретениеТоваровУслуг.Записать(РежимЗаписиДокумента.Проведение);
							Исключение
								ОписаниеОшибки = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
								ТекстСообщения = СтрШаблон(
									НСтр("ru='Произошла ошибка при записи приема на комиссию № %1 от %2: %3'"),
									ПриобретениеТоваровУслуг.Номер, Формат(ПриобретениеТоваровУслуг.Дата, "ДФ=dd.MM.yyyy"),
									ОписаниеОшибки);
								ЗаписьЖурналаРегистрации("УУ Создание регламентированных документов. Создание приема на комиссию",
									УровеньЖурналаРегистрации.Ошибка,,, ТекстСообщения);
								СписокОшибок.Вставить(ПриобретениеТоваровУслуг.Ссылка, ОписаниеОшибки);
							КонецПопытки;
							
							ТаблицаПриемаНаКомиссию = Новый ТаблицаЗначений;
							ТаблицаПриемаНаКомиссию.Колонки.Добавить("Ссылка", Новый ОписаниеТипов("ДокументСсылка.ПриобретениеТоваровУслуг"));
							ТаблицаПриемаНаКомиссию.Колонки.Добавить("ДокументыРеализации", Новый ОписаниеТипов("Массив"));
							
							СтрокаТаблицы = ТаблицаПриемаНаКомиссию.Добавить();
							СтрокаТаблицы.Ссылка = ПриобретениеТоваровУслуг.Ссылка;
							
							СозданныйДокумент = ТаблицаСозданныхДокументов.Добавить();
							СозданныйДокумент.Партнер = ВыборкаВалюты.Партнер;
							СозданныйДокумент.Договор = ВыборкаВалюты.Договор;
							СозданныйДокумент.ДокументыПриемаНаКомиссию = ТаблицаПриемаНаКомиссию;
							
						КонецЦикла; // Валюты
					КонецЦикла; // Налогообложение НДС
				КонецЦикла; // Договоры
			КонецЦикла; // Контрагенты
		КонецЦикла; // Партнеры
	КонецЦикла; // Организации
	
	Запрос.Текст =
	"УНИЧТОЖИТЬ СводЗаявок
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ДокументыПриемаНаКомиссию";
	Запрос.Выполнить();
	
КонецПроцедуры

Процедура СоздатьДокументыРеализацияТоваровУслуг(Параметры, МенеджерВременныхТаблиц, ТаблицаСозданныхДокументов, СписокОшибок)
	
	Если Не Параметры.Создавать.СоздаватьРеализации Тогда
		Возврат;
	КонецЕсли;	
	
	ДокументыПриемаНаКомиссию = ПолучитьДокументыПриемаНаКомиссиюИзТаблицыСозданныхДокументов(ТаблицаСозданныхДокументов);
	Если ДокументыПриемаНаКомиссию.Количество() = 0 Тогда
		Возврат;
	КонецЕсли; 
	
	СтавкаНДС20 = Константы.Логс_СтавкаНДС20.Получить();
	СтавкаБезНДС = Справочники.СтавкиНДС.БезНДС; 
	СтавкаНДС5 = Справочники.СтавкиНДС.НайтиПоНаименованию("5%");
	СтавкаНДС22 = Справочники.СтавкиНДС.НайтиПоНаименованию("22%");
	ЛогсисОрганизация = Справочники.Организации.НайтиПоРеквизиту("ИНН", "9725007793");
	ОрионОрганизация = Справочники.Организации.НайтиПоРеквизиту("ИНН", "9728051543");
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("Период", НачалоДня(Параметры.ДатаФормирования));
	Запрос.УстановитьПараметр("НачалоПериода", НачалоДня(Параметры.НачалоПериода));
	Запрос.УстановитьПараметр("КонецПериода", КонецДня(Параметры.КонецПериода));
	Запрос.УстановитьПараметр("ДокументыПриемаНаКомиссию", ДокументыПриемаНаКомиссию);
	Запрос.УстановитьПараметр("Организация", Параметры.Организация);
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ДОБАВИТЬКДАТЕ(ПриобретениеТоваровУслуг.Дата, СЕКУНДА, 1) КАК Дата,
	|	ПриобретениеТоваровУслуг.Организация КАК Организация,
