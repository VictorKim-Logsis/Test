	|	ТаблицаЗаявок.ОплатаНаличные,
	|	ТаблицаЗаявок.ОплатаСБП,
	|	ОбъектыРасчетов.Ссылка  
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗаявкиНаДоставку.ДатаДокумента КАК ДатаДокумента,
	|	ЗаявкиНаДоставку.Период КАК Период,
	|	ЗаявкиНаДоставку.Организация КАК Организация,
	|	ЗаявкиНаДоставку.РеализацияНаРозничного КАК РеализацияНаРозничного,    
	|	ЗаявкиНаДоставку.МетодПриходования КАК МетодПриходования,
	|	ЗаявкиНаДоставку.Хаб КАК Хаб,
	|	ЗаявкиНаДоставку.Договор КАК Договор,
	|	ЗаявкиНаДоставку.ВалютаВзаиморасчетов КАК ВалютаВзаиморасчетов,
	|	ЗаявкиНаДоставку.СтатьяДвиженияДенежныхСредств КАК СтатьяДвиженияДенежныхСредств,
	|	ЗаявкиНаДоставку.Подразделение КАК Подразделение,
	|	ЗаявкиНаДоставку.ПринятоОт КАК ПринятоОт,
	|	ЗаявкиНаДоставку.Основание КАК Основание,
	|	ЗаявкиНаДоставку.ОплатаНаличные,
	|	ЗаявкиНаДоставку.ОплатаСБП КАК ОплатаСБП,
	|	Кассы.Ссылка КАК Касса,               
	|	ЗаявкиНаДоставку.ОрганизацияУпр, 
	|	ЗаявкиНаДоставку.КонтрагентУпр,
	|	ЗаявкиНаДоставку.Сумма КАК Сумма,  
	|	ЗаявкиНаДоставку.ОбъектРасчетов КАК ОбъектРасчетов  
	|Поместить ВТ_ЗаявкиСКассами
	|ИЗ
	|	ЗаявкиНаДоставку КАК ЗаявкиНаДоставку
	|		ЛЕВОЕ СОЕДИНЕНИЕ Кассы КАК Кассы
	|		ПО ЗаявкиНаДоставку.ОрганизацияУпр = Кассы.Организация
	|			И ЗаявкиНаДоставку.Хаб = Кассы.Хаб
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗаявкиНаДоставку.ОбъектРасчетов КАК ОбъектРасчетов,  
	|	ЗаявкиНаДоставку.ДатаДокумента КАК ДатаДокумента,
	|	ЗаявкиНаДоставку.Период КАК Период,
	|	ЗаявкиНаДоставку.Организация КАК Организация,
	|	ЗаявкиНаДоставку.РеализацияНаРозничного КАК РеализацияНаРозничного,    
	|	ЗаявкиНаДоставку.МетодПриходования КАК МетодПриходования,
	|	ЗаявкиНаДоставку.Хаб КАК Хаб,
	|	ЗаявкиНаДоставку.Договор КАК Договор,
	|	ЗаявкиНаДоставку.ВалютаВзаиморасчетов КАК ВалютаВзаиморасчетов,
	|	ЗаявкиНаДоставку.СтатьяДвиженияДенежныхСредств КАК СтатьяДвиженияДенежныхСредств,
	|	ЗаявкиНаДоставку.Подразделение КАК Подразделение,
	|	ЗаявкиНаДоставку.ПринятоОт КАК ПринятоОт,
	|	ЗаявкиНаДоставку.Основание КАК Основание,
	|	ЕСТЬNULL(ПриходныйКассовыйОрдер.Ссылка, НЕОПРЕДЕЛЕНО) КАК ПриходныйКассовыйОрдерСсылка,
	|	ЗаявкиНаДоставку.Касса КАК Касса,
	|	ЗаявкиНаДоставку.Сумма КАК Сумма
	|ИЗ
	|	ВТ_ЗаявкиСКассами КАК ЗаявкиНаДоставку
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПриходныйКассовыйОрдер КАК ПриходныйКассовыйОрдер
	|		ПО ЗаявкиНаДоставку.ОрганизацияУпр = ПриходныйКассовыйОрдер.Организация
	|			И ЗаявкиНаДоставку.ОрганизацияУпр.Логс_ГоловноеПодразделение = ПриходныйКассовыйОрдер.Подразделение
	|			И ЗаявкиНаДоставку.КонтрагентУпр = ПриходныйКассовыйОрдер.Контрагент
	|			И ЗаявкиНаДоставку.ПринятоОт = ПриходныйКассовыйОрдер.ПринятоОт
	|			И ЗаявкиНаДоставку.Основание = ПриходныйКассовыйОрдер.Основание
	|			И ЗаявкиНаДоставку.Касса = ПриходныйКассовыйОрдер.Касса
	|			И ЗаявкиНаДоставку.Хаб = ПриходныйКассовыйОрдер.Логс_Хаб
	|			И (ЗаявкиНаДоставку.ДатаДокумента = НАЧАЛОПЕРИОДА(ПриходныйКассовыйОрдер.Дата, ДЕНЬ))
	|			И (ПриходныйКассовыйОрдер.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ПоступлениеОплатыОтКлиента))
	|			И (НЕ ПриходныйКассовыйОрдер.ПометкаУдаления)
	|ГДЕ
	|	ЗаявкиНаДоставку.ОплатаНаличные
	|	И &ТекстОтбораПоХабу
	|ИТОГИ ПО
	|	Организация,
	|	Хаб
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗаявкиНаДоставку.ОбъектРасчетов КАК ОбъектРасчетов,  
	|	ЗаявкиНаДоставку.ДатаДокумента КАК ДатаДокумента,
	|	ЗаявкиНаДоставку.Период КАК Период,
	|	ЗаявкиНаДоставку.Организация КАК Организация,
	|	ЗаявкиНаДоставку.Хаб КАК Хаб,
	|	ЗаявкиНаДоставку.ОплатаНаличные КАК ОплатаНаличные,
	|	ЗаявкиНаДоставку.ОплатаСБП КАК ОплатаСБП,
	|	ЗаявкиНаДоставку.Договор КАК Договор,
	|	ЗаявкиНаДоставку.ВалютаВзаиморасчетов КАК ВалютаВзаиморасчетов,
	|	ЗаявкиНаДоставку.СтатьяДвиженияДенежныхСредств КАК СтатьяДвиженияДенежныхСредств,
	|	ЗаявкиНаДоставку.НалогообложениеНДС КАК НалогообложениеНДС,
	|	ЗаявкиНаДоставку.Подразделение КАК Подразделение,
	|	ЕСТЬNULL(ОперацияПоПлатежнойКарте.Ссылка, НЕОПРЕДЕЛЕНО) КАК ОперацияПоПлатежнойКартеСсылка,
	|	ЗаявкиНаДоставку.ЭквайринговыйТерминал КАК ЭквайринговыйТерминал,
	|	ЗаявкиНаДоставку.ЭквайринговыйТерминал.Владелец КАК ДоговорЭквайринга,
	|	ЗаявкиНаДоставку.Сумма КАК Сумма
	|ИЗ
	|	ЗаявкиНаДоставку КАК ЗаявкиНаДоставку
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ОперацияПоПлатежнойКарте КАК ОперацияПоПлатежнойКарте
	|		ПО ЗаявкиНаДоставку.Организация = ОперацияПоПлатежнойКарте.Организация
	|			И (ЗаявкиНаДоставку.Подразделение = ОперацияПоПлатежнойКарте.Подразделение)
	|			И (ЗаявкиНаДоставку.ДатаДокумента = НАЧАЛОПЕРИОДА(ОперацияПоПлатежнойКарте.Дата, ДЕНЬ))
	|			И (ЗаявкиНаДоставку.ЭквайринговыйТерминал = ОперацияПоПлатежнойКарте.ЭквайринговыйТерминал)
	|			И (ОперацияПоПлатежнойКарте.Партнер = ЗНАЧЕНИЕ(Справочник.Партнеры.РозничныйПокупатель))
	|			И (ОперацияПоПлатежнойКарте.Контрагент = ЗНАЧЕНИЕ(Справочник.Контрагенты.РозничныйПокупатель))
	|			И (ОперацияПоПлатежнойКарте.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ПоступлениеОплатыОтКлиента))
	|			И (НЕ ОперацияПоПлатежнойКарте.ПометкаУдаления)
	|ГДЕ
	|	НЕ ЗаявкиНаДоставку.ОплатаНаличные
	|ИТОГИ ПО
	|	Организация";
	Запрос.УстановитьПараметр("ТаблицаЗаявок", ТаблицаЗаявок);
	
	Если Параметры.Свойство("Хаб") Тогда
		МассивХабов = Новый Массив;
		МассивХабов.Добавить(Параметры.Хаб);
		Если Параметры.Хаб = Справочники.Логс_Хабы.Москва Тогда
			МассивХабов.Добавить(Справочники.Логс_Хабы.ТД);
		КонецЕсли;
		Запрос.УстановитьПараметр("Хаб", МассивХабов);
		ТекстОтбораПоХабу = "И ЗаявкиНаДоставку.Хаб в (&Хаб)";
	Иначе
		ТекстОтбораПоХабу = "";
	КонецЕсли;
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &ТекстОтбораПоХабу", ТекстОтбораПоХабу);
	
	РезультатыЗапроса = Запрос.ВыполнитьПакет();
	
	ДанныеПоПоступлению = Новый Структура;
	ДанныеПоПоступлению.Вставить("ПКО", РезультатыЗапроса[3]);
	ДанныеПоПоступлению.Вставить("ПлатежныеКарты", РезультатыЗапроса[4]);
	
	Возврат ДанныеПоПоступлению;
	
КонецФункции 

Процедура СоздатьДокументПриходныйКассовыйОрдер(РезультатЗапроса, ТолькоСоздаватьНовые, СписокОшибок)
	
	ОрганизацияЛогсис = Логс_ДополнительныеПроцедурыИФункцииПовтИсп.ОрганизацияЛогсис();
	ОрганизацияЛССервис = Справочники.Организации.НайтиПоРеквизиту("ИНН", "7734424084");
	ОрганизацияНЛ = Справочники.Организации.НайтиПоРеквизиту("ИНН", "9725030344");
	ОрганизацияЛГ = Справочники.Организации.НайтиПоРеквизиту("ИНН", "9725007793");
	ОрганизацияОЛ = Справочники.Организации.НайтиПоРеквизиту("ИНН", "9728051543");
	КассаУпр = Справочники.Кассы.НайтиПоНаименованию("Организация Логсис (RUB)");
	ВалютаРеглУчета = Константы.ВалютаРегламентированногоУчета.Получить();
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	Контрагенты.Ссылка КАК Контрагент,
	|	Контрагенты.Партнер КАК Партнер
	|ИЗ
	|	Справочник.Контрагенты КАК Контрагенты
	|ГДЕ
	|	Контрагенты.ИНН = &ИНН");
	Запрос.УстановитьПараметр("ИНН", "9721047523");
	
	Выборка = Запрос.Выполнить().Выбрать();
	Выборка.Следующий();
	
	ПлательщикЛССервис = Выборка.Контрагент;
	ПартнерЛССервис = Выборка.Партнер;
	
	
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ДоговорыКонтрагентов.Ссылка КАК Ссылка,
	|	ДоговорыКонтрагентов.Подразделение КАК Подразделение,
	|	ДоговорыКонтрагентов.СтатьяДвиженияДенежныхСредств КАК СтатьяДвиженияДенежныхСредств,
	|	ОбъектыРасчетов.Ссылка КАК ОбъектРасчетов
	|ИЗ
	|	Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ОбъектыРасчетов КАК ОбъектыРасчетов
	|		По ОбъектыРасчетов.Объект = ДоговорыКонтрагентов.Ссылка
	|		И ОбъектыРасчетов.ТипРасчетов = Значение(Перечисление.ТипыРасчетовСПартнерами.РасчетыСКлиентом)
	|ГДЕ
	|	ДоговорыКонтрагентов.Контрагент = &Контрагент
	|	И ДоговорыКонтрагентов.Организация = &Организация
	|	И ДоговорыКонтрагентов.Наименование = &Наименование
	|	И НЕ ДоговорыКонтрагентов.ПометкаУдаления");
	Запрос.УстановитьПараметр("Контрагент", ПлательщикЛССервис);
	Запрос.УстановитьПараметр("Организация", ОрганизацияЛогсис);
	Запрос.УстановитьПараметр("Наименование", "Поступление ДС от РП ЛСС-Вох");
	
	ДоговорЛССервис = Запрос.Выполнить().Выбрать();
	ДоговорЛССервис.Следующий();
	
	Запрос.УстановитьПараметр("Наименование", "Поступление ДС от РП НЛ-Вох");
	
	ДоговорНЛ = Запрос.Выполнить().Выбрать();
	ДоговорНЛ.Следующий();
	
	Запрос.УстановитьПараметр("Наименование", "Поступление ДС от РП ЛГ-Вох");
	
	ДоговорЛГ = Запрос.Выполнить().Выбрать();
	ДоговорЛГ.Следующий();
	
	Запрос.УстановитьПараметр("Наименование", "Поступление ДС от РП ОРИОН-Вох");
	
	ДоговорОЛ = Запрос.Выполнить().Выбрать();
	ДоговорОЛ.Следующий();
	
	ВыборкаОрганизации = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаОрганизации.Следующий() Цикл
	
		ВыборкаХаб = ВыборкаОрганизации.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);   
		Пока ВыборкаХаб.Следующий() Цикл
		    Выборка = ВыборкаХаб.Выбрать();                                                      
			Пока Выборка.Следующий() Цикл
				
				Если ЗначениеЗаполнено(Выборка.ПриходныйКассовыйОрдерСсылка) Тогда
					
					Если ТолькоСоздаватьНовые Тогда
						Продолжить;
					КонецЕсли; 
					
					ПриходныйКассовыйОрдер = Выборка.ПриходныйКассовыйОрдерСсылка.ПолучитьОбъект();
					ПриходныйКассовыйОрдер.РасшифровкаПлатежа.Очистить();
					
				Иначе
					
					ПриходныйКассовыйОрдер = Документы.ПриходныйКассовыйОрдер.СоздатьДокумент();
					ПриходныйКассовыйОрдер.Дата = КонецДня(Выборка.ДатаДокумента);
					
				КонецЕсли; 
				
				Если Выборка.Организация = ОрганизацияЛССервис Тогда  //неактуально
					ПриходныйКассовыйОрдер.Организация = ОрганизацияЛогсис;
					ПриходныйКассовыйОрдер.Касса = КассаУпр;
					ПриходныйКассовыйОрдер.Контрагент = ПлательщикЛССервис;
					ПриходныйКассовыйОрдер.Партнер = ПартнерЛССервис;
					ПриходныйКассовыйОрдер.Подразделение = ДоговорЛССервис.Подразделение;
					ПриходныйКассовыйОрдер.Основание = СтрШаблон(
						НСтр("ru='Наложенный платеж ЛС Сервис за %1'"),
						Формат(Выборка.Период, "ДФ='dd.MM.yyyy""г.""'"));
				//ИначеЕсли Выборка.Организация = ОрганизацияНЛ И Выборка.Период>=Дата(2020,09,01) и не Выборка.РеализацияНаРозничного Тогда     
				ИначеЕсли Выборка.МетодПриходования = Перечисления.Логс_МетодыПриходованияНаложенногоПлатежа.Бокс и не Выборка.РеализацияНаРозничного Тогда     
					ПриходныйКассовыйОрдер.Организация = ОрганизацияЛогсис;
					ПриходныйКассовыйОрдер.Касса = Выборка.Касса;
					ПриходныйКассовыйОрдер.Контрагент = ПлательщикЛССервис;
					ПриходныйКассовыйОрдер.Партнер = ПартнерЛССервис;
					ПриходныйКассовыйОрдер.Подразделение = ДоговорНЛ.Подразделение;
					ПриходныйКассовыйОрдер.Основание = СтрШаблон(
						НСтр("ru='Наложенный платеж %1 за %2'"),
						СокрЛП(Стрзаменить(Строка(Выборка.Организация), "ООО","")),
						Формат(Выборка.Период, "ДФ='dd.MM.yyyy""г.""'"));
				Иначе

					ПриходныйКассовыйОрдер.Организация = Выборка.Организация;
					ПриходныйКассовыйОрдер.Касса = Выборка.Касса;
					ПриходныйКассовыйОрдер.Контрагент = Справочники.Контрагенты.РозничныйПокупатель;
					ПриходныйКассовыйОрдер.Партнер = Справочники.Партнеры.РозничныйПокупатель;
					ПриходныйКассовыйОрдер.Подразделение = Выборка.Подразделение;
					ПриходныйКассовыйОрдер.Основание = СтрШаблон(
						НСтр("ru='Поступление наложенного платежа за %1'"),
						Формат(Выборка.Период, "ДФ='dd.MM.yyyy""г.""'"));
				КонецЕсли; 
				
				//Если ЗначениеЗаполнено(Выборка.Хаб) и НЕ Выборка.Хаб = Справочники.Логс_Хабы.Москва и НЕ Выборка.Хаб = Справочники.Логс_Хабы.ТД Тогда
				//	КассаХаба = Логс_ДополнительныеПроцедурыИФункцииПовтИсп.ПолучитьОсновнуюКассуХаба(Выборка.Хаб, Выборка.Организация);
				//	ПриходныйКассовыйОрдер.Касса = ?(ЗначениеЗаполнено(КассаХаба), КассаХаба, ПриходныйКассовыйОрдер.Касса);
				//КонецЕсли;
					
				ПриходныйКассовыйОрдер.СуммаДокумента = Выборка.Сумма;
				ПриходныйКассовыйОрдер.Логс_Хаб = Выборка.Хаб;
				ПриходныйКассовыйОрдер.Логс_ДатаРасчетов = Выборка.Период;
				ПриходныйКассовыйОрдер.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ПоступлениеОплатыОтКлиента;
				ПриходныйКассовыйОрдер.ПринятоОт = Выборка.ПринятоОт;
				ПриходныйКассовыйОрдер.Валюта = ВалютаРеглУчета;
				ПриходныйКассовыйОрдер.ВТомЧислеНДС = НСтр("ru='Без налога (НДС)'");
				ПриходныйКассовыйОрдер.Кассир = Пользователи.ТекущийПользователь();
				
				ОтветственныеЛицаСервер.ПриИзмененииСвязанныхРеквизитовДокумента(ПриходныйКассовыйОрдер);
				
				СтрокаПлатежа = ПриходныйКассовыйОрдер.РасшифровкаПлатежа.Добавить();
				
				Если Выборка.Организация = ОрганизацияЛССервис Тогда
					СтрокаПлатежа.Партнер = ПартнерЛССервис;
					СтрокаПлатежа.ОснованиеПлатежа = ДоговорЛССервис.Ссылка;
					СтрокаПлатежа.СтатьяДвиженияДенежныхСредств = ДоговорЛССервис.СтатьяДвиженияДенежныхСредств;
					СтрокаПлатежа.ОбъектРасчетов = ДоговорЛССервис.ОбъектРасчетов;
				ИначеЕсли Выборка.Организация = ОрганизацияНЛ и НЕ Выборка.РеализацияНаРозничного Тогда    //?
					СтрокаПлатежа.Партнер = ПартнерЛССервис;
					СтрокаПлатежа.ОснованиеПлатежа = ДоговорНЛ.Ссылка;
					СтрокаПлатежа.СтатьяДвиженияДенежныхСредств = ДоговорНЛ.СтатьяДвиженияДенежныхСредств;
					СтрокаПлатежа.ОбъектРасчетов = ДоговорНЛ.ОбъектРасчетов;
				ИначеЕсли Выборка.Организация = ОрганизацияОЛ и НЕ Выборка.РеализацияНаРозничного Тогда    //?
					СтрокаПлатежа.Партнер = ПартнерЛССервис;
					СтрокаПлатежа.ОснованиеПлатежа = ДоговорОЛ.Ссылка;
					СтрокаПлатежа.СтатьяДвиженияДенежныхСредств = ДоговорОЛ.СтатьяДвиженияДенежныхСредств;
					СтрокаПлатежа.ОбъектРасчетов = ДоговорОЛ.ОбъектРасчетов;
				ИначеЕсли Выборка.Организация = ОрганизацияЛГ и НЕ Выборка.РеализацияНаРозничного Тогда    //?
					СтрокаПлатежа.Партнер = ПартнерЛССервис;
					СтрокаПлатежа.ОснованиеПлатежа = ДоговорЛГ.Ссылка;
					СтрокаПлатежа.СтатьяДвиженияДенежныхСредств = ДоговорЛГ.СтатьяДвиженияДенежныхСредств;
					СтрокаПлатежа.ОбъектРасчетов = ДоговорЛГ.ОбъектРасчетов;
				Иначе
					СтрокаПлатежа.Партнер = Справочники.Партнеры.РозничныйПокупатель;
					СтрокаПлатежа.ОснованиеПлатежа = Выборка.Договор;
					СтрокаПлатежа.СтатьяДвиженияДенежныхСредств = Выборка.СтатьяДвиженияДенежныхСредств;
					СтрокаПлатежа.ОбъектРасчетов = Выборка.ОбъектРасчетов;//СтрокаПлатежа.ОснованиеПлатежа;
				КонецЕсли;
				
				СтрокаПлатежа.Сумма = Выборка.Сумма;
				СтрокаПлатежа.ВалютаВзаиморасчетов = Выборка.ВалютаВзаиморасчетов;
				СтрокаПлатежа.Организация = ПриходныйКассовыйОрдер.Организация;
				//СтрокаПлатежа.СтавкаНДС = Перечисления.СтавкиНДС.БезНДС;
				СтрокаПлатежа.СтавкаНДС = Справочники.СтавкиНДС.БезНДС;
				СтрокаПлатежа.СуммаНДС = 0;
											
				Если ПриходныйКассовыйОрдер.Ссылка.Пустая() Тогда
					ПриходныйКассовыйОрдер.УстановитьНовыйНомер();
					ПриходныйКассовыйОрдер.Записать(РежимЗаписиДокумента.Запись,РежимПроведенияДокумента.Неоперативный);
				КонецЕсли; 

				Попытка
					ПриходныйКассовыйОрдер.Дата = КонецДня(Выборка.ДатаДокумента);
					ПриходныйКассовыйОрдер.Записать(РежимЗаписиДокумента.Проведение,РежимПроведенияДокумента.Неоперативный);
				Исключение
					ТекстСообщения = СтрШаблон(
						НСтр("ru='Произошла ошибка при записи приходного кассового ордера № %1 от %2: %3'"),
						ПриходныйКассовыйОрдер.Номер, Формат(ПриходныйКассовыйОрдер.Дата, "ДФ=dd.MM.yyyy"),
						КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
					ЗаписьЖурналаРегистрации("УУ Создание регламентированных документов. Создание приходных кассовых ордеров",
						УровеньЖурналаРегистрации.Ошибка,,, ТекстСообщения);
					СписокОшибок.Добавить(Новый Структура("ТекстОшибки,КлючДанных",
						ТекстСообщения, ПриходныйКассовыйОрдер.Ссылка));
				КонецПопытки;
				
			КонецЦикла; // Периоды
		КонецЦикла; // Хабы
	КонецЦикла; // Организации
	
КонецПроцедуры

Процедура СоздатьДокументОперацияПоПлатежнойКарте(РезультатЗапроса, ТолькоСоздаватьНовые, СписокОшибок)
	СтавкаНДС20 = Константы.Логс_СтавкаНДС20.Получить();
	СтавкаБезНДС = Справочники.СтавкиНДС.БезНДС;
	СтавкаНДС22 = Справочники.СтавкиНДС.НайтиПоНаименованию("22%");
	
	ВалютаРеглУчета = Константы.ВалютаРегламентированногоУчета.Получить();
	
	ВыборкаОрганизации = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаОрганизации.Следующий() Цикл
	
		Выборка = ВыборкаОрганизации.Выбрать();                                                
		Пока Выборка.Следующий() Цикл
			
			Если ЗначениеЗаполнено(Выборка.ОперацияПоПлатежнойКартеСсылка) Тогда
				
				Если ТолькоСоздаватьНовые Тогда
					Продолжить;
				КонецЕсли; 
				
				ОперацияПоПлатежнойКарте = Выборка.ОперацияПоПлатежнойКартеСсылка.ПолучитьОбъект();
				ОперацияПоПлатежнойКарте.РасшифровкаПлатежа.Очистить();
				
			Иначе
				ОперацияПоПлатежнойКарте = Документы.ОперацияПоПлатежнойКарте.СоздатьДокумент();
				//ОперацияПоПлатежнойКарте.Дата = КонецДня(Выборка.Период);
				ОперацияПоПлатежнойКарте.Дата = КонецДня(Выборка.ДатаДокумента);
			КонецЕсли;
			
			ОперацияПоПлатежнойКарте.Организация = Выборка.Организация;
			ОперацияПоПлатежнойКарте.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ПоступлениеОплатыОтКлиента;
			ОперацияПоПлатежнойКарте.Валюта = ВалютаРеглУчета;
			ОперацияПоПлатежнойКарте.Контрагент = Справочники.Контрагенты.РозничныйПокупатель;
			ОперацияПоПлатежнойКарте.СуммаДокумента = Выборка.Сумма;
			ОперацияПоПлатежнойКарте.ЭквайринговыйТерминал = Выборка.ЭквайринговыйТерминал;
			ОперацияПоПлатежнойКарте.ДоговорЭквайринга = Выборка.ДоговорЭквайринга;
			ОперацияПоПлатежнойКарте.НомерПлатежнойКарты = "1111111111111111111111";
			ОперацияПоПлатежнойКарте.Ответственный = Пользователи.ТекущийПользователь();
			ОперацияПоПлатежнойКарте.СтатьяДвиженияДенежныхСредств = Выборка.СтатьяДвиженияДенежныхСредств;
			ОперацияПоПлатежнойКарте.Партнер = Справочники.Партнеры.РозничныйПокупатель;
			ОперацияПоПлатежнойКарте.Подразделение = Выборка.Подразделение;
				
			СтрокаПлатежа = ОперацияПоПлатежнойКарте.РасшифровкаПлатежа.Добавить();
			СтрокаПлатежа.Партнер = Справочники.Партнеры.РозничныйПокупатель;
			СтрокаПлатежа.СтатьяДвиженияДенежныхСредств = Выборка.СтатьяДвиженияДенежныхСредств;
			СтрокаПлатежа.ОснованиеПлатежа = Выборка.Договор;
			СтрокаПлатежа.ОбъектРасчетов = Выборка.ОбъектРасчетов;
			СтрокаПлатежа.Сумма = Выборка.Сумма;
			СтрокаПлатежа.ВалютаВзаиморасчетов = Выборка.ВалютаВзаиморасчетов;
			
			Если Выборка.НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.ПродажаОблагаетсяНДС И ОперацияПоПлатежнойКарте.Дата >= Дата("20260101") Тогда
				СтрокаПлатежа.СтавкаНДС = СтавкаНДС22;
				СтрокаПлатежа.СуммаНДС = СтрокаПлатежа.Сумма * 0.22/1.22;  
			ИначеЕсли Выборка.НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.ПродажаОблагаетсяНДС Тогда
				СтрокаПлатежа.СтавкаНДС = СтавкаНДС20;
				СтрокаПлатежа.СуммаНДС = СтрокаПлатежа.Сумма * 0.2/1.2;

			Иначе
				СтрокаПлатежа.СтавкаНДС = СтавкаБезНДС;
				СтрокаПлатежа.СуммаНДС = 0;
			КонецЕсли; 
										
			Если ОперацияПоПлатежнойКарте.Ссылка.Пустая() Тогда
				ОперацияПоПлатежнойКарте.УстановитьНовыйНомер();
				ОперацияПоПлатежнойКарте.Записать(РежимЗаписиДокумента.Запись);
			КонецЕсли; 

			Попытка
				ОперацияПоПлатежнойКарте.Записать(РежимЗаписиДокумента.Проведение);
			Исключение
				ТекстСообщения = СтрШаблон(
					НСтр("ru='Произошла ошибка при записи операции по платежной карте № %1 от %2: %3'"),
					ОперацияПоПлатежнойКарте.Номер, Формат(ОперацияПоПлатежнойКарте.Дата, "ДФ=dd.MM.yyyy"),
					КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
				ЗаписьЖурналаРегистрации("УУ Создание регламентированных документов. Создание приходных кассовых ордеров",
					УровеньЖурналаРегистрации.Ошибка,,, ТекстСообщения);
				СписокОшибок.Добавить(Новый Структура("ТекстОшибки,КлючДанных",
					ТекстСообщения, ОперацияПоПлатежнойКарте.Ссылка));
			КонецПопытки;
			
		КонецЦикла; // Периоды
	КонецЦикла; // Организации
	
КонецПроцедуры

#КонецОбласти 

#КонецОбласти 

#Область СлужебныеПроцедурыИФункции

Процедура ПоместитьДоговорыПоДвижениюДенежныхСредствВоВременнуюТаблицу(Параметры, МенеджерВременныхТаблиц)
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("Организация", Параметры.Организация);
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ДоговорыКонтрагентов.Ссылка КАК Договор,
	|	ДоговорыКонтрагентов.Подразделение КАК Подразделение,
	|	ДоговорыКонтрагентов.НалогообложениеНДС КАК НалогообложениеНДС,
	|	ИСТИНА КАК ЦенаВключаетНДС,
	|	ДоговорыКонтрагентов.БанковскийСчет КАК БанковскийСчет,
	|	ДоговорыКонтрагентов.БанковскийСчетКонтрагента КАК БанковскийСчетКонтрагента,
	|	ДоговорыКонтрагентов.СтатьяДвиженияДенежныхСредств КАК СтатьяДвиженияДенежныхСредств,
	|	ДоговорыКонтрагентов.ВалютаВзаиморасчетов КАК ВалютаВзаиморасчетов,
	|	ДоговорыКонтрагентов.ПорядокРасчетов КАК ПорядокРасчетов,
	|	Неопределено КАК ПорядокОплаты,
	|	Логс_ИсторияФормыОплатыДоговоровСрезПоследних.ФормаОплатыУслугАгенту КАК ФормаОплатыУслуг,
	|	ДоговорыКонтрагентов.НаименованиеДляПечати КАК Основание,
	|	ДоговорыКонтрагентов.Дата КАК ОснованиеДата,
	|	ДоговорыКонтрагентов.Номер КАК ОснованиеНомер,
	|	ДоговорыКонтрагентов.Логс_ДоговорНаОказаниеУслуг КАК ДоговорНаОказаниеУслуг,
	|	ДоговорыКонтрагентов.Логс_ВидКлиентаCRM КАК ВидКлиента,
	|	ЕСТЬNULL(СкладыОрганизаций.Склад, НЕОПРЕДЕЛЕНО) КАК Склад
	|ПОМЕСТИТЬ СписокДоговоров
	|ИЗ
	|	РегистрСведений.Логс_ИсторияФормыОплатыДоговоров.СрезПоследних КАК Логс_ИсторияФормыОплатыДоговоровСрезПоследних
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.Логс_СкладыОрганизацийТовараАгента КАК СкладыОрганизаций
	|			ПО ДоговорыКонтрагентов.Организация = СкладыОрганизаций.Организация
	|		ПО Логс_ИсторияФормыОплатыДоговоровСрезПоследних.ДоговорКонтрагентов = ДоговорыКонтрагентов.Ссылка
	|ГДЕ
	|	ДоговорыКонтрагентов.Логс_ВидКлиентаCRM <> ЗНАЧЕНИЕ(Перечисление.Логс_ВидыКлиентовCRM.ПустаяСсылка)
	|	И НЕ ДоговорыКонтрагентов.ПометкаУдаления  И (ДоговорыКонтрагентов.Организация = &Организация или &Организация = Значение(Справочник.Организации.ПустаяСсылка))
	|	И &ТекстОтбора
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Договор";
	
	ТекстОтбора = "";
	Если Параметры.Свойство("Партнер") Тогда
		ТекстОтбора = "ДоговорыКонтрагентов.Партнер = &Партнер";
		Запрос.УстановитьПараметр("Партнер", Параметры.Партнер);
	КонецЕсли;
	Если Параметры.Свойство("СрокиВыставленияАктовВыполненныхРабот")
			И ЗначениеЗаполнено(Параметры.СрокиВыставленияАктовВыполненныхРабот) Тогда
		
		Если ТекстОтбора <> "" Тогда
			ТекстОтбора = ТекстОтбора + " И ";
		КонецЕсли; 
		
		ТекстОтбора = ТекстОтбора + "ДоговорыКонтрагентов.Логс_СрокВыставленияАктовВыполненныхРабот В(&СрокиВыставленияАктовВыполненныхРабот)";
		
		Запрос.УстановитьПараметр("СрокиВыставленияАктовВыполненныхРабот", Параметры.СрокиВыставленияАктовВыполненныхРабот);
		
	КонецЕсли;
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ТекстОтбора",
		?(ТекстОтбора = "", "ИСТИНА", ТекстОтбора));
		
	Запрос.Выполнить();
	
КонецПроцедуры 

Функция ПолучитьДокументыПриемаНаКомиссиюИзТаблицыСозданныхДокументов(ТаблицаСозданныхДокументов)
	
	ДокументыПриемаНаКомиссию = Новый Массив;
	
	Для каждого СтрокаТаблицы Из ТаблицаСозданныхДокументов Цикл
		Для каждого СтрокаДокумент Из СтрокаТаблицы.ДокументыПриемаНаКомиссию Цикл
			ДокументыПриемаНаКомиссию.Добавить(СтрокаДокумент.Ссылка);
		КонецЦикла;
	КонецЦикла;
	
	Возврат ДокументыПриемаНаКомиссию;
	
КонецФункции 

Функция ПолучитьДокументыРеализацииИзТаблицыСозданныхДокументов(ТаблицаСозданныхДокументов)
	
	ДокументыРеализации = Новый Массив;
	
	Для каждого СтрокаТаблицы Из ТаблицаСозданныхДокументов Цикл
		Для каждого СтрокаДокумент Из СтрокаТаблицы.ДокументыПриемаНаКомиссию Цикл
			Для каждого ДокументРеализации Из СтрокаДокумент.ДокументыРеализации Цикл
				ДокументыРеализации.Добавить(ДокументРеализации.Ссылка);
			КонецЦикла;
		КонецЦикла;
	КонецЦикла;
	
	Возврат ДокументыРеализации;
	
КонецФункции 

Функция ПолучитьДокументыДляСчетФактурИзТаблицыСозданныхДокументов(ТаблицаСозданныхДокументов)
	
	МассивДокументов = Новый Массив;
	
	Для каждого СтрокаТаблицы Из ТаблицаСозданныхДокументов Цикл
		Для каждого Документ Из СтрокаТаблицы.ДокументыОтчетовКомитентам Цикл
			МассивДокументов.Добавить(Документ);
		КонецЦикла;
		Для каждого Документ Из СтрокаТаблицы.ДокументыАктовВыполненныхРабот Цикл
			МассивДокументов.Добавить(Документ);
		КонецЦикла;
	КонецЦикла;
	
	Возврат МассивДокументов;
	
КонецФункции 

#Область Прочее

Функция ДеньЯвляетсяРабочим(ДатаКалендаря, ПроизводственныйКалендарь)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ДанныеПроизводственногоКалендаря.ВидДня = ЗНАЧЕНИЕ(Перечисление.ВидыДнейПроизводственногоКалендаря.Рабочий) КАК Рабочий
	|ИЗ
	|	РегистрСведений.ДанныеПроизводственногоКалендаря КАК ДанныеПроизводственногоКалендаря
	|ГДЕ
	|	ДанныеПроизводственногоКалендаря.ПроизводственныйКалендарь = &ПроизводственныйКалендарь
	|	И ДанныеПроизводственногоКалендаря.Дата = &Дата");
	Запрос.УстановитьПараметр("ПроизводственныйКалендарь", ПроизводственныйКалендарь);
	Запрос.УстановитьПараметр("Дата", ДатаКалендаря);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Возврат ?(Выборка.Следующий(),
		Выборка.Рабочий,
		ДеньНедели(ДатаКалендаря) < 6); // Если нет данных в производственном календаре, то проверяем на выходной день (Сб/Вс).
	
