	|	ОбъектыРасчетов.Ссылка КАК ОбъектРасчетов
	|ИЗ
	|	РасчетыПоНаложеннымПлатежам КАК РасчетыПоНаложеннымПлатежам
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
	|		ПО РасчетыПоНаложеннымПлатежам.Договор = ДоговорыКонтрагентов.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ОбъектыРасчетов КАК ОбъектыРасчетов
	|		ПО РасчетыПоНаложеннымПлатежам.Договор = ОбъектыРасчетов.Объект
	|		И ОбъектыРасчетов.ТипРасчетов = Значение(Перечисление.ТипыРасчетовСПартнерами.РасчетыСПоставщиком)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Организации КАК Организации
	|		ПО РасчетыПоНаложеннымПлатежам.Организация = Организации.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Кассы КАК Кассы
	|		ПО РасчетыПоНаложеннымПлатежам.Организация = Кассы.Организация
	|
	|УПОРЯДОЧИТЬ ПО
	|	Дата,
	|	Сумма
	|ИТОГИ
	|	МАКСИМУМ(БанковскийСчет),
	|	МАКСИМУМ(БанковскийСчетКонтрагента),
	|	МАКСИМУМ(Подразделение),
	|	МАКСИМУМ(СтавкаНДС),
	|	МАКСИМУМ(Касса)
	|ПО
	|	Организация,
	|	Партнер,
	|	Контрагент,
	|	Договор,
	|	Валюта";
	
	Если Параметры.Свойство("Партнер") Тогда
		Запрос.УстановитьПараметр("Партнер", Параметры.Партнер);
		ТекстОтбораПоПартнеру = "АналитикаУчетаПоПартнерам.Партнер = &Партнер";
	Иначе
		ТекстОтбораПоПартнеру = "ИСТИНА";
	КонецЕсли;
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ТекстОтбораПоПартнеру", ТекстОтбораПоПартнеру);
	
	СтатьяДДС = Справочники.СтатьиДвиженияДенежныхСредств.НайтиПоНаименованию("Поступление оплаты за услуги доставки");
	
	ПриоритетОплаты = Справочники.ПриоритетыОплаты.ПолучитьПриоритетПоУмолчанию(Неопределено);
	ПроизводственныйКалендарь = КалендарныеГрафики.ОсновнойПроизводственныйКалендарь();
							
	СтруктураПересчетаСуммы = Новый Структура;
	СтруктураПересчетаСуммы.Вставить("ЦенаВключаетНДС", Истина);
	
	СтруктураДействий = Новый Структура;
	СтруктураДействий.Вставить("ПересчитатьСуммуНДС", СтруктураПересчетаСуммы);
	
	ТекущаяДата = ТекущаяДатаСеанса();
	ДатаДокумента = ?(НачалоДня(ТекущаяДата) = НачалоДня(Параметры.Период), ТекущаяДата, КонецДня(Параметры.Период));
	
	ВыборкаОрганизации = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаОрганизации.Следующий() Цикл
		ВыборкаПартнеры = ВыборкаОрганизации.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаПартнеры.Следующий() Цикл
			ВыборкаКонтрагенты = ВыборкаПартнеры.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока ВыборкаКонтрагенты.Следующий() Цикл
					ВыборкаДоговоры = ВыборкаКонтрагенты.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
					Пока ВыборкаДоговоры.Следующий() Цикл
						ВыборкаВалюты = ВыборкаДоговоры.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
						Пока ВыборкаВалюты.Следующий() Цикл
							
							ЗаявкаНаРасходованиеДС = Документы.ЗаявкаНаРасходованиеДенежныхСредств.СоздатьДокумент();
							ЗаявкаНаРасходованиеДС.Дата = ДатаДокумента;
							ЗаявкаНаРасходованиеДС.Организация = ВыборкаВалюты.Организация;
							ЗаявкаНаРасходованиеДС.Статус = Перечисления.СтатусыЗаявокНаРасходованиеДенежныхСредств.НеСогласована;
							ЗаявкаНаРасходованиеДС.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ВозвратОплатыКлиенту;
							ЗаявкаНаРасходованиеДС.Валюта = ВыборкаВалюты.Валюта;
							ЗаявкаНаРасходованиеДС.ФормаОплатыНаличная = (ВыборкаВалюты.Организация = Логс_ДополнительныеПроцедурыИФункцииПовтИсп.ОрганизацияЛогсис());
							ЗаявкаНаРасходованиеДС.ФормаОплатыБезналичная = Не ЗаявкаНаРасходованиеДС.ФормаОплатыНаличная;
							ЗаявкаНаРасходованиеДС.БанковскийСчет = ВыборкаВалюты.БанковскийСчет;
							ЗаявкаНаРасходованиеДС.Касса = ВыборкаВалюты.Касса;
							ЗаявкаНаРасходованиеДС.Контрагент = ВыборкаВалюты.Контрагент;
							ЗаявкаНаРасходованиеДС.БанковскийСчетКонтрагента = ВыборкаВалюты.БанковскийСчетКонтрагента;
							ЗаявкаНаРасходованиеДС.Подразделение = ВыборкаВалюты.Подразделение;
							ЗаявкаНаРасходованиеДС.КтоЗаявил = Пользователи.ТекущийПользователь();
							ЗаявкаНаРасходованиеДС.Автор = ЗаявкаНаРасходованиеДС.КтоЗаявил;
							ЗаявкаНаРасходованиеДС.СтатьяДвиженияДенежныхСредств = СтатьяДДС;
							ЗаявкаНаРасходованиеДС.ПланированиеСуммы = Перечисления.СпособыПланированияОплатыЗаявок.ВВалютеПлатежа;
							ЗаявкаНаРасходованиеДС.ВариантОплаты = Перечисления.ВариантыКонтроляОплатыПоставщику.ПредоплатаДоПоступления;
							ЗаявкаНаРасходованиеДС.ВидПеречисленияВБюджет = Перечисления.ВидыПеречисленийВБюджет.ИнойПлатеж;
							ЗаявкаНаРасходованиеДС.ПриоритетОплаты = ПриоритетОплаты;
							
							СуммаВсего = 0; НомераСчетов = "";							
							Выборка = ВыборкаВалюты.Выбрать();
							Пока Выборка.Следующий() Цикл  									
								СтрокаРаспределения = ЗаявкаНаРасходованиеДС.Логс_РаспределениеПоСчетам.Добавить();
								СтрокаРаспределения.Счет = Выборка.Счет;
								СтрокаРаспределения.Сумма = Выборка.Сумма;								
								СуммаВсего = СуммаВсего + СтрокаРаспределения.Сумма;	
								НомераСчетов = НомераСчетов + "№" + Выборка.Номер + " от " + Формат(Выборка.Дата, "ДЛФ = D") + ", ";
							КонецЦикла; // Счет
							
							ЗаявкаНаРасходованиеДС.ДатаПлатежа = ДатаДокумента;
							ЗаявкаНаРасходованиеДС.ЖелательнаяДатаПлатежа = ДатаДокумента;
							ЗаявкаНаРасходованиеДС.НазначениеПлатежа = "Возврат излишне перечисленных дс по счетам: " + НомераСчетов + "договор: " + ВыборкаВалюты.Договор;
							ЗаявкаНаРасходованиеДС.СуммаДокумента = СуммаВсего;
							
							СтрокаПлатежа = ЗаявкаНаРасходованиеДС.РасшифровкаПлатежа.Добавить();
							СтрокаПлатежа.Партнер = ВыборкаВалюты.Партнер;
							СтрокаПлатежа.ОбъектРасчетов = ВыборкаВалюты.ОбъектРасчетов;
							СтрокаПлатежа.Сумма = СуммаВсего;
							СтрокаПлатежа.ВалютаВзаиморасчетов = ВыборкаВалюты.Валюта;
							СтрокаПлатежа.СтатьяДвиженияДенежныхСредств = СтатьяДДС; 
							СтрокаПлатежа.Организация = ВыборкаВалюты.Организация;
							СтрокаПлатежа.СтавкаНДС = ВыборкаВалюты.СтавкаНДС;
							
							//++ Ким Виктор 10.12.2025
							//Фикс после обновления
							//ОбработкаТабличнойЧастиСервер.ОбработатьСтрокуТЧ(СтрокаПлатежа, СтруктураДействий, КэшированныеЗначения);
							ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьСтрокуТЧ(СтрокаПлатежа, СтруктураДействий, КэшированныеЗначения);
							//-- Ким Виктор 10.12.2025
                            							
							СтрокаБанковскогоСчета = ЗаявкаНаРасходованиеДС.РаспределениеПоСчетам.Добавить();
							СтрокаБанковскогоСчета.БанковскийСчетКасса = ?(ЗаявкаНаРасходованиеДС.ФормаОплатыНаличная, ВыборкаВалюты.Касса, ВыборкаВалюты.БанковскийСчет);
							СтрокаБанковскогоСчета.Сумма = СуммаВсего;
							СтрокаБанковскогоСчета.ДатаПлатежа = ЗаявкаНаРасходованиеДС.ДатаПлатежа;
							
							ЗаявкаНаРасходованиеДС.УстановитьНовыйНомер();
							ЗаявкаНаРасходованиеДС.Записать(РежимЗаписиДокумента.Запись);
							
							Попытка
								ЗаявкаНаРасходованиеДС.Записать(РежимЗаписиДокумента.Проведение);
							Исключение
								ТекстСообщения = СтрШаблон(
									НСтр("ru='Произошла ошибка при записи заявки на расходование денежных средств по своду заявок на доставку № %1 от %2: %3'"),
									ЗаявкаНаРасходованиеДС.Номер, Формат(ЗаявкаНаРасходованиеДС.Дата, "ДФ=dd.MM.yyyy"),
									КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
								ЗаписьЖурналаРегистрации("УУ Создание регламентированных документов. Создание заявок на расходование ДС",
									УровеньЖурналаРегистрации.Ошибка,,, ТекстСообщения);
								БылиОшибки = Истина;
							КонецПопытки;							
						
						КонецЦикла; // Валюты
					КонецЦикла; // Договоры
			КонецЦикла; // Контрагенты
		КонецЦикла; // Партнеры
	КонецЦикла; // Организации	
	
	СоздатьЗаявкиНаРасходованиеДенежныхСредств(Параметры, СписокОшибок = Неопределено);
	
КонецФункции

Функция СоздатьСчетаНаОплату(Параметры, СписокОшибок = Неопределено)
	
	Если СписокОшибок = Неопределено Тогда
		СписокОшибок = Новый Массив;
	КонецЕсли; 
	Для каждого ЭлСрокиВыставленияСчетов Из Параметры.СрокиВыставленияСчетов Цикл
		Если ЭлСрокиВыставленияСчетов = Перечисления.Логс_СрокиВыставленияСчетаЗаУслугиАгента.ПриОплатеНП Тогда
			
			Запрос = Новый Запрос;
			Запрос.УстановитьПараметр("Период", Новый Граница(КонецДня(Параметры.Период), ВидГраницы.Включая));
			Запрос.УстановитьПараметр("СрокиВыставленияСчетов", Параметры.СрокиВыставленияСчетов);
			Запрос.УстановитьПараметр("ОрганизацияЛогсис", Логс_ДополнительныеПроцедурыИФункцииПовтИсп.ОрганизацияЛогсис());
			
						Запрос.Текст =
			"ВЫБРАТЬ
			|	Логс_ВзаиморасчетыЗаВычетомОстатки.АналитикаУчетаПоПартнерам.Организация КАК Организация,
			|	Логс_ВзаиморасчетыЗаВычетомОстатки.АналитикаУчетаПоПартнерам.Контрагент КАК Контрагент,
			|	Логс_ВзаиморасчетыЗаВычетомОстатки.АналитикаУчетаПоПартнерам.Договор КАК Договор,
			|	Логс_ВзаиморасчетыЗаВычетомОстатки.АналитикаУчетаПоПартнерам.Партнер КАК Партнер,
			|	Логс_ВзаиморасчетыЗаВычетомОстатки.СводЗаявок КАК СводЗаявок,
			|	Логс_ВзаиморасчетыЗаВычетомОстатки.Валюта КАК Валюта,
			|	Логс_ВзаиморасчетыЗаВычетомОстатки.АналитикаУчетаПоПартнерам.Договор.НаименованиеДляПечати КАК НаименованиеДоговора,
			|	Логс_ВзаиморасчетыЗаВычетомОстатки.АналитикаУчетаПоПартнерам.Организация.Логс_ОсновнойБанковскийСчет КАК БанковскийСчет,
			|	Логс_ВзаиморасчетыЗаВычетомОстатки.СводЗаявок.РегиональныйСвод КАК РегиональныйСвод,
			|	Логс_ВзаиморасчетыЗаВычетомОстатки.СводЗаявок.МоментВремени КАК Порядок,
			|	Логс_ВзаиморасчетыЗаВычетомОстатки.АналитикаУчетаПоПартнерам.Договор.Логс_НаименованиеУслугПоДоставке КАК НаименованиеУслугПоДоставке,
			|	ВЫБОР
			|		КОГДА Логс_ВзаиморасчетыЗаВычетомОстатки.СводЗаявок.РегиональныйСвод
			|			ТОГДА Логс_ВзаиморасчетыЗаВычетомОстатки.АналитикаУчетаПоПартнерам.Договор.Логс_СрокПлатежаРег
			|		ИНАЧЕ Логс_ВзаиморасчетыЗаВычетомОстатки.АналитикаУчетаПоПартнерам.Договор.Логс_СрокПлатежа
			|	КОНЕЦ КАК СрокПлатежа,
			|	ВЫБОР
			|		КОГДА Логс_ВзаиморасчетыЗаВычетомОстатки.СводЗаявок.РегиональныйСвод
			|			ТОГДА Логс_ВзаиморасчетыЗаВычетомОстатки.АналитикаУчетаПоПартнерам.Договор.Логс_СрокВыставленияСчетаЗаУслугиАгентаРег
			|		ИНАЧЕ Логс_ВзаиморасчетыЗаВычетомОстатки.АналитикаУчетаПоПартнерам.Договор.Логс_СрокВыставленияСчетаЗаУслугиАгента
			|	КОНЕЦ КАК СрокВыставленияСчетаЗаУслугиАгента,
			|	Логс_ВзаиморасчетыЗаВычетомОстатки.СуммаУслугОстаток КАК Сумма
			|ПОМЕСТИТЬ Данные
			|ИЗ
			|	РегистрНакопления.Логс_ВзаиморасчетыЗаВычетом.Остатки(
			|			&Период,
			|			АналитикаУчетаПоПартнерам.Договор.Логс_СрокВыставленияСчетаЗаУслугиАгентаРег В (&СрокиВыставленияСчетов)
			|			И НЕ АналитикаУчетаПоПартнерам.Организация.Логс_НеФормироватьРеглДокументы
			|				И &ТекстОтбораПоПартнеру) КАК Логс_ВзаиморасчетыЗаВычетомОстатки
			|ГДЕ
			|	Логс_ВзаиморасчетыЗаВычетомОстатки.СуммаУслугОстаток > 0
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	Данные.Организация КАК Организация,
			|	Данные.Партнер КАК Партнер,
			|	Данные.Контрагент КАК Контрагент,
			|	Данные.Договор КАК Договор,
			|	Данные.СводЗаявок КАК СводЗаявок,
			|	Данные.Валюта КАК Валюта,
			|	Данные.НаименованиеДоговора КАК НаименованиеДоговора,
			|	Данные.НаименованиеУслугПоДоставке КАК НаименованиеУслугПоДоставке,
			|	Данные.СрокВыставленияСчетаЗаУслугиАгента КАК СрокВыставленияСчетаЗаУслугиАгента,  
			|	Данные.СрокПлатежа КАК СрокПлатежаСсылка,  
			|	ЕСТЬNULL(СрокиПлатежейПоАгентскомуДоговору.СрокПлатежа, 0) КАК СрокПлатежа,
			|	ЕСТЬNULL(СрокиПлатежейПоАгентскомуДоговору.СрокДата, ЛОЖЬ) КАК СрокПлатежаДата,
			|	Данные.БанковскийСчет КАК БанковскийСчет,
			|	Данные.Сумма КАК Сумма
			|ИЗ
			|	Данные КАК Данные
			|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Логс_СрокиПлатежейПоАгентскомуДоговору КАК СрокиПлатежейПоАгентскомуДоговору
			|		ПО Данные.СрокПлатежа = СрокиПлатежейПоАгентскомуДоговору.Ссылка
			|
			|УПОРЯДОЧИТЬ ПО
			|	Данные.Порядок
			|ИТОГИ
			|	МАКСИМУМ(НаименованиеДоговора),
			|	МАКСИМУМ(НаименованиеУслугПоДоставке),
			|	МАКСИМУМ(СрокВыставленияСчетаЗаУслугиАгента),
			|	МАКСИМУМ(СрокПлатежаСсылка),
			|	МАКСИМУМ(СрокПлатежа),
			|	МАКСИМУМ(СрокПлатежаДата),
			|	СУММА(Сумма)
			|ПО
			|	Организация,
			|	Партнер,
			|	Контрагент,
			|	Договор,
			|	БанковскийСчет,
			|	Валюта";
			
			Если Параметры.Свойство("Партнер") Тогда
				Запрос.УстановитьПараметр("Партнер", Параметры.Партнер);
				ТекстОтбораПоПартнеру = "АналитикаУчетаПоПартнерам.Партнер = &Партнер";
			Иначе
				ТекстОтбораПоПартнеру = "ИСТИНА";
			КонецЕсли;
			
