Функция СоздатьДокументыПоДвижениюДенежныхСредств(Параметры, СписокОшибок = Неопределено)
	
	Перем Партнер;
	
	Если СписокОшибок = Неопределено Тогда
		СписокОшибок = Новый Массив;
	КонецЕсли; 
	
	МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	
	Параметры.Свойство("Партнер", Партнер);
	
	ПоместитьДоговорыПоДвижениюДенежныхСредствВоВременнуюТаблицу(Параметры, МенеджерВременныхТаблиц);
	РегистрыСведений.Логс_ОтборЗаявокНаДоставкуСКС.ПоместитьЗаявкиПоОтборуВоВременнуюТаблицу(
		МенеджерВременныхТаблиц, Параметры.НачалоПериода, Параметры.КонецПериода, Партнер);
	РегистрыСведений.Логс_ПроцентыСтоимостиУслугСКС.ПоместитьДанныеВоВременнуюТаблицу(
		МенеджерВременныхТаблиц, Параметры.НачалоПериода);	
	
	СозданныеДокументы = Новый ТаблицаЗначений;
	СозданныеДокументы.Колонки.Добавить("Партнер", Новый ОписаниеТипов("СправочникСсылка.Партнеры"));
	СозданныеДокументы.Колонки.Добавить("Договор", Новый ОписаниеТипов("СправочникСсылка.ДоговорыКонтрагентов"));
	СозданныеДокументы.Колонки.Добавить("ДокументыПриемаНаКомиссию", Новый ОписаниеТипов("ТаблицаЗначений"));
	СозданныеДокументы.Колонки.Добавить("ДокументыОтчетовКомитентам", Новый ОписаниеТипов("Массив"));
	СозданныеДокументы.Колонки.Добавить("ДокументыАктовВыполненныхРабот", Новый ОписаниеТипов("Массив"));
	СозданныеДокументы.Колонки.Добавить("ДокументыПриобретенияУслугСКС", Новый ОписаниеТипов("Массив"));
	СозданныеДокументы.Индексы.Добавить("Партнер,Договор");
	
	СписокОшибокДляОтчета = Новый Соответствие;
	
	СоздатьДокументыПриемНаКомиссию(Параметры, МенеджерВременныхТаблиц, СозданныеДокументы, СписокОшибокДляОтчета);
	СоздатьДокументыРеализацияТоваровУслуг(Параметры, МенеджерВременныхТаблиц, СозданныеДокументы, СписокОшибокДляОтчета);
	СоздатьДокументыОтчетКомитенту(Параметры, СозданныеДокументы, СписокОшибокДляОтчета);
	СоздатьДокументыАктВыполненныхРабот(Параметры, МенеджерВременныхТаблиц, СозданныеДокументы, СписокОшибокДляОтчета);
	СоздатьДокументыСчетФактурыВыданный(Параметры, СозданныеДокументы, СписокОшибокДляОтчета);
	///////////////////////////////////////////////////////////////////////////////////////////////////
	// Формирование регл. документов по СКС пока отключено. Нужна доработка процедуры,
	// но на текущий момент своды СКС не формируют, поэтому доработка отложена до тех пор,
	// пока не начнут формировать своды СКС
	//
	СоздатьДокументыДвиженияДенежныхСредствПоСКС(Параметры, МенеджерВременныхТаблиц, СозданныеДокументы, СписокОшибокДляОтчета);
	//++ Ким Виктор 17.01.2025
	//https://jira-sd.logsis.ru/projects/TSLOG/queues/custom/18/TSLOG-15412
	//https://jira-sd.logsis.ru/projects/TSLOG/queues/custom/18/TSLOG-15606
	//Перенесен код на форму сводов маршрутов
	//СоздатьДокументыДвиженияДенежныхСредствПоСКСТМС(Параметры, МенеджерВременныхТаблиц, СозданныеДокументы, СписокОшибокДляОтчета);
	//-- Ким Виктор 17.01.2025
	
	
	//
	///////////////////////////////////////////////////////////////////////////////////////////////////
	
	Для каждого КлючИЗначение Из СписокОшибокДляОтчета Цикл
		СписокОшибок.Добавить(Новый Структура("ТекстОшибки,КлючДанных",
			КлючИЗначение.Значение, КлючИЗначение.Ключ));
	КонецЦикла;
	
	Если Параметры.ПоказатьОтчетПоЗавершении Тогда
		ТабличныйДокумент = СформироватьОтчетОСозданныхДокументахДвиженияДС(Параметры, СозданныеДокументы, СписокОшибокДляОтчета);
	Иначе
		ТабличныйДокумент = Неопределено;
	КонецЕсли; 
	
	Возврат ТабличныйДокумент;
	
КонецФункции

Функция СоздатьДокументыПоПоступлениюДенежныхСредств(Параметры, СписокОшибок = Неопределено)
	
	Если СписокОшибок = Неопределено Тогда
		СписокОшибок = Новый Массив;
	КонецЕсли; 
	
	Если Параметры.СоздаватьПКО или Параметры.СоздаватьЭквайринговыеОперации Тогда
	
		ДанныеПоПоступлению = ПолучитьДанныеПоПоступлениюДенежныхСредств(Параметры);
		
		Если Параметры.СоздаватьПКО Тогда
			СоздатьДокументПриходныйКассовыйОрдер(ДанныеПоПоступлению.ПКО, Параметры.ТолькоСоздаватьНовые, СписокОшибок);
		КонецЕсли;
		Если Параметры.СоздаватьЭквайринговыеОперации Тогда
			СоздатьДокументОперацияПоПлатежнойКарте(ДанныеПоПоступлению.ПлатежныеКарты, Параметры.ТолькоСоздаватьНовые, СписокОшибок);
		КонецЕсли;
	КонецЕсли;
	
КонецФункции

