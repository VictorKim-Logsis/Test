Функция ПолучитьДанныеПоПоступлениюДенежныхСредств(Параметры)
	
	МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("НачалоПериода", НачалоДня(Параметры.НачалоПериода));
	Запрос.УстановитьПараметр("КонецПериода", КонецДня(Параметры.КонецПериода));
	Запрос.УстановитьПараметр("ОрганизацияЛогсис", Логс_ДополнительныеПроцедурыИФункцииПовтИсп.ОрганизацияЛогсис());
	Запрос.УстановитьПараметр("ОрганизацияЛССервис", Справочники.Организации.НайтиПоРеквизиту("ИНН", "7734424084"));
	Запрос.УстановитьПараметр("ОрганизацияНЛ", Справочники.Организации.НайтиПоРеквизиту("ИНН", "9725030344"));
	Запрос.УстановитьПараметр("КонтрагентУпр", Справочники.Контрагенты.НайтиПоРеквизиту("ИНН", "9721047523"));
	Запрос.УстановитьПараметр("СвойствоФормироватьПКОПоНаложеннымПлатежа",
		Логс_ДополнительныеПроцедурыИФункцииПовтИсп.СвойствоОрганизацияФормироватьПКОПоНаложеннымПлатежам());
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	НАЧАЛОПЕРИОДА(ЗаявкаНаДоставку.Дата, ДЕНЬ) КАК Период,
	|	ЗаявкаНаДоставку.Договор КАК Договор,
	|	ЗаявкаНаДоставку.Организация КАК Организация,
	|	ЗаявкаНаДоставку.Хаб КАК Хаб,
	|	ЗаявкаНаДоставку.Курьер КАК Курьер,
	|	ЗаявкаНаДоставку.ОплатаНаличные КАК ОплатаНаличные,
	|	ЗаявкаНаДоставку.ОплатаСБП КАК ОплатаСБП,
	|	ЗаявкаНаДоставку.ПровайдерЧека КАК ПровайдерЧека,
	|	СУММА(ЗаявкаНаДоставку.НаложенныйПлатеж) КАК Сумма
	|ПОМЕСТИТЬ ВТ_Заявки
	|ИЗ
	|	Документ.Логс_ЗаявкаНаДоставку КАК ЗаявкаНаДоставку
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Организации.ДополнительныеРеквизиты КАК ДопРеквизитыОрганизации
	|		ПО ЗаявкаНаДоставку.Организация = ДопРеквизитыОрганизации.Ссылка
	|			И (ДопРеквизитыОрганизации.Свойство = &СвойствоФормироватьПКОПоНаложеннымПлатежа)
	|ГДЕ
	|	ЗаявкаНаДоставку.Дата МЕЖДУ &НачалоПериода И &КонецПериода
	|	И НЕ(ЗаявкаНаДоставку.ОплатаНаличные
	|				И ЕСТЬNULL(ДопРеквизитыОрганизации.Свойство, ЛОЖЬ) = ЛОЖЬ)
	|	И ЗаявкаНаДоставку.Проведен
	|	И НЕ ЗаявкаНаДоставку.ТДРегион
	|	И НЕ ЗаявкаНаДоставку.Хаб.ЯвляетсяСКС
	|	И НЕ ЗаявкаНаДоставку.Партнер = ЗНАЧЕНИЕ(Справочник.Партнеры.ПустаяСсылка)
	|	И ЗаявкаНаДоставку.НаложенныйПлатеж > 0
	|	И &ТекстОтбораПоПартнеру
	|
	|СГРУППИРОВАТЬ ПО
	|	ЗаявкаНаДоставку.Организация,
	|	ЗаявкаНаДоставку.Хаб,
	|	ЗаявкаНаДоставку.Курьер,
	|	ЗаявкаНаДоставку.Договор,
	|	ЗаявкаНаДоставку.ОплатаНаличные,
	|	ЗаявкаНаДоставку.ОплатаСБП,
	|	ЗаявкаНаДоставку.ПровайдерЧека,
	|	НАЧАЛОПЕРИОДА(ЗаявкаНаДоставку.Дата, ДЕНЬ)
