	|		ЛЕВОЕ СОЕДИНЕНИЕ ГрафикОплаты КАК ГрафикОплаты
	|		ПО (ИСТИНА)
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.Логс_ИсторияФормыОплатыДоговоров.СрезПоследних(&Период, ) КАК Логс_ИсторияФормыОплатыДоговоровСрезПоследних
	|		ПО СчетНаОплатуКлиенту.Договор = Логс_ИсторияФормыОплатыДоговоровСрезПоследних.ДоговорКонтрагентов
	|			И (Логс_ИсторияФормыОплатыДоговоровСрезПоследних.ФормаОплатыУслугАгенту = ЗНАЧЕНИЕ(Перечисление.Логс_ФормыОплатыУслугАгенту.Оплата100))
	|ГДЕ
	|	СчетНаОплатуКлиенту.Ссылка = &Ссылка
	|	И НЕ СчетНаОплатуКлиенту.Аннулирован
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СчетНаОплатуКлиенту.Период КАК Период,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход) КАК ВидДвижения,
	|	СчетНаОплатуКлиенту.АналитикаУчетаПоПартнерам КАК АналитикаУчетаПоПартнерам,
	|	ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.РеализацияКлиенту) КАК ХозяйственнаяОперация,
	|	СчетНаОплатуКлиенту.ДатаПлановогоПогашения КАК ДатаПлановогоПогашения,
	|	СчетНаОплатуКлиенту.Счет КАК Счет,
	|	СчетНаОплатуКлиенту.Валюта КАК Валюта,
	|	СчетНаОплатуКлиенту.Долг КАК Долг,
	|	0 КАК Предоплата
	|ИЗ
	|	ДанныеСчет КАК СчетНаОплатуКлиенту
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СУММА(Логс_ВзаиморасчетыПоУслугам100Остатки.ПредоплатаОстаток) КАК Предоплата,
	|	Логс_ВзаиморасчетыПоУслугам100Остатки.Счет КАК Счет,
	|	Логс_ВзаиморасчетыПоУслугам100Остатки.Валюта КАК Валюта
	|ИЗ
	|	ДанныеСчет КАК СчетНаОплатуКлиенту
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.Логс_ВзаиморасчетыПоУслугам100.Остатки(&Период, ) КАК Логс_ВзаиморасчетыПоУслугам100Остатки
	|		ПО СчетНаОплатуКлиенту.АналитикаУчетаПоПартнерам = Логс_ВзаиморасчетыПоУслугам100Остатки.АналитикаУчетаПоПартнерам
	|			И СчетНаОплатуКлиенту.Счет = Логс_ВзаиморасчетыПоУслугам100Остатки.Счет
	|
	|СГРУППИРОВАТЬ ПО
	|	Логс_ВзаиморасчетыПоУслугам100Остатки.Счет,
	|	Логс_ВзаиморасчетыПоУслугам100Остатки.Валюта
	|
	|ИМЕЮЩИЕ
	|	СУММА(Логс_ВзаиморасчетыПоУслугам100Остатки.ПредоплатаОстаток) > 0");
	
	Запрос.УстановитьПараметр("Ссылка", Источник.Ссылка);
	Запрос.УстановитьПараметр("Период", Источник.МоментВремени());
	
	ПроведениеСерверУТ.ИнициализироватьДополнительныеСвойстваДляПроведения(Источник.Ссылка,
		Источник.ДополнительныеСвойства, РежимПроведения);
	
	Источник.ДополнительныеСвойства.Вставить("ЭтоНовый",    Источник.ЭтоНовый());
	Источник.ДополнительныеСвойства.Вставить("РежимЗаписи", РежимЗаписиДокумента.Проведение);
	
	Рез = Запрос.ВыполнитьПакет();
	
	ТаблицаДвижений = Рез[2].Выгрузить();
	ЗаписатьДвиженияРасчетовПоУслугамЗаДоставку(Источник, ТаблицаДвижений);
	
	ТаблицаДвижений = Рез[3].Выгрузить();
	ЗаписатьДвиженияСчетаПоУслугам100(Источник, ТаблицаДвижений);
	
	ТаблицаДвижений = Рез[5].Выгрузить();
	ТаблицаДвиженийАванс = ТаблицаДвижений.Скопировать();
	ТаблицаДвиженийАванс.Очистить();
	Если ТаблицаДвижений.Количество() > 0 Тогда
		
		// если были переплаты, то выполним зачет
		ТаблицаАванс = Рез[6].Выгрузить();
		Стр0 = ТаблицаДвижений[0];
		Ост = Стр0.Долг;
		Для каждого Строка Из ТаблицаАванс Цикл
			Если Ост = 0 Тогда
				Прервать;
			КонецЕсли;	
			Если Ост >= Строка.Предоплата Тогда
				СуммаАванс = Строка.Предоплата;
				Ост = Ост - Строка.Предоплата;
			Иначе
				СуммаАванс = Ост;
				Ост = 0;
			КонецЕсли;	
			НовСтрока = ТаблицаДвиженийАванс.Добавить();
			НовСтрока.Период = Стр0.Период;
			НовСтрока.ВидДвижения = ВидДвиженияНакопления.Расход;
			НовСтрока.АналитикаУчетаПоПартнерам = Стр0.АналитикаУчетаПоПартнерам;
			НовСтрока.Валюта = Строка.Валюта;
			НовСтрока.ХозяйственнаяОперация = перечисления.ХозяйственныеОперации.ВзаимозачетЗадолженности;
			НовСтрока.Счет = Строка.Счет;
			НовСтрока.Предоплата = СуммаАванс;
			
			НовСтрока = ТаблицаДвиженийАванс.Добавить();
			ЗаполнитьЗначенияСвойств(НовСтрока, Стр0); 
			НовСтрока.ВидДвижения = ВидДвиженияНакопления.Расход;
			НовСтрока.ХозяйственнаяОперация = перечисления.ХозяйственныеОперации.ВзаимозачетЗадолженности;
			НовСтрока.Долг = СуммаАванс;
			
		КонецЦикла;	
		
	КонецЕсли;	
	
	Для каждого Строка Из ТаблицаДвиженийАванс Цикл
		НовСтрока = ТаблицаДвижений.Добавить();
		ЗаполнитьЗначенияСвойств(НовСтрока, Строка);
	КонецЦикла;	
	
	ЗаписатьДвиженияВзаиморасчетыПоУслугам100(Источник, ТаблицаДвижений);	
	
КонецПроцедуры 

Процедура ДвиженияРасчетовПоСводамЗаявокНаДоставкуПоступлениеБезналичныхДС(Источник, Отказ, РежимПроведения)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ПоступлениеБезналичныхДенежныхСредств.Дата КАК Дата,
	|	ПоступлениеБезналичныхДенежныхСредств.Номер КАК Номер,
	|	Аналитика.КлючАналитики КАК АналитикаУчетаПоПартнерам,
	|	РаспределениеПоСводам.СводЗаявок КАК СводЗаявок,
	|	ДокСводЗаявокНаДоставку.Валюта КАК Валюта,
	|	ПоступлениеБезналичныхДенежныхСредств.ХозяйственнаяОперация КАК ХозяйственнаяОперация,
	|	ПоступлениеБезналичныхДенежныхСредств.ПроведеноБанком КАК ПроведеноБанком,
	|	РаспределениеПоСводам.Сумма КАК Сумма
	|ПОМЕСТИТЬ Данные
	|ИЗ
	|	Документ.ПоступлениеБезналичныхДенежныхСредств.Логс_РаспределениеПоСводамЗаявокНаДоставку КАК РаспределениеПоСводам
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПоступлениеБезналичныхДенежныхСредств КАК ПоступлениеБезналичныхДенежныхСредств
	|		ПО РаспределениеПоСводам.Ссылка = ПоступлениеБезналичныхДенежныхСредств.Ссылка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.Логс_СводЗаявокНаДоставку КАК ДокСводЗаявокНаДоставку
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.АналитикаУчетаПоПартнерам КАК Аналитика
	|			ПО ДокСводЗаявокНаДоставку.Партнер = Аналитика.Партнер
	|				И ДокСводЗаявокНаДоставку.Организация = Аналитика.Организация
	|				И ДокСводЗаявокНаДоставку.Контрагент = Аналитика.Контрагент
	|				И ДокСводЗаявокНаДоставку.Договор = Аналитика.Договор
	|				И (Аналитика.НаправлениеДеятельности = ЗНАЧЕНИЕ(Справочник.НаправленияДеятельности.ПустаяСсылка))
	|		ПО РаспределениеПоСводам.СводЗаявок = ДокСводЗаявокНаДоставку.Ссылка
	|ГДЕ
	|	РаспределениеПоСводам.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Данные.Дата КАК Период,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход) КАК ВидДвижения,
	|	Данные.АналитикаУчетаПоПартнерам КАК АналитикаУчетаПоПартнерам,
	|	Данные.СводЗаявок КАК СводЗаявок,
	|	Данные.Валюта КАК Валюта,
	|	Данные.ХозяйственнаяОперация КАК ХозяйственнаяОперация,
	|	Данные.Дата КАК ДатаРегистратора,
	|	Данные.Номер КАК НомерРегистратора,
	|	Данные.Сумма КАК Сумма,
	|	Данные.Сумма КАК КОплате,
	|	Данные.Сумма КАК Оплачивается,
	|	Данные.Сумма КАК Выставлено
	|ИЗ
	|	Данные КАК Данные
	|ГДЕ
	|	Данные.ПроведеноБанком
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Данные.Дата,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход),
	|	Данные.АналитикаУчетаПоПартнерам,
	|	Данные.СводЗаявок,
	|	Данные.Валюта,
	|	Данные.ХозяйственнаяОперация,
	|	Данные.Дата,
	|	Данные.Номер,
	|	0,
	|	0,
	|	Данные.Сумма,
	|	0
	|ИЗ
	|	Данные КАК Данные");
	
	Запрос.УстановитьПараметр("Ссылка", Источник.Ссылка);
	
	ТаблицаДвижений = Запрос.Выполнить().Выгрузить();
	
	Если ТаблицаДвижений.Количество() = 0 Тогда
		Возврат;
	КонецЕсли; 
	
	ПроведениеСерверУТ.ИнициализироватьДополнительныеСвойстваДляПроведения(Источник.Ссылка,
		Источник.ДополнительныеСвойства, РежимПроведения);
	
	Источник.ДополнительныеСвойства.Вставить("ЭтоНовый",    Источник.ЭтоНовый());
	Источник.ДополнительныеСвойства.Вставить("РежимЗаписи", РежимЗаписиДокумента.Проведение);
	
	ЗаписатьДвиженияРасчетовПоУслугамЗаДоставку(Источник, ТаблицаДвижений);
	            
	Источник.Движения.Логс_РасчетыПоУслугамЗаДоставку.Записать();
	Источник.Движения.Логс_РасчетыПоУслугамЗаДоставку.Записывать = Ложь; // Избежание повторной записи регистра.
	
	МассивЗавимыхСводовЗаявок = ТаблицаДвижений.ВыгрузитьКолонку("СводЗаявок");
	
	Источник.ДополнительныеСвойства.Вставить("МассивЗависимыхСводовЗаявок", Новый ФиксированныйМассив(МассивЗавимыхСводовЗаявок));
	РегистрыСведений.Логс_СостоянияСводовЗаявокНаДоставку.ОтразитьСостояниеСводаЗаявокНаДоставку(Источник, Отказ);
	
КонецПроцедуры

Процедура ДвиженияРасчетовПоСводамЗаявокНаДоставкуПоступлениеБезналичныхДСПоFIFO(Источник, Отказ, РежимПроведения)
	
	ТаблицаДвижений = СоздатьТаблицуДвиженийРасчетыПоУслугамЗаДоставку();
	МассивЗавимыхСводовЗаявок = Новый Массив;
	
	Запрос = Новый Запрос(ТекстЗапросаСводыЗаявокОплачиваемыеКлиентом());
	Запрос.УстановитьПараметр("Ссылка", Источник.Ссылка);
	Запрос.УстановитьПараметр("Период", Источник.Дата);
	Запрос.УстановитьПараметр("ПериодГраница", Новый Граница(Источник.МоментВремени(), ВидГраницы.Исключая));
	
	ВыборкаАналитика = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаАналитика.Следующий() Цикл
		ВыборкаВалюта = ВыборкаАналитика.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаВалюта.Следующий() Цикл
			
			Если ВыборкаВалюта.Сумма <= 0 Тогда
				// Нет положительного общего остатка по сводам. Закрывать нечего.
				Продолжить;
			КонецЕсли; 
			
			ТаблицаСводов = СоздатьТаблицуСводовЗаявокОплачиваемыхКлиентом();
			
			СуммаПлатежа = ВыборкаВалюта.СуммаПлатежа;
			
			// Заполним таблицу сводов, по которым есть остатки, чтобы потом "раскрутить"
			// её в обратном порядке для корректного зачёта отрицательных сумм.
			Выборка = ВыборкаВалюта.Выбрать();
			Пока Выборка.Следующий() Цикл
				СтрокаСвода = ТаблицаСводов.Добавить();
				СтрокаСвода.Период = Выборка.Период;
				СтрокаСвода.ДатаРегистратора = Выборка.ДатаРегистратора;
				СтрокаСвода.НомерРегистратора = Выборка.НомерРегистратора;
				СтрокаСвода.ХозяйственнаяОперация = Выборка.ХозяйственнаяОперация;
				СтрокаСвода.СводЗаявок = Выборка.СводЗаявок;
				СтрокаСвода.Сумма = Выборка.Сумма;
				СтрокаСвода.КОплате = Выборка.КОплате;
				СтрокаСвода.КВыставлению = Выборка.КВыставлению;
				СтрокаСвода.Выставлено = Выборка.Выставлено;
			КонецЦикла; 
			
			// В обратном порядке ищём свод, по которому возник отрацительный остаток.
			ТекОстаток = ВыборкаВалюта.Сумма;
			
			НомерПоследнейСтроки = ТаблицаСводов.Количество() - 1;
			Пока НомерПоследнейСтроки >= 0 Цикл
				СтрокаСвода = ТаблицаСводов[НомерПоследнейСтроки];
				
				ТекОстаток = ТекОстаток + СтрокаСвода.Сумма;
				Если ТекОстаток < 0 Тогда
					Прервать;
				КонецЕсли; 
				
				НомерПоследнейСтроки = НомерПоследнейСтроки - 1;
			КонецЦикла; 
			
			// Добавляем в движения все своды до того свода, по которому найден отрицательный остаток включительно.
			ТекОстаток = 0;
			
			Для НомерСтроки = 0 По НомерПоследнейСтроки Цикл
				СтрокаСвода = ТаблицаСводов[НомерСтроки];
				
				ДобавитьДвижениеРасчетыПоУслугамЗаДоставкуВТаблицу(ТаблицаДвижений, Источник, СтрокаСвода,
					ВыборкаВалюта.КлючАналитики, ВыборкаВалюта.Валюта, СтрокаСвода.Сумма);
				
				МассивЗавимыхСводовЗаявок.Добавить(СтрокаСвода.СводЗаявок);
				
				ТекОстаток = ТекОстаток + СтрокаСвода.Сумма;
			КонецЦикла;
			
			// Из оставшихся строк таблицы набираем своды на нужную сумму.
			Для НомерСтроки = НомерПоследнейСтроки + 1 По ТаблицаСводов.Количество() - 1 Цикл
				
				СтрокаСвода = ТаблицаСводов[НомерСтроки];
				
				МассивЗавимыхСводовЗаявок.Добавить(СтрокаСвода.СводЗаявок);
				
				Если ТекОстаток + СтрокаСвода.Сумма < СуммаПлатежа Тогда
					// Свод подходит в полном объёме.
					ДобавитьДвижениеРасчетыПоУслугамЗаДоставкуВТаблицу(ТаблицаДвижений, Источник, СтрокаСвода,
						ВыборкаВалюта.КлючАналитики, ВыборкаВалюта.Валюта, СтрокаСвода.Сумма);
				Иначе
					Сумма = СуммаПлатежа - ТекОстаток;
					ДобавитьДвижениеРасчетыПоУслугамЗаДоставкуВТаблицу(ТаблицаДвижений, Источник, СтрокаСвода,
						ВыборкаВалюта.КлючАналитики, ВыборкаВалюта.Валюта, Сумма);
						
					// Нужную сумму из сводов набрали.
					Прервать;
				КонецЕсли; 
				
				ТекОстаток = ТекОстаток + СтрокаСвода.Сумма;
				
			КонецЦикла;
			
		КонецЦикла; 
	КонецЦикла; 
	
	Если ТаблицаДвижений.Количество() = 0 Тогда
		Возврат;
	КонецЕсли; 
	
	ПроведениеСерверУТ.ИнициализироватьДополнительныеСвойстваДляПроведения(Источник.Ссылка,
		Источник.ДополнительныеСвойства, РежимПроведения);
	
	Источник.ДополнительныеСвойства.Вставить("ЭтоНовый",    Источник.ЭтоНовый());
	Источник.ДополнительныеСвойства.Вставить("РежимЗаписи", РежимЗаписиДокумента.Проведение);
	
	ЗаписатьДвиженияРасчетовПоУслугамЗаДоставку(Источник, ТаблицаДвижений);
	            
	Источник.Движения.Логс_РасчетыПоУслугамЗаДоставку.Записать();
	Источник.Движения.Логс_РасчетыПоУслугамЗаДоставку.Записывать = Ложь; // Избежание повторной записи регистра.
	
	Источник.ДополнительныеСвойства.Вставить("МассивЗависимыхСводовЗаявок", Новый ФиксированныйМассив(МассивЗавимыхСводовЗаявок));
	РегистрыСведений.Логс_СостоянияСводовЗаявокНаДоставку.ОтразитьСостояниеСводаЗаявокНаДоставку(Источник, Отказ);
	
КонецПроцедуры 

Процедура ДвиженияРасчетовПоСводамЗаявокНаДоставкуПоступлениеБезналичныхДС_20(Источник, Отказ, РежимПроведения)
	
	ТаблицаДвижений = СоздатьТаблицуДвиженийВзаиморасчетыПоУслугам100();

	Запрос = Новый Запрос(ТекстЗапросаСводыЗаявокОплачиваемыеКлиентом_20());
	Запрос.УстановитьПараметр("Ссылка", Источник.Ссылка);
	Запрос.УстановитьПараметр("Период", Источник.Дата);
	Запрос.УстановитьПараметр("ПериодГраница", Новый Граница(Источник.МоментВремени(), ВидГраницы.Исключая));
	
