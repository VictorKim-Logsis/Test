Процедура ДобавитьДвижениеРасчетыПоУслугамЗаДоставкуВТаблицу(ТаблицаДвижений, Источник, СтрокаСвода, КлючАналитики, Валюта, Сумма)
	
	Если Источник.ПроведеноБанком Тогда
			
		Движение = ТаблицаДвижений.Добавить();
		Движение.Период = СтрокаСвода.Период;
		Движение.ВидДвижения = ВидДвиженияНакопления.Расход;
		Движение.АналитикаУчетаПоПартнерам = КлючАналитики;
		Движение.СводЗаявок = СтрокаСвода.СводЗаявок;
		Движение.Валюта = Валюта;
		Движение.ХозяйственнаяОперация = СтрокаСвода.ХозяйственнаяОперация;
		Движение.ДатаРегистратора = СтрокаСвода.ДатаРегистратора;
		Движение.НомерРегистратора = СтрокаСвода.НомерРегистратора;
		Движение.Сумма = Сумма;
		Движение.Оплачивается = Сумма;
		
		Если СтрокаСвода.Выставлено <> 0 Тогда
			// Был выставлен счёт.
			
			Если СтрокаСвода.Сумма = Сумма Тогда
				// Свод оплачен полностью. Так же полностью спишем остатки по счёту.
				// Например, свод был на 1000 руб, счёт выставили на 800, но оплатили полностью 1000.
				Выставлено = СтрокаСвода.Выставлено;
			Иначе
				Выставлено = Мин(СтрокаСвода.Выставлено, Сумма);
			КонецЕсли; 
			
			КВыставлению = Выставлено - Сумма; // Корректировка, если оплатили больше, чем сумма по счёту.
			
			Движение.КОплате = Выставлено;
			Движение.Выставлено = Выставлено;
			Движение.КВыставлению = КВыставлению;
			
		Иначе
			// Оплата без счёта.
			
			Движение.КВыставлению = -Сумма;
			
		КонецЕсли;
		
	КонецЕсли; 
	
	Движение = ТаблицаДвижений.Добавить();
	Движение.Период = СтрокаСвода.Период;
	Движение.ВидДвижения = ВидДвиженияНакопления.Приход;
	Движение.АналитикаУчетаПоПартнерам = КлючАналитики;
	Движение.СводЗаявок = СтрокаСвода.СводЗаявок;
	Движение.Валюта = Валюта;
	Движение.ХозяйственнаяОперация = СтрокаСвода.ХозяйственнаяОперация;
	Движение.ДатаРегистратора = СтрокаСвода.ДатаРегистратора;
	Движение.НомерРегистратора = СтрокаСвода.НомерРегистратора;
	Движение.Сумма = 0;
	Движение.КОплате = 0;
	Движение.Оплачивается = Сумма;
	Движение.Выставлено = 0;
		
КонецПроцедуры 

Процедура ЗаписатьДвиженияРасчетовПоНаложеннымПлатежам(Источник, ТаблицаДвижений)
	
	Если ТаблицаДвижений.Количество() = 0 Тогда
