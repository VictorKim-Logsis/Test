Функция ПолучитьХарактеристикуНоменклатурыАгента(Номенклатура, НомерСводаЗаявокНаДоставку, СоздаватьНовую = Истина) Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ХарактеристикиНоменклатуры.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ХарактеристикиНоменклатуры КАК ХарактеристикиНоменклатуры
	|ГДЕ
	|	ХарактеристикиНоменклатуры.Владелец = &Номенклатура
	|	И ХарактеристикиНоменклатуры.Наименование = &НомерСводаЗаявокНаДоставку
	|	И НЕ ХарактеристикиНоменклатуры.ПометкаУдаления");
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	Запрос.УстановитьПараметр("НомерСводаЗаявокНаДоставку", НомерСводаЗаявокНаДоставку);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ссылка;
	КонецЕсли; 
	
	Если Не СоздаватьНовую Тогда
		Возврат Справочники.ХарактеристикиНоменклатуры.ПустаяСсылка();
	КонецЕсли; 
	
	Характеристика = Справочники.ХарактеристикиНоменклатуры.СоздатьЭлемент();
	Характеристика.Владелец = Номенклатура;
	Характеристика.Наименование = НомерСводаЗаявокНаДоставку;
	Характеристика.НаименованиеПолное = Характеристика.Наименование;
	Характеристика.Записать();
	
	Возврат Характеристика.Ссылка;
	
КонецФункции 

Функция ПолучитьБлижайшийДеньНедели(Знач Дата, ДниНедели) Экспорт
	
	ТипЧисло = Тип("Число");
	
	// Проверка корретности переданных данных, иначе возможно зацикливание.
	Для каждого ДеньНедели Из ДниНедели Цикл
		Если ТипЗнч(ДеньНедели) <> ТипЧисло
				Или ДеньНедели < 1
				Или ДеньНедели > 7 Тогда
			ВызватьИсключение СтрШаблон(НСтр("ru='Массив дней недели содержит неверный элемент %1'"), ДеньНедели);
		КонецЕсли; 
	КонецЦикла;
	
	ТекДеньНедели = ДеньНедели(Дата);
	Пока ДниНедели.Найти(ТекДеньНедели) = Неопределено Цикл
		Дата = Дата + 86400;
		ТекДеньНедели = ДеньНедели(Дата);
	КонецЦикла; 
	
	Возврат Дата;
	
КонецФункции 

Функция СформироватьНаименованиеУслугНаДоставкуПоСводу(СводУслуг, УказыватьПериод = Ложь, УказыватьДоговор = Ложь) Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	СводУслуг.Номер КАК Номер,
	|	СводУслуг.Дата КАК Дата,
	|	СводУслуг.ВидКлиента КАК ВидКлиента,
	|	ДоговорыКонтрагентов.Логс_НаименованиеУслугПоДоставке КАК НаименованиеУслугПоДоставке,
	|	ДоговорыКонтрагентов.Логс_ДоговорНаОказаниеУслуг КАК ДоговорНаОказаниеУслуг,
	|	ДоговорыКонтрагентов.Ссылка как Договор
	|ИЗ
	|	Документ.Логс_СводЗаявокНаДоставку КАК СводУслуг
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
	|		ПО СводУслуг.Договор = ДоговорыКонтрагентов.Ссылка
	|ГДЕ
	|	СводУслуг.Ссылка = &Ссылка");
	Запрос.УстановитьПараметр("Ссылка", СводУслуг);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Не Выборка.Следующий() Тогда
		Возврат Строка(СводУслуг);
	КонецЕсли; 
	
	Если Выборка.ВидКлиента = Перечисления.Логс_ВидыКлиентовCRM.Принципал Тогда
		ШаблонНаименования = ?(Выборка.ДоговорНаОказаниеУслуг,
			НСтр("ru='%1 по отчету о доставке заказов №%2 от %3'"),
			НСтр("ru='%1 по отчету агента №%2 от %3'"));
	ИначеЕсли Выборка.ВидКлиента = Перечисления.Логс_ВидыКлиентовCRM.Агент Тогда
		ШаблонНаименования = ?(Выборка.ДоговорНаОказаниеУслуг,
			НСтр("ru='%1 по отчету о доставке заказов №%2 от %3'"),
			НСтр("ru='%1 по отчету субагента №%2 от %3'"));
	Иначе
		ШаблонНаименования = НСтр("ru='%1 по отчету субагента №%2 от %3'");
	КонецЕсли; 
	
	Наименование = СтрШаблон(ШаблонНаименования, Выборка.НаименованиеУслугПоДоставке, Выборка.Номер, Формат(Выборка.Дата, "ДФ=dd.MM.yyyy"));
	
	Если УказыватьДоговор Тогда
		ДополнениеКСодержанию = СтрШаблон(НСтр("ru=' по %1'"), Выборка.Договор);
		Наименование = Наименование + ДополнениеКСодержанию;
	КонецЕсли;
	
	Если УказыватьПериод Тогда
		ДатаНачалаУчета = Дата(2019, 6, 27);
		НачалоПериода = Макс(
			ДатаНачалаУчета,
			?(День(Выборка.Дата) <= 15,
				НачалоМесяца(Выборка.Дата),
				Дата(Год(Выборка.Дата), Месяц(Выборка.Дата), 16)
			));
		КонецПериода = Выборка.Дата;
		ДополнениеКСодержанию = СтрШаблон(НСтр("ru=' за период с %1 по %2'"),
			День(НачалоПериода), Формат(КонецПериода, "ДЛФ=DD"));
		Наименование = Наименование + ДополнениеКСодержанию;
	КонецЕсли;
	
	
	Возврат Наименование;
	
КонецФункции 

Функция РегистраторРасчетовПоУслугамЗаДоставку(ОбъектРасчетов, АналитикаУчетаПоПартнерам, Валюта, Организация = Неопределено) Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	РегистраторРасчетов.Ссылка КАК Ссылка,
	|	РегистраторРасчетов.Дата КАК Дата,
	|	РегистраторРасчетов.Проведен КАК Проведен
	|ИЗ
	|	Документ.Логс_РегистраторРасчетовПоУслугамЗаДоставку КАК РегистраторРасчетов
	|ГДЕ
	|	РегистраторРасчетов.ОбъектРасчетов = &ОбъектРасчетов
	|	И РегистраторРасчетов.АналитикаУчетаПоПартнерам = &АналитикаУчетаПоПартнерам
	|	И РегистраторРасчетов.Валюта = &Валюта
	|	И НЕ РегистраторРасчетов.ПометкаУдаления");
	Запрос.УстановитьПараметр("Валюта", Валюта);
	Запрос.УстановитьПараметр("АналитикаУчетаПоПартнерам", АналитикаУчетаПоПартнерам);
	Запрос.УстановитьПараметр("ОбъектРасчетов", ОбъектРасчетов);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		ДокументОбъект = Выборка.Ссылка.ПолучитьОбъект();
		Если Не Выборка.Проведен Тогда
			ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение);
		КонецЕсли; 
	Иначе
		ДокументОбъект = Документы.Логс_РегистраторРасчетовПоУслугамЗаДоставку.СоздатьДокумент();
		ДокументОбъект.Валюта = Валюта;
		ДокументОбъект.АналитикаУчетаПоПартнерам = АналитикаУчетаПоПартнерам;
		ДокументОбъект.Организация = ?(Организация = Неопределено,
			ОбщегоНазначения.ЗначениеРеквизитаОбъекта(АналитикаУчетаПоПартнерам, "Организация"),
			Организация);
		ДокументОбъект.ОбъектРасчетов = ОбъектРасчетов;
		ДокументОбъект.Дата = ТекущаяДатаСеанса();
		ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение);
	КонецЕсли; 
	
	Возврат ДокументОбъект;
	
КонецФункции 

Функция ПодключитьВнешнююОбработкуИзДвоичныхДанных(ДвоичныеДанные) Экспорт
	
	АдресВоВременномХранилище = ПоместитьВоВременноеХранилище(ДвоичныеДанные);
	
	Если ОбщегоНазначения.ЕстьЗащитаОтОпасныхДействий() Тогда
		ИмяОбработки = ВнешниеОбработки.Подключить(АдресВоВременномХранилище,, Ложь,
			ОбщегоНазначения.ОписаниеЗащитыБезПредупреждений());
	Иначе
		ИмяОбработки = ВнешниеОбработки.Подключить(АдресВоВременномХранилище,, Ложь);
	КонецЕсли; 
	
	Возврат ВнешниеОбработки.Создать(ИмяОбработки);
	
КонецФункции 

Функция ПодключитьВнешнююОбработкуИзХранилищаЗначения(ХранилищеЗначения) Экспорт
	
	Возврат ПодключитьВнешнююОбработкуИзДвоичныхДанных(ХранилищеЗначения.Получить());
	
КонецФункции 

// Определяет, используется ли по документу КУДИР в особом порядке.
//
// Параметры:
//  ДокументСсылка - ДокументСсылка - ссылка на документ.
// 
// Возвращаемое значение:
//  Булево - Истина, если по документу КУДИР в особом порядке.
//
Функция КУДИРвОсобомПорядке(ДокументСсылка) Экспорт
	
	ТипДокумента = ТипЗнч(ДокументСсылка);
	
	Если ТипДокумента = Тип("ДокументСсылка.ПоступлениеБезналичныхДенежныхСредств") Тогда
		
		РеквизитыДокумента = ПолучитьРеквизитыКУДИРПоступленияДС(ДокументСсылка);
		
		Если РеквизитыДокумента.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ПоступлениеОплатыПоПлатежнойКарте
				Или РеквизитыДокумента.КУДиРвОсобомПорядке
		Тогда
			Возврат Истина;
		КонецЕсли;
		
	//ИначеЕсли ТипДокумента = Тип("ДокументСсылка.ОтчетБанкаПоОперациямЭквайринга") Тогда
	//	
	//	Возврат Истина;
	ИначеЕсли ТипДокумента = Тип("ДокументСсылка.СписаниеБезналичныхДенежныхСредств") Тогда
		
		РеквизитыДокумента = ПолучитьРеквизитыКУДИРСписанияДС(ДокументСсылка);
		
		Если РеквизитыДокумента.КУДиРвОсобомПорядке Тогда
			Возврат Истина;
		КонецЕсли;
		              
	ИначеЕсли ТипДокумента = Тип("ДокументСсылка.ОтчетКомитенту") Тогда
		
		РеквизитыДокумента = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДокументСсылка,
			"УдержатьВознаграждение,Договор,СуммаДокумента,СуммаВознаграждения");
		
		Если Не РеквизитыДокумента.УдержатьВознаграждение Тогда
			Возврат Истина;
		КонецЕсли; 
		
	ИначеЕсли ТипДокумента = Тип("ДокументСсылка.КорректировкаЗадолженности") Тогда
		
		Если ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументСсылка, "Логс_НеФомироватьРасходыУСН") Тогда
			Возврат Истина;
		КонецЕсли; 
		
	Иначе
		
		ДокументМетаданные = ДокументСсылка.Метаданные();
		
		Если ДокументМетаданные.Реквизиты.Найти("Логс_КУДиРвОсобомПорядке") <> Неопределено Тогда
			
			Если ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументСсылка, "Логс_КУДиРвОсобомПорядке") = Истина Тогда
				Возврат Истина;
			КонецЕсли; 
			
		КонецЕсли; 
		
		Если ТипДокумента <> Тип("ДокументСсылка.ПриобретениеУслугПрочихАктивов")
				И ДокументМетаданные.Реквизиты.Найти("Договор") <> Неопределено
		Тогда
			
			Договор = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументСсылка, "Договор");
			Возврат ЗначениеЗаполнено(Договор)
						И ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Договор, "Логс_КУДиРвОсобомПорядке") = Истина;
						
		КонецЕсли;
		
	КонецЕсли; 
	
	Возврат Ложь;
	
КонецФункции 

Функция СформироватьНаименованиеУслугНаДоставкуПоСводуМаршрутов(СводМаршрутов, УказыватьПериод = Ложь, УказыватьДоговор = Ложь) Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	Логс_СводМаршрутов.Номер КАК Номер,
	|	Логс_СводМаршрутов.Дата КАК Дата,
	|	ДоговорыКонтрагентов.Логс_НаименованиеУслугПоДоставке КАК НаименованиеУслугПоДоставке,
	|	ДоговорыКонтрагентов.Логс_ДоговорНаОказаниеУслуг КАК ДоговорНаОказаниеУслуг,
	|	ДоговорыКонтрагентов.Ссылка КАК Договор,
	|	Логс_СводМаршрутов.Ссылка КАК СводМаршрутов
	|ИЗ
	|	Документ.Логс_СводМаршрутов КАК Логс_СводМаршрутов
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
	|		ПО Логс_СводМаршрутов.ДоговорСКС = ДоговорыКонтрагентов.Ссылка
	|ГДЕ
	|	Логс_СводМаршрутов.Ссылка = &Ссылка");
	Запрос.УстановитьПараметр("Ссылка", СводМаршрутов);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Не Выборка.Следующий() Тогда
		Возврат Строка(СводМаршрутов);
	КонецЕсли; 
	
	ШаблонНаименования = НСтр("ru='%1 по отчету субагента №%2 от %3'");
	
	//"Субагентское вознаграждение за доставку заказов по отчету субагента №5783-SKS-00002 от 31.12.2024"
	//Наименование = СтрШаблон(ШаблонНаименования, Выборка.НаименованиеУслугПоДоставке, Выборка.Номер, Формат(Выборка.Дата, "ДФ=dd.MM.yyyy"));
	Наименование = СтрШаблон(ШаблонНаименования, "Субагентское вознаграждение за доставку заказов", Выборка.Номер, Формат(Выборка.Дата, "ДФ=dd.MM.yyyy"));
	
	Если УказыватьДоговор Тогда
		ДополнениеКСодержанию = СтрШаблон(НСтр("ru=' по %1'"), Выборка.Договор);
		Наименование = Наименование + ДополнениеКСодержанию;
	КонецЕсли;
	
	Если УказыватьПериод Тогда
		ДатаНачалаУчета = Дата(2019, 6, 27);
		НачалоПериода = Макс(
			ДатаНачалаУчета,
			?(День(Выборка.Дата) <= 15,
				НачалоМесяца(Выборка.Дата),
				Дата(Год(Выборка.Дата), Месяц(Выборка.Дата), 16)
			));
		КонецПериода = Выборка.Дата;
		ДополнениеКСодержанию = СтрШаблон(НСтр("ru=' за период с %1 по %2'"),
			День(НачалоПериода), Формат(КонецПериода, "ДЛФ=DD"));
		Наименование = Наименование + ДополнениеКСодержанию;
	КонецЕсли;
	
	
	Возврат Наименование;
	
КонецФункции 

#КонецОбласти 

#Область ПодпискиНаСобытия

Процедура ДвиженияРасчетовПоСводамЗаявокНаДоставкуОбработкаПроведения(Источник, Отказ, РежимПроведения) Экспорт
	
	ТипИсточника = ТипЗнч(Источник);
	
	ОбновитьДвиженияЗаВычетом(Источник);
	
	Логс_ВзаиморасчетыСКлиентамиСервер.ОбновитьДвиженияДокумента(Источник);
	
	Если НЕ Источник.Движения.Найти("Логс_ВзаиморасчетыПоУслугам100") = Неопределено Тогда
		Источник.Движения.Логс_ВзаиморасчетыПоУслугам100.Очистить();
		Источник.Движения.Логс_ВзаиморасчетыПоУслугам100.Записать();
	КонецЕсли;

	
	Если ТипИсточника = Тип("ДокументОбъект.ЗаявкаНаРасходованиеДенежныхСредств") Тогда
		ДвиженияРасчетовПоСводамЗаявокНаДоставкуЗаявкаНаРасходованиеДС(Источник, Отказ, РежимПроведения);
		//ДвиженияЛогс_ВзаиморасчетыЗаВычетомЗаявкаНаРасходованиеДС(Источник, Отказ, РежимПроведения);
		ДвиженияРасчетовПоСводамЗаявокНаДоставкуЗаявкаНаРасходованиеДС_20(Источник, Отказ, РежимПроведения);
	ИначеЕсли ТипИсточника = Тип("ДокументОбъект.СписаниеБезналичныхДенежныхСредств") Тогда
		ДвиженияРасчетовПоСводамЗаявокНаДоставкуСписаниеБезналичныхДС(Источник, Отказ, РежимПроведения);
		//ДвиженияЛогс_ВзаиморасчетыЗаВычетомСписаниеБезналичныхДС(Источник, Отказ, РежимПроведения);
	ИначеЕсли ТипИсточника = Тип("ДокументОбъект.РасходныйКассовыйОрдер") Тогда
		ДвиженияРасчетовПоСводамЗаявокНаДоставкуРасходныйКассовыйОрдер(Источник, Отказ, РежимПроведения);
		//ДвиженияЛогс_ВзаиморасчетыЗаВычетомРасходныйКассовыйОрдер(Источник, Отказ, РежимПроведения);
	ИначеЕсли ТипИсточника = Тип("ДокументОбъект.ПоступлениеБезналичныхДенежныхСредств") Тогда
		ДвиженияРасчетовПоСводамЗаявокНаДоставкуПоступлениеБезналичныхДС_20(Источник, Отказ, РежимПроведения);
		//ДвиженияЛогс_ВзаиморасчетыЗаВычетомПоступлениеБезналичныхДС(Источник, Отказ, РежимПроведения);
	ИначеЕсли ТипИсточника = Тип("ДокументОбъект.СчетНаОплатуКлиенту") Тогда
		ДвиженияРасчетовПоСводамЗаявокНаДоставкуСчетНаОплатуКлиенту(Источник, Отказ, РежимПроведения);
	ИначеЕсли ТипИсточника = Тип("ДокументОбъект.ПриходныйКассовыйОрдер") Тогда
		ДвиженияРасчетовПоСводамЗаявокНаДоставкуПКО_20(Источник, Отказ, РежимПроведения);
		//а нету старого алгоритма
	ИначеЕсли ТипИсточника = Тип("ДокументОбъект.КорректировкаЗадолженности") Тогда
		ДвиженияРасчетовПоСводамЗаявокНаДоставкуСписаниеЗадолженности_20(Источник, Отказ, РежимПроведения);
		//ДвиженияЛогс_ВзаиморасчетыЗаВычетомСписаниеЗадолженности(Источник, Отказ, РежимПроведения);
	ИначеЕсли ТипИсточника = Тип("ДокументОбъект.ВзаимозачетЗадолженности") Тогда
		ДвиженияРасчетовПоСводамЗаявокНаДоставкуВзаимозачетЗадолженности_20(Источник, Отказ, РежимПроведения);
		//ДвиженияЛогс_ВзаиморасчетыЗаВычетомВзаимозачетЗадолженности(Источник, Отказ, РежимПроведения);
	Иначе
		ТекстСообщения = СтрШаблон(
			НСтр("ru='Для документа %1 не поддерживаются расчеты по сводам заявок на доставку'"),
			Источник.Метаданные().Синоним);
		ВызватьИсключение ТекстСообщения;
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбработкаУдаленияПроведенияРасчетыПоСводамЗаявокНаДоставкуОбработкаУдаленияПроведения(Источник, Отказ) Экспорт
	
	ТипИсточника = ТипЗнч(Источник);
	
	Если ТипИсточника = Тип("ДокументОбъект.СчетНаОплатуКлиенту") Тогда
		ПроведениеСерверУТ.ИнициализироватьДополнительныеСвойстваДляПроведения(Источник.Ссылка,
			Источник.ДополнительныеСвойства);
		
		Источник.ДополнительныеСвойства.Вставить("ЭтоНовый",    Источник.ЭтоНовый());
		Источник.ДополнительныеСвойства.Вставить("РежимЗаписи", РежимЗаписиДокумента.ОтменаПроведения);
		
		Движения = Источник.Движения.Логс_РасчетыПоУслугамЗаДоставку;
		
		ПроведениеСерверУТ.ЗаполнитьДополнительныеСвойстваНабораПоДокументу(Источник, Движения);
		
		Движения.Очистить();
		Движения.Записать();
		
		Движения = Источник.Движения.Логс_СчетаПоУслугам100;
		
		ПроведениеСерверУТ.ЗаполнитьДополнительныеСвойстваНабораПоДокументу(Источник, Движения);
		
		Движения.Очистить();
		Движения.Записать();
		
		Движения = Источник.Движения.Логс_ВзаиморасчетыПоУслугам100;
		
		ПроведениеСерверУТ.ЗаполнитьДополнительныеСвойстваНабораПоДокументу(Источник, Движения);
		
		Движения.Очистить();
		Движения.Записать();
	ИначеЕсли ТипИсточника = Тип("ДокументОбъект.КорректировкаЗадолженности") Тогда
		ПроведениеСерверУТ.ИнициализироватьДополнительныеСвойстваДляПроведения(Источник.Ссылка,
			Источник.ДополнительныеСвойства);
		
		Источник.ДополнительныеСвойства.Вставить("ЭтоНовый",    Источник.ЭтоНовый());
		Источник.ДополнительныеСвойства.Вставить("РежимЗаписи", РежимЗаписиДокумента.ОтменаПроведения);
		
		Движения = Источник.Движения.Логс_ВзаиморасчетыПоУслугам100;
		
		ПроведениеСерверУТ.ЗаполнитьДополнительныеСвойстваНабораПоДокументу(Источник, Движения);
		
		Движения.Очистить();
		Движения.Записать();
	ИначеЕсли ТипИсточника = Тип("ДокументОбъект.ВзаимозачетЗадолженности") Тогда
		ПроведениеСерверУТ.ИнициализироватьДополнительныеСвойстваДляПроведения(Источник.Ссылка,
			Источник.ДополнительныеСвойства);
		
		Источник.ДополнительныеСвойства.Вставить("ЭтоНовый",    Источник.ЭтоНовый());
		Источник.ДополнительныеСвойства.Вставить("РежимЗаписи", РежимЗаписиДокумента.ОтменаПроведения);
		
		Движения = Источник.Движения.Логс_ВзаиморасчетыПоУслугам100;
		
		ПроведениеСерверУТ.ЗаполнитьДополнительныеСвойстваНабораПоДокументу(Источник, Движения);
		
		Движения.Очистить();
		Движения.Записать();	
	ИначеЕсли ТипИсточника = Тип("ДокументОбъект.СписаниеБезналичныхДенежныхСредств") Тогда
		СфорироватьСписокЗависимыхСводовЗаявокПоСписаниюБезналичныхДС(Источник);
		РегистрыСведений.Логс_СостоянияСводовЗаявокНаДоставку.ОтразитьСостояниеСводаЗаявокНаДоставку(Источник, Отказ);
	ИначеЕсли ТипИсточника = Тип("ДокументОбъект.ПоступлениеБезналичныхДенежныхСредств") Тогда
		РегистрыСведений.Логс_СостоянияСводовЗаявокНаДоставку.ОтразитьСостояниеСводаЗаявокНаДоставку(Источник, Отказ);
	КонецЕсли; 
	
КонецПроцедуры

