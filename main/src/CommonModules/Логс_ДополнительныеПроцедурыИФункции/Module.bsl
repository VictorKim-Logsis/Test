	|	ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.РеализацияКлиенту),
	|	ИСТИНА,
	|	0,
	|	Данные.Сумма,
	|	0
	|ИЗ
	|	Данные КАК Данные
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Данные.Дата,
	|	Данные.Дата,
	|	Данные.Номер,
	|	НАЧАЛОПЕРИОДА(Данные.ДатаПлатежаПоГрафику, ДЕНЬ),
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход),
	|	Данные.АналитикаУчетаПоПартнерам,
	|	Данные.СводЗаявок,
	|	Данные.Валюта,
	|	ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.РеализацияКлиенту),
	|	ИСТИНА,
	|	0,
	|	0,
	|	Данные.Сумма
	|ИЗ
	|	Данные КАК Данные
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Данные.Дата КАК Период,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход) КАК ВидДвижения,
	|	Данные.АналитикаУчетаПоПартнерам КАК АналитикаУчетаПоПартнерам,
	|	Данные.СводЗаявок КАК СводЗаявок,
	|	Данные.Валюта КАК Валюта,
	|	ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.РеализацияКлиенту) КАК ХозяйственнаяОперация,
	|	Данные.Сумма КАК Сумма
	|ИЗ
	|	Данные КАК Данные
	|ГДЕ
	|	Данные.Сумма > 0
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Данные.Дата,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход),
	|	Данные.АналитикаУчетаПоПартнерам,
	|	Данные.СводЗаявок,
	|	Данные.Валюта,
	|	ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ВзаимозачетЗадолженности),
	|	-Данные.Сумма
	|ИЗ
	|	Данные КАК Данные
	|ГДЕ
	|	Данные.Сумма < 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СчетНаОплатуКлиенту.Дата КАК Период,
	|	Аналитика.КлючАналитики КАК АналитикаУчетаПоПартнерам,
	|	КОНЕЦПЕРИОДА(ЕСТЬNULL(ГрафикОплаты.ДатаПлатежа, СчетНаОплатуКлиенту.Дата), ДЕНЬ) КАК ДатаПлановогоПогашения,
	|	СчетНаОплатуКлиенту.Ссылка КАК Счет,
	|	СчетНаОплатуКлиенту.Валюта КАК Валюта,
	|	СчетНаОплатуКлиенту.СуммаДокумента КАК Долг
	|ПОМЕСТИТЬ ДанныеСчет
	|ИЗ
	|	Документ.СчетНаОплатуКлиенту КАК СчетНаОплатуКлиенту
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.АналитикаУчетаПоПартнерам КАК Аналитика
	|		ПО СчетНаОплатуКлиенту.Партнер = Аналитика.Партнер
	|			И СчетНаОплатуКлиенту.Организация = Аналитика.Организация
