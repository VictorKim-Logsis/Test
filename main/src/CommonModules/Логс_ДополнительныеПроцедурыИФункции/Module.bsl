	|		ПО РаспределениеПоСводамЗаявокНаДоставку.СводЗаявок = ДокСводЗаявокНаДоставку.Ссылка
	|			И (РаспределениеПоСводамЗаявокНаДоставку.СводЗаявок.ФормаОплаты = ЗНАЧЕНИЕ(Перечисление.Логс_ФормыОплатыУслугАгенту.ОплатаЗаВычетом))
	|ГДЕ
	|	ЗаявкаНаРасходованиеДенежныхСредств.Ссылка = &Ссылка
	|	И ЗаявкаНаРасходованиеДенежныхСредств.Статус <> ЗНАЧЕНИЕ(Перечисление.СтатусыЗаявокНаРасходованиеДенежныхСредств.Отклонена)
	|	И ЗаявкаНаРасходованиеДенежныхСредств.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ВозвратОплатыКлиенту)
	|	И РаспределениеПоСводамЗаявокНаДоставку.ЭтоВозврат");
	
	Запрос.УстановитьПараметр("Ссылка", Источник.Ссылка);
	
	ТаблицаДвижений = Запрос.Выполнить().Выгрузить();
	Движения = Источник.Движения.Логс_ВзаиморасчетыЗаВычетом;
	
	ПроведениеСерверУТ.ЗаполнитьДополнительныеСвойстваНабораПоДокументу(Источник, Движения);
	
	Движения.Записывать = Истина;
	Движения.Загрузить(ТаблицаДвижений);
	
КонецПроцедуры

Процедура ДвиженияЛогс_ВзаиморасчетыЗаВычетомПоступлениеБезналичныхДС(Источник, Отказ, РежимПроведения)
	
	Запрос = Новый Запрос("ВЫБРАТЬ
	|	ПоступлениеБезналичныхДенежныхСредствЛогс_РаспределениеПоСводамЗаявокНаДоставку.СводЗаявок КАК СводЗаявок,
	|	ПоступлениеБезналичныхДенежныхСредствЛогс_РаспределениеПоСводамЗаявокНаДоставку.Сумма КАК СуммаПоступления,
	|	АналитикаУчетаПоПартнерам.КлючАналитики КАК АналитикаУчетаПоПартнерам,
	|	ПоступлениеБезналичныхДенежныхСредствЛогс_РаспределениеПоСводамЗаявокНаДоставку.Ссылка.Валюта КАК Валюта,
	|	ПоступлениеБезналичныхДенежныхСредствЛогс_РаспределениеПоСводамЗаявокНаДоставку.Ссылка.Дата КАК Дата
	|ПОМЕСТИТЬ РасшифровкаПлатежа
	|ИЗ
	|	Документ.ПоступлениеБезналичныхДенежныхСредств.Логс_РаспределениеПоСводамЗаявокНаДоставку КАК ПоступлениеБезналичныхДенежныхСредствЛогс_РаспределениеПоСводамЗаявокНаДоставку
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.АналитикаУчетаПоПартнерам КАК АналитикаУчетаПоПартнерам
	|		ПО ПоступлениеБезналичныхДенежныхСредствЛогс_РаспределениеПоСводамЗаявокНаДоставку.СводЗаявок.Организация = АналитикаУчетаПоПартнерам.Организация
	|			И ПоступлениеБезналичныхДенежныхСредствЛогс_РаспределениеПоСводамЗаявокНаДоставку.СводЗаявок.Контрагент = АналитикаУчетаПоПартнерам.Контрагент
	|			И ПоступлениеБезналичныхДенежныхСредствЛогс_РаспределениеПоСводамЗаявокНаДоставку.СводЗаявок.Партнер = АналитикаУчетаПоПартнерам.Партнер
	|			И ПоступлениеБезналичныхДенежныхСредствЛогс_РаспределениеПоСводамЗаявокНаДоставку.СводЗаявок.Договор = АналитикаУчетаПоПартнерам.Договор
	|			И ПоступлениеБезналичныхДенежныхСредствЛогс_РаспределениеПоСводамЗаявокНаДоставку.Ссылка.НаправлениеДеятельности = АналитикаУчетаПоПартнерам.НаправлениеДеятельности
	|ГДЕ
	|	ПоступлениеБезналичныхДенежныхСредствЛогс_РаспределениеПоСводамЗаявокНаДоставку.СводЗаявок.ФормаОплаты = ЗНАЧЕНИЕ(Перечисление.Логс_ФормыОплатыУслугАгенту.ОплатаЗаВычетом)
	|	И ПоступлениеБезналичныхДенежныхСредствЛогс_РаспределениеПоСводамЗаявокНаДоставку.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	РасшифровкаПлатежа.Дата КАК Период,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход) КАК ВидДвижения,
	|	РасшифровкаПлатежа.АналитикаУчетаПоПартнерам КАК АналитикаУчетаПоПартнерам,
	|	РасшифровкаПлатежа.СводЗаявок КАК СводЗаявок,
	|	РасшифровкаПлатежа.СводЗаявок КАК КоррСводЗаявок,
	|	РасшифровкаПлатежа.Валюта КАК Валюта,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(Логс_ВзаиморасчетыЗаВычетомОстатки.СуммаУслугОстаток, 0) <= РасшифровкаПлатежа.СуммаПоступления
	|			ТОГДА РасшифровкаПлатежа.СуммаПоступления
	|		ИНАЧЕ ЕСТЬNULL(Логс_ВзаиморасчетыЗаВычетомОстатки.СуммаУслугОстаток, 0)
	|	КОНЕЦ КАК СуммаУслуг,
	|	0 КАК СуммаКОплате
	|ИЗ
	|	РасшифровкаПлатежа КАК РасшифровкаПлатежа
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.Логс_ВзаиморасчетыЗаВычетом.Остатки(&Период, ) КАК Логс_ВзаиморасчетыЗаВычетомОстатки
	|		ПО РасшифровкаПлатежа.СводЗаявок = Логс_ВзаиморасчетыЗаВычетомОстатки.СводЗаявок
	|			И РасшифровкаПлатежа.АналитикаУчетаПоПартнерам = Логс_ВзаиморасчетыЗаВычетомОстатки.АналитикаУчетаПоПартнерам
	|ГДЕ
	|	РасшифровкаПлатежа.СуммаПоступления >= ЕСТЬNULL(Логс_ВзаиморасчетыЗаВычетомОстатки.СуммаУслугОстаток, 0)
	|	И ВЫБОР
	|			КОГДА ЕСТЬNULL(Логс_ВзаиморасчетыЗаВычетомОстатки.СуммаУслугОстаток, 0) <= РасшифровкаПлатежа.СуммаПоступления
	|				ТОГДА РасшифровкаПлатежа.СуммаПоступления
	|			ИНАЧЕ ЕСТЬNULL(Логс_ВзаиморасчетыЗаВычетомОстатки.СуммаУслугОстаток, 0)
	|		КОНЕЦ <> 0
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	РасшифровкаПлатежа.Дата,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход),
	|	РасшифровкаПлатежа.АналитикаУчетаПоПартнерам,
	|	РасшифровкаПлатежа.СводЗаявок,
	|	РасшифровкаПлатежа.СводЗаявок,
	|	РасшифровкаПлатежа.Валюта,
	|	0,
	|	РасшифровкаПлатежа.СуммаПоступления - ЕСТЬNULL(Логс_ВзаиморасчетыЗаВычетомОстатки.СуммаУслугОстаток, 0)
	|ИЗ
	|	РасшифровкаПлатежа КАК РасшифровкаПлатежа
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.Логс_ВзаиморасчетыЗаВычетом.Остатки(&Период, ) КАК Логс_ВзаиморасчетыЗаВычетомОстатки
	|		ПО РасшифровкаПлатежа.СводЗаявок = Логс_ВзаиморасчетыЗаВычетомОстатки.СводЗаявок
	|			И РасшифровкаПлатежа.АналитикаУчетаПоПартнерам = Логс_ВзаиморасчетыЗаВычетомОстатки.АналитикаУчетаПоПартнерам
	|ГДЕ
	|	ЕСТЬNULL(Логс_ВзаиморасчетыЗаВычетомОстатки.СуммаУслугОстаток, 0) - РасшифровкаПлатежа.СуммаПоступления > 0");
	
	Запрос.УстановитьПараметр("Ссылка", Источник.Ссылка);
	Запрос.УстановитьПараметр("Период", Источник.Дата);
	ТаблицаДвижений = Запрос.Выполнить().Выгрузить();
	
	Если ТаблицаДвижений.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Движения = Источник.Движения.Логс_ВзаиморасчетыЗаВычетом;
	
	ПроведениеСерверУТ.ЗаполнитьДополнительныеСвойстваНабораПоДокументу(Источник, Движения);
	
	Движения.Записывать = Истина;
	Движения.Загрузить(ТаблицаДвижений);
	
КонецПроцедуры

