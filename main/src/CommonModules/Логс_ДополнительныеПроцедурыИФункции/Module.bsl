		               |			И Задолженность.Партнер = АналитикаУчетаПоПартнерам.Партнер
		               |			И Задолженность.ОбъектРасчетов.Договор = АналитикаУчетаПоПартнерам.Договор
		               |			И ЗНАЧЕНИЕ(Справочник.НаправленияДеятельности.ПустаяСсылка) = АналитикаУчетаПоПартнерам.НаправлениеДеятельности
		               |ГДЕ
		               |	Задолженность.Ссылка = &Ссылка
		               |	И Задолженность.ОбъектРасчетов.Объект ССЫЛКА Справочник.ДоговорыКонтрагентов";
		Запрос.УстановитьПараметр("Ссылка", Ссылка);
		
		Выборка = Запрос.Выполнить().Выбрать();
		Если НЕ Выборка.Следующий() или НЕ ЗначениеЗаполнено(Выборка.АналитикаУчетаПоПартнерам) Тогда
			Возврат;  // не нашли ключ аналитики
		КонецЕсли;
		КлючАналитики = Выборка.АналитикаУчетаПоПартнерам;
		
		Если Данные.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.СписаниеКредиторскойЗадолженности Тогда
		
			Показатель = "СуммаКОплате";
			ВидДвижения = ВидДвиженияНакопления.Расход;
			
			//закрываем возможные ошибки
			
			РаспределениеСвободное = РаспределитьОстаткиВзаиморасчетовЗаВычетом(КлючАналитики, Новый Граница( данные.дата, ВидГраницы.Включая), Показатель, Распределение.Остаток);
			
			Если РаспределениеСвободное.Распределение.Количество() > 0 Тогда
			
				Для Каждого Строка из РаспределениеСвободное.Распределение Цикл
					Движение = Движения.Добавить();
					ЗаполнитьЗначенияСвойств(Движение, Строка, "АналитикаУчетаПоПартнерам, Валюта"); 
					Движение.Период = Данные.Дата;
					Движение.ВидДвижения = ВидДвижения;
					Движение.СводЗаявок = Строка.СводЗаявок;
					Движение.КоррСводЗаявок = Строка.СводЗаявок;
					Движение[Показатель] = Строка[Показатель];
					
				КонецЦикла;
			КонецЕсли;
			
			Показатель = "СуммаНаложенногоПлатежа";
			ВидДвижения = ВидДвиженияНакопления.Расход;
			
			//закрываем возможные ошибки
			
			РаспределениеСвободное = РаспределитьОстаткиВзаиморасчетовЗаВычетом(КлючАналитики, Новый Граница( данные.дата, ВидГраницы.Включая), Показатель, РаспределениеСвободное.Остаток);
			
			Если РаспределениеСвободное.Распределение.Количество() > 0 Тогда
			
				Для Каждого Строка из РаспределениеСвободное.Распределение Цикл
					Движение = Движения.Добавить();
					ЗаполнитьЗначенияСвойств(Движение, Строка, "АналитикаУчетаПоПартнерам, Валюта"); 
					Движение.Период = Данные.Дата;
					Движение.ВидДвижения = ВидДвижения;
					Движение.СводЗаявок = Строка.СводЗаявок;
					Движение.КоррСводЗаявок = Строка.СводЗаявок;
					Движение[Показатель] = Строка[Показатель];
					
				КонецЦикла;
			КонецЕсли;
			
			Если РаспределениеСвободное.Остаток >0 Тогда
				
					Движение = Движения.Добавить();
					Движение.АналитикаУчетаПоПартнерам = КлючАналитики;
					Движение.Валюта = ОбщегоНазначенияБПВызовСервераПовтИсп.ПолучитьВалютуРегламентированногоУчета();//Константы.ВалютаРегламентированногоУчета.Получить();
					Движение.Период = Данные.Дата;
					Движение.ВидДвижения = ВидДвижения;
					Движение.СводЗаявок = Неопределено;
					Движение.КоррСводЗаявок = Неопределено;
					Движение[Показатель] = РаспределениеСвободное.Остаток;
				
			КонецЕсли;
			
		ИначеЕсли Данные.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.СписаниеДебиторскойЗадолженности Тогда
		
			Показатель = "СуммаКОплате";
			ВидДвижения = ВидДвиженияНакопления.Приход;
			
			//закрываем возможные ошибки
			
			РаспределениеСвободное = РаспределитьОстаткиВзаиморасчетовЗаВычетом(КлючАналитики, Новый Граница( данные.дата, ВидГраницы.Включая), Показатель, -Распределение.Остаток);
			
			Если РаспределениеСвободное.Распределение.Количество() > 0 Тогда
			
				Для Каждого Строка из РаспределениеСвободное.Распределение Цикл
					Движение = Движения.Добавить();
					ЗаполнитьЗначенияСвойств(Движение, Строка, "АналитикаУчетаПоПартнерам, Валюта"); 
					Движение.Период = Данные.Дата;
					Движение.ВидДвижения = ВидДвижения;
					Движение.СводЗаявок = Строка.СводЗаявок;
					Движение.КоррСводЗаявок = Строка.СводЗаявок;
					Движение[Показатель] = Строка[Показатель];
					
				КонецЦикла;
			КонецЕсли;
			
			Показатель = "СуммаУслуг";
			ВидДвижения = ВидДвиженияНакопления.Расход;
			
			//закрываем возможные ошибки
			
			РаспределениеСвободное = РаспределитьОстаткиВзаиморасчетовЗаВычетом(КлючАналитики, Новый Граница( данные.дата, ВидГраницы.Включая), Показатель, РаспределениеСвободное.Остаток);
			
			Если РаспределениеСвободное.Распределение.Количество() > 0 Тогда
			
				Для Каждого Строка из РаспределениеСвободное.Распределение Цикл
					Движение = Движения.Добавить();
					ЗаполнитьЗначенияСвойств(Движение, Строка, "АналитикаУчетаПоПартнерам, Валюта"); 
					Движение.Период = Данные.Дата;
					Движение.ВидДвижения = ВидДвижения;
					Движение.СводЗаявок = Строка.СводЗаявок;
					Движение.КоррСводЗаявок = Строка.СводЗаявок;
					Движение[Показатель] = Строка[Показатель];
					
				КонецЦикла;
			КонецЕсли;
			
			Если РаспределениеСвободное.Остаток <>0 Тогда
				
				Движение = Движения.Добавить();
				Движение.АналитикаУчетаПоПартнерам = КлючАналитики;
				Движение.Валюта = ОбщегоНазначенияБПВызовСервераПовтИсп.ПолучитьВалютуРегламентированногоУчета();//Константы.ВалютаРегламентированногоУчета.Получить();
				Движение.Период = Данные.Дата;
				Движение.ВидДвижения = ВидДвиженияНакопления.Приход;//ВидДвижения;
				Движение.СводЗаявок = Неопределено;
				Движение.КоррСводЗаявок = Неопределено;
				Движение[Показатель] = РаспределениеСвободное.Остаток;
				
			КонецЕсли;
	
		КонецЕсли;
	КонецЕсли;
		
КонецПроцедуры

Функция ПолучитьКлючАналитикиУчетаПоПартнерам(СтруктураДанных)
	
	ДанныеАналитики = Новый Структура;
	ДанныеАналитики.Вставить("Организация", СтруктураДанных.Организация);
	ДанныеАналитики.Вставить("Контрагент", СтруктураДанных.Контрагент);
	ДанныеАналитики.Вставить("Партнер", СтруктураДанных.Партнер);
	ДанныеАналитики.Вставить("Договор", СтруктураДанных.Договор);
	ДанныеАналитики.Вставить("НаправлениеДеятельности", Справочники.НаправленияДеятельности.ПустаяСсылка());
	
	Возврат РегистрыСведений.АналитикаУчетаПоПартнерам.ЗначениеКлючаАналитики(ДанныеАналитики);
	
КонецФункции 
Функция ПолучитьОстаткиВзаиморасчетовЗаВычетом(АналитикаУчетаПоПартнерам, Период, Показатель, СсылкаНаДокумент = Неопределено, Договор = Неопределено)
	
	Если СсылкаНаДокумент = Неопределено Тогда
		Запрос = Новый Запрос;
		ТекстЗапроса = "ВЫБРАТЬ
		               |	Логс_ВзаиморасчетыЗаВычетомОстатки.АналитикаУчетаПоПартнерам КАК АналитикаУчетаПоПартнерам,
		               |	Логс_ВзаиморасчетыЗаВычетомОстатки.СводЗаявок КАК СводЗаявок,
		               |	Логс_ВзаиморасчетыЗаВычетомОстатки.Валюта КАК Валюта,
		               |	&Показатель КАК Показатель
					   //|	Логс_ВзаиморасчетыЗаВычетомОстатки.СуммаУслугОстаток КАК СуммаУслуг,
					   //|	Логс_ВзаиморасчетыЗаВычетомОстатки.СуммаНаложенногоПлатежаОстаток КАК СуммаНаложенногоПлатежа,
					   //|	Логс_ВзаиморасчетыЗаВычетомОстатки.СуммаКОплатеОстаток КАК СуммаКОплате
		               |ИЗ
		               |	РегистрНакопления.Логс_ВзаиморасчетыЗаВычетом.Остатки(&Период, АналитикаУчетаПоПартнерам = &АналитикаУчетаПоПартнерам) КАК Логс_ВзаиморасчетыЗаВычетомОстатки
		               |
		               |УПОРЯДОЧИТЬ ПО
		               |	Логс_ВзаиморасчетыЗаВычетомОстатки.СводЗаявок.Дата";
		Запрос.Текст = СтрЗаменить(ТекстЗапроса, "&Показатель КАК Показатель","Логс_ВзаиморасчетыЗаВычетомОстатки."+Показатель+"Остаток КАК "+Показатель);
		Запрос.УстановитьПараметр("Период", Период);
		Запрос.УстановитьПараметр("АналитикаУчетаПоПартнерам", АналитикаУчетаПоПартнерам);
		
		Возврат Запрос.Выполнить().Выгрузить();
	Иначе
		Запрос = Новый Запрос;
		ТекстЗапроса = "ВЫБРАТЬ
		               |	ДанныеРаспределения.СводЗаявок КАК СводЗаявок,
		               |	ДанныеРаспределения.НаправлениеДеятельности КАК НаправлениеДеятельности,
		               |	ДанныеРаспределения.Валюта КАК Валюта,
		               |	СУММА(ДанныеРаспределения.Сумма) КАК Сумма
		               |ПОМЕСТИТЬ ВТ_ДанныеДокумента
		               |ИЗ
		               |	(ВЫБРАТЬ
		               |		Распределение.СводЗаявок КАК СводЗаявок,
		               |		Распределение.Ссылка.НаправлениеДеятельности КАК НаправлениеДеятельности,
		               |		Распределение.Ссылка.Валюта КАК Валюта,
		               |		Распределение.Сумма КАК Сумма
		               |	ИЗ
		               |		Документ.СписаниеБезналичныхДенежныхСредств.Логс_РаспределениеПоСводамЗаявокНаДоставку КАК Распределение
		               |	ГДЕ
		               |		Распределение.Ссылка = &СсылкаНаДокумент
		               |		И Распределение.Ссылка.ПроведеноБанком
		               |	
		               |	ОБЪЕДИНИТЬ ВСЕ
		               |	
		               |	ВЫБРАТЬ
		               |		Распределение.СводЗаявок,
		               |		Распределение.Ссылка.НаправлениеДеятельности,
		               |		Распределение.Ссылка.Валюта,
		               |		Распределение.Сумма
		               |	ИЗ
		               |		Документ.РасходныйКассовыйОрдер.Логс_РаспределениеПоСводамЗаявокНаДоставку КАК Распределение
		               |	ГДЕ
		               |		Распределение.Ссылка = &СсылкаНаДокумент
		               |	
		               |	ОБЪЕДИНИТЬ ВСЕ
		               |	
		               |	ВЫБРАТЬ
		               |		Распределение.СводЗаявок,
		               |		Распределение.Ссылка.НаправлениеДеятельности,
		               |		Распределение.Ссылка.Валюта,
		               |		Распределение.Сумма
		               |	ИЗ
		               |		Документ.ПоступлениеБезналичныхДенежныхСредств.Логс_РаспределениеПоСводамЗаявокНаДоставку КАК Распределение
		               |	ГДЕ
		               |		Распределение.Ссылка = &СсылкаНаДокумент
		               |		И Распределение.Ссылка.ХозяйственнаяОперация В (ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ПоступлениеОплатыОтКлиента), ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ВозвратДенежныхСредствОтПоставщика))
		               |		И Распределение.Ссылка.ПроведеноБанком
		               |	
		               |	ОБЪЕДИНИТЬ ВСЕ
		               |	
		               |	ВЫБРАТЬ
		               |		Распределение.СводЗаявок,
		               |		Распределение.Ссылка.НаправлениеДеятельности,
		               |		Распределение.Ссылка.Валюта,
		               |		Распределение.Сумма
		               |	ИЗ
		               |		Документ.ПриходныйКассовыйОрдер.Логс_РаспределениеПоСводамЗаявокНаДоставку КАК Распределение
		               |	ГДЕ
		               |		Распределение.Ссылка = &СсылкаНаДокумент
		               |		И Распределение.Ссылка.ХозяйственнаяОперация В (ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ПоступлениеОплатыОтКлиента), ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ВозвратДенежныхСредствОтПоставщика))
		               |	
		               |	ОБЪЕДИНИТЬ ВСЕ
		               |	
		               |	ВЫБРАТЬ
		               |		Распределение.Свод,
		               |		ЗНАЧЕНИЕ(Справочник.НаправленияДеятельности.ПустаяСсылка),
		               |		&РегВалюта,
		               |		Распределение.Сумма
		               |	ИЗ
		               |		Документ.КорректировкаЗадолженности.Своды КАК Распределение
		               |	ГДЕ
		               |		Распределение.Ссылка = &СсылкаНаДокумент
		               |		И Распределение.Ссылка.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.СписаниеКредиторскойЗадолженности)
		               |	
		               |	ОБЪЕДИНИТЬ ВСЕ
		               |	
		               |	ВЫБРАТЬ
		               |		Распределение.Свод,
		               |		ЗНАЧЕНИЕ(Справочник.НаправленияДеятельности.ПустаяСсылка),
		               |		&РегВалюта,
		               |		Распределение.Сумма
		               |	ИЗ
		               |		Документ.КорректировкаЗадолженности.Своды КАК Распределение
		               |	ГДЕ
		               |		Распределение.Ссылка = &СсылкаНаДокумент
		               |		И Распределение.Ссылка.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.СписаниеДебиторскойЗадолженности)
		               |	
		               |	ОБЪЕДИНИТЬ ВСЕ
		               |	
		               |	ВЫБРАТЬ РАЗЛИЧНЫЕ
		               |		Распределение.СводЗаявок,
		               |		Распределение.НаправлениеДеятельности,
		               |		Распределение.Валюта,
		               |		Распределение.Сумма
		               |	ИЗ
		               |		(ВЫБРАТЬ
		               |			Распределение.СводЗаявок КАК СводЗаявок,
		               |			Распределение.Ссылка.НаправлениеДеятельности КАК НаправлениеДеятельности,
		               |			Распределение.Ссылка.Валюта КАК Валюта,
		               |			Распределение.Сумма КАК Сумма
		               |		ИЗ
		               |			Документ.ЗаявкаНаРасходованиеДенежныхСредств.Логс_РаспределениеПоСводамЗаявокНаДоставку КАК Распределение
		               |		ГДЕ
		               |			Распределение.Ссылка = &СсылкаНаДокумент
		               |			И Распределение.Ссылка.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗаявокНаРасходованиеДенежныхСредств.КОплате)
		               |		
		               |		ОБЪЕДИНИТЬ ВСЕ
		               |		
		               |		ВЫБРАТЬ
		               |			Распределение.СводЗаявок,
		               |			Распределение.Ссылка.НаправлениеДеятельности,
		               |			Распределение.Ссылка.Валюта,
		               |			Распределение.Сумма
		               |		ИЗ
		               |			Документ.ЗаявкаНаРасходованиеДенежныхСредств.Логс_РаспределениеПоСводамЗаявокНаДоставкуДвижения КАК Распределение
		               |		ГДЕ
		               |			ЛОЖЬ
		               |			И Распределение.Ссылка = &СсылкаНаДокумент
		               |			И Распределение.Ссылка.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗаявокНаРасходованиеДенежныхСредств.КОплате)) КАК Распределение
		               |	
		               |	ОБЪЕДИНИТЬ ВСЕ
		               |	
		               |	ВЫБРАТЬ РАЗЛИЧНЫЕ
		               |		Распределение.СводЗаявок,
		               |		Распределение.НаправлениеДеятельности,
		               |		Распределение.Валюта,
		               |		Распределение.Сумма
		               |	ИЗ
		               |		(ВЫБРАТЬ
		               |			Распределение.Свод КАК СводЗаявок,
		               |			ЗНАЧЕНИЕ(Справочник.НаправленияДеятельности.ПустаяСсылка) КАК НаправлениеДеятельности,
		               |			Распределение.Ссылка.Валюта КАК Валюта,
		               |			Распределение.Сумма КАК Сумма
		               |		ИЗ
		               |			Документ.ВзаимозачетЗадолженности.СводыКредит КАК Распределение
		               |		ГДЕ
		               |			Распределение.Ссылка = &СсылкаНаДокумент
		               |		
		               |		ОБЪЕДИНИТЬ ВСЕ
		               |		
		               |		ВЫБРАТЬ
		               |			Распределение.Свод,
		               |			ЗНАЧЕНИЕ(Справочник.НаправленияДеятельности.ПустаяСсылка),
		               |			Распределение.Ссылка.Валюта,
		               |			-Распределение.Сумма
		               |		ИЗ
		               |			Документ.ВзаимозачетЗадолженности.СводыДебет КАК Распределение
		               |		ГДЕ
		               |			ЛОЖЬ
		               |			И Распределение.Ссылка = &СсылкаНаДокумент) КАК Распределение) КАК ДанныеРаспределения
		               |ГДЕ
		               |	ДанныеРаспределения.СводЗаявок.Договор = &Договор
		               |
		               |СГРУППИРОВАТЬ ПО
		               |	ДанныеРаспределения.СводЗаявок,
		               |	ДанныеРаспределения.НаправлениеДеятельности,
		               |	ДанныеРаспределения.Валюта
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ
		               |	РС_АналитикаУчетаПоПартнерам.КлючАналитики КАК АналитикаУчетаПоПартнерам,
		               |	ВТ_ДанныеДокумента.СводЗаявок КАК СводЗаявок,
		               |	ВТ_ДанныеДокумента.Валюта КАК Валюта,
		               |	&Показатель КАК Показатель
		               |ИЗ
		               |	ВТ_ДанныеДокумента КАК ВТ_ДанныеДокумента
		               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.Логс_ВзаиморасчетыЗаВычетом.Остатки(&Период, ) КАК Логс_ВзаиморасчетыЗаВычетомОстатки
		               |		ПО ВТ_ДанныеДокумента.СводЗаявок = Логс_ВзаиморасчетыЗаВычетомОстатки.СводЗаявок
		               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.АналитикаУчетаПоПартнерам КАК РС_АналитикаУчетаПоПартнерам
		               |		ПО ВТ_ДанныеДокумента.СводЗаявок.Организация = РС_АналитикаУчетаПоПартнерам.Организация
		               |			И ВТ_ДанныеДокумента.СводЗаявок.Контрагент = РС_АналитикаУчетаПоПартнерам.Контрагент
		               |			И ВТ_ДанныеДокумента.СводЗаявок.Партнер = РС_АналитикаУчетаПоПартнерам.Партнер
		               |			И ВТ_ДанныеДокумента.СводЗаявок.Договор = РС_АналитикаУчетаПоПартнерам.Договор
		               |			И ВТ_ДанныеДокумента.НаправлениеДеятельности = РС_АналитикаУчетаПоПартнерам.НаправлениеДеятельности
		               |ГДЕ
		               |	ВТ_ДанныеДокумента.СводЗаявок.ФормаОплаты = ЗНАЧЕНИЕ(Перечисление.Логс_ФормыОплатыУслугАгенту.ОплатаЗаВычетом)
		               |
		               |УПОРЯДОЧИТЬ ПО
		               |	Логс_ВзаиморасчетыЗаВычетомОстатки.СводЗаявок.Дата,
		               |	Показатель";
					   //|	Логс_ВзаиморасчетыЗаВычетомОстатки.СуммаУслугОстаток КАК СуммаУслуг,
					   //|	Логс_ВзаиморасчетыЗаВычетомОстатки.СуммаНаложенногоПлатежаОстаток КАК СуммаНаложенногоПлатежа,
					   //|	Логс_ВзаиморасчетыЗаВычетомОстатки.СуммаКОплатеОстаток КАК СуммаКОплате
					   
		ИмяПоказателя = "Логс_ВзаиморасчетыЗаВычетомОстатки."+Показатель+"Остаток";
		ФормулаПоля = "Выбор Когда ЕстьNull("+ИмяПоказателя+",0)<ВТ_ДанныеДокумента.Сумма Тогда ЕстьNull("+ИмяПоказателя+",0) Иначе ВТ_ДанныеДокумента.Сумма Конец";
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&Показатель КАК Показатель", ФормулаПоля + " КАК " + Показатель);
		Если ЗначениеЗаполнено(Договор) Тогда
			Запрос.УстановитьПараметр("Договор", Договор);
		Иначе
			ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "ДанныеРаспределения.СводЗаявок.Договор = &Договор", "Истина")
		КонецЕсли;
		Запрос.Текст = СтрЗаменить(ТекстЗапроса, "Показатель", Показатель);
		Запрос.УстановитьПараметр("Период", Период);
		Запрос.УстановитьПараметр("АналитикаУчетаПоПартнерам", АналитикаУчетаПоПартнерам);
		Запрос.УстановитьПараметр("СсылкаНаДокумент", СсылкаНаДокумент);
		Запрос.УстановитьПараметр("РегВалюта", ОбщегоНазначенияБПВызовСервераПовтИсп.ПолучитьВалютуРегламентированногоУчета());
		
		Возврат Запрос.Выполнить().Выгрузить();
	КонецЕсли;
	
КонецФункции
Функция РаспределитьОстаткиВзаиморасчетовЗаВычетом(АналитикаУчетаПоПартнерам, Период, Показатель, Сумма, СсылкаНаДокумент = Неопределено, Договор = Неопределено) Экспорт
	
	Результат = Новый Структура("Распределение, Остаток");
	
	ТаблицаОстатков = ПолучитьОстаткиВзаиморасчетовЗаВычетом(АналитикаУчетаПоПартнерам, Период, Показатель, СсылкаНаДокумент, Договор);
	
	Остаток = Сумма;
	Распределение = ТаблицаОстатков.СкопироватьКолонки();
	
	Для Каждого Строка из ТаблицаОстатков Цикл
		Если Остаток = 0 Тогда
			Прервать;
		КонецЕсли;
		Если Строка[Показатель]>0 и Сумма>0 Тогда
		
			Новая = Распределение.Добавить();
			ЗаполнитьЗначенияСвойств(Новая, Строка);
			
			Если Строка[Показатель]>=Остаток Тогда
				Новая[Показатель] = Остаток;
				Остаток = 0;
			Иначе
				Остаток = Остаток - Новая[Показатель];
			КонецЕсли;
		ИначеЕсли Строка[Показатель]<0 и Сумма<0 Тогда
		
			Новая = Распределение.Добавить();
			ЗаполнитьЗначенияСвойств(Новая, Строка);
			
			Если Строка[Показатель]>=Остаток Тогда
				Новая[Показатель] = Остаток;
				Остаток = 0;
			Иначе
				Остаток = Остаток - Новая[Показатель];
			КонецЕсли;
			
		
		КонецЕсли;
		
	КонецЦикла;
	
	Результат.Распределение = Распределение;
	Результат.Остаток = Остаток;
	
	Возврат Результат;
	
КонецФункции


#КонецОбласти

#Область ДвиженияРасчетовПоСводамЗаявокНаДоставку

Процедура ДвиженияРасчетовПоСводамЗаявокНаДоставкуЗаявкаНаРасходованиеДС(Источник, Отказ, РежимПроведения)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ЗаявкаНаРасходованиеДенежныхСредств.Дата КАК Период,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход) КАК ВидДвижения,
	|	Аналитика.КлючАналитики КАК АналитикаУчетаПоПартнерам,
	|	РаспределениеПоСводамЗаявокНаДоставку.СводЗаявок КАК СводЗаявок,
	|	ДокСводЗаявокНаДоставку.Валюта КАК Валюта,
	|	0 КАК Сумма,
	|	0 КАК КОплате,
	|	РаспределениеПоСводамЗаявокНаДоставку.Сумма КАК Оплачивается
	|ИЗ
	|	Документ.ЗаявкаНаРасходованиеДенежныхСредств.Логс_РаспределениеПоСводамЗаявокНаДоставку КАК РаспределениеПоСводамЗаявокНаДоставку
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаявкаНаРасходованиеДенежныхСредств КАК ЗаявкаНаРасходованиеДенежныхСредств
	|		ПО РаспределениеПоСводамЗаявокНаДоставку.Ссылка = ЗаявкаНаРасходованиеДенежныхСредств.Ссылка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.Логс_СводЗаявокНаДоставку КАК ДокСводЗаявокНаДоставку
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.АналитикаУчетаПоПартнерам КАК Аналитика
	|			ПО ДокСводЗаявокНаДоставку.Партнер = Аналитика.Партнер
	|				И ДокСводЗаявокНаДоставку.Организация = Аналитика.Организация
	|				И ДокСводЗаявокНаДоставку.Контрагент = Аналитика.Контрагент
	|				И ДокСводЗаявокНаДоставку.Договор = Аналитика.Договор
	|				И (Аналитика.НаправлениеДеятельности = ЗНАЧЕНИЕ(Справочник.НаправленияДеятельности.ПустаяСсылка))
	|		ПО РаспределениеПоСводамЗаявокНаДоставку.СводЗаявок = ДокСводЗаявокНаДоставку.Ссылка
	|ГДЕ
	|	ЗаявкаНаРасходованиеДенежныхСредств.Ссылка = &Ссылка
	|	И ЗаявкаНаРасходованиеДенежныхСредств.Статус <> ЗНАЧЕНИЕ(Перечисление.СтатусыЗаявокНаРасходованиеДенежныхСредств.Отклонена)
	|	И ЗаявкаНаРасходованиеДенежныхСредств.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ОплатаПоставщику)");
	Запрос.УстановитьПараметр("Ссылка", Источник.Ссылка);
	
	ТаблицаДвижений = Запрос.Выполнить().Выгрузить();
	ЗаписатьДвиженияРасчетовПоНаложеннымПлатежам(Источник, ТаблицаДвижений);
	
КонецПроцедуры

Процедура ДвиженияРасчетовПоСводамЗаявокНаДоставкуЗаявкаНаРасходованиеДС_20(Источник, Отказ, РежимПроведения)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ЗаявкаНаРасходованиеДенежныхСредств.Дата КАК Период,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход) КАК ВидДвижения,
	|	Аналитика.КлючАналитики КАК АналитикаУчетаПоПартнерам,
	|	РаспределениеПоСводамЗаявокНаДоставку.СводЗаявок КАК СводЗаявок,
	|	ДокСводЗаявокНаДоставку.Валюта КАК Валюта,
	|	РаспределениеПоСводамЗаявокНаДоставку.Сумма КАК Сумма
	|ИЗ
	|	Документ.ЗаявкаНаРасходованиеДенежныхСредств.Логс_РаспределениеПоСводамЗаявокНаДоставку КАК РаспределениеПоСводамЗаявокНаДоставку
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаявкаНаРасходованиеДенежныхСредств КАК ЗаявкаНаРасходованиеДенежныхСредств
	|		ПО РаспределениеПоСводамЗаявокНаДоставку.Ссылка = ЗаявкаНаРасходованиеДенежныхСредств.Ссылка
