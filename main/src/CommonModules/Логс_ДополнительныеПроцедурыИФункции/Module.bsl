Процедура ЗаписатьДвиженияРасчетовПоУслугамЗаДоставку(Источник, ТаблицаДвижений)
	
	Если ТаблицаДвижений.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Движения = Источник.Движения.Логс_РасчетыПоУслугамЗаДоставку;
	
	ПроведениеСерверУТ.ЗаполнитьДополнительныеСвойстваНабораПоДокументу(Источник, Движения);
	
	ТипДокумента = ТипЗнч(Движения.Отбор.Регистратор.Значение);
	Если ТипДокумента <> Тип("ДокументСсылка.Логс_СводЗаявокНаДоставку") Тогда
		ДобавитьЗаполнитьПорядокРасчетовПоУслугамЗаДоставку(ТаблицаДвижений, ТипДокумента);
	КонецЕсли; 
	
	Движения.Записывать = Истина;
	Движения.Загрузить(ТаблицаДвижений);
	
КонецПроцедуры

