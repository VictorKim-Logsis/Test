		КонецЕсли;	
	
		НомерСчета = "";
		НазначениеТекст = НРег(НазначениеТекст);
		Поз = СтрНайти(НазначениеТекст, СтрПоиск);
		Если Поз <> 0 Тогда
			Назначение = Прав(НазначениеТекст, СтрДлина(НазначениеТекст) - Поз+1);
			Назначение = СокрЛП(СтрЗаменить(Назначение, СтрПоиск, ""));
			ПерваяЦифраНайдена = Ложь;
			Пока Истина Цикл
				Если СтрДлина(Назначение) = 0 Тогда
					Прервать;
				КонецЕсли;
				Символ = Лев(Назначение, 1);
				
				// убираем возможные символы перед номеров (№ и т.д)
				Если Не ПерваяЦифраНайдена Тогда
					Если Не ЭтоЦифра(Символ, Исключения) Тогда
						Назначение = Прав(Назначение, СтрДлина(Назначение) - 1);
						Продолжить;
					Иначе
						ПерваяЦифраНайдена = Истина;
					КонецЕсли;
				КонецЕсли;
				
				// как только заканчиваются цифры - перестаем формировать номер
				Если Не ЭтоЦифра(Символ, Исключения) Тогда
					Прервать;
				КонецЕсли;
				НомерСчета = НомерСчета + Символ;
				Назначение = Прав(Назначение, СтрДлина(Назначение) - 1);			
			КонецЦикла;
			Если НЕ ПустаяСтрока(НомерСчета) Тогда
				Счет = Документы.СчетНаОплатуКлиенту.НайтиПоНомеру(НомерСчета, ТекущаяДата());
				НомерСчета = "";
				Если ЗначениеЗаполнено(Счет) Тогда
					Прервать;
				КонецЕсли;	
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;	
	
	Возврат Счет;
	        
КонецФункции

Функция НайтиСчетПоНазначениюПлатежа(Знач НазначениеТекст, Организация, Договор) Экспорт
	
	Счет = Неопределено;
	
	RegExp = Новый COMОбъект("VBScript.RegExp");// создаем объект для работы с регулярными выражениями
	RegExp.MultiLine = Истина;  // истина — текст многострочный, ложь — одна строка
	RegExp.Global = Истина;     // истина — поиск по всей строке, ложь — до первого совпадения
	RegExp.IgnoreCase = Истина; // истина — игнорировать регистр строки при поиске

	Шаблон = Организация.Префикс + "00-" + "\d+\d+\d+\d+\d+\d"; 
	RegExp.Pattern = Шаблон;    // шаблон (регулярное выражение)
	Matches = RegExp.Execute(НазначениеТекст);
	
	МассивНомера = Новый Массив;
	Для каждого StrMatches Из Matches Цикл		
		МассивНомера.Добавить(StrMatches.Value);				
	КонецЦикла;
	
	// если нашли несколько номеров, то разносить надо вручную
	Если МассивНомера.Количество() > 1 Тогда
		Возврат Счет;	
	КонецЕсли;	
	
	Для каждого НомерСчета Из МассивНомера Цикл
		Счет = Документы.СчетНаОплатуКлиенту.НайтиПоНомеру(НомерСчета, ТекущаяДата());
		Если Счет.Организация <> Организация ИЛИ Счет.Договор <> Договор Тогда
			Счет = Неопределено;
		КонецЕсли;	
	КонецЦикла;	
	
	Возврат Счет;	 
	        
КонецФункции


Функция ЭтоЦифра(Символ, Исключения)
	
	Если Символ = "0" ИЛИ Символ = "1" ИЛИ Символ = "2" ИЛИ Символ = "3" ИЛИ Символ = "4" ИЛИ Символ = "5" ИЛИ
		 Символ = "6" ИЛИ Символ = "7" ИЛИ Символ = "8" ИЛИ Символ = "9" ИЛИ Исключения.Найти(ВРЕГ(Символ)) <> Неопределено Тогда
		 Возврат Истина;
	Иначе
		 Возврат Ложь;
	КонецЕсли;
	
КонецФункции	

Функция ПолучитьРеквизитыКУДИРПоступленияДС(ДокументСсылка)
	
	РеквизитыДокумента = Новый Структура("ХозяйственнаяОперация,КУДиРвОсобомПорядке", Неопределено, Ложь);
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ПоступлениеБезналичныхДенежныхСредств.ХозяйственнаяОперация КАК ХозяйственнаяОперация,
	|	ЕСТЬNULL(ДоговорыКонтрагентов.Логс_КУДиРвОсобомПорядке, ЛОЖЬ) КАК КУДиРвОсобомПорядке
	|ИЗ
	|	Документ.ПоступлениеБезналичныхДенежныхСредств КАК ПоступлениеБезналичныхДенежныхСредств
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПоступлениеБезналичныхДенежныхСредств.РасшифровкаПлатежа
	|							КАК ПоступлениеБезналичныхДенежныхСредствРасшифровкаПлатежа
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
	|			ПО ПоступлениеБезналичныхДенежныхСредствРасшифровкаПлатежа.ОбъектРасчетов.Договор = ДоговорыКонтрагентов.Ссылка
	|		ПО ПоступлениеБезналичныхДенежныхСредств.Ссылка = ПоступлениеБезналичныхДенежныхСредствРасшифровкаПлатежа.Ссылка
	|			И (ПоступлениеБезналичныхДенежныхСредствРасшифровкаПлатежа.НомерСтроки = 1)
	|ГДЕ
	|	ПоступлениеБезналичныхДенежныхСредств.Ссылка = &ДокументСсылка");
	Запрос.УстановитьПараметр("ДокументСсылка", ДокументСсылка);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(РеквизитыДокумента, Выборка);
	КонецЕсли; 
	
	Возврат РеквизитыДокумента;
	
КонецФункции 

