Процедура ДвиженияЗаВычетомЗаявкаНаРасходованиеДенежныхСредств_хм(Ссылка, Договор, Движения)
	Показатель = "СуммаНаложенногоПлатежа";
	Данные = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Ссылка, "СуммаДокумента, Дата");
	ГраницаКонецДня = Новый Граница(КонецДня(Данные.Дата), ВидГраницы.Включая);
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	Распределение.СводЗаявок КАК СводЗаявок,
	               |	Распределение.Ссылка.НаправлениеДеятельности КАК НаправлениеДеятельности,
	               |	Распределение.Ссылка.Валюта КАК Валюта,
	               |	Распределение.Сумма КАК Сумма
	               |Поместить ВТ_ДанныеДокумента
	               |	ИЗ
	               |		Документ.ЗаявкаНаРасходованиеДенежныхСредств.Логс_РаспределениеПоСводамЗаявокНаДоставку КАК Распределение
	               |	ГДЕ
	               |		Распределение.Ссылка = &СсылкаНаДокумент
	               |		И Распределение.Ссылка.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗаявокНаРасходованиеДенежныхСредств.КОплате) ;
				   |ВЫБРАТЬ
	               |	РС_АналитикаУчетаПоПартнерам.КлючАналитики КАК АналитикаУчетаПоПартнерам,
	               |	ВТ_ДанныеДокумента.СводЗаявок КАК СводЗаявок,
	               |	ВТ_ДанныеДокумента.Валюта КАК Валюта,
	               |	ВТ_ДанныеДокумента.Сумма КАК Показатель
	               |ИЗ
	               |	ВТ_ДанныеДокумента КАК ВТ_ДанныеДокумента
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.АналитикаУчетаПоПартнерам КАК РС_АналитикаУчетаПоПартнерам
	               |		ПО ВТ_ДанныеДокумента.СводЗаявок.Организация = РС_АналитикаУчетаПоПартнерам.Организация
	               |			И ВТ_ДанныеДокумента.СводЗаявок.Контрагент = РС_АналитикаУчетаПоПартнерам.Контрагент
	               |			И ВТ_ДанныеДокумента.СводЗаявок.Партнер = РС_АналитикаУчетаПоПартнерам.Партнер
	               |			И ВТ_ДанныеДокумента.СводЗаявок.Договор = РС_АналитикаУчетаПоПартнерам.Договор
	               |			И ВТ_ДанныеДокумента.НаправлениеДеятельности = РС_АналитикаУчетаПоПартнерам.НаправлениеДеятельности
	               |ГДЕ
	               |	ВТ_ДанныеДокумента.СводЗаявок.ФормаОплаты = ЗНАЧЕНИЕ(Перечисление.Логс_ФормыОплатыУслугАгенту.ОплатаЗаВычетом)
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	ВТ_ДанныеДокумента.СводЗаявок.Дата,
	               |	Показатель";
	Запрос.УстановитьПараметр("СсылкаНаДокумент", Ссылка);
	
	Распределение = Запрос.Выполнить().Выгрузить();
	
	//Распределение = РаспределитьОстаткиВзаиморасчетовЗаВычетом(Неопределено, ГраницаКонецДня, Показатель, Данные.СуммаДокумента, Ссылка);
	
	Если Распределение.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	СнижениеНП = 0;
	
	Для Каждого Строка из Распределение Цикл
		Движение = Движения.Добавить();
		ЗаполнитьЗначенияСвойств(Движение, Строка, "АналитикаУчетаПоПартнерам, Валюта"); 
		Движение.Период = Данные.Дата;
		Движение.ВидДвижения = ВидДвиженияНакопления.Расход;
		Движение.СводЗаявок = Строка.СводЗаявок;
		Движение.КоррСводЗаявок = Строка.СводЗаявок;
		Движение.СуммаНаложенногоПлатежа = Строка["Показатель"];
			
		Если Строка["Показатель"]<0 Тогда
			СнижениеНП = СнижениеНП - Строка["Показатель"];
		КонецЕсли;
	КонецЦикла;
	
	Для Каждого Строка из Распределение Цикл
		Если Строка["Показатель"]>0 Тогда
			ТекущееУнижение = Мин(СнижениеНП, Строка["Показатель"]); 
			СнижениеНП = СнижениеНП-ТекущееУнижение;
			
			Если Строка["Показатель"]>ТекущееУнижение Тогда
				Движение = Движения.Добавить();
				ЗаполнитьЗначенияСвойств(Движение, Строка, "АналитикаУчетаПоПартнерам, Валюта"); 
				Движение.Период = Данные.Дата;
				Движение.ВидДвижения = ВидДвиженияНакопления.Приход;
				Движение.СводЗаявок = Строка.СводЗаявок;
				Движение.КоррСводЗаявок = Строка.СводЗаявок;
				Движение.СуммаКОплате = Строка["Показатель"]-ТекущееУнижение;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;

	
КонецПроцедуры
