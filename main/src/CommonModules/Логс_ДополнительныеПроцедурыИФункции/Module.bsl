Функция СоздатьСводыЗаявокНаДоставку(НачалоПериода, КонецПериода, ПериодФормирования = Неопределено,
									Партнер = Неопределено, ОтправлятьПоПочте = Ложь, Хаб = Неопределено) Экспорт
	                                                                  
	ЕстьОшибки = Ложь;
		
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	
	ПоместитьВоВременнуюТаблицуСводыЗаявокНаДоставкуКОформлениюСводов(Запрос.МенеджерВременныхТаблиц,
		НачалоПериода, КонецПериода, ПериодФормирования, Партнер, Хаб);
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЗаявкиКОформлению.Период КАК Дата,
	|	Заявка.Ссылка КАК ЗаявкаНаДоставку,
	|	Заявка.Организация КАК Организация,
	|	Заявка.Партнер КАК Партнер,
	|	Заявка.Контрагент КАК Контрагент,
	|	Заявка.Договор КАК Договор,
	|	Заявка.ФормаОплаты КАК ФормаОплаты,
	|	Заявка.НалогообложениеНДС КАК НалогообложениеНДС,
	|	Заявка.Валюта КАК Валюта,
	|	ЕСТЬNULL(ДоговорыКонтрагентов.Логс_ИдентификаторCRM, """") КАК ИдентификаторКлиента,
	|	ДоговорыКонтрагентов.Логс_ВидКлиентаCRM КАК ВидКлиента,
	|	ЕСТЬNULL(ДоговорыКонтрагентов.Логс_НеОтправлятьСтандартныеОтчетыАгента, ЛОЖЬ) КАК Логс_НеОтправлятьСтандартныеОтчетыАгента,
	|	Заявка.Дата КАК ДатаДоставки,
	|	Заявка.Номер КАК НомерЗаказа,
	|	Заявка.НомерЗаказаКлиента КАК НомерЗаказаКлиента,
	|	Заявка.СтавкаНДС КАК СтавкаНДС,
	|	Заявка.Статус КАК Статус,
	|	Заявка.Курьер КАК Курьер,
	|	Заявка.Вес КАК Вес,
	|	Заявка.ОбъемныйВес КАК ОбъемныйВес,
	|	Заявка.РасстояниеОтМКАД КАК РасстояниеОтМКАД,
	|	Заявка.ОценочнаяСтоимость КАК ОценочнаяСтоимость,
	|	Заявка.НаложенныйПлатеж КАК НаложенныйПлатеж,
	|	Заявка.Тариф КАК Тариф,
	|	Заявка.ПовторнаяДоставка КАК ПовторнаяДоставка,
	|	Заявка.КассовоеОбслуживание КАК КассовоеОбслуживание,
	|	Заявка.Эквайринг КАК Эквайринг,
	|	Заявка.Страхование КАК Страхование,
	|	Заявка.ЗаносКГТ КАК ЗаносКГТ,
	|	Заявка.ВозвратныеДокументы КАК ВозвратныеДокументы,
	|	Заявка.СМС КАК СМС,
	|	Заявка.Прозвон КАК Прозвон,
	|	Заявка.ПолнаяСтоимость КАК ПолнаяСтоимость,
	|	Заявка.ПолнаяСтоимостьНДС КАК ПолнаяСтоимостьНДС,
	|	Заявка.ПолнаяСтоимостьСНДС КАК ПолнаяСтоимостьСНДС,
	|	Заявка.КПеречислению КАК КПеречислению,
	|	Заявка.СтоимостьЗаказа КАК СтоимостьЗаказа,
	|	Заявка.ДатаЗабора КАК ДатаЗабора,
	|	Заявка.ДатаВозврата КАК ДатаВозврата,
	|	Заявка.СуммаВозврата КАК СуммаВозврата,
	|	ВЫБОР
	|		КОГДА ДоговорыКонтрагентов.Логс_НеРазделятьОтчетыАгентовПоРегионам
	|			ТОГДА ЛОЖЬ
	|		КОГДА Заявка.Хаб = ЗНАЧЕНИЕ(Справочник.Логс_Хабы.ТД)
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ Заявка.РегиональнаяЗаявка
	|	КОНЕЦ КАК РегиональнаяЗаявка,
	|	ВЫБОР
	|		КОГДА ДоговорыКонтрагентов.Логс_НеРазделятьОтчетыАгентовПоРегионам
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.Логс_Хабы.Москва)
	|		КОГДА Заявка.Хаб = ЗНАЧЕНИЕ(Справочник.Логс_Хабы.ТД)
	|				ИЛИ Заявка.РегиональнаяЗаявка
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.Логс_Хабы.ПустаяСсылка)
	|		КОГДА НЕ Заявка.Хаб.РодительскийХаб = ЗНАЧЕНИЕ(Справочник.Логс_Хабы.ПустаяСсылка)
	|			ТОГДА Заявка.Хаб.РодительскийХаб
	|		ИНАЧЕ Заявка.Хаб
	|	КОНЕЦ КАК Хаб,
	|	ВЫБОР
	|		КОГДА ДоговорыКонтрагентов.Логс_НеРазделятьОтчетыАгентовПоРегионам
	|			ТОГДА ""MSK""
	|		КОГДА НЕ Заявка.Хаб.РодительскийХаб = ЗНАЧЕНИЕ(Справочник.Логс_Хабы.ПустаяСсылка)
	|			ТОГДА Заявка.Хаб.РодительскийХаб.ПрефиксЗаявок
	|		ИНАЧЕ Заявка.Хаб.ПрефиксЗаявок
	|	КОНЕЦ КАК ПрефиксХаба,
	|	Заявка.ОбработкаЧастичногоВыкупа КАК ОбработкаЧастичногоВыкупа,
	|	Заявка.ОбработкаВозврата КАК ОбработкаВозврата,
	|	Заявка.СуммаКлиентскогоВозврата КАК СуммаКлиентскогоВозврата,
	|	Заявка.СуммаКлиентскогоОбмена КАК СуммаКлиентскогоОбмена,
	|	Заявка.МагистральноеПеремещение КАК МагистральноеПеремещение, 
	|	Заявка.Хранение КАК Хранение
	|ИЗ
	|	ЗаявкиКОформлению КАК ЗаявкиКОформлению
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.Логс_ЗаявкаНаДоставку КАК Заявка
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
	|			ПО Заявка.Договор = ДоговорыКонтрагентов.Ссылка
	|		ПО ЗаявкиКОформлению.ЗаявкаНаДоставку = Заявка.Ссылка
	|ГДЕ
	|	(&Хаб = ЗНАЧЕНИЕ(Справочник.Логс_Хабы.ПустаяСсылка)
	|			ИЛИ &хаб = НЕОПРЕДЕЛЕНО
	|			ИЛИ ВЫБОР
	|				КОГДА ДоговорыКонтрагентов.Логс_НеРазделятьОтчетыАгентовПоРегионам
	|					ТОГДА ЗНАЧЕНИЕ(Справочник.Логс_Хабы.Москва)
	|				ИНАЧЕ Заявка.Хаб
	|			КОНЕЦ = &Хаб)
	|
	|УПОРЯДОЧИТЬ ПО
	|	РегиональнаяЗаявка,
	|	Дата,
	|	ДатаДоставки,
	|	НомерЗаказа
	|ИТОГИ
	|	МАКСИМУМ(ИдентификаторКлиента),
	|	МАКСИМУМ(ВидКлиента),
	|	МАКСИМУМ(ПрефиксХаба)
	|ПО
	|	Хаб,
	|	РегиональнаяЗаявка,
	|	Дата,
	|	Организация,
	|	Партнер,
	|	Контрагент,
	|	Договор,
	|	ФормаОплаты,
	|	Валюта,
	|	НалогообложениеНДС
	|АВТОУПОРЯДОЧИВАНИЕ";
	Запрос.УстановитьПараметр("Хаб", Хаб);
	ВыборкаХаб = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаХаб.Следующий() Цикл
		ВыборкаДата = ВыборкаХаб.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаДата.Следующий() Цикл
			ВыборкаОрганизация = ВыборкаДата.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока ВыборкаОрганизация.Следующий() Цикл
				ВыборкаПартнер = ВыборкаОрганизация.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
				Пока ВыборкаПартнер.Следующий() Цикл
					ВыборкаКонтрагент = ВыборкаПартнер.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
					Пока ВыборкаКонтрагент.Следующий() Цикл
						ВыборкаДоговор = ВыборкаКонтрагент.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
						Пока ВыборкаДоговор.Следующий() Цикл
							ВыборкаРегион = ВыборкаДоговор.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
							Пока ВыборкаРегион.Следующий() Цикл
								ВыборкаФормаОплаты = ВыборкаРегион.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
								Пока ВыборкаФормаОплаты.Следующий() Цикл
									ВыборкаВалюта = ВыборкаФормаОплаты.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
									Пока ВыборкаВалюта.Следующий() Цикл
										ВыборкаНалогообложение = ВыборкаВалюта.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
										Пока ВыборкаНалогообложение.Следующий() Цикл
											
											СводЗаявок = Документы.Логс_СводЗаявокНаДоставку.СоздатьДокумент();
											СводЗаявок.Дата = КонецДня(ВыборкаНалогообложение.Дата);
											СводЗаявок.Организация = ВыборкаНалогообложение.Организация;
											СводЗаявок.Партнер = ВыборкаНалогообложение.Партнер;
											СводЗаявок.Контрагент = ВыборкаНалогообложение.Контрагент;
											СводЗаявок.Договор = ВыборкаНалогообложение.Договор;
											СводЗаявок.ФормаОплаты = ВыборкаНалогообложение.ФормаОплаты;
											СводЗаявок.НалогообложениеНДС = ВыборкаНалогообложение.НалогообложениеНДС;
											СводЗаявок.Валюта = ВыборкаНалогообложение.Валюта;
											СводЗаявок.ВидКлиента = ВыборкаНалогообложение.ВидКлиента;
											СводЗаявок.РегиональныйСвод = ВыборкаНалогообложение.РегиональнаяЗаявка;
											СводЗаявок.Ответственный = Пользователи.ТекущийПользователь();
											
											
											НеОтправлятьСтандартные = Ложь;
											Выборка = ВыборкаНалогообложение.Выбрать();
											Пока Выборка.Следующий() Цикл
												СтрокаЗаявки = СводЗаявок.Заявки.Добавить();
												ЗаполнитьЗначенияСвойств(СтрокаЗаявки, Выборка);
												НеОтправлятьСтандартные = Выборка.Логс_НеОтправлятьСтандартныеОтчетыАгента;
											КонецЦикла;
											СводЗаявок.ЗаполнитьДатуВыставленияСчета();

											//Префикс = СтрШаблон(НСтр("ru='%1%2-'"),
											//	ВыборкаНалогообложение.Договор.Логс_ИдентификаторCRM,
											//	?(СводЗаявок.РегиональныйСвод, "REG", "MSK"));
											//Префикс = СтрШаблон(НСтр("ru='%1%2-'"),
											//	ВыборкаНалогообложение.Договор.Логс_ИдентификаторCRM,
											//	?(СводЗаявок.РегиональныйСвод, "REG", "MSK"));
											ПрефиксРегиона = ?(ВыборкаХаб.ПрефиксХаба = "", "MSK", ВыборкаХаб.ПрефиксХаба);
											Префикс = СтрШаблон(НСтр("ru='%1%2-'"),
												ВыборкаНалогообложение.Договор.Логс_ИдентификаторCRM,
												?(СводЗаявок.РегиональныйСвод, "REG", ПрефиксРегиона));
												
											СводЗаявок.Хаб = ВыборкаХаб.Хаб;	
											СводЗаявок.УстановитьНовыйНомер(Префикс);
											СводЗаявок.Записать(РежимЗаписиДокумента.Запись);
											
											Попытка
												СводЗаявок.Записать(РежимЗаписиДокумента.Проведение);
											Исключение
												ТекстСообщения = СтрШаблон(
													НСтр("ru='Произошла ошибка при проведении свода заявок № %1 от %2: %3'"),
													СводЗаявок.Номер, СводЗаявок.Дата,
													КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
												ЗаписьЖурналаРегистрации("Обмен с CRM. Создание сводов заявок",
													УровеньЖурналаРегистрации.Ошибка,,, ТекстСообщения);
												ЕстьОшибки = Истина;
												Продолжить;
											КонецПопытки; 
											
											//Fil
											Если СводЗаявок.Проведен И ОтправлятьПоПочте и НЕ НеОтправлятьСтандартные Тогда
												ОтправитьПоПочтеСчетОтчет(СводЗаявок.Ссылка, "Отчет");
											КонецЕсли;									
										КонецЦикла; // Налогообложение
									КонецЦикла; // Валюта
								КонецЦикла; // Форма оплаты
							КонецЦикла; // Регионы
						КонецЦикла; // Договор
					КонецЦикла; // Контрагент
				КонецЦикла; // Партнер
			КонецЦикла; // Организация
		КонецЦикла; // Дата
	КонецЦикла; // Хаб
	
	Возврат Не ЕстьОшибки;
	
КонецФункции

Процедура СоздатьСводыЗаявокНаДоставкуВФоне(Параметры, АдресХранилища) Экспорт
	Перем Партнер, Хаб;
	
	Параметры.Свойство("Партнер", Партнер);
	Параметры.Свойство("Хаб", Хаб);
	
	БылиОшибки = Не СоздатьСводыЗаявокНаДоставку(Параметры.НачалоПериода, Параметры.КонецПериода,
		Параметры.ПериодыФормированияСводов, Партнер, Параметры.ОтправлятьПоЭлектроннойПочте, Хаб);
	
	Результат = Новый Структура("Успешно", Не БылиОшибки);
	ПоместитьВоВременноеХранилище(Результат, АдресХранилища);
	
КонецПроцедуры

