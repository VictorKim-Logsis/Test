	|	Заявки.ДоговорРеализации КАК ДоговорРеализации,
	|	Заявки.Доля КАК Доля,
	|	Заявки.ОплатаНаличные КАК ОплатаНаличные,
	|	Заявки.ПроцентОтСтоимостиУслуг КАК ПроцентОтСтоимостиУслуг,
	|	Заявки.ФормаОплаты КАК ФормаОплаты
	|ИЗ
	|	ВТ_Заявки КАК Заявки 
	//|	Левое соединение ВТ_ИндивидуальныеНастройкиДоговоров как ВТ_ИндивидуальныеНастройкиДоговоров по Заявки.ДоговорИсходный = ВТ_ИндивидуальныеНастройкиДоговоров.Договор и Заявки.Период = ВТ_ИндивидуальныеНастройкиДоговоров.Период и Заявки.ОплатаНаличные
	//|ГДЕ ВТ_ИндивидуальныеНастройкиДоговоров.ОтражатьРеализациюНаРозничногоПокупателя есть null или ВТ_ИндивидуальныеНастройкиДоговоров.ОтражатьРеализациюНаРозничногоПокупателя =ЛОЖЬ
	|УПОРЯДОЧИТЬ ПО
	|	ДатаДоставки,
	|	НомерЗаказа
	|ИТОГИ
	|	МАКСИМУМ(ПроцентОтСтоимостиУслуг)
	|ПО
	|	Партнер,
	|	Контрагент,
	|	Договор, 
	|	ОплатаНаличные 
	|АВТОУПОРЯДОЧИВАНИЕ"; 
	
	Если Партнер <> Неопределено Тогда
		Запрос.УстановитьПараметр("Партнер", Партнер);
		ТекстОтбораПоПартнеру = "Заявка.Партнер = &Партнер";
	Иначе
		ТекстОтбораПоПартнеру = "ИСТИНА";
	КонецЕсли;
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ТекстОтбораПоПартнеру", ТекстОтбораПоПартнеру);
	
	ВыборкаПартнер = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Партнер");
	
	Пока ВыборкаПартнер.Следующий() Цикл
		
		ВыборкаКонтрагент = ВыборкаПартнер.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Контрагент");
		Пока ВыборкаКонтрагент.Следующий() Цикл
			
			ВыборкаДоговор = ВыборкаКонтрагент.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Договор");
			Пока ВыборкаДоговор.Следующий() Цикл
				
				ВыборкаОплата = ВыборкаДоговор.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "ОплатаНаличные");
				Пока ВыборкаОплата.Следующий() Цикл
			
					ПроцентОтСтоимостиУслуг = ВыборкаОплата.ПроцентОтСтоимостиУслуг / 100;
				
					СводЗаявок = Документы.Логс_СводЗаявокНаДоставку.СоздатьДокумент();
					СводЗаявок.Дата = КонецДня(ДатаСводов);
					СводЗаявок.Организация = ВыборкаОплата.Договор.Организация;
					СводЗаявок.Партнер = ВыборкаОплата.Партнер;
					СводЗаявок.Контрагент = ВыборкаОплата.Контрагент;
					СводЗаявок.Договор = ВыборкаОплата.Договор;
					СводЗаявок.ФормаОплаты = ВыборкаОплата.ФормаОплаты; 
					
					//++ Ким Виктор 17.02.2026
					//НДС для СКС
					//https://logit.okdesk.ru/issues/1051
					Если УчетнаяПолитикаПереопределяемый.ПрименяетсяУСН(СводЗаявок.Организация, ДатаСводов) Тогда
						НалогообложениеНДС = перечисления.ТипыНалогообложенияНДС.ПродажаНеОблагаетсяНДС;
					Иначе
						НалогообложениеНДС = перечисления.ТипыНалогообложенияНДС.ПродажаОблагаетсяНДС;
					КонецЕсли;	
					
					Если СводЗаявок.Организация = ОрионОрганизация Тогда
						НалогообложениеНДС = перечисления.ТипыНалогообложенияНДС.ПродажаОблагаетсяНДС;
					КонецЕсли;
					
					//НалогообложениеНДС = ВыборкаОплата.Договор.НалогообложениеНДС;
					СводЗаявок.НалогообложениеНДС = НалогообложениеНДС;  
					
				    //-- Ким Виктор 17.02.2026
					
					СводЗаявок.Валюта = ВыборкаОплата.Договор.ВалютаВзаиморасчетов;
					СводЗаявок.ВидКлиента = Перечисления.Логс_ВидыКлиентовCRM.СКС;
					СводЗаявок.Ответственный = Пользователи.ТекущийПользователь();
					
					Выборка = ВыборкаОплата.Выбрать();
					Пока Выборка.Следующий() Цикл
						
						СтрокаЗаявки = СводЗаявок.Заявки.Добавить();
						ЗаполнитьЗначенияСвойств(СтрокаЗаявки, Выборка);
						СтрокаЗаявки.ОценочнаяСтоимость = Выборка.ОценочнаяСтоимость * ПроцентОтСтоимостиУслуг;
						СтрокаЗаявки.НаложенныйПлатеж = Выборка.НаложенныйПлатеж;
						СтрокаЗаявки.Тариф = Выборка.Тариф * ПроцентОтСтоимостиУслуг;
						СтрокаЗаявки.ПовторнаяДоставка = Выборка.ПовторнаяДоставка * ПроцентОтСтоимостиУслуг;
						СтрокаЗаявки.КассовоеОбслуживание = Выборка.КассовоеОбслуживание * ПроцентОтСтоимостиУслуг;
						СтрокаЗаявки.Эквайринг = Выборка.Эквайринг * ПроцентОтСтоимостиУслуг;
						СтрокаЗаявки.Страхование = Выборка.Страхование * ПроцентОтСтоимостиУслуг;
						СтрокаЗаявки.ЗаносКГТ = Выборка.ЗаносКГТ * ПроцентОтСтоимостиУслуг;
						СтрокаЗаявки.СМС = Выборка.СМС * ПроцентОтСтоимостиУслуг;
						СтрокаЗаявки.ВозвратныеДокументы = Выборка.ВозвратныеДокументы * ПроцентОтСтоимостиУслуг;
						//2 раза одна и таже строка.
						//СтрокаЗаявки.ПолнаяСтоимостьСНДС = Выборка.ПолнаяСтоимостьСНДС * ПроцентОтСтоимостиУслуг;
						
						//++ Ким Виктор 18.04.2025
						//https://jira-sd.logsis.ru/projects/TSLOG/queues/custom/16/TSLOG-16282  
						ИзПолнойСтоимостииНДС = Ложь;
						Если НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.ПродажаНеОблагаетсяНДС Тогда
							СтрокаЗаявки.ПолнаяСтоимость = Выборка.ПолнаяСтоимостьСНДС * ПроцентОтСтоимостиУслуг;
							СтрокаЗаявки.ПолнаяСтоимостьНДС = 0;
						Иначе
							Если ВыборкаОплата.Договор.СтавкаНДС = Справочники.СтавкиНДС.НайтиПоНаименованию("5%") 
								ИЛИ ВыборкаОплата.Договор.СтавкаНДС = Справочники.СтавкиНДС.НайтиПоНаименованию("22%") Тогда 
								СтавкаИзДоговора = ВыборкаОплата.Договор.СтавкаНДС.Ставка;
								ЧислительНДС   = СтавкаИзДоговора / 100;
								ЗнаменательНДС = 1 +(СтавкаИзДоговора / 100 );  
								СтрокаЗаявки.ПолнаяСтоимостьСНДС = (Выборка.ПолнаяСтоимость + Выборка.ПолнаяСтоимость * ЧислительНДС); 
								СтрокаЗаявки.ПолнаяСтоимость = (СтрокаЗаявки.ПолнаяСтоимостьСНДС - СтрокаЗаявки.ПолнаяСтоимостьСНДС * ЧислительНДС / ЗнаменательНДС) * ПроцентОтСтоимостиУслуг;
								СтрокаЗаявки.ПолнаяСтоимостьНДС = (СтрокаЗаявки.ПолнаяСтоимостьСНДС * ЧислительНДС / ЗнаменательНДС) * ПроцентОтСтоимостиУслуг;	
								СтрокаЗаявки.ПолнаяСтоимостьСНДС = СтрокаЗаявки.ПолнаяСтоимостьСНДС * ПроцентОтСтоимостиУслуг;
								ИзПолнойСтоимостииНДС = Истина;	
								//СтрокаЗаявки.ПолнаяСтоимость = (Выборка.ПолнаяСтоимостьСНДС - Выборка.ПолнаяСтоимостьСНДС * 0.05 / 1.05 ) * ПроцентОтСтоимостиУслуг;
								//СтрокаЗаявки.ПолнаяСтоимостьНДС = (Выборка.ПолнаяСтоимостьСНДС * 0.05 / 1.05) * ПроцентОтСтоимостиУслуг;											
							ИначеЕсли ВыборкаОплата.Договор.СтавкаНДС = Справочники.СтавкиНДС.БезНДС Тогда
								СтрокаЗаявки.ПолнаяСтоимость = Выборка.ПолнаяСтоимостьСНДС * ПроцентОтСтоимостиУслуг;
								СтрокаЗаявки.ПолнаяСтоимостьНДС = 0;
							Иначе
								СтрокаЗаявки.ПолнаяСтоимость = (Выборка.ПолнаяСтоимостьСНДС - Выборка.ПолнаяСтоимостьСНДС * 0.2 / 1.2) * ПроцентОтСтоимостиУслуг;
								СтрокаЗаявки.ПолнаяСтоимостьНДС = (Выборка.ПолнаяСтоимостьСНДС * 0.2 / 1.2) * ПроцентОтСтоимостиУслуг;											
							КонецЕсли;
						КонецЕсли;
						//-- Ким Виктор 18.04.2025 
						
						//СтрокаЗаявки.ПолнаяСтоимость = ?(НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.ПродажаНеОблагаетсяНДС, 
						//								Выборка.ПолнаяСтоимостьСНДС, 
						//								Выборка.ПолнаяСтоимостьСНДС - Выборка.ПолнаяСтоимостьСНДС * 0.2 / 1.2) * ПроцентОтСтоимостиУслуг;
						//СтрокаЗаявки.ПолнаяСтоимостьНДС = ?(НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.ПродажаНеОблагаетсяНДС, 
						//									0, 
						//									Выборка.ПолнаяСтоимостьСНДС * 0.2 / 1.2) * ПроцентОтСтоимостиУслуг;	
						Если НЕ ИзПолнойСтоимостииНДС Тогда 
							СтрокаЗаявки.ПолнаяСтоимостьСНДС = Выборка.ПолнаяСтоимостьСНДС * ПроцентОтСтоимостиУслуг;  
						КонецЕсли;
						СтрокаЗаявки.КПеречислению = СтрокаЗаявки.НаложенныйПлатеж - ?(СводЗаявок.ФормаОплаты = Перечисления.Логс_ФормыОплатыУслугАгенту.Оплата100, 0, СтрокаЗаявки.ПолнаяСтоимостьСНДС);
						
					КонецЦикла;	
					
					СводЗаявок.ЗаполнитьДатуВыставленияСчета();

					СводЗаявок.УстановитьНовыйНомер(СокрЛП(ВыборкаОплата.Договор.Номер) + "SKS-");
					СводЗаявок.Записать(РежимЗаписиДокумента.Запись);
					
					Попытка
						СводЗаявок.Записать(РежимЗаписиДокумента.Проведение);
					Исключение
						ТекстСообщения = СтрШаблон(
							НСтр("ru='Произошла ошибка при проведении свода заявок № %1 от %2: %3'"),
							СводЗаявок.Номер, СводЗаявок.Дата,
							КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
						ЗаписьЖурналаРегистрации("Создание сводов заявок СКС", УровеньЖурналаРегистрации.Ошибка,,, ТекстСообщения);
						ЕстьОшибки = Истина;
						Продолжить;
					КонецПопытки;    				
				КонецЦикла;	
			КонецЦикла;  
			
		КонецЦикла; 		
				
	КонецЦикла;	
	
	Возврат Не ЕстьОшибки;

КонецФункции 

//++ Ким Виктор 14.01.2025
//https://jira-sd.logsis.ru/projects/TSLOG/queues/custom/18/TSLOG-15412
Функция СоздатьСводыЗаявокСКСТМС(ДатаСводов, НачалоПериода, КонецПериода, Партнер = Неопределено) Экспорт 
	
	ЕстьОшибки = Ложь;
	
	МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	ПараметрыСТ = Новый Структура;
	ПараметрыСТ.Вставить("НачалоПериода", НачалоПериода);
	ПараметрыСТ.Вставить("КонецПериода",  КонецПериода);
	ПараметрыСТ.Вставить("Партнер", 		Партнер);
	РегистрыСведений.Логс_ПроцентыСтоимостиУслугСКСTMS.ПоместитьДанныеВоВременнуюТаблицуСписокРеестровАвито(МенеджерВременныхТаблиц, ПараметрыСТ);
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц; 
	Запрос.УстановитьПараметр("Период", НачалоПериода);
	Запрос.УстановитьПараметр("ПартнерСКС", Партнер);
	Запрос.УстановитьПараметр("ПартнерЗаполнен", ЗначениеЗаполнено(Партнер));
	Запрос.Текст = ( "ВЫБРАТЬ
	                 |	ВЫРАЗИТЬ(втРеестрыСамозанятых.Контрагент КАК Справочник.Контрагенты) КАК Контрагент,
	                 |	ВЫРАЗИТЬ(втРеестрыСамозанятых.Партнер КАК Справочник.Партнеры) КАК Партнер,
	                 |	ВЫРАЗИТЬ(втРеестрыСамозанятых.Договор КАК Справочник.ДоговорыКонтрагентов) КАК Договор,
	                 |	втРеестрыСамозанятых.ДатаОказанияУслуг КАК ДатаОказанияУслуг,
	                 |	СУММА(втРеестрыСамозанятых.Сумма) КАК Сумма,
	                 |	СУММА(втРеестрыСамозанятых.СуммаСНалогом) КАК СуммаСНалогом,
	                 |	СУММА(втРеестрыСамозанятых.КоличествоМаршрутов) КАК КоличествоТочек,
	                 |	ВЫРАЗИТЬ(втРеестрыСамозанятых.Договор КАК Справочник.ДоговорыКонтрагентов).Организация КАК Организация,
	                 |	1 КАК КоличествоМаршрутов
	                 |ПОМЕСТИТЬ втРеестрыОрганизация
	                 |ИЗ
	                 |	втРеестрыСамозанятых КАК втРеестрыСамозанятых
	                 |
	                 |СГРУППИРОВАТЬ ПО
	                 |	ВЫРАЗИТЬ(втРеестрыСамозанятых.Договор КАК Справочник.ДоговорыКонтрагентов),
	                 |	ВЫРАЗИТЬ(втРеестрыСамозанятых.Договор КАК Справочник.ДоговорыКонтрагентов).Организация,
	                 |	втРеестрыСамозанятых.ДатаОказанияУслуг,
	                 |	ВЫРАЗИТЬ(втРеестрыСамозанятых.Партнер КАК Справочник.Партнеры),
	                 |	ВЫРАЗИТЬ(втРеестрыСамозанятых.Контрагент КАК Справочник.Контрагенты)
	                 |;
	                 |
	                 |////////////////////////////////////////////////////////////////////////////////
	                 |ВЫБРАТЬ
	                 |	втРеестрыОрганизация.Контрагент КАК Контрагент,
	                 |	втРеестрыОрганизация.Партнер КАК Партнер,
	                 |	втРеестрыОрганизация.Договор КАК Договор,
	                 |	втРеестрыОрганизация.ДатаОказанияУслуг КАК ДатаОказанияУслуг,
	                 |	втРеестрыОрганизация.Сумма КАК Сумма,
	                 |	втРеестрыОрганизация.СуммаСНалогом КАК СуммаСНалогом,
	                 |	втРеестрыОрганизация.Организация КАК Организация,
	                 |	ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка) КАК КонтрагентСКС,
	                 |	ЗНАЧЕНИЕ(Справочник.Партнеры.ПустаяССылка) КАК ПартнерСКС,
	                 |	ЗНАЧЕНИЕ(Справочник.ДоговорыКонтрагентов.ПустаяСсылка) КАК ДоговорСКС,
	                 |	0 КАК ПроцентОтСтоимостиУслуг,
	                 |	0 КАК Доля,
	                 |	0 КАК РаспределениеСКС,
	                 |	ЗНАЧЕНИЕ(Справочник.ДоговорыКонтрагентов.ПустаяСсылка) КАК ДоговорРеализации,
	                 |	втРеестрыОрганизация.КоличествоТочек КАК КоличествоТочек,
	                 |	втРеестрыОрганизация.КоличествоМаршрутов КАК КоличествоМаршрутов
	                 |ИЗ
	                 |	втРеестрыОрганизация КАК втРеестрыОрганизация
	                 |;
	                 |
	                 |////////////////////////////////////////////////////////////////////////////////
	                 |ВЫБРАТЬ
	                 |	втРеестрыОрганизация.Организация КАК Организация,
	                 |	СУММА(втРеестрыОрганизация.Сумма) КАК Сумма,
	                 |	СУММА(втРеестрыОрганизация.СуммаСНалогом) КАК СуммаСНалогом
	                 |ПОМЕСТИТЬ втРеестрыИтогиПоОрганизации
	                 |ИЗ
	                 |	втРеестрыОрганизация КАК втРеестрыОрганизация
	                 |
	                 |СГРУППИРОВАТЬ ПО
	                 |	втРеестрыОрганизация.Организация
	                 |;
	                 |
	                 |////////////////////////////////////////////////////////////////////////////////
	                 |ВЫБРАТЬ
	                 |	Логс_ПроцентыСтоимостиУслугСКСTMSСрезПоследних.Организация КАК Организация,
	                 |	Логс_ПроцентыСтоимостиУслугСКСTMSСрезПоследних.Партнер КАК ПартнерСКС,
	                 |	Логс_ПроцентыСтоимостиУслугСКСTMSСрезПоследних.Контрагент КАК КонтрагентСКС,
	                 |	Логс_ПроцентыСтоимостиУслугСКСTMSСрезПоследних.Договор КАК ДоговорСКС,
	                 |	Логс_ПроцентыСтоимостиУслугСКСTMSСрезПоследних.ПроцентОтСтоимостиУслуг КАК ПроцентОтСтоимостиУслуг,
	                 |	Логс_ПроцентыСтоимостиУслугСКСTMSСрезПоследних.Доля КАК Доля,
	                 |	Логс_ПроцентыСтоимостиУслугСКСTMSСрезПоследних.ДоговорРеализации КАК ДоговорРеализации,
	                 |	0 КАК КоличествоЛимитаРаспределения,
	                 |	втРеестрыИтогиПоОрганизации.СуммаСНалогом * (Логс_ПроцентыСтоимостиУслугСКСTMSСрезПоследних.ПроцентОтСтоимостиУслуг / 100) * Логс_ПроцентыСтоимостиУслугСКСTMSСрезПоследних.Доля КАК СуммаЛимитаРаспределения
	                 |ИЗ
	                 |	РегистрСведений.Логс_ПроцентыСтоимостиУслугСКСTMS.СрезПоследних(&Период, ) КАК Логс_ПроцентыСтоимостиУслугСКСTMSСрезПоследних
	                 |		ЛЕВОЕ СОЕДИНЕНИЕ втРеестрыИтогиПоОрганизации КАК втРеестрыИтогиПоОрганизации
	                 |		ПО Логс_ПроцентыСтоимостиУслугСКСTMSСрезПоследних.Организация = втРеестрыИтогиПоОрганизации.Организация
	                 |ГДЕ
	                 |	ВЫБОР
	                 |			КОГДА &ПартнерЗаполнен
	                 |				ТОГДА Логс_ПроцентыСтоимостиУслугСКСTMSСрезПоследних.Партнер = &ПартнерСКС
	                 |			ИНАЧЕ ИСТИНА
	                 |		КОНЕЦ
	                 |
	                 |СГРУППИРОВАТЬ ПО
	                 |	Логс_ПроцентыСтоимостиУслугСКСTMSСрезПоследних.Партнер,
	                 |	Логс_ПроцентыСтоимостиУслугСКСTMSСрезПоследних.Контрагент,
	                 |	Логс_ПроцентыСтоимостиУслугСКСTMSСрезПоследних.Организация,
	                 |	Логс_ПроцентыСтоимостиУслугСКСTMSСрезПоследних.Договор,
	                 |	Логс_ПроцентыСтоимостиУслугСКСTMSСрезПоследних.ДоговорРеализации,
	                 |	Логс_ПроцентыСтоимостиУслугСКСTMSСрезПоследних.ПроцентОтСтоимостиУслуг,
	                 |	Логс_ПроцентыСтоимостиУслугСКСTMSСрезПоследних.Доля,
	                 |	втРеестрыИтогиПоОрганизации.СуммаСНалогом * (Логс_ПроцентыСтоимостиУслугСКСTMSСрезПоследних.ПроцентОтСтоимостиУслуг / 100) * Логс_ПроцентыСтоимостиУслугСКСTMSСрезПоследних.Доля") ;  
	
	Результат = Запрос.ВыполнитьПакет();
	
	ТаблицаРеестров 		= Результат[1].Выгрузить();
	ТаблицаУсловийПроцентов = Результат[3].Выгрузить();  
	
	ИтогРаспределения = 0;
	
	Для Каждого СтрУсловий из  ТаблицаУсловийПроцентов Цикл 
		
		ИтогРаспределения = СтрУсловий.СуммаЛимитаРаспределения;
		ОтборНеРаспределенных = Новый Структура;
		ОтборНеРаспределенных.Вставить("ПроцентОтСтоимостиУслуг", 0);
		ОтборНеРаспределенных.Вставить("Доля", 0);
		ОтборНеРаспределенных.Вставить("РаспределениеСКС", 0);
		ОтборНеРаспределенных.Вставить("Организация", СтрУсловий.Организация);
		
		МассивСтрок = ТаблицаРеестров.НайтиСтроки(ОтборНеРаспределенных);
		
		Для Каждого Стр из МассивСтрок Цикл 
			
			Если ИтогРаспределения < 0 Тогда 
				Прервать;
			КонецЕсли;   
			
			ЗаполнитьЗначенияСвойств(Стр, СтрУсловий, "КонтрагентСКС, ПартнерСКС, ДоговорСКС, ПроцентОтСтоимостиУслуг, Доля, ДоговорРеализации");  
			Стр.РаспределениеСКС 		= Стр.СуммаСНалогом * (СтрУсловий.ПроцентОтСтоимостиУслуг / 100);
						
			ИтогРаспределения = ИтогРаспределения - Стр.РаспределениеСКС;
			
		КонецЦикла;
					
	КонецЦикла; 

	
	Запрос = Новый Запрос;
	Запрос.Текст =  ("ВЫБРАТЬ
	                 |	втРеестрыОрганизация.Контрагент КАК Контрагент,
	                 |	втРеестрыОрганизация.Партнер КАК Партнер,
	                 |	втРеестрыОрганизация.Договор КАК Договор,
	                 |	втРеестрыОрганизация.ДатаОказанияУслуг КАК ДатаОказанияУслуг,
	                 |	втРеестрыОрганизация.Сумма КАК Сумма,
	                 |	втРеестрыОрганизация.СуммаСНалогом КАК СуммаСНалогом,
	                 |	втРеестрыОрганизация.Организация КАК Организация,
	                 |	втРеестрыОрганизация.КонтрагентСКС КАК КонтрагентСКС,
	                 |	втРеестрыОрганизация.ПартнерСКС КАК ПартнерСКС,
	                 |	втРеестрыОрганизация.ДоговорСКС КАК ДоговорСКС,
	                 |	втРеестрыОрганизация.ПроцентОтСтоимостиУслуг КАК ПроцентОтСтоимостиУслуг,
	                 |	втРеестрыОрганизация.КоличествоМаршрутов КАК КоличествоМаршрутов,
	                 |	втРеестрыОрганизация.КоличествоТочек КАК КоличествоТочек,
	                 |	втРеестрыОрганизация.Доля КАК Доля,
	                 |	втРеестрыОрганизация.РаспределениеСКС КАК РаспределениеСКС,
	                 |	втРеестрыОрганизация.ДоговорРеализации КАК ДоговорРеализации
	                 |ПОМЕСТИТЬ втРаспределение
	                 |ИЗ
	                 |	&втРеестрыОрганизация КАК втРеестрыОрганизация
	                 |;
	                 |
	                 |////////////////////////////////////////////////////////////////////////////////
	                 |ВЫБРАТЬ
	                 |	Логс_СводМаршрутовРаспределениеСКС.Ссылка КАК СводМашрутов,
	                 |	Логс_СводМаршрутовРаспределениеСКС.Партнер КАК Партнер,
	                 |	Логс_СводМаршрутовРаспределениеСКС.Контрагент КАК Контрагент,
	                 |	Логс_СводМаршрутовРаспределениеСКС.Договор КАК Договор,
	                 |	Логс_СводМаршрутовРаспределениеСКС.ДатаОказанияУслуг КАК ДатаОказанияУслуг
	                 |ПОМЕСТИТЬ втСозданныеСводыМашрутов
	                 |ИЗ
	                 |	Документ.Логс_СводМаршрутов.РаспределениеСКС КАК Логс_СводМаршрутовРаспределениеСКС
	                 |ГДЕ
	                 |	Логс_СводМаршрутовРаспределениеСКС.ДатаОказанияУслуг МЕЖДУ &НачалоПериода И &КонецПериода
	                 |	И Логс_СводМаршрутовРаспределениеСКС.Ссылка.Проведен
	                 |;
	                 |
	                 |////////////////////////////////////////////////////////////////////////////////
	                 |ВЫБРАТЬ
	                 |	втРаспределение.Контрагент КАК Контрагент,
	                 |	втРаспределение.Партнер КАК Партнер,
	                 |	втРаспределение.Договор КАК Договор,
	                 |	втРаспределение.ДатаОказанияУслуг КАК ДатаОказанияУслуг,
	                 |	втРаспределение.Сумма КАК Сумма,
	                 |	втРаспределение.СуммаСНалогом КАК СуммаСНалогом,
	                 |	втРаспределение.Организация КАК Организация,
	                 |	втРаспределение.КонтрагентСКС КАК КонтрагентСКС,
	                 |	втРаспределение.ПартнерСКС КАК ПартнерСКС,
	                 |	втРаспределение.ДоговорСКС КАК ДоговорСКС,
	                 |	втРаспределение.ПроцентОтСтоимостиУслуг КАК ПроцентОтСтоимостиУслуг,
	                 |	втРаспределение.Доля КАК Доля,
	                 |	втРаспределение.РаспределениеСКС КАК СуммаРаспределения,
	                 |	втРаспределение.ДоговорРеализации КАК ДоговорРеализации,
	                 |	ЕСТЬNULL(втСозданныеСводыМашрутов.СводМашрутов, НЕОПРЕДЕЛЕНО) КАК СводМаршрутов,
	                 |	втРаспределение.КоличествоТочек КАК КоличествоТочек,
	                 |	втРаспределение.КоличествоМаршрутов КАК КоличествоМаршрутов
	                 |ИЗ
	                 |	втРаспределение КАК втРаспределение
	                 |		ЛЕВОЕ СОЕДИНЕНИЕ втСозданныеСводыМашрутов КАК втСозданныеСводыМашрутов
	                 |		ПО втРаспределение.Контрагент = втСозданныеСводыМашрутов.Контрагент
	                 |			И втРаспределение.Партнер = втСозданныеСводыМашрутов.Партнер
	                 |			И втРаспределение.Договор = втСозданныеСводыМашрутов.Договор
	                 |			И втРаспределение.ДатаОказанияУслуг = втСозданныеСводыМашрутов.ДатаОказанияУслуг
	                 |ГДЕ
	                 |	втСозданныеСводыМашрутов.СводМашрутов ЕСТЬ NULL
	                 |	И втРаспределение.РаспределениеСКС <> 0
	                 |ИТОГИ
	                 |	СУММА(СуммаРаспределения)
	                 |ПО
	                 |	Организация,
	                 |	КонтрагентСКС,
	                 |	ПартнерСКС,
	                 |	ДоговорСКС");   
	Запрос.УстановитьПараметр("втРеестрыОрганизация", ТаблицаРеестров);   
	Запрос.УстановитьПараметр("НачалоПериода", НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода", КонецПериода);
	
	
	Результат = Запрос.Выполнить();
	
	ВыборкаОрганизации  = Результат.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока ВыборкаОрганизации.Следующий() Цикл 
		
		ВыборкаПоКонтрагентам = ВыборкаОрганизации.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		
		Пока ВыборкаПоКонтрагентам.Следующий() Цикл 
			
			ВыборкаПоПартнерам = ВыборкаПоКонтрагентам.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			
			Пока ВыборкаПоПартнерам.Следующий() Цикл 
			
				ВыборкаПоДоговорам = ВыборкаПоПартнерам.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
				
				Пока ВыборкаПоДоговорам.Следующий() Цикл 
					
					СводМаршрутов 			 			 = Документы.Логс_СводМаршрутов.СоздатьДокумент();
					СводМаршрутов.Дата 		 			 = КонецДня(ДатаСводов);
					СводМаршрутов.Организация 			 = ВыборкаОрганизации.Организация;
					СводМаршрутов.Система     			 = Справочники.Логс_ВнешниеСистемы.TMS;
					СводМаршрутов.СамозанятыеНерезиденты = Истина;
					СводМаршрутов.СуммаДокумента		 = ВыборкаПоДоговорам.СуммаРаспределения;
					СводМаршрутов.КонтрагентСКС			 = ВыборкаПоКонтрагентам.КонтрагентСКС;
					СводМаршрутов.ПартнерСКС			 = ВыборкаПоКонтрагентам.КонтрагентСКС.Партнер;
					СводМаршрутов.ДоговорСКС			 = ВыборкаПоДоговорам.ДоговорСКС;  
					СводМаршрутов.Ответственный			 = ПараметрыСеанса.ТекущийПользователь;
					
					ВыборкаДетальная = ВыборкаПоДоговорам.Выбрать();
					//КолВоМаршрутов = 0;
					Пока ВыборкаДетальная.Следующий() Цикл 
						
						//КолВоМаршрутов = КолВоМаршрутов + 1;
						СтрокаСвода = СводМаршрутов.РаспределениеСКС.Добавить();
						ЗаполнитьЗначенияСвойств(СтрокаСвода, ВыборкаДетальная);
						//Это количество точек!!!
						//Если СтрокаСвода.КоличествоМаршрутов = 0 Тогда 
							СтрокаСвода.КоличествоМаршрутов = ВыборкаДетальная.КоличествоТочек;	
						//КонецЕсли;
												
					КонецЦикла;
					
					СводМаршрутов.УстановитьНовыйНомер(СокрЛП(ВыборкаПоДоговорам.ДоговорСКС.Номер) + "TMS-");
					СводМаршрутов.Записать(РежимЗаписиДокумента.Запись);
					
					
					Попытка
						СводМаршрутов.Записать(РежимЗаписиДокумента.Проведение);
					Исключение
						ТекстСообщения = СтрШаблон(
						НСтр("ru='Произошла ошибка при проведении свода маршрутов № %1 от %2: %3'"),
						СводМаршрутов.Номер, СводМаршрутов.Дата,
						КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
						ЗаписьЖурналаРегистрации("Создание сводов маршрутов СКС", УровеньЖурналаРегистрации.Ошибка,,, ТекстСообщения);
						ЕстьОшибки = Истина;
						Продолжить;
					КонецПопытки;   
					
				КонецЦикла;  //Договор
				
			КонецЦикла; //Партнер
			
		КонецЦикла; //Контрагент
		
	КонецЦикла; //Организация
	
	Возврат Не ЕстьОшибки;
    	
КонецФункции
