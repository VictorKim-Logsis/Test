Процедура ДвиженияЗаВычетомПоСводу(Ссылка, Договор, Движения) Экспорт
	
	Данные = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Ссылка, "Организация,Контрагент,Партнер,Договор,Дата,Валюта,ПолнаяСтоимостьВсего,НаложенныйПлатежВсего");
	Дата = Данные.Дата;
	Валюта = Данные.Валюта;
	
	КлючАналитики = ПолучитьКлючАналитикиУчетаПоПартнерам(Данные);
	
	Если Данные.ПолнаяСтоимостьВсего > 0 ИЛИ Данные.НаложенныйПлатежВсего > 0 Тогда
		// Полная стоимость услуг и наложенного платежа
		Движение = Движения.Добавить();
		Движение.Период = Дата;
		Движение.ВидДвижения = ВидДвиженияНакопления.Приход;
		Движение.АналитикаУчетаПоПартнерам = КлючАналитики;
		Движение.СводЗаявок = Ссылка;
		Движение.КоррСводЗаявок = Ссылка;
		Движение.Валюта = Валюта;
		Движение.СуммаУслуг = Данные.ПолнаяСтоимостьВсего;
		Движение.СуммаНаложенногоПлатежа = Данные.НаложенныйПлатежВсего;
		Движение.СуммаКОплате = 0;
	КонецЕсли;
	
	СуммаУслугОстаток = Данные.ПолнаяСтоимостьВсего;
	СуммаНаложенногоПлатежаОстаток = Данные.НаложенныйПлатежВсего;
	
	// Зачет	
	СуммаЗачета = Мин(СуммаУслугОстаток, СуммаНаложенногоПлатежаОстаток);
	
	Если СуммаЗачета > 0 Тогда
		
		Движение = Движения.Добавить();
		Движение.Период = Дата;
		Движение.ВидДвижения = ВидДвиженияНакопления.Расход;
		Движение.АналитикаУчетаПоПартнерам = КлючАналитики;
		Движение.СводЗаявок = Ссылка;
		Движение.КоррСводЗаявок = Ссылка;
		Движение.Валюта = Валюта;
		Движение.СуммаУслуг = СуммаЗачета;
		Движение.СуммаНаложенногоПлатежа = 0;
		Движение.СуммаКОплате = 0;
		
		Движение = Движения.Добавить();
		Движение.Период = Дата;
		Движение.ВидДвижения = ВидДвиженияНакопления.Расход;
		Движение.АналитикаУчетаПоПартнерам = КлючАналитики;
		Движение.СводЗаявок = Ссылка;
		Движение.КоррСводЗаявок = Ссылка;
		Движение.Валюта = Валюта;
		Движение.СуммаУслуг = 0;
		Движение.СуммаНаложенногоПлатежа = СуммаЗачета;
		Движение.СуммаКОплате = 0;
		
		СуммаНаложенногоПлатежаОстаток = СуммаНаложенногоПлатежаОстаток - СуммаЗачета;
		СуммаУслугОстаток = СуммаУслугОстаток - СуммаЗачета;
	КонецЕсли;
	
	/////ЗДЕСЬ НУЖЕН Контроль АВАНСА
	Если СуммаУслугОстаток > 0 Тогда
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ
		               |	Логс_ВзаиморасчетыЗаВычетомОстатки.АналитикаУчетаПоПартнерам КАК АналитикаУчетаПоПартнерам,
		               |	Логс_ВзаиморасчетыЗаВычетомОстатки.СводЗаявок КАК СводЗаявок,
		               |	Логс_ВзаиморасчетыЗаВычетомОстатки.Валюта КАК Валюта,
		               |	Логс_ВзаиморасчетыЗаВычетомОстатки.СуммаУслугОстаток КАК СуммаУслуг
		               |ИЗ
		               |	РегистрНакопления.Логс_ВзаиморасчетыЗаВычетом.Остатки(&Период, АналитикаУчетаПоПартнерам = &АналитикаУчетаПоПартнерам и СводЗаявок = Значение(Документ.Логс_СводЗаявокНаДоставку.ПустаяСсылка)) КАК Логс_ВзаиморасчетыЗаВычетомОстатки
		               |Где Логс_ВзаиморасчетыЗаВычетомОстатки.СуммаУслугОстаток<0";
		Запрос.УстановитьПараметр("Период", Новый Граница(Данные.Дата, ВидГраницы.Включая));
		Запрос.УстановитьПараметр("АналитикаУчетаПоПартнерам", КлючАналитики);
		
		Выборка = Запрос.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда
			тСуммаСписания = Мин(СуммаУслугОстаток, -Выборка.СуммаУслуг); 
			//списываем сумму услуг этого свода
			Движение = Движения.Добавить();
			Движение.АналитикаУчетаПоПартнерам = КлючАналитики;
			Движение.Валюта = Валюта;
			Движение.Период = Дата;
			Движение.ВидДвижения = ВидДвиженияНакопления.Расход;
			Движение.СводЗаявок = Ссылка;
			Движение.СуммаУслуг = тСуммаСписания;
			
			//списываем НП с аванса
			Движение = Движения.Добавить();
			Движение.АналитикаУчетаПоПартнерам = КлючАналитики;
			Движение.Валюта = Валюта;
			Движение.Период = Дата;
			Движение.ВидДвижения = ВидДвиженияНакопления.Расход;
			Движение.КоррСводЗаявок = Ссылка;
			Движение.СуммаУслуг = -тСуммаСписания;
			
			СуммаУслугОстаток = СуммаУслугОстаток - тСуммаСписания;
		КонецЕсли;
	КонецЕсли;
	////ДА
	
	
	//Если Дата >= Дата('20200728') Тогда
		
		Если СуммаУслугОстаток > 0 Тогда
			//Распределяем услуги в невыплаченный НП
			Показатель = "СуммаНаложенногоПлатежа";
			//Распределение = Логс_ДополнительныеПроцедурыИФункции.РаспределитьОстаткиВзаиморасчетовЗаВычетом(КлючАналитики, Ссылка.МоментВремени(), Показатель, СуммаУслугОстаток);
			
			Распределение = РаспределитьОстаткиВзаиморасчетовЗаВычетом(КлючАналитики, Новый Граница(Данные.Дата, ВидГраницы.Включая), Показатель, СуммаУслугОстаток);
			//Распределение = Логс_ДополнительныеПроцедурыИФункции.РаспределитьОстаткиВзаиморасчетовЗаВычетом(КлючАналитики, Новый Граница(Данные.Дата, ВидГраницы.Включая), Показатель, СуммаУслугОстаток);
			Для Каждого Строка из Распределение.Распределение Цикл
				//списываем сумму услуг этого свода
				Движение = Движения.Добавить();
				ЗаполнитьЗначенияСвойств(Движение, Строка, "АналитикаУчетаПоПартнерам, Валюта"); 
				Движение.Период = Дата;
				Движение.ВидДвижения = ВидДвиженияНакопления.Расход;
				Движение.СводЗаявок = Ссылка;
				Движение.КоррСводЗаявок = Строка.СводЗаявок;
				Движение.СуммаУслуг = Строка[Показатель];
				Движение.СуммаНаложенногоПлатежа = 0;
				
				//списываем НП с "богатого" свода
				Движение = Движения.Добавить();
				ЗаполнитьЗначенияСвойств(Движение, Строка, "АналитикаУчетаПоПартнерам, Валюта"); 
				Движение.Период = Дата;
				Движение.ВидДвижения = ВидДвиженияНакопления.Расход;
				Движение.СводЗаявок = Строка.СводЗаявок;
				Движение.КоррСводЗаявок = Ссылка;
				Движение.СуммаУслуг = 0;
				Движение.СуммаНаложенногоПлатежа = Строка[Показатель];
			КонецЦикла;
			
		ИначеЕсли СуммаНаложенногоПлатежаОстаток > 0 Тогда
			//Распределяем долги по услугам
			Показатель = "СуммаУслуг";
			Распределение = РаспределитьОстаткиВзаиморасчетовЗаВычетом(КлючАналитики, Ссылка.МоментВремени(), Показатель, СуммаНаложенногоПлатежаОстаток);
			//Распределение = Логс_ДополнительныеПроцедурыИФункции.РаспределитьОстаткиВзаиморасчетовЗаВычетом(КлючАналитики, Ссылка.МоментВремени(), Показатель, СуммаНаложенногоПлатежаОстаток);
			Для Каждого Строка из Распределение.Распределение Цикл
				//списываем непогашенные услуги другого свода
				Движение = Движения.Добавить();
