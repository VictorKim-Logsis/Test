Процедура РасходыПриУСНОбработатьКУДИРвОсобомПорядке(НаборЗаписей) Экспорт
	
	Регистратор = НаборЗаписей.Отбор.Регистратор.Значение;
	ТипРегистратора = ТипЗнч(Регистратор);
	
	Если КУДИРвОсобомПорядке(Регистратор) Тогда
		
		НаборЗаписей.Очистить();
		
	ИначеЕсли ТипРегистратора = Тип("ДокументСсылка.РегламентнаяОперация") Тогда
		
		ЗаписиДляУдаления = Новый Массив;
		
		Для каждого Запись Из НаборЗаписей Цикл
			
			Если ЗначениеЗаполнено(Запись.ДокументВозникновенияРасходов)
					И КУДИРвОсобомПорядке(Запись.ДокументВозникновенияРасходов)
			Тогда
				ЗаписиДляУдаления.Добавить(Запись);
			КонецЕсли;
			
		КонецЦикла;
		
		Для каждого Запись Из ЗаписиДляУдаления Цикл
			НаборЗаписей.Удалить(Запись);
		КонецЦикла;
		
	КонецЕсли; 
	
КонецПроцедуры 
