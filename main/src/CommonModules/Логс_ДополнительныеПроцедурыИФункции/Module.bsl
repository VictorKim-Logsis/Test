Процедура ДобавитьЗаполнитьПорядокРасчетовПоУслугамЗаДоставку(ТаблицаРасчеты, ТипДокумента)
	
	ТаблицаРасчеты.Колонки.Добавить("ПорядокОперации", Новый ОписаниеТипов("Строка"));
	ТаблицаРасчеты.Колонки.Добавить("ПорядокЗачетаПоДатеПлатежа", Новый ОписаниеТипов("Строка"));
	
	ВидТипДокумента = ?(ТипДокумента = Тип("ДокументСсылка.СчетНаОплатуКлиенту"),
		Новый Структура("Вид,Тип", "2", "91"),
		ОперативныеВзаиморасчетыСервер.ВидТипДокумента(ТипДокумента));
	
	Для каждого СтрокаТаблицы Из ТаблицаРасчеты Цикл
		
		ДатаПлатежа = СтрокаТаблицы.ДатаПлатежа;
		
		// План оплаты
		Если СтрокаТаблицы.Выставлено = 0 И СтрокаТаблицы.КОплате <> 0 Тогда
			
			//СтрокаТаблицы.ПорядокОперации = ОперативныеВзаиморасчетыСервер.Порядок(
			//	СтрокаТаблицы.ДатаРегистратора, СтрокаТаблицы.НомерРегистратора, ВидТипДокумента);
			//СтрокаТаблицы.ПорядокЗачетаПоДатеПлатежа = ОперативныеВзаиморасчетыСервер.Порядок(
			//	ДатаПлатежа, СтрокаТаблицы.НомерРегистратора, ВидТипДокумента); 
						
			СтрокаТаблицы.ПорядокОперации = ОперативныеВзаиморасчетыСервер.Порядок(
				СтрокаТаблицы.ДатаРегистратора, СтрокаТаблицы.НомерРегистратора, ВидТипДокумента.Тип, ВидТипДокумента.Вид, ВидТипДокумента.Тип);
			СтрокаТаблицы.ПорядокЗачетаПоДатеПлатежа = ОперативныеВзаиморасчетыСервер.Порядок(
				ДатаПлатежа, СтрокаТаблицы.НомерРегистратора, ВидТипДокумента.Тип, ВидТипДокумента.Вид, ВидТипДокумента.Тип); 
				
		// Платежные документы и сторно отгрузки
		ИначеЕсли СтрокаТаблицы.ВидДвижения = ВидДвиженияНакопления.Расход
						И СтрокаТаблицы.Выставлено > 0
					Или СтрокаТаблицы.ВидДвижения = ВидДвиженияНакопления.Приход
						И СтрокаТаблицы.Выставлено < 0 Тогда
			
			СтрокаТаблицы.ПорядокОперации = ОперативныеВзаиморасчетыСервер.Порядок(
				СтрокаТаблицы.Период, СтрокаТаблицы.НомерРегистратора, ВидТипДокумента.Тип, ВидТипДокумента.Вид);
			СтрокаТаблицы.ПорядокЗачетаПоДатеПлатежа = СтрокаТаблицы.ПорядокОперации;
			
		// Накладные и пр.
		ИначеЕсли СтрокаТаблицы.Выставлено <> 0 Или СтрокаТаблицы.КОплате <> 0 Тогда
			
			СтрокаТаблицы.ПорядокОперации = ОперативныеВзаиморасчетыСервер.Порядок(
				СтрокаТаблицы.ДатаРегистратора, СтрокаТаблицы.НомерРегистратора, ВидТипДокумента.Тип, ВидТипДокумента.Вид, ВидТипДокумента.Тип);
			СтрокаТаблицы.ПорядокЗачетаПоДатеПлатежа = ОперативныеВзаиморасчетыСервер.Порядок(
				ДатаПлатежа, СтрокаТаблицы.НомерРегистратора, ВидТипДокумента.Тип, ВидТипДокумента.Вид, ВидТипДокумента.Тип);
			
		КонецЕсли; 
		
	КонецЦикла;
	
КонецПроцедуры 

Функция СфорироватьСписокЗависимыхСводовЗаявокПоСписаниюБезналичныхДС(Объект)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	СводЗаявокНаДоставку.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.Логс_СводЗаявокНаДоставку КАК СводЗаявокНаДоставку
	|ГДЕ
	|	СводЗаявокНаДоставку.Ссылка В(&МассивСводов)
	|
	|СГРУППИРОВАТЬ ПО
	|	СводЗаявокНаДоставку.Ссылка
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	СводЗаявокНаДоставку.Ссылка
	|ИЗ
	|	Документ.Логс_СводЗаявокНаДоставку КАК СводЗаявокНаДоставку
	|ГДЕ
	|	СводЗаявокНаДоставку.Ссылка В
	|			(ВЫБРАТЬ
	|				РасшифровкаПоСводам.СводЗаявок
	|			ИЗ
	|				Документ.СписаниеБезналичныхДенежныхСредств.Логс_РаспределениеПоСводамЗаявокНаДоставку КАК РасшифровкаПоСводам
	|			ГДЕ
	|				РасшифровкаПоСводам.Ссылка = &Ссылка)
	|
	|СГРУППИРОВАТЬ ПО
	|	СводЗаявокНаДоставку.Ссылка");
	Запрос.УстановитьПараметр("МассивСводов", Объект.Логс_РаспределениеПоСводамЗаявокНаДоставку.ВыгрузитьКолонку("СводЗаявок"));
	Запрос.УстановитьПараметр("Ссылка", Объект.Ссылка);
	
	УстановитьПривилегированныйРежим(Истина);
	МассивЗавимыхСводовЗаявок = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	Объект.ДополнительныеСвойства.Вставить("МассивЗависимыхСводовЗаявок", Новый ФиксированныйМассив(МассивЗавимыхСводовЗаявок));
	
