	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.Логс_ИсторияФормыОплатыДоговоров.СрезПоследних(&Период, ) КАК Логс_ИсторияФормыОплатыДоговоровСрезПоследних
	|			ПО (ДокСводЗаявокНаДоставку.Договор = Логс_ИсторияФормыОплатыДоговоровСрезПоследних.ДоговорКонтрагентов
	|					И Логс_ИсторияФормыОплатыДоговоровСрезПоследних.ФормаОплатыУслугАгенту = ЗНАЧЕНИЕ(Перечисление.Логс_ФормыОплатыУслугАгенту.Оплата100))
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.АналитикаУчетаПоПартнерам КАК Аналитика
	|			ПО ДокСводЗаявокНаДоставку.Партнер = Аналитика.Партнер
	|				И ДокСводЗаявокНаДоставку.Организация = Аналитика.Организация
	|				И ДокСводЗаявокНаДоставку.Контрагент = Аналитика.Контрагент
	|				И ДокСводЗаявокНаДоставку.Договор = Аналитика.Договор
	|				И (Аналитика.НаправлениеДеятельности = ЗНАЧЕНИЕ(Справочник.НаправленияДеятельности.ПустаяСсылка))
	|		ПО РаспределениеПоСводамЗаявокНаДоставку.СводЗаявок = ДокСводЗаявокНаДоставку.Ссылка
	|ГДЕ
	|	ЗаявкаНаРасходованиеДенежныхСредств.Ссылка = &Ссылка
	|	И ЗаявкаНаРасходованиеДенежныхСредств.Статус <> ЗНАЧЕНИЕ(Перечисление.СтатусыЗаявокНаРасходованиеДенежныхСредств.Отклонена)
	|	И ЗаявкаНаРасходованиеДенежныхСредств.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ОплатаПоставщику)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗаявкаНаРасходованиеДенежныхСредств.Дата КАК Период,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход) КАК ВидДвижения,
	|	Аналитика.КлючАналитики КАК АналитикаУчетаПоПартнерам,
	|	ЗаявкаНаРасходованиеДенежныхСредств_РаспределениеПоСчетам.Счет КАК Счет,
	|	СчетНаОплатуКлиенту.Валюта КАК Валюта,
	|	ЗаявкаНаРасходованиеДенежныхСредств_РаспределениеПоСчетам.Сумма КАК Долг,
	|	ЕСТЬNULL(Логс_ВзаиморасчетыПоУслугам100Остатки.ПредоплатаОстаток, 0) КАК ПредоплатаОстаток,
	|	ВЗ_СчетДатаПлатежа.ДатаПлатежа КАК ДатаПлановогоПогашения
	|ИЗ
	|	Документ.ЗаявкаНаРасходованиеДенежныхСредств.Логс_РаспределениеПоСчетам КАК ЗаявкаНаРасходованиеДенежныхСредств_РаспределениеПоСчетам
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаявкаНаРасходованиеДенежныхСредств КАК ЗаявкаНаРасходованиеДенежныхСредств
	|		ПО ЗаявкаНаРасходованиеДенежныхСредств_РаспределениеПоСчетам.Ссылка = ЗаявкаНаРасходованиеДенежныхСредств.Ссылка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.СчетНаОплатуКлиенту КАК СчетНаОплатуКлиенту
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.АналитикаУчетаПоПартнерам КАК Аналитика
	|			ПО СчетНаОплатуКлиенту.Партнер = Аналитика.Партнер
	|				И СчетНаОплатуКлиенту.Организация = Аналитика.Организация
	|				И СчетНаОплатуКлиенту.Контрагент = Аналитика.Контрагент
	|				И СчетНаОплатуКлиенту.Договор = Аналитика.Договор
	|				И (Аналитика.НаправлениеДеятельности = ЗНАЧЕНИЕ(Справочник.НаправленияДеятельности.ПустаяСсылка))
	|			ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|				СчетНаОплатуКлиентуЭтапыГрафикаОплаты.Ссылка КАК Ссылка,
	|				МАКСИМУМ(СчетНаОплатуКлиентуЭтапыГрафикаОплаты.ДатаПлатежа) КАК ДатаПлатежа
	|			ИЗ
	|				Документ.СчетНаОплатуКлиенту.ЭтапыГрафикаОплаты КАК СчетНаОплатуКлиентуЭтапыГрафикаОплаты
	|			
	|			СГРУППИРОВАТЬ ПО
	|				СчетНаОплатуКлиентуЭтапыГрафикаОплаты.Ссылка) КАК ВЗ_СчетДатаПлатежа
	|			ПО СчетНаОплатуКлиенту.Ссылка = ВЗ_СчетДатаПлатежа.Ссылка
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.Логс_ИсторияФормыОплатыДоговоров.СрезПоследних(&Период, ) КАК Логс_ИсторияФормыОплатыДоговоровСрезПоследних
	|			ПО (СчетНаОплатуКлиенту.Договор = Логс_ИсторияФормыОплатыДоговоровСрезПоследних.ДоговорКонтрагентов
	|					И Логс_ИсторияФормыОплатыДоговоровСрезПоследних.ФормаОплатыУслугАгенту = ЗНАЧЕНИЕ(Перечисление.Логс_ФормыОплатыУслугАгенту.Оплата100))
	|		ПО ЗаявкаНаРасходованиеДенежныхСредств_РаспределениеПоСчетам.Счет = СчетНаОплатуКлиенту.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.Логс_ВзаиморасчетыПоУслугам100.Остатки(, ) КАК Логс_ВзаиморасчетыПоУслугам100Остатки
	|		ПО ЗаявкаНаРасходованиеДенежныхСредств_РаспределениеПоСчетам.Счет = Логс_ВзаиморасчетыПоУслугам100Остатки.Счет
	|ГДЕ
	|	ЗаявкаНаРасходованиеДенежныхСредств.Ссылка = &Ссылка
	|	И ЗаявкаНаРасходованиеДенежныхСредств.Статус <> ЗНАЧЕНИЕ(Перечисление.СтатусыЗаявокНаРасходованиеДенежныхСредств.Отклонена)
	|	И ЗаявкаНаРасходованиеДенежныхСредств.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ВозвратОплатыКлиенту)");
	
	Запрос.УстановитьПараметр("Ссылка", Источник.Ссылка);
	Запрос.УстановитьПараметр("Период", Источник.МоментВремени());
	
	Рез = Запрос.ВыполнитьПакет();
	
	ТаблицаДвижений = Рез[0].Выгрузить();
	ЗаписатьДвиженияЗаявкиНаРасход100(Источник, ТаблицаДвижений);
	
	ТаблицаДвижений = СоздатьТаблицуДвиженийВзаиморасчетыПоУслугам100();
	Выборка = Рез[1].Выбрать();
	Пока Выборка.Следующий() Цикл
		
		Сумма = Выборка.Долг;
		
		// по счету висит предоплата
		Если Выборка.ПредоплатаОстаток > 0 Тогда
			Строка =  ТаблицаДвижений.Добавить();
			ЗаполнитьЗначенияСвойств(Строка, Выборка);
			Строка.ВидДвижения = ВидДвиженияНакопления.Расход;
			Строка.Долг = 0;
			Строка.Предоплата = Мин(Выборка.Долг, Выборка.ПредоплатаОстаток);
			Сумма = Сумма - Строка.Предоплата;
			Строка.ДатаПлановогоПогашения = Дата(1, 1, 1);
		КонецЕсли;
		
		Если Сумма > 0 Тогда
			Строка =  ТаблицаДвижений.Добавить();
			ЗаполнитьЗначенияСвойств(Строка, Выборка);
			Строка.Долг = Сумма;
			Строка.Предоплата = 0;
		КонецЕсли;			
		
	КонецЦикла;	
	ЗаписатьДвиженияВзаиморасчетыПоУслугам100(Источник, ТаблицаДвижений);
	
КонецПроцедуры

Процедура ДвиженияРасчетовПоСводамЗаявокНаДоставкуСписаниеБезналичныхДС(Источник, Отказ, РежимПроведения)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	СписаниеБезналичныхДенежныхСредств.Дата КАК Период,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход) КАК ВидДвижения,
	|	Аналитика.КлючАналитики КАК АналитикаУчетаПоПартнерам,
	|	РаспределениеПоСводамЗаявокНаДоставку.СводЗаявок КАК СводЗаявок,
	|	ДокСводЗаявокНаДоставку.Валюта КАК Валюта,
	|	РаспределениеПоСводамЗаявокНаДоставку.Сумма КАК Сумма,
	|	РаспределениеПоСводамЗаявокНаДоставку.Сумма КАК КОплате,
	|	РаспределениеПоСводамЗаявокНаДоставку.Сумма КАК Оплачивается
	|ИЗ
	|	Документ.СписаниеБезналичныхДенежныхСредств.Логс_РаспределениеПоСводамЗаявокНаДоставку КАК РаспределениеПоСводамЗаявокНаДоставку
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.СписаниеБезналичныхДенежныхСредств КАК СписаниеБезналичныхДенежныхСредств
	|		ПО РаспределениеПоСводамЗаявокНаДоставку.Ссылка = СписаниеБезналичныхДенежныхСредств.Ссылка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.Логс_СводЗаявокНаДоставку КАК ДокСводЗаявокНаДоставку
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.АналитикаУчетаПоПартнерам КАК Аналитика
	|			ПО ДокСводЗаявокНаДоставку.Партнер = Аналитика.Партнер
	|				И ДокСводЗаявокНаДоставку.Организация = Аналитика.Организация
	|				И ДокСводЗаявокНаДоставку.Контрагент = Аналитика.Контрагент
	|				И ДокСводЗаявокНаДоставку.Договор = Аналитика.Договор
	|				И (Аналитика.НаправлениеДеятельности = ЗНАЧЕНИЕ(Справочник.НаправленияДеятельности.ПустаяСсылка))
	|		ПО РаспределениеПоСводамЗаявокНаДоставку.СводЗаявок = ДокСводЗаявокНаДоставку.Ссылка
	|ГДЕ
	|	СписаниеБезналичныхДенежныхСредств.Ссылка = &Ссылка
	|	И СписаниеБезналичныхДенежныхСредств.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ОплатаПоставщику)");
	Запрос.УстановитьПараметр("Ссылка", Источник.Ссылка);
	
	ТаблицаДвижений = Запрос.Выполнить().Выгрузить();
	ЗаписатьДвиженияРасчетовПоНаложеннымПлатежам(Источник, ТаблицаДвижений);
	
	Источник.Движения.Логс_РасчетыПоНаложеннымПлатежам.Записать();
	
	СфорироватьСписокЗависимыхСводовЗаявокПоСписаниюБезналичныхДС(Источник);
	РегистрыСведений.Логс_СостоянияСводовЗаявокНаДоставку.ОтразитьСостояниеСводаЗаявокНаДоставку(Источник, Отказ);
	
КонецПроцедуры

