Функция СтрокаВЧисло(Строка) 
	
	Если Строка = Неопределено Тогда 
		Возврат 0 ;
	КонецЕсли;
	
	Попытка
		Возврат Число(Строка);
	Исключение
		Возврат 0;
	КонецПопытки;
	
