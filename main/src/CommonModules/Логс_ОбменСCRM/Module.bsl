Функция ПолучитьТоварыЗаявки(НомерЗаказа)
	
	ПараметрыЗапроса = Новый Структура;
	ПараметрыЗапроса.Вставить("key", "bc47ef070acd827b5f2f8b3f202a31b6");
	ПараметрыЗапроса.Вставить("order_id", СокрЛП(НомерЗаказа));
	
	Ответ = ЗапросКСерверуCRM_Альт("orders/details", ПараметрыЗапроса);
	 
	Если Не Ответ.Свойство("response") Тогда
		ВызватьИсключение НСтр("ru='Неверный ответ от сервера CRM или ответ содержит ошибку'");
	КонецЕсли; 
	
	Возврат Ответ.response[0].goods;
КонецФункции


Функция ПолучитьДеталиЗаявки(НомерЗаказа)

	ПараметрыЗапроса = Новый Структура;
	ПараметрыЗапроса.Вставить("key", "bc47ef070acd827b5f2f8b3f202a31b6");
	ПараметрыЗапроса.Вставить("order_id", СокрЛП(НомерЗаказа));
	
	Ответ = ЗапросКСерверуCRM_Альт("orders/details", ПараметрыЗапроса);
	 
	Если Не Ответ.Свойство("response") Тогда
		ВызватьИсключение НСтр("ru='Неверный ответ от сервера CRM или ответ содержит ошибку'");
	КонецЕсли; 
	
	Адреса = Новый Структура;
	Адреса.Вставить("АдресСкладаОтправителя",Ответ.response[0].warehouse_address);
