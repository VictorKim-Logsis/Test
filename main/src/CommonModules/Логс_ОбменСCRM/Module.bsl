#Область ОбменССерверомCRM

Функция ЗапросКСерверу(АдресСервера, АдресРесурса, ПараметрыЗапроса, Заголовки = Неопределено) Экспорт
	
	//Соединение = Новый HTTPСоединение(АдресСервера);
	Соединение = Новый HTTPСоединение(АдресСервера,,,,,,Новый ЗащищенноеСоединениеOpenSSL());
	
	СтрокаПараметров = СтруктураВПараметрыЗапроса(ПараметрыЗапроса);
	
	Запрос = Новый HTTPЗапрос(АдресРесурса, Заголовки);
	Запрос.УстановитьТелоИзСтроки(СтрокаПараметров);
	
	Ответ = Соединение.ОтправитьДляОбработки(Запрос);
	
	Если Ответ.КодСостояния <> 200 Тогда
		ТекстСообщения = СтрШаблон(НСтр("ru='При обращении к серверу %1 произошла ошибка %2'"), АдресСервера, Ответ.КодСостояния);
			
		ТекстОшибки = "";
		Попытка
			ТекстОшибки = Ответ.response.Error;
		Исключение
		КонецПопытки;
		СтрокаОтвета = Ответ.ПолучитьТелоКакСтроку();
		
		Если ТекстОшибки = "" Тогда
			ТекстОшибки = ПолучитьТекстОшибкиИзJSON(СтрокаОтвета) + Символы.ПС + СтрокаОтвета; 
		КонецЕсли;
	
		Если ЗначениеЗаполнено(ТекстОшибки) Тогда
			ТекстСообщения = ТекстСообщения + ": " + ТекстОшибки;
		КонецЕсли; 
		
		ВызватьИсключение ТекстСообщения;
	КонецЕсли; 
	
	Поток = Ответ.ПолучитьТелоКакПоток();
	
	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.ОткрытьПоток(Поток);
	
	Результат = ПрочитатьJSON(ЧтениеJSON);
	ТипРезультата = Тип(Результат);
	
	ЧтениеJSON.Закрыть();
	Поток.Закрыть();
	
	Возврат Результат;
	
КонецФункции

