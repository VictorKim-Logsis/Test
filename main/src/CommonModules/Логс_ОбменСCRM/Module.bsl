Функция ПолучитьДоговораИзСРМ(Параметры)
	
	МассивИДДоговора = Новый Массив;		
		
	ПараметрыЗапроса = Новый Структура;
	ПараметрыЗапроса.Вставить("key", "bc47ef070acd827b5f2f8b3f202a31b6");
	ПараметрыЗапроса.Вставить("client_id", "");
	ПараметрыЗапроса.Вставить("date_beg", Формат(Параметры.НачалоПериода, "ДФ=yyyy-MM-dd"));
	ПараметрыЗапроса.Вставить("date_end", Формат(Параметры.КонецПериода, "ДФ=yyyy-MM-dd"));
	ПараметрыЗапроса.Вставить("detail", "1");
		
	Ответ = Логс_ОбменСCRM.ЗапросКСерверуCRM("clientsprices", ПараметрыЗапроса);
			
	Если Не Ответ.Свойство("response") Тогда
		ВызватьИсключение НСтр("ru='Неверный ответ от сервера CRM или ответ содержит ошибку'");
		Возврат МассивИДДоговора;
	КонецЕсли; 			
			
	Для каждого Элемент Из Ответ.response Цикл
		Если МассивИДДоговора.Найти(Элемент.cli_ag_dog) <> Неопределено Тогда
			Продолжить;
		КонецЕсли;	
		МассивИДДоговора.Добавить(Элемент.cli_ag_dog);
	КонецЦикла;
			
	Возврат МассивИДДоговора;	
	
КонецФункции	


