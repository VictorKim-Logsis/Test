Функция ЗагрузитьЗаявкиНаДоставку(Параметры, СписокОшибок) Экспорт
	Перем Партнер, НомерЗаявки, ТДРегион;
	
	НачалоПериода = Параметры.НачалоПериода;
	КонецПериода = Параметры.КонецПериода;
	ОбновлятьСуществующие = Параметры.ОбновлятьСуществующие;
	Параметры.Свойство("Партнер", Партнер);
	Параметры.Свойство("НомерЗаявки", НомерЗаявки);
	Параметры.Свойство("ТДРегион", ТДРегион); 
	
	СписокОшибок = Новый Массив;
	МассивДоговоров = Новый Массив;
	ТаблицаЗаявок = СоздатьТаблицуЗаявок();
	
	// если чтоит фильтр по контрагенту, то оставляем старый алгоритм
	Если ЗначениеЗаполнено(Партнер) Тогда
		СписокАгентов = ПолучитьСписокАгентовДляЗагрузкиЗаявокНаДоставку(Партнер);
	// если идет запрос по всем, то меняем алгоритм - сначала получаем список договоров, по которым есть заявки
	Иначе
		МассивНомерДоговор = ПолучитьДоговораИзСРМ(Параметры);
	    СписокАгентов = ПолучитьСписокАгентовДляЗагрузкиЗаявокНаДоставку(Партнер, МассивНомерДоговор);
	КонецЕсли;
	
	Для каждого ДанныеАгента Из СписокАгентов Цикл
		
		Попытка
			
			СводЗаявок = ПолучитьСводЗаявокНаДоставку(ДанныеАгента.ИдентификаторКлиента, НачалоПериода, КонецПериода, НомерЗаявки, ТДРегион);
			
		Исключение
			
			ТекстСообщения = СтрШаблон(
				НСтр("ru='Произошла ошибка при получении заявок агента %1 из CRM: %2'"),
				ДанныеАгента.Партнер, КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
				
			ЗаписьЖурналаРегистрации("Обмен с CRM. Загрузка заявок", УровеньЖурналаРегистрации.Ошибка,,, ТекстСообщения);
			СписокОшибок.Добавить(Новый Структура("ТекстОшибки,КлючДанных", ТекстСообщения, Неопределено));
			
			Продолжить;
			
		КонецПопытки;
		
		ДобавитьМассивЗаявокВТаблицуЗначений(ТаблицаЗаявок, СводЗаявок, ДанныеАгента,, ТДРегион);
		
		МассивДоговоров.Добавить(ДанныеАгента.Договор);
		
	КонецЦикла;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	НАЧАЛОПЕРИОДА(Заявки.ДатаДоставки, ДЕНЬ) КАК ДатаДоставки,
	|	Заявки.ДатаДоставкиПлан КАК ДатаДоставкиПлан,
	|	Заявки.НомерЗаказа КАК НомерЗаказа,
