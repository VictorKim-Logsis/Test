Функция ПолучитьДетальныеДанныеСводыЗаявокНаДоставку(НомерОтчетаАгента = Неопределено, ДатаНачала = Неопределено, ДатаОкончания = Неопределено) 
	
	Запрос = новый Запрос;
	Запрос.Текст =  ( "ВЫБРАТЬ
	                  |	Логс_СводЗаявокНаДоставкуЗаявки.Ссылка.Дата КАК Дата,
	                  |	Логс_СводЗаявокНаДоставкуЗаявки.Статус КАК Статус,
	                  |	ЕСТЬNULL(ДоговорыКонтрагентов.Логс_ИдентификаторCRM, ""0"") КАК ИдентификаторКлиента,
	                  |	Логс_СводЗаявокНаДоставкуЗаявки.Ссылка.Номер КАК НомерОтчетаАгента,
	                  |	Логс_СводЗаявокНаДоставкуЗаявки.НомерЗаказа КАК НомерЗаявкиНаДоставку,
	                  |	Логс_СводЗаявокНаДоставкуЗаявки.НаложенныйПлатеж КАК НаложенныйПлатеж,
	                  |	Логс_СводЗаявокНаДоставкуЗаявки.КПеречислению КАК КПеречислению,
	                  |	Логс_СводЗаявокНаДоставкуЗаявки.ПолнаяСтоимость КАК ПолнаяСтоимость
	                  |ИЗ
	                  |	Документ.Логс_СводЗаявокНаДоставку.Заявки КАК Логс_СводЗаявокНаДоставкуЗаявки
	                  |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
	                  |		ПО Логс_СводЗаявокНаДоставкуЗаявки.Ссылка.Договор = ДоговорыКонтрагентов.Ссылка
	                  |ГДЕ
	                  |	&ТекстОтборСводовПоПериоду
	                  |	И ВЫБОР
	                  |			КОГДА &НомерОтчетАгентаЗаполнен
	                  |				ТОГДА Логс_СводЗаявокНаДоставкуЗаявки.Ссылка.Номер = &НомерОтчетаАгента
	                  |			ИНАЧЕ ИСТИНА
	                  |		КОНЕЦ
	                  |	И НЕ Логс_СводЗаявокНаДоставкуЗаявки.Ссылка.ПометкаУдаления");
	
	Запрос.УстановитьПараметр("НомерОтчетАгентаЗаполнен", ЗначениеЗаполнено(НомерОтчетаАгента));
	Запрос.УстановитьПараметр("НомерОтчетаАгента", НомерОтчетаАгента);
	Запрос.УстановитьПараметр("ДатаНачала", ?(ДатаНачала = Неопределено, '00010101', НачалоДня(ДатаНачала)));
	Запрос.УстановитьПараметр("ДатаОкончания", ?(ДатаОкончания = Неопределено, '00010101', КонецДня(ДатаОкончания)));
	
	Если ЗначениеЗаполнено(ДатаНачала) И ЗначениеЗаполнено(ДатаОкончания) Тогда
		ТекстОтборСводовПоПериоду = "Логс_СводЗаявокНаДоставкуЗаявки.Ссылка.Дата МЕЖДУ &ДатаНачала И &ДатаОкончания";
	ИначеЕсли ЗначениеЗаполнено(ДатаНачала) Тогда
		ТекстОтборСводовПоПериоду = "Логс_СводЗаявокНаДоставкуЗаявки.Ссылка.Дата >= &ДатаНачала";
	ИначеЕсли ЗначениеЗаполнено(ДатаОкончания) Тогда
		ТекстОтборСводовПоПериоду = "Логс_СводЗаявокНаДоставкуЗаявки.Ссылка.Дата <= &ДатаОкончания";
	Иначе
		ТекстОтборСводовПоПериоду = "ИСТИНА";
	КонецЕсли; 
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ТекстОтборСводовПоПериоду", ТекстОтборСводовПоПериоду);
	
	РезультатЗапроса = Запрос.Выполнить();   
	
	ДанныеСводов = Новый Структура;
	ДанныеСводов.Вставить("Своды", РезультатЗапроса.Выбрать());
	
	Возврат ДанныеСводов; 
	
КонецФункции

