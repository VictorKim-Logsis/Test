#Область ФоновыеПроцедурыОбновленияДанныхНаСервереCRM

Процедура ОповеститьCRMОСозданииКлиента(Договор, АдресХранилища) Экспорт
	
	РезультатВыполнения = ОбновитьДанныеКлиентаВCRM(Договор);
	ПоместитьВоВременноеХранилище(РезультатВыполнения, АдресХранилища);
	
КонецПроцедуры

Функция ОбновитьДанныеКлиентаВCRM(Договор) Экспорт
	Если НЕ Договор.Логс_ВидДоговораCRM = Перечисления.Логс_ВидыДоговоровCRM.Агентский Тогда
		Возврат Новый Структура("Успешно", Истина);
	КонецЕсли; 
	
	УстановитьПривилегированныйРежим(Истина);
	
	ДанныеДоговора = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Договор,
		"Организация,Контрагент,Партнер,Номер,Дата,Логс_ИдентификаторCRM,БанковскийСчетКонтрагента," +
		"Менеджер,Логс_Аккаунт,Логс_МенеджерКО," +
		"Логс_БрендАгента,Логс_ИмяПользователяCRM,Логс_ПарольCRM,Статус, Логс_ДоговорОферты," +
		"Логс_КоличествоЗаказовВыбранноеПоОферте, Логс_СрокПеречисленияНП, Логс_ПериодФормированияСводовАгента");
	ДанныеПартнера = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(
		ДанныеДоговора.Партнер, "Наименование,НаименованиеПолное");
	ДанныеКонтрагента = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(
		ДанныеДоговора.Контрагент, "ИНН,КПП");
	ОГРН = УправлениеСвойствами.ЗначениеСвойства(ДанныеДоговора.Партнер, "АБС_КонтрагентОГРН");
	//Банк = ДанныеДоговора.БанковскийСчетКонтрагента.Банк;	
	ДанныеБанковскогоСчета = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДанныеДоговора.БанковскийСчетКонтрагента,
		"НаименованиеБанка, БИКБанка, КоррСчетБанка, НомерСчета");
		
	Если НЕ ЗначениеЗаполнено(ДанныеДоговора.Логс_ИмяПользователяCRM) Тогда
		Возврат Новый Структура("Успешно", Истина);
	КонецЕсли;
	
	ИдентификаторОрганизации = УправлениеСвойствами.ЗначениеСвойства(ДанныеДоговора.Организация,
		Логс_ДополнительныеПроцедурыИФункцииПовтИсп.СвойствоИдентификаторОрганизацииCRM());
	
	Обновить = ЗначениеЗаполнено(ДанныеДоговора.Логс_ИдентификаторCRM);
	
	ПараметрыЗапроса = Новый Структура;
//	ПараметрыЗапроса.Вставить("key", "901076233795fc304901c25412fa87b2");  //bc47ef070acd827b5f2f8b3f202a31b6
	ПараметрыЗапроса.Вставить("key", "bc47ef070acd827b5f2f8b3f202a31b6");  //
	ПараметрыЗапроса.Вставить("uid", Строка(ДанныеДоговора.Партнер.УникальныйИдентификатор()));
	ПараметрыЗапроса.Вставить("agentName", ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДанныеДоговора.Логс_БрендАгента, "Наименование"));
	ПараметрыЗапроса.Вставить("agentFullName", ДанныеПартнера.НаименованиеПолное);
	ПараметрыЗапроса.Вставить("address", УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъекта(
		ДанныеДоговора.Контрагент, Справочники.ВидыКонтактнойИнформации.ЮрАдресКонтрагента, ТекущаяДатаСеанса()));
	ПараметрыЗапроса.Вставить("inn", ДанныеКонтрагента.ИНН);
	ПараметрыЗапроса.Вставить("kpp", ДанныеКонтрагента.КПП);
	ПараметрыЗапроса.Вставить("ogrn", ОГРН);
	ПараметрыЗапроса.Вставить("client_type", "agent");
	ПараметрыЗапроса.Вставить("parent_company", ?(ЗначениеЗаполнено(ИдентификаторОрганизации), ИдентификаторОрганизации, ""));
	ПараметрыЗапроса.Вставить("dogNum", ДанныеДоговора.Номер);
	ПараметрыЗапроса.Вставить("dogDate", Формат(ДанныеДоговора.Дата, "ДФ=yyyy-MM-dd"));
	ПараметрыЗапроса.Вставить("status", ?(ДанныеДоговора.Статус = Перечисления.СтатусыДоговоровКонтрагентов.Действует, 1, 0));
	ПараметрыЗапроса.Вставить("email", УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъекта(
		ДанныеДоговора.Партнер, Справочники.ВидыКонтактнойИнформации.EmailПартнера));
	ПараметрыЗапроса.Вставить("user", Строка(ПараметрыСеанса.ТекущийПользователь));
	ПараметрыЗапроса.Вставить("sales_manager_uid", ДанныеДоговора.Логс_МенеджерКО.УникальныйИдентификатор());
	ПараметрыЗапроса.Вставить("sales_manager_name", ДанныеДоговора.Логс_МенеджерКО);
	ПараметрыЗапроса.Вставить("connection_manager_uid", ДанныеДоговора.Менеджер.УникальныйИдентификатор());
	ПараметрыЗапроса.Вставить("connection_manager_name", ДанныеДоговора.Менеджер);
	ПараметрыЗапроса.Вставить("account_manager_name", ДанныеДоговора.Логс_Аккаунт);
	ПараметрыЗапроса.Вставить("account_manager_uid", ДанныеДоговора.Логс_Аккаунт.УникальныйИдентификатор());  
	
	ПараметрыЗапроса.Вставить("bank_name", ДанныеБанковскогоСчета.НаименованиеБанка);
	ПараметрыЗапроса.Вставить("bank_bik", ДанныеБанковскогоСчета.БИКБанка);
	ПараметрыЗапроса.Вставить("bank_korr", ДанныеБанковскогоСчета.КоррСчетБанка);
	ПараметрыЗапроса.Вставить("bank_raschet", ДанныеБанковскогоСчета.НомерСчета);
	
	
//перенести в повтисп на релизе//////////////////////////////////////////////////////////////////////////////////////
/////////////////////////////////////
СоответствиеСроковНП = Новый Соответствие;
СоответствиеСроковНП.Вставить(Перечисления.Логс_СрокиПеречисленияНП.Ежедневно, 1);			//Ежедневно+2 раб.дня
СоответствиеСроковНП.Вставить(Перечисления.Логс_СрокиПеречисленияНП.ПлатежныйДень, 2);		//Платежный день (Вт/Пт)
СоответствиеСроковНП.Вставить(Перечисления.Логс_СрокиПеречисленияНП.Еженедельно, 3);		//4 раза в месяц+2 раб.дня
СоответствиеСроковНП.Вставить(Перечисления.Логс_СрокиПеречисленияНП.НеПозднее10КалДней, 4);	//Не позднее 10 календ.дней
СоответствиеСроковНП.Вставить(Перечисления.Логс_СрокиПеречисленияНП.Ежедневно3, 5);			//Ежедневно + 3 раб.дня
СоответствиеСроковНП.Вставить(Перечисления.Логс_СрокиПеречисленияНП.ПлатежныйДеньСрПт, 6);	//Платежный день (Ср/Пн)
СоответствиеСроковНП.Вставить(Перечисления.Логс_СрокиПеречисленияНП.Еженедельно3, 7);		//4 раза в месяц + 3 раб.дня
СоответствиеСроковНП.Вставить(Перечисления.Логс_СрокиПеречисленияНП.НеделяПлюсШестьДней, 8);//4 раза в мес +6 раб.дн.
СоответствиеСроковНП.Вставить(Перечисления.Логс_СрокиПеречисленияНП.Ежедневно5, 9);			//Ежедневно + 5 раб.дней

СоответствиеПериодичностиОтчетовА = Новый Соответствие;
СоответствиеПериодичностиОтчетовА.Вставить(Перечисления.Логс_ПериодыФормированияСводовАгентов.Ежедневно, 1);			//Ежедневно
СоответствиеПериодичностиОтчетовА.Вставить(Перечисления.Логс_ПериодыФормированияСводовАгентов.ДваРазаВНеделю, 2);		//Пн - Ср / Чт - Вс
СоответствиеПериодичностиОтчетовА.Вставить(Перечисления.Логс_ПериодыФормированияСводовАгентов.Еженедельно, 3);			//4 раза в месяц
СоответствиеПериодичностиОтчетовА.Вставить(Перечисления.Логс_ПериодыФормированияСводовАгентов.ДваРазаВМесяц, 4);		//15/30(31) число
СоответствиеПериодичностиОтчетовА.Вставить(Перечисления.Логс_ПериодыФормированияСводовАгентов.Декадно, 5);				//1-10, 11-20, 21-30(31)
СоответствиеПериодичностиОтчетовА.Вставить(Перечисления.Логс_ПериодыФормированияСводовАгентов.ПоПятницам, 6);			//4 раза в мес по ПТ
СоответствиеПериодичностиОтчетовА.Вставить(Перечисления.Логс_ПериодыФормированияСводовАгентов.Ежемесячно, 7);			//Ежемесячно
/////////////////////////////////////

	СрокНП = СоответствиеСроковНП.Получить(ДанныеДоговора.Логс_СрокПеречисленияНП);
	ПараметрыЗапроса.Вставить("payment_rule", ?(ЗначениеЗаполнено(СрокНП), СрокНП, 0));

	ПериодичностьОтчетов = СоответствиеПериодичностиОтчетовА.Получить(ДанныеДоговора.Логс_ПериодФормированияСводовАгента);
	ПараметрыЗапроса.Вставить("report_period", ?(ЗначениеЗаполнено(ПериодичностьОтчетов), ПериодичностьОтчетов, 0));

	Запрос = Новый Запрос(
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	КонтактныеЛицаПартнеров.Ссылка КАК Ссылка,
	|	КонтактныеЛицаПартнеров.Наименование КАК Наименование,
	|	КонтактныеЛицаПартнеров.ДополнительнаяИнформация КАК ДополнительнаяИнформация
	|ИЗ
	|	Справочник.КонтактныеЛицаПартнеров.РолиКонтактногоЛица КАК КонтактныеЛицаПартнеровРолиКонтактногоЛица
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.КонтактныеЛицаПартнеров КАК КонтактныеЛицаПартнеров
	|		ПО КонтактныеЛицаПартнеровРолиКонтактногоЛица.Ссылка = КонтактныеЛицаПартнеров.Ссылка
	|			И (КонтактныеЛицаПартнеров.Владелец = &Владелец)
	|			И (НЕ КонтактныеЛицаПартнеров.ПометкаУдаления)
	|ГДЕ
	|	КонтактныеЛицаПартнеровРолиКонтактногоЛица.РольКонтактногоЛица = &КонтактДляКО
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	КонтактныеЛицаПартнеров.Ссылка КАК Ссылка,
	|	КонтактныеЛицаПартнеров.Наименование КАК Наименование,
	|	КонтактныеЛицаПартнеров.ДополнительнаяИнформация КАК ДополнительнаяИнформация
	|ИЗ
	|	Справочник.КонтактныеЛицаПартнеров.РолиКонтактногоЛица КАК КонтактныеЛицаПартнеровРолиКонтактногоЛица
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.КонтактныеЛицаПартнеров КАК КонтактныеЛицаПартнеров
	|		ПО КонтактныеЛицаПартнеровРолиКонтактногоЛица.Ссылка = КонтактныеЛицаПартнеров.Ссылка
	|			И (КонтактныеЛицаПартнеров.Владелец = &Владелец)
	|			И (НЕ КонтактныеЛицаПартнеров.ПометкаУдаления)
	|ГДЕ
	|	КонтактныеЛицаПартнеровРолиКонтактногоЛица.РольКонтактногоЛица = &ПодписантДоговора");
	Запрос.УстановитьПараметр("Владелец", ДанныеДоговора.Партнер);
	Запрос.УстановитьПараметр("КонтактДляКО",
		Справочники.РолиКонтактныхЛицПартнеров.НайтиПоНаименованию(
			"контакт для КО", Истина)
	);
	Запрос.УстановитьПараметр("ПодписантДоговора",
		Справочники.РолиКонтактныхЛицПартнеров.НайтиПоНаименованию(
			"подписант договора", Истина)
	);
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	Выборка = РезультатЗапроса[0].Выбрать();
	Если Выборка.Следующий() Тогда
		ПараметрыЗапроса.Вставить("contact_name", Выборка.Наименование);
		ПараметрыЗапроса.Вставить("contact_phone", УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъекта(
			Выборка.Ссылка, Справочники.ВидыКонтактнойИнформации.ТелефонКонтактногоЛица));
		ПараметрыЗапроса.Вставить("contact_email", УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъекта(
			Выборка.Ссылка, Справочники.ВидыКонтактнойИнформации.EmailКонтактногоЛица));
		ПараметрыЗапроса.Вставить("contact_add_info", Выборка.ДополнительнаяИнформация);
		
	Иначе
		ПараметрыЗапроса.Вставить("contact_name", "");
		ПараметрыЗапроса.Вставить("contact_phone", "");
		ПараметрыЗапроса.Вставить("contact_email", "");
		ПараметрыЗапроса.Вставить("contact_add_info", "");
	КонецЕсли; 
	
	Выборка = РезультатЗапроса[1].Выбрать();
	ПараметрыЗапроса.Вставить("director", ?(Выборка.Следующий(),
		Выборка.Наименование, ""));
		
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
					|	Телефоны.Телефон КАК Телефон
					|ИЗ
					|	(ВЫБРАТЬ
					|		ВЫРАЗИТЬ(КонтрагентыКонтактнаяИнформация.Представление КАК СТРОКА(20)) КАК Телефон
					|	ИЗ
					|		Справочник.Контрагенты.КонтактнаяИнформация КАК КонтрагентыКонтактнаяИнформация
					|	ГДЕ
					|		КонтрагентыКонтактнаяИнформация.Ссылка = &Контрагент
					|		И КонтрагентыКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ТелефонКонтрагента)
					|	
					|	ОБЪЕДИНИТЬ ВСЕ
					|	
					|	ВЫБРАТЬ
					|		ВЫРАЗИТЬ(ПартнерыКонтактнаяИнформация.Представление КАК СТРОКА(20))
					|	ИЗ
					|		Справочник.Партнеры.КонтактнаяИнформация КАК ПартнерыКонтактнаяИнформация
					|	ГДЕ
					|		ПартнерыКонтактнаяИнформация.Ссылка = &Партнер
					|		И ПартнерыКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ТелефонПартнера)) КАК Телефоны
					|УПОРЯДОЧИТЬ ПО
					|	Телефон УБЫВ";	
	Запрос.УстановитьПараметр("Контрагент", ДанныеДоговора.Контрагент); 
	Запрос.УстановитьПараметр("Партнер", ДанныеДоговора.Партнер); 
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		ПараметрыЗапроса.Вставить("callcenter_phone", Выборка.Телефон);
	Иначе
		ПараметрыЗапроса.Вставить("callcenter_phone", ПараметрыЗапроса.contact_phone);
	КонецЕсли;
		
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	EmailДляРассылки.Адрес КАК Адрес
	|ИЗ
	|	Справочник.ДоговорыКонтрагентов.Логс_EmailДляРассылки КАК EmailДляРассылки
	|ГДЕ
	|	EmailДляРассылки.Ссылка = &Договор
	|	И EmailДляРассылки.Адрес <> """"");
	Запрос.УстановитьПараметр("Договор", Договор);
	
	EmailДляРассылки = "";
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Если EmailДляРассылки <> "" Тогда
			EmailДляРассылки = EmailДляРассылки + ", ";
		КонецЕсли; 
		EmailДляРассылки = EmailДляРассылки + Выборка.Адрес;
	КонецЦикла; 
	
	ПараметрыЗапроса.Вставить("contact_mail_client", EmailДляРассылки);
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	EmailДляРассылокКО.Адрес КАК Адрес
	|ИЗ
	|	Справочник.ДоговорыКонтрагентов.Логс_EmailДляРассылокКО КАК EmailДляРассылокКО
	|ГДЕ
	|	EmailДляРассылокКО.Ссылка = &Договор
	|	И EmailДляРассылокКО.Адрес <> """"");
	Запрос.УстановитьПараметр("Договор", Договор);
	
	EmailДляРассылкиКО = "";
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Если EmailДляРассылкиКО <> "" Тогда
			EmailДляРассылкиКО = EmailДляРассылкиКО + ", ";
		КонецЕсли; 
		EmailДляРассылкиКО = EmailДляРассылкиКО + Выборка.Адрес;
	КонецЦикла;
	
	ПараметрыЗапроса.Вставить("mail_ko", EmailДляРассылкиКО);
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
		|	Логс_ИсторияФормыОплатыДоговоровСрезПоследних.ДоговорКонтрагентов КАК ДоговорКонтрагентов,
		|	Логс_ИсторияФормыОплатыДоговоровСрезПоследних.ФормаОплатыУслугАгенту КАК ФормаОплатыУслугАгенту
		|ИЗ
		|	РегистрСведений.Логс_ИсторияФормыОплатыДоговоров.СрезПоследних(&Период, ДоговорКонтрагентов = &Договор) КАК Логс_ИсторияФормыОплатыДоговоровСрезПоследних";
	Запрос.УстановитьПараметр("Договор", Договор);
	Запрос.УстановитьПараметр("Период", ТекущаяДата());
	
	тФормаОплаты = 0;
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		тФормаОплаты = ?(Выборка.ФормаОплатыУслугАгенту = Перечисления.Логс_ФормыОплатыУслугАгенту.Оплата100, 1, 2)
	КонецЦикла;
	
	ПараметрыЗапроса.Вставить("payment_form", тФормаОплаты);
	
	
	Если Обновить Тогда
		ПараметрыЗапроса.Вставить("update", 1);
		ПараметрыЗапроса.Вставить("client_id", ДанныеДоговора.Логс_ИдентификаторCRM);
	Иначе
		ПараметрыЗапроса.Вставить("update", 0);
		ПараметрыЗапроса.Вставить("userName", ДанныеДоговора.Логс_ИмяПользователяCRM);
		ПараметрыЗапроса.Вставить("password", ДанныеДоговора.Логс_ПарольCRM);
		
		ПараметрыЗапроса.Вставить("is_offer", ?(ДанныеДоговора.Логс_ДоговорОферты, 1,0));
		ПараметрыЗапроса.Вставить("month_orders_count", ?(ДанныеДоговора.Логс_ДоговорОферты, ДанныеДоговора.Логс_КоличествоЗаказовВыбранноеПоОферте,0));
	КонецЕсли; 
	
	Попытка
		//Ответ = ОбновитьДанныеНаСервереCRM("1cdognum", ПараметрыЗапроса);
		Ответ = ОбновитьДанныеНаСервереCRM_Альт("clients", ПараметрыЗапроса);
		Результат = Ответ.response[0];
		Если Результат.Свойство("client_id") Тогда
			УстановитьПривилегированныйРежим(Истина);
			ДоговорОбъект = Договор.ПолучитьОбъект();
			ДоговорОбъект.Логс_ИдентификаторCRM = Формат(Результат.client_id,"ЧГ=");
			ДоговорОбъект.ОбменДанными.Загрузка = Истина;
			ДоговорОбъект.Записать();
			УстановитьПривилегированныйРежим(Ложь);
			
			РезультатВыполнения = Новый Структура("Успешно,Идентификатор",
				Истина, Результат.client_id);
				
			тТекстПисьма = "Имя пользователя: "+ДанныеДоговора.Логс_ИмяПользователяCRM+ Символы.ПС + "Пароль: "+ ДанныеДоговора.Логс_ПарольCRM;
			Отдел = ?(ДанныеДоговора.Логс_ДоговорОферты, "Оферта", "Коммерческий");
			ОповеститьПоПочтеНужныйОтдел(Отдел, Формат(Результат.client_id, "ЧГ="), ДанныеДоговора.Контрагент, тТекстПисьма);
			ОповеститьПоПочтеНужныйОтдел("Аккаунтинг", Формат(Результат.client_id, "ЧГ="), ДанныеДоговора.Контрагент, тТекстПисьма);
			
			Если ДанныеДоговора.Логс_ДоговорОферты Тогда
				ТекстПисьма = Константы.Логс_ТекстПисьмаНовогоЛКпоОферте.Получить();
				ТекстПисьма = СтрЗаменить(ТекстПисьма, "[[+email]]", ДанныеДоговора.Логс_ИмяПользователяCRM);
				ТекстПисьма = СтрЗаменить(ТекстПисьма, "[[+password]]", ДанныеДоговора.Логс_ПарольCRM); 
				РегистрыСведений.Логс_ПочтовыеРассылки.ОтправитьРассылкуСинхронно(ПараметрыЗапроса.email, "Договор оферты Logsis", ТекстПисьма, "Учетные данные оферта");
			КонецЕсли;
		ИначеЕсли Результат.Свойство("success") Тогда
			// Обновление клиента.
			РезультатВыполнения = Новый Структура("Успешно,Идентификатор",
				Истина, Неопределено);
		Иначе
			РезультатВыполнения = Новый Структура("Успешно", Ложь);
			
			Если Результат.Свойство("Error") Тогда
				РезультатВыполнения.Вставить("ТекстОшибки", Результат.Error);
			Иначе
				РезультатВыполнения.Вставить("ТекстОшибки", НСтр("ru='Неизвестная ошибка'"));
			КонецЕсли; 
				
			ЗаписьЖурналаРегистрации(
				"Обмен с CRM. Оповещение о создании агента",
				УровеньЖурналаРегистрации.Ошибка,
				Метаданные.Справочники.ДоговорыКонтрагентов,
				Договор,
				СтрШаблон(НСтр("ru='Произошла ошибка при обновлении данных на сервере CRM: %1'"), РезультатВыполнения.ТекстОшибки));
		КонецЕсли; 
	Исключение
		РезультатВыполнения = Новый Структура("Успешно,ТекстОшибки",
			Ложь,
			КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
			
		ЗаписьЖурналаРегистрации(
			"Обмен с CRM. Оповещение о создании агента",
			УровеньЖурналаРегистрации.Ошибка,
			Метаданные.Справочники.ДоговорыКонтрагентов,
			Договор,
			СтрШаблон(НСтр("ru='Произошла ошибка при обновлении данных на сервере CRM: %1'"), КраткоеПредставлениеОшибки(ИнформацияОбОшибке())));
	КонецПопытки; 
	
	//ПоместитьВоВременноеХранилище(РезультатВыполнения, АдресХранилища);
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат РезультатВыполнения;
КонецФункции 
 

Процедура ОповеститьCRMОСозданииКурьера(Сотрудник, АдресХранилища) Экспорт
	
	Если ТипЗнч(Сотрудник) = Тип("СправочникСсылка.ДоговорыКонтрагентов") Тогда
		Возврат;
		ОповеститьCRMОСозданииКурьераСамозанятого(Сотрудник, АдресХранилища);
	КонецЕсли;
	
	ОбменСCRM = УправлениеСвойствами.ЗначениеСвойства(Сотрудник,
		Логс_ДополнительныеПроцедурыИФункцииПовтИсп.СвойствоСотрудникОбменСCRM());
		
	////неактуальный код - отключение курьеров также происходит в 1С	
	//Если ОбменСCRM <> Истина Тогда
	//		
	//	РезультатВыполнения = Новый Структура("Успешно,ТекстОшибки", Ложь,
	//		СтрШаблон(НСтр("ru='Сотрудник %1 не используется в обмене с CRM'"), Сотрудник));
	//		
	//	ПоместитьВоВременноеХранилище(РезультатВыполнения, АдресХранилища);
	//	
	//	Возврат;
	//	
	//КонецЕсли; 
	
	ДанныеКурьера = ПолучитьДанныеКурьера(Сотрудник);
	КонтактнаяИнформация = ДанныеКурьера.ФизическоеЛицо.КонтактнаяИнформация;
	Для каждого Строка из КонтактнаяИнформация Цикл
		Если Строка.Вид.Наименование = "Адрес по прописке" Тогда
		 АдресПоПрописке = Строка.Представление;	
		ИначеЕсли Строка.Вид.Наименование = "Адрес места проживания" Тогда
		 ФактичАдрес = Строка.Представление;	
		КонецЕсли;
	КонецЦикла;	
	
	ХабИД = Логс_ДополнительныеПроцедурыИФункцииПовтИсп.ПолучитьХабСотрудника(Сотрудник).ИД;
	
	ФИОФизическогоЛица = ФизическиеЛицаУТ.ФамилияИмяОтчество(ДанныеКурьера.ФизическоеЛицо);
	ФамилияИнициалы = ФизическиеЛицаКлиентСервер.ФамилияИнициалы(ФИОФизическогоЛица);
	
	ФИОКоротко = "" + СокрЛП(ФИОФизическогоЛица.Фамилия) + " " + СокрЛП(ФИОФизическогоЛица.Имя);
	
	//// ABS начало изменения*
	//// 05.12.2019 Архипкин Р.В.
	//// не уникальное имя курьера, берем больше символов из фамилии
	////ИмяПользователя = НРег(Лев(ФИОФизическогоЛица.Фамилия, 1) + "." + ФИОФизическогоЛица.Имя);
	//ИмяПользователя = НРег(Лев(ФИОФизическогоЛица.Фамилия, 5) + "." + ФИОФизическогоЛица.Имя);
	//// ABS конец изменения**
	
	///Снова проблемы с уникальностью
	///делаем перебор - код переместился в момент выполнения запроса
	
	//ИмяПользователя = СтроковыеФункцииКлиентСервер.СтрокаЛатиницей(ИмяПользователя);
	
	ПараметрыЗапроса = Новый Структура;
	//ПараметрыЗапроса.Вставить("key", "901076233795fc304901c25412fa87b2"); //bc47ef070acd827b5f2f8b3f202a31b6
	ПараметрыЗапроса.Вставить("key", "bc47ef070acd827b5f2f8b3f202a31b6"); //
	
	//Если Не ЗначениеЗаполнено(ДанныеКурьера.ИдентификаторCRM) Тогда
	//	ПараметрыЗапроса.Вставить("update", 0);
	//	ПараметрыЗапроса.Вставить("userName", ИмяПользователя);
	//	ПараметрыЗапроса.Вставить("password", "lk" + ИмяПользователя);
	//Иначе
	//	ПараметрыЗапроса.Вставить("update", 1);
	//	ПараметрыЗапроса.Вставить("courier_id", ДанныеКурьера.ИдентификаторCRM);
	//КонецЕсли; 
	
	Телефон = "";
	Для Сч = 1 По СтрДлина(ДанныеКурьера.Телефон) Цикл
		ТекСимвол = Сред(ДанныеКурьера.Телефон, Сч, 1);
		Если ТекСимвол >= "0" И ТекСимвол <= "9" Тогда
			Телефон = Телефон + ТекСимвол;
		КонецЕсли; 
	КонецЦикла;
	
	ПараметрыЗапроса.Вставить("cr_fullname", ДанныеКурьера.ФИО);
	ПараметрыЗапроса.Вставить("cr_shortname", ФИОКоротко);
	Если Не ЗначениеЗаполнено(ДанныеКурьера.ИдентификаторCRM) Тогда
		ПараметрыЗапроса.Вставить("cr_email", ДанныеКурьера.Email);
		ПараметрыЗапроса.Вставить("cr_dphone", Телефон);
		ПараметрыЗапроса.Вставить("parent_company", ДанныеКурьера.ГоловнаяОрганизация);
		
	КонецЕсли;
	СерияНомер =ДанныеКурьера.СерияПаспорта+ " "+ ДанныеКурьера.НомерПаспорта;
	ПараметрыЗапроса.Вставить("cr_pass_sn", СерияНомер);
	ПараметрыЗапроса.Вставить("cr_pass_kod", ДанныеКурьера.КодПодразделения);
	ПараметрыЗапроса.Вставить("fact_addr", ФактичАдрес);            //фактический адрес
	ПараметрыЗапроса.Вставить("pass_addr", АдресПоПрописке);   //адрес по прописке
	ПараметрыЗапроса.Вставить("cr_birthday", Формат(ДанныеКурьера.ДатаРождения,"ДЛФ=Д"));
	ПараметрыЗапроса.Вставить("cr_pass_date ", Формат(ДанныеКурьера.ДатаВыдачи,"ДЛФ=Д"));//Дата Выдачи паспрота
	ПараметрыЗапроса.Вставить("cr_pass_kem ", ДанныеКурьера.КемВыдан);   //адрес по прописке
	ПараметрыЗапроса.Вставить("default_hub_id", ХабИД);
	КадровыеДанныеСотрудников = КадровыйУчет.КадровыеДанныеСотрудников(Истина, 
    ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(Сотрудник), 
    "ДатаУвольнения", ТекущаяДата());
	Если КадровыеДанныеСотрудников[0].ДатаУвольнения = Дата(1,1,1) и ОбменСCRM=Истина Тогда
		ПараметрыЗапроса.Вставить("cr_status", 1);
	Иначе
		ПараметрыЗапроса.Вставить("cr_status", 0);
	КонецЕсли;
	ПараметрыЗапроса.Вставить("is_self_employed", ?(ДанныеКурьера.Логс_Самозанятый и НЕ ДанныеКурьера.Логс_КурьерИП, 1,0));
	ПараметрыЗапроса.Вставить("is_sole_proprietor", ?(ДанныеКурьера.Логс_КурьерИП, 1,0));
	
	ТипКурьераСтрокой = НРег(ДанныеКурьера.ТипКурьера);
	//++ Ким Виктор 18.07.2024
	//https://jira-sd.logsis.ru/projects/TSLOG/queues/custom/18/TSLOG-13912
	
	// Соответствия типов курьеров.
	//// Авто
	//const CRTYPE_AUTO = 1;
	//// Пеший
	//const CRTYPE_PEDESTRIAN = 2;
	//// Грузовой
	//const CRTYPE_CARGO = 3;
	//// Пятитонник
	//const CRTYPE_FIVE_TON = 4;
	//// Наемник
	//const CRTYPE_HIRE = 5;
	//// Субагент
	//const CRTYPE_FASTZILLA = 6;
	//// Стадол
	//const CRTYPE_STADOL = 7;
	//// Стажер
	//const CRTYPE_STAGER = 8;
	//// ПВЗ
	//const CRTYPE_PVZ = 9;
	//// ПВЗ - Авито
	//const CRTYPE_PVZ_AVITO = 10;

	Если ТипКурьераСтрокой = "авто" Тогда
		ТипКурьера = 1;
	ИначеЕсли ТипКурьераСтрокой = "пеший" Тогда
		ТипКурьера = 2;
	ИначеЕсли ТипКурьераСтрокой = "грузовой" Тогда
		ТипКурьера = 3;
	ИначеЕсли ТипКурьераСтрокой = "пятитонник" Тогда
		Типкурьера = 4;
	ИначеЕсли ТипКурьераСтрокой = "наемник" Тогда
		Типкурьера = 5;
	ИначеЕсли ТипКурьераСтрокой = "субагент" Тогда
		Типкурьера = 6;
	ИначеЕсли ТипКурьераСтрокой = "стадол" Тогда
		Типкурьера = 7;
	ИначеЕсли ТипКурьераСтрокой = "стажер" Тогда
		ТипКурьера = 8;
	ИначеЕсли ТипКурьераСтрокой = "пвз" Тогда
		ТипКурьера = 9;
	ИначеЕсли ТипКурьераСтрокой = "пвз - авито" Тогда
		ТипКурьера = 10;
	Иначе
		ТипКурьера = 0;
	КонецЕсли; 

	//-- Ким Виктор 18.07.2024	
	ПараметрыЗапроса.Вставить("cr_type", ТипКурьера);
	ПараметрыЗапроса.Вставить("inn", ДанныеКурьера.ИНН);
	
	
	РезультатВыполнения = Неопределено;
	ИнформацияОбОшибкеПоследняя = "";
	////брутфорс валидного юзернейма
	Для К = 1 по СтрДлина(ФИОФизическогоЛица.Фамилия) Цикл
		ИмяПользователя = НРег(Лев(ФИОФизическогоЛица.Фамилия, К) + "." + ФИОФизическогоЛица.Имя);
		ИмяПользователя = СтроковыеФункцииКлиентСервер.СтрокаЛатиницей(ИмяПользователя);
		
		Если Не ЗначениеЗаполнено(ДанныеКурьера.ИдентификаторCRM) Тогда
			ПараметрыЗапроса.Вставить("update", 0);
			ПараметрыЗапроса.Вставить("userName", ИмяПользователя);
			ПараметрыЗапроса.Вставить("password", "lk" + ИмяПользователя);
		Иначе
			ПараметрыЗапроса.Вставить("update", 1);
			ПараметрыЗапроса.Вставить("courier_id", ДанныеКурьера.ИдентификаторCRM);
		КонецЕсли; 
	
	//	Попытка
			//Ответ = ЗапросКСерверуCRM("1ccourieradd", ПараметрыЗапроса);
			Ответ = ЗапросКСерверуCRM_Альт("couriers", ПараметрыЗапроса);
			
			Результат = Ответ.response;
			Если ТипЗнч(Результат) = Тип("Массив") Тогда
				Результат = Результат[0];
			КонецЕсли; 
			
			Если Результат.Свойство("courier_id") Тогда
				СвойствоИдентификатор = Логс_ДополнительныеПроцедурыИФункцииПовтИсп.СвойствоИдентификаторКурьераCRM();
				
				СотрудникОбъект = Сотрудник.ПолучитьОбъект();
				
				СтрокаРеквизита = СотрудникОбъект.ДополнительныеРеквизиты.Найти(СвойствоИдентификатор, "Свойство");
				Если СтрокаРеквизита = Неопределено Тогда
					СтрокаРеквизита = СотрудникОбъект.ДополнительныеРеквизиты.Добавить();
					СтрокаРеквизита.Свойство = СвойствоИдентификатор;
				КонецЕсли; 
				СтрокаРеквизита.Значение = Формат(Результат.courier_id, "ЧГ=");
				СтрокаРеквизита.ТекстоваяСтрока = Строка(СтрокаРеквизита.Значение);
				
				СотрудникОбъект.ОбменДанными.Загрузка = Истина;
				
				Записано = Ложь;
				Для Ы = 1 по 10 Цикл
					Попытка
						СотрудникОбъект.Записать();
						Записано = Истина;
						Прервать 
					Исключение 
						Описание = ОписаниеОшибки();
						//ОбщегоНазначенияБТС.Пауза(10);
						
						//Костыль TODO#
						Если Справочники.Сотрудники.ПолучитьСсылку(Сотрудник.УникальныйИдентификатор()).ВерсияДанных <> СотрудникОбъект.ВерсияДанных  Тогда 
							СотрудникОбъект = Справочники.Сотрудники.НайтиПоКоду(Сотрудник.Код).ПолучитьОбъект();	
						КонецЕсли;
						
					КонецПопытки;
				КонецЦикла;				
				Если Записано Тогда
					РезультатВыполнения = Новый Структура("Успешно,Идентификатор",
						Истина, Результат.courier_id);
				Иначе
					РезультатВыполнения = Новый Структура("Успешно,Идентификатор",
						Ложь, Результат.courier_id);				
				КонецЕсли;
					
				Прервать; // прервем цикл брутфорса, если информация обновлена
			ИначеЕсли ЗначениеЗаполнено(ДанныеКурьера.ИдентификаторCRM) Тогда
				ТекстОшибки = ?(Результат.Свойство("Error"),
					Результат.Error,
					НСтр("ru='Неизвестная ошибка'"));
				ТекстСообщения = СтрШаблон(
					НСтр("ru='Произошла ошибка при обновлении данных на сервере CRM: %1'"),
					ТекстОшибки);
					
				РезультатВыполнения = Новый Структура("Успешно,ТекстОшибки", Ложь, ТекстСообщения);
					
				ЗаписьЖурналаРегистрации(
					"Обмен с CRM. Оповещение о создании курьера",
					УровеньЖурналаРегистрации.Ошибка,
					Метаданные.Справочники.Сотрудники,
					Сотрудник,
					ТекстСообщения);
					
				Прервать; // прервем цикл брутфорса, если запрос упал, и есть ИД курьера
			КонецЕсли; 
		//Исключение
		//	ИнформацияОбОшибкеПоследняя = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		//КонецПопытки;
	КонецЦикла;
	
	Если РезультатВыполнения = Неопределено Тогда
			ТекстСообщения = СтрШаблон(НСтр("ru='Произошла ошибка при обновлении данных на сервере CRM: %1'"), ИнформацияОбОшибкеПоследняя);
			
			РезультатВыполнения = Новый Структура("Успешно,ТекстОшибки",
				Ложь, ТекстСообщения);
				
			ЗаписьЖурналаРегистрации(
				"Обмен с CRM. Оповещение о создании курьера",
				УровеньЖурналаРегистрации.Ошибка,
				Метаданные.Справочники.Сотрудники,
				Сотрудник,
				ТекстСообщения);
	КонецЕсли;

	АдресХранилища=ПоместитьВоВременноеХранилище(РезультатВыполнения, АдресХранилища);
КонецПроцедуры 

Процедура ОповеститьCRMОСозданииКурьераСамозанятого(Договор, АдресХранилища) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = "Выбрать * из Справочник.ДоговорыКонтрагентов как спр где спр.Ссылка = &Договор";
	Запрос.УстановитьПараметр("Договор", Договор);
	ДанныеДоговора = Запрос.Выполнить().Выбрать();
	ДанныеДоговора.Следующий();
	
	ОбменСCRM = ДанныеДоговора.Логс_ОбменСCRM и (ДанныеДоговора.Логс_ВидКлиентаCRM = Перечисления.Логс_ВидыКлиентовCRM.СамозанятыйКурьер);
	
	Если ОбменСCRM <> Истина Тогда
			
		РезультатВыполнения = Новый Структура("Успешно,ТекстОшибки", Ложь,
			СтрШаблон(НСтр("ru='Сотрудник %1 не используется в обмене с CRM'"), ДанныеДоговора.Контрагент));
			
		ПоместитьВоВременноеХранилище(РезультатВыполнения, АдресХранилища);
		
		Возврат;
		
	КонецЕсли; 
	
	ДанныеКурьера = ПолучитьДанныеСамозанятогоКурьера(Договор);
	КонтактнаяИнформация = ДанныеКурьера.Контрагент.КонтактнаяИнформация;
	Для каждого Строка из КонтактнаяИнформация Цикл
		Если Строка.Вид.Наименование = "Адрес по прописке" Тогда
		 АдресПоПрописке = Строка.Представление;	
		ИначеЕсли Строка.Вид.Наименование = "Адрес места проживания" Тогда
		 ФактичАдрес = Строка.Представление;	
		КонецЕсли;
	КонецЦикла;	
	
	ХабИД = Логс_ДополнительныеПроцедурыИФункцииПовтИсп.ПолучитьХабСотрудника(Договор).ИД;
	
	ФИОФизическогоЛица = ФизическиеЛицаУТ.ФамилияИмяОтчество(ДанныеКурьера.ФИО);
	ФамилияИнициалы = ФизическиеЛицаКлиентСервер.ФамилияИнициалы(ФИОФизическогоЛица);
	
	ФИОКоротко = "" + СокрЛП(ФИОФизическогоЛица.Фамилия) + " " + СокрЛП(ФИОФизическогоЛица.Имя);
	
	ПараметрыЗапроса = Новый Структура;
	ПараметрыЗапроса.Вставить("key", "901076233795fc304901c25412fa87b2");
	
	Телефон = "";
	Для Сч = 1 По СтрДлина(ДанныеКурьера.Телефон) Цикл
		ТекСимвол = Сред(ДанныеКурьера.Телефон, Сч, 1);
		Если ТекСимвол >= "0" И ТекСимвол <= "9" Тогда
			Телефон = Телефон + ТекСимвол;
		КонецЕсли; 
	КонецЦикла;
	
	ПараметрыЗапроса.Вставить("cr_fullname", ДанныеКурьера.ФИО);
	ПараметрыЗапроса.Вставить("cr_shortname", ФИОКоротко);
	Если Не ЗначениеЗаполнено(ДанныеКурьера.ИдентификаторCRM) Тогда
		ПараметрыЗапроса.Вставить("cr_email", ДанныеКурьера.Email);
		ПараметрыЗапроса.Вставить("cr_dphone", Телефон);
		ПараметрыЗапроса.Вставить("parent_company", ДанныеКурьера.ГоловнаяОрганизация);
		
	КонецЕсли;
	СерияНомер =ДанныеКурьера.СерияПаспорта+ " "+ ДанныеКурьера.НомерПаспорта;
	ПараметрыЗапроса.Вставить("cr_pass_sn", СерияНомер);
	ПараметрыЗапроса.Вставить("cr_pass_kod", ДанныеКурьера.КодПодразделения);
	ПараметрыЗапроса.Вставить("fact_addr", ФактичАдрес);            //фактический адрес
	ПараметрыЗапроса.Вставить("pass_addr", АдресПоПрописке);   //адрес по прописке
	ПараметрыЗапроса.Вставить("cr_birthday", Формат(ДанныеКурьера.ДатаРождения,"ДЛФ=Д"));
	ПараметрыЗапроса.Вставить("cr_pass_date ", Формат(ДанныеКурьера.ДатаВыдачи,"ДЛФ=Д"));//Дата Выдачи паспрота
	ПараметрыЗапроса.Вставить("cr_pass_kem ", ДанныеКурьера.КемВыдан);   //адрес по прописке
	ПараметрыЗапроса.Вставить("default_hub_id", ХабИД);
	ПараметрыЗапроса.Вставить("cr_status", ДанныеКурьера.Статус);
	
	ТипКурьераСтрокой = НРег(ДанныеКурьера.ТипКурьера);
	Если ТипКурьераСтрокой = "авто" Тогда
		ТипКурьера = 1;
	ИначеЕсли ТипКурьераСтрокой = "пеший" Тогда
		ТипКурьера = 2;
	ИначеЕсли ТипКурьераСтрокой = "грузовой" Тогда
		ТипКурьера = 3;
	ИначеЕсли ТипКурьераСтрокой = "стажер" Тогда
		ТипКурьера = 4;
	Иначе
		ТипКурьера = 0;
	КонецЕсли; 
	
	ПараметрыЗапроса.Вставить("cr_type", ТипКурьера);
	
	
	РезультатВыполнения = Неопределено;
	ИнформацияОбОшибкеПоследняя = "";
	////брутфорс валидного юзернейма
	Для К = 1 по СтрДлина(ФИОФизическогоЛица.Фамилия) Цикл
		ИмяПользователя = НРег(Лев(ФИОФизическогоЛица.Фамилия, К) + "." + ФИОФизическогоЛица.Имя);
		ИмяПользователя = СтроковыеФункцииКлиентСервер.СтрокаЛатиницей(ИмяПользователя);
		
		Если Не ЗначениеЗаполнено(ДанныеКурьера.ИдентификаторCRM) Тогда
			ПараметрыЗапроса.Вставить("update", 0);
			ПараметрыЗапроса.Вставить("userName", ИмяПользователя);
			ПараметрыЗапроса.Вставить("password", "lk" + ИмяПользователя);
		Иначе
			ПараметрыЗапроса.Вставить("update", 1);
			ПараметрыЗапроса.Вставить("courier_id", ДанныеКурьера.ИдентификаторCRM);
		КонецЕсли; 
	
		Попытка
			//Ответ = ЗапросКСерверуCRM("1ccourieradd", ПараметрыЗапроса);
			Ответ = ЗапросКСерверуCRM_Альт("couriers", ПараметрыЗапроса);
			
			Результат = Ответ.response;
			Если ТипЗнч(Результат) = Тип("Массив") Тогда
				Результат = Результат[0];
			КонецЕсли; 
			
			Если Результат.Свойство("courier_id") Тогда
				
				ДоговорОбъект = Договор.ПолучитьОбъект();
				ДоговорОбъект.Логс_ИдентификаторCRM = Результат.courier_id;
				ДоговорОбъект.ОбменДанными.Загрузка = Истина;
				ДоговорОбъект.Записать();
				
				РезультатВыполнения = Новый Структура("Успешно,Идентификатор",
					Истина, Результат.courier_id);
					
				Прервать; // прервем цикл брутфорса, если информация обновлена
			ИначеЕсли ЗначениеЗаполнено(ДанныеКурьера.ИдентификаторCRM) Тогда
				ТекстОшибки = ?(Результат.Свойство("Error"),
					Результат.Error,
					НСтр("ru='Неизвестная ошибка'"));
				ТекстСообщения = СтрШаблон(
					НСтр("ru='Произошла ошибка при обновлении данных на сервере CRM: %1'"),
					ТекстОшибки);
					
				РезультатВыполнения = Новый Структура("Успешно,ТекстОшибки", Ложь, ТекстСообщения);
					
				ЗаписьЖурналаРегистрации(
					"Обмен с CRM. Оповещение о создании курьера",
					УровеньЖурналаРегистрации.Ошибка,
					Метаданные.Справочники.ДоговорыКонтрагентов,
					Договор,
					ТекстСообщения);
					
				Прервать; // прервем цикл брутфорса, если запрос упал, и есть ИД курьера
			КонецЕсли; 
		Исключение
			ИнформацияОбОшибкеПоследняя = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		КонецПопытки;
	КонецЦикла;
	
	Если РезультатВыполнения = Неопределено Тогда
			ТекстСообщения = СтрШаблон(НСтр("ru='Произошла ошибка при обновлении данных на сервере CRM: %1'"), ИнформацияОбОшибкеПоследняя);
			
			РезультатВыполнения = Новый Структура("Успешно,ТекстОшибки",
				Ложь, ТекстСообщения);
				
			ЗаписьЖурналаРегистрации(
				"Обмен с CRM. Оповещение о создании курьера",
				УровеньЖурналаРегистрации.Ошибка,
				Метаданные.Справочники.ДоговорыКонтрагентов,
				Договор,
				ТекстСообщения);
	КонецЕсли;

	ПоместитьВоВременноеХранилище(РезультатВыполнения, АдресХранилища);
КонецПроцедуры 

Функция ПолучитьДанныеКурьера(Сотрудник)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	Сотрудники.Ссылка КАК Ссылка,
	|	Сотрудники.ФизическоеЛицо КАК ФизическоеЛицо,
	|	Сотрудники.Логс_Самозанятый КАК Логс_Самозанятый,
	|	Сотрудники.Логс_КурьерИП КАК Логс_КурьерИП,
	|	ЕСТЬNULL(ДопРеквизитыОрганизации.Значение, """") КАК ГоловнаяОрганизация,
	|	ФизическиеЛица.ФИО КАК ФИО,
	|	ВЫБОР
	|		КОГДА Сотрудники.ВАрхиве
	|			ТОГДА 0
	|		ИНАЧЕ 1
	|	КОНЕЦ КАК Статус
	|ПОМЕСТИТЬ ДанныеСотрудника
	|ИЗ
	|	Справочник.Сотрудники КАК Сотрудники
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ФизическиеЛица КАК ФизическиеЛица
	|		ПО Сотрудники.ФизическоеЛицо = ФизическиеЛица.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Организации.ДополнительныеРеквизиты КАК ДопРеквизитыОрганизации
	|		ПО Сотрудники.ГоловнаяОрганизация = ДопРеквизитыОрганизации.Ссылка
	|			И (ДопРеквизитыОрганизации.Свойство = &СвойствоИдентификаторОрганизации)
	|ГДЕ
	|	Сотрудники.Ссылка = &Ссылка
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ФизическоеЛицо
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КонтактнаяИнформация.Ссылка КАК Ссылка,
	|	КонтактнаяИнформация.Вид КАК Вид,
	|	КонтактнаяИнформация.Представление КАК Представление
	|ПОМЕСТИТЬ КонтактнаяИнформация
	|ИЗ
	|	Справочник.ФизическиеЛица.КонтактнаяИнформация КАК КонтактнаяИнформация
	|ГДЕ
	|	КонтактнаяИнформация.Ссылка В
	|			(ВЫБРАТЬ
	|				ДанныеСотрудника.ФизическоеЛицо
	|			ИЗ
	|				ДанныеСотрудника)
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СотрудникиДополнительныеРеквизиты.Ссылка КАК Ссылка,
	|	СотрудникиДополнительныеРеквизиты.Свойство КАК Свойство,
	|	СотрудникиДополнительныеРеквизиты.Значение КАК Значение
	|ПОМЕСТИТЬ ДополнительныеРеквизиты
	|ИЗ
	|	Справочник.Сотрудники.ДополнительныеРеквизиты КАК СотрудникиДополнительныеРеквизиты
	|ГДЕ
	|	СотрудникиДополнительныеРеквизиты.Ссылка = &Ссылка
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДанныеСотрудника.Ссылка КАК Ссылка,
	|	ДанныеСотрудника.ФизическоеЛицо КАК ФизическоеЛицо,   
	|	ДанныеСотрудника.Логс_Самозанятый КАК Логс_Самозанятый,   
	|	ДанныеСотрудника.Логс_КурьерИП КАК Логс_КурьерИП,   
	|	ДанныеСотрудника.ФИО КАК ФИО,
	|	ДанныеСотрудника.ГоловнаяОрганизация КАК ГоловнаяОрганизация,
	|	ЕСТЬNULL(КонтактнаяИнформацияТелефон.Представление, """") КАК Телефон,
	|	ЕСТЬNULL(КонтактнаяИнформацияEmail.Представление, """") КАК Email,
	|	ЕСТЬNULL(ДокументыФизическихЛиц.Серия, """") КАК СерияПаспорта,
	|	ЕСТЬNULL(ДокументыФизическихЛиц.Номер, """") КАК НомерПаспорта,
	|	ДанныеСотрудника.Статус КАК Статус,
	|	ЕСТЬNULL(ДополнительныеРеквизитыТипКурьера.Значение, """") КАК ТипКурьера,
	|	ЕСТЬNULL(ДополнительныеРеквизитыИдентификаторCRM.Значение, """") КАК ИдентификаторCRM,
	|	ЕСТЬNULL(ДокументыФизическихЛиц.КодПодразделения, """") КАК КодПодразделения,
	|	ЕСТЬNULL(ДокументыФизическихЛиц.КемВыдан, """") КАК КемВыдан,
	|	ЕСТЬNULL(ДокументыФизическихЛиц.ДатаВыдачи, """") КАК ДатаВыдачи,
	|	ЕСТЬNULL(ДанныеСотрудника.ФизическоеЛицо.ДатаРождения, """") КАК ДатаРождения,
	|	ДанныеСотрудника.ФизическоеЛицо.ИНН как ИНН 
	|ИЗ
	|	ДанныеСотрудника КАК ДанныеСотрудника
	|		ЛЕВОЕ СОЕДИНЕНИЕ КонтактнаяИнформация КАК КонтактнаяИнформацияТелефон
	|		ПО ДанныеСотрудника.ФизическоеЛицо = КонтактнаяИнформацияТелефон.Ссылка
	|			И (КонтактнаяИнформацияТелефон.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ТелефонМобильныйФизическиеЛица))
	|		ЛЕВОЕ СОЕДИНЕНИЕ КонтактнаяИнформация КАК КонтактнаяИнформацияEmail
	|		ПО ДанныеСотрудника.ФизическоеЛицо = КонтактнаяИнформацияEmail.Ссылка
	|			И (КонтактнаяИнформацияEmail.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.EMailФизическиеЛица))
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДокументыФизическихЛиц.СрезПоследних КАК ДокументыФизическихЛиц
	|		ПО ДанныеСотрудника.ФизическоеЛицо = ДокументыФизическихЛиц.Физлицо
	|			И (ДокументыФизическихЛиц.ВидДокумента в (ЗНАЧЕНИЕ(Справочник.ВидыДокументовФизическихЛиц.ПаспортРФ), ЗНАЧЕНИЕ(Справочник.ВидыДокументовФизическихЛиц.ИностранныйПаспорт), ЗНАЧЕНИЕ(Справочник.ВидыДокументовФизическихЛиц.ВидНаЖительство)))
	|		ЛЕВОЕ СОЕДИНЕНИЕ ДополнительныеРеквизиты КАК ДополнительныеРеквизитыТипКурьера
	|		ПО ДанныеСотрудника.Ссылка = ДополнительныеРеквизитыТипКурьера.Ссылка
	|			И (ДополнительныеРеквизитыТипКурьера.Свойство = &СвойствоТипКурьера)
	|		ЛЕВОЕ СОЕДИНЕНИЕ ДополнительныеРеквизиты КАК ДополнительныеРеквизитыИдентификаторCRM
	|		ПО ДанныеСотрудника.Ссылка = ДополнительныеРеквизитыИдентификаторCRM.Ссылка
	|			И (ДополнительныеРеквизитыИдентификаторCRM.Свойство = &СвойствоИдентификаторCRM)");

	Запрос.УстановитьПараметр("Ссылка", Сотрудник);
	Запрос.УстановитьПараметр("СвойствоТипКурьера", Логс_ДополнительныеПроцедурыИФункцииПовтИсп.СвойствоСотрудникиТипКурьера());
	Запрос.УстановитьПараметр("СвойствоИдентификаторCRM", Логс_ДополнительныеПроцедурыИФункцииПовтИсп.СвойствоИдентификаторКурьераCRM());
	Запрос.УстановитьПараметр("СвойствоИдентификаторОрганизации", Логс_ДополнительныеПроцедурыИФункцииПовтИсп.СвойствоИдентификаторОрганизацииCRM());
	
	Выборка = Запрос.Выполнить().Выбрать();
	Выборка.Следующий();
	
	Возврат Выборка;
	
КонецФункции 

Функция ПолучитьДанныеСамозанятогоКурьера(Договор)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	КонтактнаяИнформация.Ссылка КАК Ссылка,
	|	КонтактнаяИнформация.Вид КАК Вид,
	|	КонтактнаяИнформация.Представление КАК Представление
	|ПОМЕСТИТЬ ВТ_КонтактнаяИнформация
	|ИЗ
	|	Справочник.Контрагенты.КонтактнаяИнформация КАК КонтактнаяИнформация
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ДоговорыКонтрагентов КАК Договоры
	|		ПО КонтактнаяИнформация.Ссылка = Договоры.Контрагент
	|ГДЕ
	|	Договоры.Ссылка = &Договор
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДанныеДоговора.Ссылка КАК Договор,
	|	ДанныеДоговора.Контрагент КАК Контрагент,
	|	ДанныеДоговора.Контрагент.Наименование КАК ФИО,
	|	ДанныеДоговора.Организация КАК ГоловнаяОрганизация,
	|	ВЫБОР
	|		КОГДА ДанныеДоговора.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыДоговоровКонтрагентов.Действует)
	|			ТОГДА 1
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК Статус,
	|	ДанныеДоговора.Логс_ИдентификаторCRM КАК ИдентификаторCRM,
	|	ДанныеДоговора.Логс_ТипКурьера КАК ТипКурьера,
	|	ЕСТЬNULL(КонтактнаяИнформацияТелефон.Представление, """") КАК Телефон,
	|	ЕСТЬNULL(КонтактнаяИнформацияEmail.Представление, """") КАК Email,
	|	ЕСТЬNULL(ДокументыФизическихЛиц.Серия, """") КАК СерияПаспорта,
	|	ЕСТЬNULL(ДокументыФизическихЛиц.Номер, """") КАК НомерПаспорта,
	|	ЕСТЬNULL(ДокументыФизическихЛиц.КодПодразделения, """") КАК КодПодразделения,
	|	ЕСТЬNULL(ДокументыФизическихЛиц.КемВыдан, """") КАК КемВыдан,
	|	ЕСТЬNULL(ДокументыФизическихЛиц.ДатаВыдачи, """") КАК ДатаВыдачи,
	|	ЕСТЬNULL(ДанныеДоговора.Партнер.ДатаРождения, """") КАК ДатаРождения
	|ИЗ
	|	Справочник.ДоговорыКонтрагентов КАК ДанныеДоговора
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_КонтактнаяИнформация КАК КонтактнаяИнформацияТелефон
	|		ПО ДанныеДоговора.Контрагент = КонтактнаяИнформацияТелефон.Ссылка
	|			И (КонтактнаяИнформацияТелефон.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ТелефонМобильныйФизическиеЛица))
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_КонтактнаяИнформация КАК КонтактнаяИнформацияEmail
	|		ПО ДанныеДоговора.Контрагент = КонтактнаяИнформацияEmail.Ссылка
	|			И (КонтактнаяИнформацияEmail.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.EMailФизическиеЛица))
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДокументыФизическихЛиц.СрезПоследних КАК ДокументыФизическихЛиц
	|		ПО ДанныеДоговора.Контрагент = ДокументыФизическихЛиц.Физлицо
	|			И (ДокументыФизическихЛиц.ВидДокумента = ЗНАЧЕНИЕ(Справочник.ВидыДокументовФизическихЛиц.ПаспортРФ))
	|ГДЕ
	|	ДанныеДоговора.Ссылка = &Договор";

	Запрос.УстановитьПараметр("Ссылка", Договор);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Выборка.Следующий();
	
	Возврат Выборка;
	
КонецФункции 

