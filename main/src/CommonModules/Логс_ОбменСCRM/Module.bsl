	КонецЕсли; 
	
	СводыЗаявок = Новый Структура;
	СводыЗаявок.Вставить("Своды", ?(ТипЗнч(Ответ.response) = Тип("Массив"),
									Ответ.response, Новый Массив));
	СводыЗаявок.Вставить("Заборы", ?(Ответ.Свойство("zresponse")
										И ТипЗнч(Ответ.zresponse) = Тип("Массив"),
									Ответ.zresponse, Новый Массив));
	
	Возврат СводыЗаявок;
	
КонецФункции

