Функция ПреобразоватьДатуJSON(ДатаСтрока) Экспорт
	
	//Если Не ЗначениеЗаполнено(ДатаСтрока)  Тогда
	// 21.12.2019 Архипкин Р.В.
	// обрабатываем необычный формат даты
	Если Не ЗначениеЗаполнено(ДатаСтрока) ИЛИ ДатаСтрока = "0000-00-00" Тогда
		Возврат '00010101';
	КонецЕсли; 
	
	ЧастиДатыJSON = СтрРазделить(ДатаСтрока, "T");
	КоличествоЧастейДаты = ЧастиДатыJSON.Количество();
	Если КоличествоЧастейДаты < 1 Тогда
		ВызватьИсключение НСтр("ru='Неверный формат даты'");
	КонецЕсли; 
	
	СоставДаты = СтрРазделить(ЧастиДатыJSON[0], "-");
	Если СоставДаты.Количество() <> 3 Тогда
		ВызватьИсключение НСтр("ru='Неверный формат даты'");
	КонецЕсли; 
	
	Если КоличествоЧастейДаты > 1 Тогда
		СоставВремени = СтрРазделить(ЧастиДатыJSON[1], ":");
		Если СоставВремени.Количество() <> 3 Тогда
			ВызватьИсключение НСтр("ru='Неверный формат даты'");
		КонецЕсли; 
	Иначе
		СоставВремени = Неопределено;
	КонецЕсли;
	
	Результат = Дата(Число(СоставДаты[0]), Число(СоставДаты[1]), Число(СоставДаты[2]));
	
	Если СоставВремени <> Неопределено Тогда  
		
		//++ Ким Виктор 02.03.2026
		//https://logit.okdesk.ru/issues/1055#!
		Если СтрНайти(СоставВремени[2], "Z")  <> 0 Тогда 
			СоставВремени[2] = СтрЗаменить(СоставВремени[2], "Z", "");
		КонецЕсли;   
		//-- Ким Виктор 02.03.2026
				
		КоличествоСекунд = Число(СоставВремени[0]) * 3600 + Число(СоставВремени[1]) * 60 + Число(СоставВремени[2]);
		Результат = Результат + КоличествоСекунд;
	КонецЕсли; 
	
	Возврат Результат;
	
КонецФункции 

Функция ВебСервисОтвет(КодРезультата, Данные, ТекстОшибки = Неопределено) Экспорт
	
	Ответ = Новый Структура;
	Ответ.Вставить("status", КодРезультата);
	
	Если ЗначениеЗаполнено(Данные) Тогда
		Ответ.Вставить("response", Данные);
	КонецЕсли; 
	Если ТекстОшибки <> Неопределено Тогда
		Ответ.Вставить("error", ТекстОшибки);
	КонецЕсли; 
	
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ЗаписатьJSON(ЗаписьJSON, Ответ);
	
	HTTPОтвет = Новый HTTPСервисОтвет(200);
	HTTPОтвет.Заголовки.Вставить("Content-type", "application/json; charset=utf-8");
	HTTPОтвет.УстановитьТелоИзСтроки(ЗаписьJSON.Закрыть());
	Возврат HTTPОтвет;
	
КонецФункции 

Функция ПараметрыЗапросаВСтруктуру(ПараметрыЗапроса) Экспорт
	
	Результат = Новый Структура;
	
	Если Не ЗначениеЗаполнено(ПараметрыЗапроса) Тогда
		Возврат Результат;
	КонецЕсли; 
	
	МассивПараметров = СтрРазделить(ПараметрыЗапроса, "&", Ложь);
	
	Для каждого Параметр Из МассивПараметров Цикл
		КлючИЗначение = СтрРазделить(Параметр, "=");
		Результат.Вставить(КлючИЗначение[0], ?(КлючИЗначение.Количество() = 1, Неопределено, КлючИЗначение[1]));
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции 

Функция ЗначениеПараметраЗапроса(ПараметрыЗапроса, ИмяПараметра, ЗначениеПоУмолчанию = Неопределено) Экспорт
	
	ЗначениеПараметра = ПараметрыЗапроса.Получить(ИмяПараметра);
	Возврат ?(ЗначениеПараметра = Неопределено, ЗначениеПоУмолчанию, ЗначениеПараметра);
	
КонецФункции 

