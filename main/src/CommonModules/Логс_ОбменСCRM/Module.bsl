	Если Не СтроковыеФункцииКлиентСервер.ТолькоЦифрыВСтроке(НомерДоговора) Тогда
		Возврат;
	КонецЕсли;
	
	НомерДоговора = Число(НомерДоговора);
	ТекНомерДоговора = ПолучитьНомерДоговораАгента();
	
	Если ТекНомерДоговора = Неопределено
			Или ТекНомерДоговора < НомерДоговора Тогда
		
		ЗаписьРегистра = РегистрыСведений.Логс_НомераДоговоровАгентов.СоздатьМенеджерЗаписи();
		ЗаписьРегистра.НомерДоговора = НомерДоговора;
		ЗаписьРегистра.Записать();
		
	КонецЕсли; 
	
