	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗаявкаНаДоставку.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.Логс_ЗаявкаНаДоставку КАК ЗаявкаНаДоставку
	|ГДЕ
	|	ЗаявкаНаДоставку.Дата МЕЖДУ &НачалоПериода И &КонецПериода
	|	И ЗаявкаНаДоставку.Договор В(&МассивДоговоров)
	|	И НЕ ЗаявкаНаДоставку.Ссылка В
	|				(ВЫБРАТЬ
	|					Заявки.Ссылка
	|				ИЗ
	|					Заявки)
	|	И НЕ ЗаявкаНаДоставку.ПометкаУдаления");
	Запрос.УстановитьПараметр("ТаблицаЗаявок", ТаблицаЗаявок);
	Запрос.УстановитьПараметр("НачалоПериода", НачалоДня(НачалоПериода));
	Запрос.УстановитьПараметр("КонецПериода", КонецДня(КонецПериода));
	Запрос.УстановитьПараметр("МассивДоговоров", МассивДоговоров);
	Запрос.УстановитьПараметр("СвойствоИдентификатор",
		Логс_ДополнительныеПроцедурыИФункцииПовтИсп.СвойствоИдентификаторКурьераCRM());
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	Выборка = РезультатЗапроса[3].Выбрать();
	Пока Выборка.Следующий() Цикл
		
		Если ЗначениеЗаполнено(Выборка.Ссылка) Тогда
			Если Не ОбновлятьСуществующие Тогда
				Продолжить;
			КонецЕсли; 
			
			ЗаявкаОбъект = Выборка.Ссылка.ПолучитьОбъект();
			ЗаявкаОбъект.ПометкаУдаления = Ложь;
		Иначе
			ЗаявкаОбъект = Документы.Логс_ЗаявкаНаДоставку.СоздатьДокумент();
			ЗаявкаОбъект.Номер = Выборка.НомерЗаказа;
		КонецЕсли; 
		
		ЗаявкаОбъект.Дата = НачалоДня(Выборка.ДатаДоставки);
		ЗаполнитьЗначенияСвойств(ЗаявкаОбъект, Выборка,, "Ссылка");
		
		ЗаявкаОбъект.ЗаполнитьДатуФормированияСвода();
		
		Если ЗаявкаОбъект.Договор.Логс_ЗагружатьТоварыВЗаявке Тогда
		
			Попытка
				ТоварыЗаявки = ПолучитьТоварыЗаявки(Выборка.НомерЗаказа);
			Исключение
				ТоварыЗаявки = Неопределено;
			КонецПопытки;
			
			Если ТоварыЗаявки <> Неопределено Тогда
				ЗаявкаОбъект.Товары.Очистить();
				
				Для каждого ДанныеТовара Из ТоварыЗаявки Цикл
					СтрокаТовар = ЗаявкаОбъект.Товары.Добавить();
					//СтрокаТовар.КодТовара = ДанныеТовара.artname;
					СтрокаТовар.КодТовара = ДанныеТовара.articul;
					//СтрокаТовар.СтатусПередачи = ДанныеТовара.goodStatus;
					СтрокаТовар.СтатусПередачи = ?(ДанныеТовара.is_cancel = "1",
						НСтр("ru='Возвращен'"), НСтр("ru='Вручен'"));
					СтрокаТовар.Стоимость = Число(ДанныеТовара.price) * Число(ДанныеТовара.Count);
					//СтрокаТовар.НаложенныйПлатеж = ДанныеТовара.price_client;
					Если ДанныеТовара.is_cancel = "1" Тогда
						СтрокаТовар.ЧастичныйВозврат = СтрокаТовар.Стоимость;
					Иначе
						Если ЗаявкаОбъект.НаложенныйПлатеж <> 0 Тогда
							СтрокаТовар.НаложенныйПлатеж = СтрокаТовар.Стоимость;
						КонецЕсли;	
					КонецЕсли;	
				КонецЦикла;
			КонецЕсли;
		КонецЕсли;	

		Если ЗаявкаОбъект.ЭтоНовый() Тогда
			ЗаявкаОбъект.Записать(РежимЗаписиДокумента.Запись);
		КонецЕсли; 
		
		Попытка
			
			ЗаявкаОбъект.Записать(РежимЗаписиДокумента.Проведение);
			
		Исключение
			
			ТекстСообщения = СтрШаблон(
				НСтр("ru='Произошла ошибка при проведении заявки № %1 от %2: %3'"),
				ЗаявкаОбъект.Номер, ЗаявкаОбъект.Дата,
				КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
				
			ЗаписьЖурналаРегистрации("Обмен с CRM. Загрузка заявок",
				УровеньЖурналаРегистрации.Ошибка,,, ТекстСообщения);
			СписокОшибок.Добавить(Новый Структура("ТекстОшибки,КлючДанных",
				ТекстСообщения, ЗаявкаОбъект.Ссылка));
			
			Продолжить;
			
		КонецПопытки;
		
	КонецЦикла; 
	
	// Удаление заявок, отсутствующих в загрузке (в CRM изменился статус на НЕ конечный).
	Если Не ЗначениеЗаполнено(НомерЗаявки) И ТДРегион = Неопределено Тогда
		Выборка = РезультатЗапроса[4].Выбрать();
		Пока Выборка.Следующий() Цикл
			
			ЗаявкаОбъект = Выборка.Ссылка.ПолучитьОбъект();
			
			Попытка
				
				ЗаявкаОбъект.УстановитьПометкуУдаления(Истина);
				
			Исключение
				
				ТекстСообщения = СтрШаблон(
					НСтр("ru='Произошла ошибка при пометке на удаление заявки № %1 от %2: %3'"),
					ЗаявкаОбъект.Номер, ЗаявкаОбъект.Дата,
					КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
					
				ЗаписьЖурналаРегистрации("Обмен с CRM. Загрузка заявок", УровеньЖурналаРегистрации.Ошибка,,, ТекстСообщения);
				СписокОшибок.Добавить(Новый Структура("ТекстОшибки,КлючДанных", ТекстСообщения, ЗаявкаОбъект.Ссылка));
				
			КонецПопытки;
			
		КонецЦикла;
	КонецЕсли;	
	
	Возврат СписокОшибок.Количество() = 0;
	
КонецФункции


Процедура ЗагрузкаЗаявокНаДоставкуВФоне(ПараметрыЗагрузки, АдресХранилища) Экспорт
	Перем Партнер, СписокОшибок;
	
	БылиОшибки = НЕ ЗагрузитьЗаявкиНаДоставку(ПараметрыЗагрузки, СписокОшибок);
	
	Результат = Новый Структура("Успешно,СписокОшибок", Не БылиОшибки, СписокОшибок);
	ПоместитьВоВременноеХранилище(Результат, АдресХранилища);
	
КонецПроцедуры 

