#Область ПрограммныйИнтерфейс

#Область HTTPСервис

Функция ПолучитьСписокКлиентов(ИНН, КПП, ВидДоговора, Идентификатор) Экспорт
	
	ТекстУсловияОтбора = "ДоговорыКонтрагентов.Логс_ВидДоговораCRM = &ВидДоговора";
	
	Если ЗначениеЗаполнено(Идентификатор) Тогда
		Если ТекстУсловияОтбора <> "" Тогда
			ТекстУсловияОтбора = ТекстУсловияОтбора + " И ";
		КонецЕсли; 
		ТекстУсловияОтбора = "ДоговорыКонтрагентов.Логс_ИдентификаторCRM = &Идентификатор";
	КонецЕсли; 
	Если ЗначениеЗаполнено(ИНН) Тогда
		Если ТекстУсловияОтбора <> "" Тогда
			ТекстУсловияОтбора = ТекстУсловияОтбора + " И ";
		КонецЕсли; 
		ТекстУсловияОтбора = "Контрагенты.ИНН = &ИНН";
	КонецЕсли; 
	Если ЗначениеЗаполнено(КПП) Тогда
		Если ТекстУсловияОтбора <> "" Тогда
			ТекстУсловияОтбора = ТекстУсловияОтбора + " И ";
		КонецЕсли; 
		ТекстУсловияОтбора = ТекстУсловияОтбора + "Контрагенты.КПП = &КПП";
	КонецЕсли; 
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЕСТЬNULL(Партнеры.Ссылка, ЗНАЧЕНИЕ(Справочник.Партнеры.ПустаяСсылка)) КАК Ссылка,
	|	Контрагенты.Наименование КАК Наименование,
	|	Контрагенты.НаименованиеПолное КАК НаименованиеПолное,
	|	Контрагенты.ИНН КАК ИНН,
	|	Контрагенты.КПП КАК КПП,
	|	ДоговорыКонтрагентов.Логс_ИдентификаторCRM КАК Идентификатор,
	|	ВЫБОР
	|		КОГДА ДоговорыКонтрагентов.Логс_ВидДоговораCRM = ЗНАЧЕНИЕ(Перечисление.Логс_ВидыДоговоровCRM.Агентский)
	|			ТОГДА ""agent""
	|	КОНЕЦ КАК ВидКлиента,
	|	ЕСТЬNULL(Организации.Наименование, """") КАК НаименованиеОрганизации,
	|	ЕСТЬNULL(Организации.ИНН, """") КАК ИННОрганизации
	|ИЗ
	|	Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Контрагенты
	|		ПО ДоговорыКонтрагентов.Контрагент = Контрагенты.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Партнеры КАК Партнеры
	|		ПО ДоговорыКонтрагентов.Партнер = Партнеры.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Организации КАК Организации
	|		ПО ДоговорыКонтрагентов.Организация = Организации.Ссылка
	|ГДЕ
	|	&ТекстУсловияОтбора");
	Запрос.УстановитьПараметр("ИНН", ИНН);
	Запрос.УстановитьПараметр("КПП", КПП);
	Запрос.УстановитьПараметр("Идентификатор", Идентификатор);
	Запрос.УстановитьПараметр("ВидДоговора", ВидДоговора);
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ТекстУсловияОтбора", ТекстУсловияОтбора);
	
	МассивКлиентов = Новый Массив;
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		ОписаниеКлиента = Новый Структура;
		ОписаниеКлиента.Вставить("client_id", Выборка.Идентификатор);
		ОписаниеКлиента.Вставить("uid", Строка(Выборка.Ссылка.УникальныйИдентификатор()));
		ОписаниеКлиента.Вставить("agentName", Выборка.Наименование);
		ОписаниеКлиента.Вставить("agentFullName", Выборка.НаименованиеПолное);
		ОписаниеКлиента.Вставить("inn", Выборка.ИНН);
		ОписаниеКлиента.Вставить("kpp", Выборка.КПП);
		ОписаниеКлиента.Вставить("client_type", Выборка.ВидКлиента);
		ОписаниеКлиента.Вставить("parent_company_name", Выборка.НаименованиеОрганизации);
		ОписаниеКлиента.Вставить("parent_company_inn", Выборка.ИННОрганизации);
		
		МассивКлиентов.Добавить(ОписаниеКлиента);
		
	КонецЦикла; 
	
	Возврат ВебСервисОтвет(200, МассивКлиентов);
	
КонецФункции 

Функция ПолучитьНомераСводовЗаявокНаДоставку(ИдентификаторКлиента = Неопределено, УИДКлиентаСтрока = Неопределено,
			ДатаНачала, ДатаОкончания = Неопределено) Экспорт
	Перем Партнер, Договор;
	
	Если УИДКлиентаСтрока <> Неопределено Тогда
	
		Попытка
			УИДКлиента = Новый УникальныйИдентификатор(УИДКлиентаСтрока);
		Исключение
			Возврат ВебСервисОтвет(400,, НСтр("ru='Передан неверный uid'"));
		КонецПопытки;
	
		Партнер = Справочники.Партнеры.ПолучитьСсылку(УИДКлиента);
		Если Партнер.ПолучитьОбъект() = Неопределено Тогда
			Возврат ВебСервисОтвет(404,, СтрШаблон(НСтр("ru='Не найден агент с uid %1'"), УИДКлиентаСтрока));
		КонецЕсли; 
		
	ИначеЕсли ИдентификаторКлиента <> Неопределено Тогда
		
		Договор = НайтиДоговорАгентаПоИдентификатору(ИдентификаторКлиента);
		Если Договор.Пустая() Тогда
			Возврат ВебСервисОтвет(404,, СтрШаблон(НСтр("ru='Не найден агент с client_id %1'"), ИдентификаторКлиента));
		КонецЕсли; 
		
	КонецЕсли; 
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	СводЗаявокНаДоставку.Ссылка КАК Ссылка,
	|	СводЗаявокНаДоставку.Номер КАК Номер,
	|	СводЗаявокНаДоставку.Дата КАК Дата,
	|	ЕСТЬNULL(ДоговорыКонтрагентов.Логс_ИдентификаторCRM, ""0"") КАК ИдентификаторКлиента,
	|	СводЗаявокНаДоставку.ПолнаяСтоимостьВсего КАК ПолнаяСтоимостьВсего,
	|	СводЗаявокНаДоставку.НаложенныйПлатежВсего КАК НаложенныйПлатежВсего
	|ПОМЕСТИТЬ СводыЗаявок
	|ИЗ
	|	Документ.Логс_СводЗаявокНаДоставку КАК СводЗаявокНаДоставку
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
	|		ПО СводЗаявокНаДоставку.Договор = ДоговорыКонтрагентов.Ссылка
	|ГДЕ
	|	&ТекстОтборСводовПоПериоду
	|	И ВЫБОР
	|			КОГДА &ОтборПоПартнеру
	|				ТОГДА СводЗаявокНаДоставку.Партнер = &Партнер
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И ВЫБОР
	|			КОГДА &ОтборПоДоговору
	|				ТОГДА СводЗаявокНаДоставку.Договор = &Договор
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И НЕ СводЗаявокНаДоставку.ПометкаУдаления
	|	И (ЕСТЬNULL(ДоговорыКонтрагентов.Логс_ИдентификаторCRM, ""0"") <> 0  И ЕСТЬNULL(ДоговорыКонтрагентов.Логс_ИдентификаторCRM, ""0"") <> """") 
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	СводЗаявокНаДоставкуЗаявки.Ссылка КАК Ссылка,
	|	СводЗаявокНаДоставкуЗаявки.ДатаДоставки КАК ДатаДоставки
	|ПОМЕСТИТЬ Заявки
	|ИЗ
	|	Документ.Логс_СводЗаявокНаДоставку.Заявки КАК СводЗаявокНаДоставкуЗаявки
	|ГДЕ
	|	СводЗаявокНаДоставкуЗаявки.Ссылка В
	|			(ВЫБРАТЬ
	|				СводыЗаявок.Ссылка
	|			ИЗ
	|				СводыЗаявок)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СводыЗаявок.Ссылка КАК Ссылка,
	|	СводыЗаявок.Номер КАК Номер,
	|	СводыЗаявок.Дата КАК Дата,
	|	СводыЗаявок.ИдентификаторКлиента КАК ИдентификаторКлиента,
	|	ЕСТЬNULL(Заявки.ДатаДоставки, ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)) КАК ДатаДоставки,
	|	СводыЗаявок.ПолнаяСтоимостьВсего КАК ПолнаяСтоимостьВсего,
	|	СводыЗаявок.НаложенныйПлатежВсего КАК НаложенныйПлатежВсего
	|ИЗ
	|	СводыЗаявок КАК СводыЗаявок
	|		ЛЕВОЕ СОЕДИНЕНИЕ Заявки КАК Заявки
	|		ПО СводыЗаявок.Ссылка = Заявки.Ссылка
	|ГДЕ
	|	СводыЗаявок.ИдентификаторКлиента <> """"
	|ИТОГИ
	|	МАКСИМУМ(Номер),
	|	МАКСИМУМ(Дата),
	|	МАКСИМУМ(ИдентификаторКлиента),
	|	МАКСИМУМ(ПолнаяСтоимостьВсего),
	|	МАКСИМУМ(НаложенныйПлатежВсего)
	|ПО
	|	Ссылка");
	Запрос.УстановитьПараметр("ОтборПоПартнеру", ЗначениеЗаполнено(Партнер));
	Запрос.УстановитьПараметр("Партнер", Партнер);
	Запрос.УстановитьПараметр("ОтборПоДоговору", ЗначениеЗаполнено(Договор));
	Запрос.УстановитьПараметр("Договор", Договор);
	Запрос.УстановитьПараметр("ДатаНачала", ?(ДатаНачала = Неопределено, '00010101', НачалоДня(ДатаНачала)));
	Запрос.УстановитьПараметр("ДатаОкончания", ?(ДатаОкончания = Неопределено, '00010101', КонецДня(ДатаОкончания)));
	
	Если ЗначениеЗаполнено(ДатаНачала) И ЗначениеЗаполнено(ДатаОкончания) Тогда
		ТекстОтборСводовПоПериоду = "СводЗаявокНаДоставку.Дата МЕЖДУ &ДатаНачала И &ДатаОкончания";
	ИначеЕсли ЗначениеЗаполнено(ДатаНачала) Тогда
		ТекстОтборСводовПоПериоду = "СводЗаявокНаДоставку.Дата >= &ДатаНачала";
	ИначеЕсли ЗначениеЗаполнено(ДатаОкончания) Тогда
		ТекстОтборСводовПоПериоду = "СводЗаявокНаДоставку.Дата <= &ДатаОкончания";
	Иначе
		ТекстОтборСводовПоПериоду = "ИСТИНА";
	КонецЕсли; 
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ТекстОтборСводовПоПериоду", ТекстОтборСводовПоПериоду);
	
	МассивСводов = Новый Массив;
	
	АдресБазы = Константы.АдресПубликацииИнформационнойБазыВИнтернете.Получить();
	Если Прав(АдресБазы, 1) <> "/" Тогда
		АдресБазы = АдресБазы + "/";
	КонецЕсли; 
	
	ВыборкаСводы = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаСводы.Следующий() Цикл
		
		ДанныеСвода = Новый Структура;
		ДанныеСвода.Вставить("client_id", ВыборкаСводы.ИдентификаторКлиента);
		ДанныеСвода.Вставить("order_num", ВыборкаСводы.Номер);
		ДанныеСвода.Вставить("order_total_sum_with_vat", ВыборкаСводы.ПолнаяСтоимостьВсего);
		ДанныеСвода.Вставить("order_total_cod", ВыборкаСводы.НаложенныйПлатежВсего);
		ДанныеСвода.Вставить("order_date", Формат(ВыборкаСводы.Дата, "ДФ=yyyy-MM-dd"));
		ДанныеСвода.Вставить("download_link", АдресБазы +
			"hs/crmexchange/download/agentreports/" +
			Строка(ВыборкаСводы.Ссылка.УникальныйИдентификатор()));
		ДанныеСвода.Вставить("download_report_ext_link", АдресБазы +
			"hs/crmexchange/download/agentreportsext/" +
			Строка(ВыборкаСводы.Ссылка.УникальныйИдентификатор()));
		
		ДатыДоставки = Новый Массив;
		
		Выборка = ВыборкаСводы.Выбрать();
		Пока Выборка.Следующий() Цикл
			ДатыДоставки.Добавить(Формат(Выборка.ДатаДоставки, "ДФ=yyyy-MM-dd"));
		КонецЦикла; 
		
		ДанныеСвода.Вставить("delivery_dates", ДатыДоставки);
		
		МассивСводов.Добавить(ДанныеСвода);
		
	КонецЦикла; 
	
	Возврат ВебСервисОтвет(200, МассивСводов);
	
КонецФункции 

Функция ПолучитьСводыЗаявокНаДоставку(ИдентификаторКлиента = Неопределено, УИДКлиентаСтрока = Неопределено, ДатаНачала, ДатаОкончания = Неопределено) Экспорт
	Перем Партнер, Договор;
	
	Если УИДКлиентаСтрока <> Неопределено Тогда
	
		Попытка
			УИДКлиента = Новый УникальныйИдентификатор(УИДКлиентаСтрока);
		Исключение
			Возврат ВебСервисОтвет(400,, НСтр("ru='Передан неверный uid'"));
		КонецПопытки;
	
		Партнер = Справочники.Партнеры.ПолучитьСсылку(УИДКлиента);
		Если Партнер.ПолучитьОбъект() = Неопределено Тогда
			Возврат ВебСервисОтвет(404,, СтрШаблон(НСтр("ru='Не найден агент с uid %1'"), УИДКлиентаСтрока));
		КонецЕсли; 
		
	ИначеЕсли ИдентификаторКлиента <> Неопределено Тогда
		
		Договор = НайтиДоговорАгентаПоИдентификатору(ИдентификаторКлиента);
		Если Договор.Пустая() Тогда
			Возврат ВебСервисОтвет(404,, СтрШаблон(НСтр("ru='Не найден агент с client_id %1'"), ИдентификаторКлиента));
		КонецЕсли; 
		
	КонецЕсли; 
	
	МассивСводов = Новый Массив;
	
	АдресБазы = Константы.АдресПубликацииИнформационнойБазыВИнтернете.Получить();
	Если Прав(АдресБазы, 1) <> "/" Тогда
		АдресБазы = АдресБазы + "/";
	КонецЕсли; 
	
	СтруктураПоиска = Новый Структура("СводЗаявок");
	
	ДанныеСводов = ПолучитьДанныеСводовЗаявокНаДоставку(Партнер, Договор, ДатаНачала, ДатаОкончания);
	
	ВыборкаСводы    = ДанныеСводов.Своды;
	ВыборкаПлатежки = ДанныеСводов.ПлатежныеПоручения;
	ВыборкаСчета    = ДанныеСводов.СчетаНаОплату;
	
	Пока ВыборкаСводы.Следующий() Цикл
		
		// Основные данные
		
		СуммаУслуг = ?(ВыборкаСводы.ФормаОплаты = Перечисления.Логс_ФормыОплатыУслугАгенту.Оплата100,
						ВыборкаСводы.ПолнаяСтоимость,
						-ВыборкаСводы.КПеречислению);
		СуммаОплачено = ВыборкаСводы.СуммаОплаченныхУслуг;
		
		Если СуммаОплачено > 0 И СуммаУслуг > 0 Тогда
			СтатусУслуг = ?(СуммаОплачено < СуммаУслуг, "Част. оплачен", "Оплачен");
		Иначе	
			СтатусУслуг = "Не оплачен";
		КонецЕсли; 
		
		ДанныеСвода = Новый Структура;
		ДанныеСвода.Вставить("client_id", ВыборкаСводы.ИдентификаторКлиента);
		ДанныеСвода.Вставить("report_num", ВыборкаСводы.Номер);
		ДанныеСвода.Вставить("report_date", Формат(ВыборкаСводы.Дата, "ДФ=yyyy-MM-dd"));
		ДанныеСвода.Вставить("price_client", Формат(ВыборкаСводы.НаложенныйПлатеж, "ЧЦ=15; ЧДЦ=2"));
		ДанныеСвода.Вставить("pd_full", Формат(ВыборкаСводы.ПолнаяСтоимость, "ЧЦ=15; ЧДЦ=2"));
		ДанныеСвода.Вставить("sum2p", Формат(ВыборкаСводы.КПеречислению, "ЧЦ=15; ЧДЦ=2"));
		
		ДанныеСвода.Вставить("f_price_client", Формат(ВыборкаСводы.НаложенныйПлатеж, "ЧРД=.; ЧГ=0"));
		ДанныеСвода.Вставить("f_pd_full", Формат(ВыборкаСводы.ПолнаяСтоимость, "ЧРД=.; ЧГ=0"));
		ДанныеСвода.Вставить("f_sum2p", Формат(ВыборкаСводы.КПеречислению, "ЧРД=.; ЧГ=0"));
		
		ДанныеСвода.Вставить("payment_type",
			?(ВыборкаСводы.ФормаОплаты = Перечисления.Логс_ФормыОплатыУслугАгенту.ОплатаЗаВычетом,
				"without_delivery", "full"
			));
		ДанныеСвода.Вставить("payment_status", СтатусУслуг);
		
		СтруктураПоиска.СводЗаявок = ВыборкаСводы.Ссылка;
		
		// Перечисление НП
		
		ПлатежныеПоручения = Новый Массив;
		
		Если ВыборкаПлатежки.НайтиСледующий(СтруктураПоиска) Тогда
			
			СуммаПеречислено = ВыборкаПлатежки.Сумма;
			
			Выборка = ВыборкаПлатежки.Выбрать();
			Пока Выборка.Следующий() Цикл
				
				ПлатежноеПоручение = Новый Структура;
				ПлатежноеПоручение.Вставить("num", Выборка.Номер);
				ПлатежноеПоручение.Вставить("date", Формат(Выборка.Дата, "ДФ=yyyy-MM-dd"));
				ПлатежноеПоручение.Вставить("sum", Формат(Выборка.Сумма, "ЧЦ=15; ЧДЦ=2"));    
				ПлатежноеПоручение.Вставить("f_sum", Формат(Выборка.Сумма, "ЧРД=.; ЧГ=0"));    
				
				ПлатежныеПоручения.Добавить(ПлатежноеПоручение);
				
			КонецЦикла; 
			
			ВыборкаПлатежки.Сбросить();
		Иначе
			
			СуммаПеречислено = 0;
			
		КонецЕсли; 
		
		СуммаНП = ?(ВыборкаСводы.ФормаОплаты = Перечисления.Логс_ФормыОплатыУслугАгенту.Оплата100,
					ВыборкаСводы.НаложенныйПлатеж,
					ВыборкаСводы.КПеречислению);
		Если СуммаПеречислено > 0 И СуммаНП > 0 Тогда
			СтатусНП = ?(СуммаПеречислено < СуммаНП, "Част. переведен", "Переведен");
		Иначе
			СтатусНП = "Не переведен";
		КонецЕсли; 
		
		ДанныеСвода.Вставить("np_status", СтатусНП);
		ДанныеСвода.Вставить("payment_orders", ПлатежныеПоручения);
		
		// Счета на оплату
		
		Счета = Новый Массив;
		
		Если ВыборкаСчета.НайтиСледующий(СтруктураПоиска) Тогда
			
			Выборка = ВыборкаСчета.Выбрать();
			Пока Выборка.Следующий() Цикл
				
				Счет = Новый Структура;
				Счет.Вставить("num", Выборка.Номер);
				Счет.Вставить("date", Формат(Выборка.Дата, "ДФ=yyyy-MM-dd"));
				Счет.Вставить("download_link", АдресБазы +
					"hs/crmexchange/download/bill/" +
					Строка(Выборка.Ссылка.УникальныйИдентификатор()));
					
				Счета.Добавить(Счет);
				
			КонецЦикла; 
			
		КонецЕсли; 
		
		ДанныеСвода.Вставить("req_for_pay", Счета);
		
		ДанныеСвода.Вставить("download_link", АдресБазы +
			"hs/crmexchange/download/agentreports/" +
			Строка(ВыборкаСводы.Ссылка.УникальныйИдентификатор()));
		ДанныеСвода.Вставить("download_report_ext_link", АдресБазы +
			"hs/crmexchange/download/agentreportsext/" +
			Строка(ВыборкаСводы.Ссылка.УникальныйИдентификатор()));
		
		МассивСводов.Добавить(ДанныеСвода);
		
	КонецЦикла; 
	
	Возврат ВебСервисОтвет(200, МассивСводов);
	
КонецФункции 

Функция ПолучитьДанныеСводовЗаявокНаДоставку(Партнер, Договор, ДатаНачала, ДатаОкончания)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	СводЗаявокНаДоставку.Ссылка КАК Ссылка,
	|	СводЗаявокНаДоставку.Номер КАК Номер,
	|	СводЗаявокНаДоставку.Дата КАК Дата,
	|	СводЗаявокНаДоставку.ФормаОплаты КАК ФормаОплаты,
	|	СводЗаявокНаДоставку.НаложенныйПлатежВсего КАК НаложенныйПлатеж,
	|	СводЗаявокНаДоставку.ПолнаяСтоимостьВсего КАК ПолнаяСтоимость,
	|	СводЗаявокНаДоставку.КПеречислениюВсего КАК КПеречислению,
	|	ЕСТЬNULL(ДоговорыКонтрагентов.Логс_ИдентификаторCRM, ""0"") КАК ИдентификаторКлиента
	|ПОМЕСТИТЬ СводыЗаявок
	|ИЗ
	|	Документ.Логс_СводЗаявокНаДоставку КАК СводЗаявокНаДоставку
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
	|		ПО СводЗаявокНаДоставку.Договор = ДоговорыКонтрагентов.Ссылка
	|ГДЕ
	|	&ТекстОтборСводовПоПериоду
	|	И ВЫБОР
	|			КОГДА &ОтборПоПартнеру
	|				ТОГДА СводЗаявокНаДоставку.Партнер = &Партнер
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И ВЫБОР
	|			КОГДА &ОтборПоДоговору
	|				ТОГДА СводЗаявокНаДоставку.Договор = &Договор
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И НЕ СводЗаявокНаДоставку.ПометкаУдаления
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	РасчетыПоУслугамЗаДоставку.СводЗаявок КАК СводЗаявок,
	|	СУММА(-РасчетыПоУслугамЗаДоставку.СуммаОборот) КАК Сумма
	|ПОМЕСТИТЬ ОплатаУслуг
	|ИЗ
	|	РегистрНакопления.Логс_РасчетыПоУслугамЗаДоставку.Обороты(
	|			,
	|			,
	|			Регистратор,
	|			СводЗаявок В
	|				(ВЫБРАТЬ
	|					СводыЗаявок.Ссылка
	|				ИЗ
	|					СводыЗаявок)) КАК РасчетыПоУслугамЗаДоставку
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПоступлениеБезналичныхДенежныхСредств КАК ПоступлениеБезналичныхДенежныхСредств
	|		ПО РасчетыПоУслугамЗаДоставку.Регистратор = ПоступлениеБезналичныхДенежныхСредств.Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	РасчетыПоУслугамЗаДоставку.СводЗаявок
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	СводЗаявок
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СводыЗаявок.Ссылка КАК Ссылка,
	|	СводыЗаявок.Номер КАК Номер,
	|	СводыЗаявок.Дата КАК Дата,
	|	СводыЗаявок.ФормаОплаты КАК ФормаОплаты,
	|	СводыЗаявок.НаложенныйПлатеж КАК НаложенныйПлатеж,
	|	СводыЗаявок.ПолнаяСтоимость КАК ПолнаяСтоимость,
	|	СводыЗаявок.КПеречислению КАК КПеречислению,
	|	ЕСТЬNULL(ОплатаУслуг.Сумма, 0) КАК СуммаОплаченныхУслуг,
	|	СводыЗаявок.ИдентификаторКлиента КАК ИдентификаторКлиента
	|ИЗ
	|	СводыЗаявок КАК СводыЗаявок
	|		ЛЕВОЕ СОЕДИНЕНИЕ ОплатаУслуг КАК ОплатаУслуг
	|		ПО СводыЗаявок.Ссылка = ОплатаУслуг.СводЗаявок
	|
	|УПОРЯДОЧИТЬ ПО
	|	Дата УБЫВ,
	|	Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	РаспределениеПоСводамЗаявокНаДоставку.СводЗаявок КАК СводЗаявок,
	|	СписаниеБезналичныхДенежныхСредств.НомерВходящегоДокумента КАК Номер,
	|	СписаниеБезналичныхДенежныхСредств.ДатаВходящегоДокумента КАК Дата,
	|	СУММА(РаспределениеПоСводамЗаявокНаДоставку.Сумма) КАК Сумма
	|ИЗ
	|	Документ.СписаниеБезналичныхДенежныхСредств.Логс_РаспределениеПоСводамЗаявокНаДоставку КАК РаспределениеПоСводамЗаявокНаДоставку
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.СписаниеБезналичныхДенежныхСредств КАК СписаниеБезналичныхДенежныхСредств
	|		ПО РаспределениеПоСводамЗаявокНаДоставку.Ссылка = СписаниеБезналичныхДенежныхСредств.Ссылка
	|ГДЕ
	|	РаспределениеПоСводамЗаявокНаДоставку.СводЗаявок В
	|			(ВЫБРАТЬ
	|				СводыЗаявок.Ссылка
	|			ИЗ
	|				СводыЗаявок)
	|	И СписаниеБезналичныхДенежныхСредств.Проведен
	|
	|СГРУППИРОВАТЬ ПО
	|	РаспределениеПоСводамЗаявокНаДоставку.СводЗаявок,
	|	СписаниеБезналичныхДенежныхСредств.НомерВходящегоДокумента,
	|	СписаниеБезналичныхДенежныхСредств.ДатаВходящегоДокумента
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	РаспределениеПоСводамЗаявокНаДоставку.СводЗаявок,
	|	РасходныйКассовыйОрдер.Номер,
	|	РасходныйКассовыйОрдер.Дата,
	|	СУММА(РаспределениеПоСводамЗаявокНаДоставку.Сумма)
	|ИЗ
	|	Документ.РасходныйКассовыйОрдер.Логс_РаспределениеПоСводамЗаявокНаДоставку КАК РаспределениеПоСводамЗаявокНаДоставку
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РасходныйКассовыйОрдер КАК РасходныйКассовыйОрдер
	|		ПО РаспределениеПоСводамЗаявокНаДоставку.Ссылка = РасходныйКассовыйОрдер.Ссылка
	|ГДЕ
	|	РаспределениеПоСводамЗаявокНаДоставку.СводЗаявок В
	|			(ВЫБРАТЬ
	|				СводыЗаявок.Ссылка
	|			ИЗ
	|				СводыЗаявок)
	|	И РасходныйКассовыйОрдер.Проведен
	|
	|СГРУППИРОВАТЬ ПО
	|	РаспределениеПоСводамЗаявокНаДоставку.СводЗаявок,
	|	РасходныйКассовыйОрдер.Номер,
	|	РасходныйКассовыйОрдер.Дата
	|
	|УПОРЯДОЧИТЬ ПО
	|	СводЗаявок
	|ИТОГИ
	|	СУММА(Сумма)
	|ПО
	|	СводЗаявок
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	СчетНаОплатуКлиентуРаспределениеПоСводам.СводЗаявок КАК СводЗаявок,
	|	СчетНаОплатуКлиентуРаспределениеПоСводам.Ссылка КАК Ссылка,
	|	СчетНаОплатуКлиенту.Дата КАК Дата,
	|	СчетНаОплатуКлиенту.Номер КАК Номер
	|ИЗ
	|	Документ.СчетНаОплатуКлиенту.Логс_РаспределениеПоСводамЗаявокНаДоставку КАК СчетНаОплатуКлиентуРаспределениеПоСводам
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.СчетНаОплатуКлиенту КАК СчетНаОплатуКлиенту
	|		ПО СчетНаОплатуКлиентуРаспределениеПоСводам.Ссылка = СчетНаОплатуКлиенту.Ссылка
	|ГДЕ
	|	СчетНаОплатуКлиентуРаспределениеПоСводам.СводЗаявок В
	|			(ВЫБРАТЬ
	|				СводыЗаявок.Ссылка
	|			ИЗ
	|				СводыЗаявок)
	|	И СчетНаОплатуКлиенту.Проведен
	|
	|УПОРЯДОЧИТЬ ПО
	|	СводЗаявок
	|ИТОГИ ПО
	|	СводЗаявок");
	Запрос.УстановитьПараметр("ОтборПоПартнеру", ЗначениеЗаполнено(Партнер));
	Запрос.УстановитьПараметр("Партнер", Партнер);
	Запрос.УстановитьПараметр("ОтборПоДоговору", ЗначениеЗаполнено(Договор));
	Запрос.УстановитьПараметр("Договор", Договор);
	Запрос.УстановитьПараметр("ДатаНачала", ?(ДатаНачала = Неопределено, '00010101', НачалоДня(ДатаНачала)));
	Запрос.УстановитьПараметр("ДатаОкончания", ?(ДатаОкончания = Неопределено, '00010101', КонецДня(ДатаОкончания)));
	
	Если ЗначениеЗаполнено(ДатаНачала) И ЗначениеЗаполнено(ДатаОкончания) Тогда
		ТекстОтборСводовПоПериоду = "СводЗаявокНаДоставку.Дата МЕЖДУ &ДатаНачала И &ДатаОкончания";
	ИначеЕсли ЗначениеЗаполнено(ДатаНачала) Тогда
		ТекстОтборСводовПоПериоду = "СводЗаявокНаДоставку.Дата >= &ДатаНачала";
	ИначеЕсли ЗначениеЗаполнено(ДатаОкончания) Тогда
		ТекстОтборСводовПоПериоду = "СводЗаявокНаДоставку.Дата <= &ДатаОкончания";
	Иначе
		ТекстОтборСводовПоПериоду = "ИСТИНА";
	КонецЕсли; 
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ТекстОтборСводовПоПериоду", ТекстОтборСводовПоПериоду);
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	ДанныеСводов = Новый Структура;
	ДанныеСводов.Вставить("Своды", РезультатЗапроса[2].Выбрать());
	ДанныеСводов.Вставить("ПлатежныеПоручения", РезультатЗапроса[3].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам));
	ДанныеСводов.Вставить("СчетаНаОплату", РезультатЗапроса[4].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам));
	
	Возврат ДанныеСводов;
	
КонецФункции 

Функция ПолучитьСчетФактурыАгентов(ИдентификаторКлиента = Неопределено, УИДКлиентаСтрока = Неопределено, ДатаНачала, ДатаОкончания = Неопределено) Экспорт
	Перем Партнер, Договор;
	
	Если УИДКлиентаСтрока <> Неопределено Тогда
	
		Попытка
			УИДКлиента = Новый УникальныйИдентификатор(УИДКлиентаСтрока);
		Исключение
			Возврат ВебСервисОтвет(400,, НСтр("ru='Передан неверный uid'"));
		КонецПопытки;
	
		Партнер = Справочники.Партнеры.ПолучитьСсылку(УИДКлиента);
		Если Партнер.ПолучитьОбъект() = Неопределено Тогда
			Возврат ВебСервисОтвет(404,, СтрШаблон(НСтр("ru='Не найден агент с uid %1'"), УИДКлиентаСтрока));
		КонецЕсли; 
		
	ИначеЕсли ИдентификаторКлиента <> Неопределено Тогда
		
		Договор = НайтиДоговорАгентаПоИдентификатору(ИдентификаторКлиента);
		Если Договор.Пустая() Тогда
			Возврат ВебСервисОтвет(404,, СтрШаблон(НСтр("ru='Не найден агент с client_id %1'"), ИдентификаторКлиента));
		КонецЕсли; 
		
	КонецЕсли; 
	
	АдресБазы = Константы.АдресПубликацииИнформационнойБазыВИнтернете.Получить();
	Если Прав(АдресБазы, 1) <> "/" Тогда
		АдресБазы = АдресБазы + "/";
	КонецЕсли; 
	
	МассивСчетФактур = Новый Массив;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	СчетФактура.Ссылка КАК Ссылка,
	|	СчетФактура.Дата КАК Дата,
	|	СчетФактура.Номер КАК Номер
	|ИЗ
	|	Документ.АктВыполненныхРабот КАК СчетФактура
	|ГДЕ
	|	&ТекстОтборПоПериоду
	|	И ВЫБОР
	|			КОГДА &ОтборПоПартнеру
	|				ТОГДА СчетФактура.Партнер = &Партнер
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И ВЫБОР
	|			КОГДА &ОтборПоДоговору
	|				ТОГДА СчетФактура.Договор = &Договор
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И СчетФактура.Проведен
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	СчетФактура.Ссылка,
	|	СчетФактура.Дата,
	|	СчетФактура.Номер
	|ИЗ
	|	Документ.ОтчетКомитенту КАК СчетФактура
	|ГДЕ
	|	&ТекстОтборПоПериоду
	|	И ВЫБОР
	|			КОГДА &ОтборПоПартнеру
	|				ТОГДА СчетФактура.Партнер = &Партнер
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И ВЫБОР
	|			КОГДА &ОтборПоДоговору
	|				ТОГДА СчетФактура.Договор = &Договор
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И СчетФактура.Проведен");
	Запрос.УстановитьПараметр("ОтборПоПартнеру", ЗначениеЗаполнено(Партнер));
	Запрос.УстановитьПараметр("Партнер", Партнер);
	Запрос.УстановитьПараметр("ОтборПоДоговору", ЗначениеЗаполнено(Договор));
	Запрос.УстановитьПараметр("Договор", Договор);
	Запрос.УстановитьПараметр("ДатаНачала", ?(ДатаНачала = Неопределено, '00010101', НачалоДня(ДатаНачала)));
	Запрос.УстановитьПараметр("ДатаОкончания", ?(ДатаОкончания = Неопределено, '00010101', КонецДня(ДатаОкончания)));
	
	Если ЗначениеЗаполнено(ДатаНачала) И ЗначениеЗаполнено(ДатаОкончания) Тогда
		ТекстОтборПоПериоду = "СчетФактура.Дата МЕЖДУ &ДатаНачала И &ДатаОкончания";
	ИначеЕсли ЗначениеЗаполнено(ДатаНачала) Тогда
		ТекстОтборПоПериоду = "СчетФактура.Дата >= &ДатаНачала";
	ИначеЕсли ЗначениеЗаполнено(ДатаОкончания) Тогда
		ТекстОтборПоПериоду = "СчетФактура.Дата <= &ДатаОкончания";
	Иначе
		ТекстОтборПоПериоду = "ИСТИНА";
	КонецЕсли; 
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ТекстОтборПоПериоду", ТекстОтборПоПериоду);
	
	СчетФактуры = Новый Массив;
	
	Выборка = Запрос.Выполнить().Выбрать();
