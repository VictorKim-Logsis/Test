		Если ТекущееКоличествоВТранзакции = 0 И НЕ Выборка.ОбрабатыватьВнеТранзакции Тогда
			НачатьТранзакцию();
		КонецЕсли;
		
		                  //этот мутный код зачем-то сначала записывал новый док, а потом проводил
		Если ЗаявкаОбъект.ЭтоНовый() Тогда
			Попытка
				ЗаявкаОбъект.Записать(РежимЗаписиДокумента.Проведение);
			Исключение
				
				ТекстСообщения = СтрШаблон(
					НСтр("ru='Произошла ошибка при импорте заявки № %1 от %2: %3'"),
					ЗаявкаОбъект.Номер, ЗаявкаОбъект.Дата,
					КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
					
				ЗаписьЖурналаРегистрации("Обмен с CRM. Загрузка заявок",
					УровеньЖурналаРегистрации.Ошибка,,, ТекстСообщения);
				СписокОшибок.Добавить(Новый Структура("ТекстОшибки,КлючДанных",
					ТекстСообщения, ЗаявкаОбъект.Ссылка));
				
				Продолжить;
				
			КонецПопытки;
		Иначе
			Попытка
				
				ЗаявкаОбъект.Записать(РежимЗаписиДокумента.Проведение);
				
			Исключение
				
				ТекстСообщения = СтрШаблон(
					НСтр("ru='Произошла ошибка при обновлении данных заявки № %1 от %2: %3'"),
					ЗаявкаОбъект.Номер, ЗаявкаОбъект.Дата,
					КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
					
				ЗаписьЖурналаРегистрации("Обмен с CRM. Загрузка заявок",
					УровеньЖурналаРегистрации.Ошибка,,, ТекстСообщения);
				СписокОшибок.Добавить(Новый Структура("ТекстОшибки,КлючДанных",
					ТекстСообщения, ЗаявкаОбъект.Ссылка));
				
				Продолжить;
				
			КонецПопытки;
		КонецЕсли;
		
		//++ Ким Виктор 31.03.2025
		//Запишем новые реквизиты в регистр сведений
		//https://jira-sd.logsis.ru/projects/TSLOG/queues/custom/18/TSLOG-16074
		//Если Выборка.СортировкаАгента <> 0 или Выборка.НадбавкаАгента <> 0 или 
		//	Выборка.ГарантированнаяДоставка <> 0 или Выборка.ОжиданиеКурьера <> 0 или 
		//	Выборка.ОплатаПарковкиАгента <> 0 Тогда 
		Если  Выборка.Статус <> "Отмена" и Выборка.Статус <> "Полный отказ" 
			//ШОП ТВ ООО (Справочник.Контрагенты) 
			И Выборка.Контрагент = Справочники.Контрагенты.ПолучитьСсылку(Новый УникальныйИдентификатор("0fef8649-2b0e-11eb-810c-000c29986c98")) Тогда
			
			СтруктураЗаписи = РегистрыСведений.Логс_РеквизитыЗаявкиНаДоставку.ПолучитьСтруктуруЗаписи();	
			
			ЗаполнитьЗначенияСвойств(СтруктураЗаписи, Выборка, "СортировкаАгента, НадбавкаАгента, 
			| ГарантированнаяДоставка, ОжиданиеКурьера, ОплатаПарковкиАгента" );
			СтруктураЗаписи.ЗаявкаНаДоставку = ЗаявкаОбъект.Ссылка;
			СтруктураЗаписи.СтавкаНДСЧисло = СтавкаНДСЧисло;
			ЗаписатьНовыйРеквизиты(СтруктураЗаписи);
			
		КонецЕсли;
		//-- Ким Виктор 31.03.2025
		
		//++ Ким Виктор 29.01.2026
		//Доработка расшифровки отчета агента для СМ(Остин)
		Если  Выборка.Партнер.Логс_ГруппаКомпанийКлиента = Справочники.Логс_ГруппыКомпанийКлиентов.ПолучитьСсылку(Новый УникальныйИдентификатор("36dccc0e-5282-11ec-9403-00505696b95d")) Тогда 
			
			СтрукутраЗаписиСпецРеквизитов = РегистрыСведений.Логс_СпецифическиеРеквизитыЗаявкиНаДоставку.ПолучитьСтруктуруЗаписи();   
			ЗаполнитьЗначенияСвойств(СтрукутраЗаписиСпецРеквизитов, Выборка, "ХабОтправителя, ХабПолучателя, ЛыжиИлиНеЛыжи");
			СтрукутраЗаписиСпецРеквизитов.ЗаявкаНаДоставку = ЗаявкаОбъект.Ссылка;
			ЗаписатьНовыеСпецифическиеРеквизиты(СтрукутраЗаписиСпецРеквизитов);
			
		КонецЕсли;
		//-- Ким Виктор 29.01.2026
				
		Если НЕ Выборка.ОбрабатыватьВнеТранзакции Тогда
			ТекущееКоличествоВТранзакции = ТекущееКоличествоВТранзакции+1;
		КонецЕсли;	
			
		Если ТекущееКоличествоВТранзакции = РазмерТранзакции Тогда
			ЗафиксироватьТранзакцию();
			ТекущееКоличествоВТранзакции = 0;
		КонецЕсли;
		
		Если СтруктураЗаписиКоллизии.Количество()>0 Тогда
			НоваяКоллизия = Коллизии.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяКоллизия, СтруктураЗаписиКоллизии);
			НоваяКоллизия.Заявка = ЗаявкаОбъект.Ссылка;
			НоваяКоллизия.ДатаЗагрузки = ДатаЗагрузки;
		КонецЕсли;
			
	КонецЦикла; 
	
	Если ТекущееКоличествоВТранзакции >0 Тогда
		ЗафиксироватьТранзакцию();
		ТекущееКоличествоВТранзакции = 0;
	КонецЕсли;
	
	Если Коллизии.Количество()>0 Тогда
		Коллизии.Записать(Истина);
	КонецЕсли;
	
	// Удаление заявок, отсутствующих в загрузке (в CRM изменился статус на НЕ конечный).
	Если Не ЗначениеЗаполнено(НомерЗаявки) И ТДРегион = Неопределено Тогда
		Выборка = РезультатЗапроса[4].Выбрать();
		Пока Выборка.Следующий() Цикл
			
			ЗаявкаОбъект = Выборка.Ссылка.ПолучитьОбъект();
			
			Попытка
				
				ЗаявкаОбъект.УстановитьПометкуУдаления(Истина);
				
			Исключение
				
				ТекстСообщения = СтрШаблон(
					НСтр("ru='Произошла ошибка при пометке на удаление заявки № %1 от %2: %3'"),
					ЗаявкаОбъект.Номер, ЗаявкаОбъект.Дата,
					КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
					
				ЗаписьЖурналаРегистрации("Обмен с CRM. Загрузка заявок", УровеньЖурналаРегистрации.Ошибка,,, ТекстСообщения);
				СписокОшибок.Добавить(Новый Структура("ТекстОшибки,КлючДанных", ТекстСообщения, ЗаявкаОбъект.Ссылка));
				
			КонецПопытки;
			
		КонецЦикла;
	КонецЕсли;	
	
	Возврат СписокОшибок.Количество() = 0;
	
КонецФункции

