	Адреса.Вставить("РегионСкладаОтправителя",Ответ.response[0].warehouse_region);
	Адреса.Вставить("ГородДоставки",Ответ.response[0].target_city);
	Адреса.Вставить("РегионДоставки",Ответ.response[0].target_region);
	
	КлиентскиеПоля = Ответ.response[0].clients_fields;
	Возврат Новый Структура("Товары, КлиентскиеПоля, Адреса",Ответ.response[0].goods, ?(КлиентскиеПоля = Неопределено, Новый Структура, КлиентскиеПоля), Адреса);
КонецФункции

