Процедура ДобавитьМассивЗаявокВТаблицуЗначений(ТаблицаЗаявок, СводЗаявок, ДанныеАгента, НомерЗаявки = Неопределено, ТДРегион = Неопределено)
	
	Для каждого Заявки Из СводЗаявок.Своды Цикл
		
		Если НомерЗаявки <> Неопределено
				И НомерЗаявки <> СокрЛП(Заявки.order_id) Тогда
			Продолжить;
		КонецЕсли; 
		
		// если есть отбор по ТД регион
		Если Заявки.is_regional <> "0" Тогда
			ТДРегионСРМ = Истина;
		Иначе	
			ТДРегионСРМ = Ложь;	
		КонецЕсли;
		Если ТДРегион <> Неопределено Тогда 			
			Если ТДРегион <> ТДРегионСРМ Тогда
				Продолжить;
			КонецЕсли;			
		КонецЕсли;	  			
		
		СтрокаЗаявка = ТаблицаЗаявок.Добавить();
		СтрокаЗаявка.ЭтоЗабор = Ложь;
		
		ЗаполнитьЗначенияСвойств(СтрокаЗаявка, ДанныеАгента,
			"ИдентификаторКлиента,Организация,Партнер,Контрагент," +
			"Договор,СтавкаНДС,НалогообложениеНДС,Валюта");
		
		СтрокаЗаявка.ДатаДоставки = ПреобразоватьДатуJSON(Заявки.delivery_date);
		СтрокаЗаявка.ДатаДоставкиПлан = ПреобразоватьДатуJSON(Заявки.plan_delivery_date);
		СтрокаЗаявка.НомерЗаказа = СокрЛП(Заявки.order_id);
		СтрокаЗаявка.Статус = Заявки.status;
		СтрокаЗаявка.Вес = СтрокаВЧисло(Заявки.weight);
		СтрокаЗаявка.РасстояниеОтМКАД = СтрокаВЧисло(Заявки.mkad_distance);
		СтрокаЗаявка.ОценочнаяСтоимость = СтрокаВЧисло(Заявки.os);
		СтрокаЗаявка.СтоимостьЗаказа = СтрокаВЧисло(Заявки.price_first);
		СтрокаЗаявка.ДатаЗабора = ПреобразоватьДатуJSON(Заявки.akt_on_ware_date);
		СтрокаЗаявка.ДатаВозврата = ПреобразоватьДатуJSON(Заявки.akt_to_back_cli);
		СтрокаЗаявка.СуммаВозврата = СтрокаВЧисло(Заявки.goodsSumma);
		СтрокаЗаявка.IDЗона = Заявки.zone_id;
		СтрокаЗаявка.КодРегиона = Заявки.region_code;
		СтрокаЗаявка.Приоритет = Заявки.pay_type;
		СтрокаЗаявка.ТипКурьера = Заявки.courier_type;
		СтрокаЗаявка.РегиональнаяЗаявка = СтрокаЗаявка.КодРегиона <> ""
											И СтрокаЗаявка.КодРегиона <> "77"
											И СтрокаЗаявка.КодРегиона <> "50";
		СтрокаЗаявка.ФормаОплаты = Логс_ДоговорыАгентов.ФормаОплатыУслугАгенту(ДанныеАгента, СтрокаЗаявка.РегиональнаяЗаявка, СтрокаЗаявка.ДатаДоставки);
		
		Если Заявки.Свойство("inner_n") Тогда
			СтрокаЗаявка.НомерЗаказаКлиента = Заявки.inner_n;
		КонецЕсли; 
		МассивГород = Заявки.city;
		Если ТипЗнч(МассивГород) = Тип("Массив") И МассивГород.Количество() > 0 Тогда
			СтрокаЗаявка.Город = МассивГород[0];
		КонецЕсли;
		СтрокаЗаявка.СтоимостьДоставкиПринципала = Заявки.price_client_delivery;
		
		СтрокаЗаявка.НаложенныйПлатеж = СтрокаВЧисло(Заявки.price_client);
		СтрокаЗаявка.Тариф = СтрокаВЧисло(Заявки.pd_tar);
		СтрокаЗаявка.КассовоеОбслуживание = СтрокаВЧисло(Заявки.pd_ko);
		СтрокаЗаявка.Эквайринг = СтрокаВЧисло(Заявки.pd_eq);
		СтрокаЗаявка.Страхование = СтрокаВЧисло(Заявки.pd_dop_strah);
		СтрокаЗаявка.Комплектация = СтрокаВЧисло(Заявки.pd_dop_compl);
		СтрокаЗаявка.Упаковка = СтрокаВЧисло(Заявки.pd_dop_pack);
		СтрокаЗаявка.Этикирование = СтрокаВЧисло(Заявки.pd_label);
		СтрокаЗаявка.Прозвон = СтрокаВЧисло(Заявки.pd_call);
		СтрокаЗаявка.СМС = СтрокаВЧисло(Заявки.pd_sms);
		СтрокаЗаявка.ОбработкаВозврата = СтрокаВЧисло(Заявки.pd_dop_vozvrat);
		СтрокаЗаявка.Обмен = СтрокаВЧисло(Заявки.pd_change);
		СтрокаЗаявка.ЗаносКГТ = СтрокаВЧисло(Заявки.pd_kgt_tar);
		СтрокаЗаявка.ВозвратныеДокументы = СтрокаВЧисло(Заявки.pd_docs_return);
		СтрокаЗаявка.ОбработкаЧастичногоВыкупа = СтрокаВЧисло(Заявки.pd_return);
		СтрокаЗаявка.ТДРегион = ТДРегионСРМ;	
		Если СтрокаЗаявка.ТДРегион Тогда
			СтрокаЗаявка.АгентРегион = Справочники.Партнеры.НайтиПоНаименованию("ИНТЕРНЕТ ЛОГИСТИКА", Истина);
		Иначе
			СтрокаЗаявка.АгентРегион = Справочники.Партнеры.ПустаяСсылка();
		КонецЕсли;	
			
		СтрокаЗаявка.ПолнаяСтоимость = СтрокаЗаявка.Тариф + СтрокаЗаявка.ПовторнаяДоставка +
			СтрокаЗаявка.КассовоеОбслуживание + СтрокаЗаявка.Эквайринг + СтрокаЗаявка.Страхование + 
			СтрокаЗаявка.ЗаносКГТ + СтрокаЗаявка.ВозвратныеДокументы + СтрокаЗаявка.СМС +
			СтрокаЗаявка.Прозвон + СтрокаЗаявка.ОбработкаЧастичногоВыкупа;
			//СтрокаСвода.Комплектация + СтрокаСвода.Упаковка + СтрокаСвода.Этикирование + СтрокаСвода.Прозвон;
		
		СтавкаНДСЧисло = УчетНДСУПКлиентСервер.ПолучитьСтавкуНДС(СтрокаЗаявка.СтавкаНДС);	
			
		СтрокаЗаявка.ПолнаяСтоимостьНДС = УчетНДСУПКлиентСервер.РассчитатьСуммуНДС(
			СтрокаЗаявка.ПолнаяСтоимость,
			СтавкаНДСЧисло,
			Ложь);
		СтрокаЗаявка.ПолнаяСтоимостьСНДС = СтрокаЗаявка.ПолнаяСтоимость + СтрокаЗаявка.ПолнаяСтоимостьНДС;
		
		СтрокаЗаявка.СУДСНДС = УчетНДСУПКлиентСервер.РассчитатьСуммуНДС(
			СтрокаЗаявка.КассовоеОбслуживание + СтрокаЗаявка.Эквайринг,
			СтавкаНДСЧисло,
			Ложь);
		СтрокаЗаявка.СУДС_СНДС = СтрокаЗаявка.КассовоеОбслуживание + СтрокаЗаявка.Эквайринг + СтрокаЗаявка.СУДСНДС;		

		СтрокаЗаявка.КПеречислению =
			?(СтрокаЗаявка.ФормаОплаты = Перечисления.Логс_ФормыОплатыУслугАгенту.Оплата100,
				СтрокаЗаявка.НаложенныйПлатеж,
				СтрокаЗаявка.НаложенныйПлатеж - СтрокаЗаявка.ПолнаяСтоимостьСНДС
			);
		
		Если Заявки.Свойство("courier_id") И ЗначениеЗаполнено(Заявки.courier_id) Тогда
			СтрокаЗаявка.ИдентификаторКурьера = Заявки.courier_id;
		КонецЕсли; 
		
		Если Заявки.Свойство("card")
				И Заявки.card = "Оплата наличными"
				И СтрокаЗаявка.НаложенныйПлатеж <> 0 Тогда
			
			СтрокаЗаявка.ОплатаНаличные = Истина;
			СтрокаЗаявка.ВозвратНаличные = Истина;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Для каждого Заборы Из СводЗаявок.Заборы Цикл
		
		СтрокаЗаявка = ТаблицаЗаявок.Добавить();
		СтрокаЗаявка.ЭтоЗабор = Истина;
		
		ЗаполнитьЗначенияСвойств(СтрокаЗаявка, ДанныеАгента,
			"ИдентификаторКлиента,Организация,Партнер,Контрагент," +
			"Договор,СтавкаНДС,НалогообложениеНДС,Валюта");
		
		СтрокаЗаявка.ДатаДоставки = ПреобразоватьДатуJSON(Заборы.delivery_date);
		СтрокаЗаявка.НомерЗаказа = Заборы.zorder_id;
		СтрокаЗаявка.Статус = Заборы.status;
		СтрокаЗаявка.ФормаОплаты = Логс_ДоговорыАгентов.ФормаОплатыУслугАгенту(ДанныеАгента, СтрокаЗаявка.РегиональнаяЗаявка);
		СтрокаЗаявка.Тариф = СтрокаВЧисло(Заборы.zprice_price_client);
			
		СтрокаЗаявка.ПолнаяСтоимость = СтрокаЗаявка.Тариф;
		
		СтрокаЗаявка.ПолнаяСтоимостьНДС = УчетНДСУПКлиентСервер.РассчитатьСуммуНДС(
			СтрокаЗаявка.ПолнаяСтоимость,
			УчетНДСУПКлиентСервер.ПолучитьСтавкуНДС(СтрокаЗаявка.СтавкаНДС),
			Ложь);
		СтрокаЗаявка.ПолнаяСтоимостьСНДС = СтрокаЗаявка.ПолнаяСтоимость + СтрокаЗаявка.ПолнаяСтоимостьНДС;

		СтрокаЗаявка.КПеречислению =
			?(СтрокаЗаявка.ФормаОплаты = Перечисления.Логс_ФормыОплатыУслугАгенту.Оплата100,
				0,
				-СтрокаЗаявка.ПолнаяСтоимостьСНДС
			);
			
		Если Заборы.Свойство("courier_id") И ЗначениеЗаполнено(Заборы.courier_id) Тогда
			СтрокаЗаявка.ИдентификаторКурьера = Заборы.courier_id;
		КонецЕсли;				
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ОповеститьПоПочтеНужныйОтдел(Отдел, client_id, Контрагент, ТекстПисьма="")
	МассивАдресов = Новый Массив;
	Если Отдел = "Коммерческий" Тогда
		Адрес = "sales_dep@logsis.ru";
		ИмяАдреса = "Sales_Dep";
		МассивАдресов.Добавить(Новый Структура("email,name,type",Адрес, ИмяАдреса, "to"));
	ИначеЕсли Отдел = "Аккаунтинг" Тогда
		Адрес = "service@logsis.ru";
		ИмяАдреса = "Service";
		МассивАдресов.Добавить(Новый Структура("email,name,type",Адрес, ИмяАдреса, "to"));
	ИначеЕсли Отдел = "Оферта" Тогда
		Адрес = Константы.Логс_АдресаРассылкиНовойОферты.Получить();
		Список = СтрРазделить(Адрес, ";",Ложь);
		Для Каждого тАдрес из Список Цикл
			МассивАдресов.Добавить(Новый Структура("email,name,type",тАдрес, тАдрес, "to"));
		КонецЦикла;	
		
	КонецЕсли;
	
	Путь = КаталогВременныхФайлов();	
	ПутьКJSON = "" + Путь + client_id;
	
	СоздатьКаталог(ПутьКJSON);
	
	Запись = Новый ЗаписьJSON;
	
	Запись.ОткрытьФайл("" + ПутьКJSON + "\" + "send.json");
	
	НастройкиСериализации = Новый НастройкиСериализацииJSON;
    НастройкиСериализации.ФорматСериализацииДаты = ФорматДатыJSON.ISO;
    НастройкиСериализации.ВариантЗаписиДаты = ВариантЗаписиДатыJSON.ЛокальнаяДата;
	
	
	//МассивФайлов = Новый Массив;
	Если Отдел = "Оферта" Тогда
		Тема = "Открыт ЛК (Оферта) №" + client_id + " " + Контрагент;
		Текст = "Открыт ЛК (Оферта) №" + client_id + " " + Контрагент + ?(ТекстПисьма = "", "", ""+Символы.ПС+ТекстПисьма);
	Иначе
		Тема = "Открыт ЛК № " + client_id + " " + Контрагент;
		Текст = "Открыт ЛК № " + client_id + " " + Контрагент + ?(ТекстПисьма = "", "", ""+Символы.ПС+ТекстПисьма);
	КонецЕсли;
	
	ДанныеСообщения = Новый Структура;
	ДанныеСообщения.Вставить("html", "<p>" + Текст + "</p>");
	ДанныеСообщения.Вставить("subject", Тема);
	ДанныеСообщения.Вставить("from_email", "info@logsis.ru");
	ДанныеСообщения.Вставить("from_name", "logsis");
	ДанныеСообщения.Вставить("to", МассивАдресов);
	ДанныеСообщения.Вставить("important", "false");
	ДанныеСообщения.Вставить("track_opens", "null");
    ДанныеСообщения.Вставить("track_clicks", "null");
    ДанныеСообщения.Вставить("auto_text", "null");
    ДанныеСообщения.Вставить("auto_html", "null");
    ДанныеСообщения.Вставить("inline_css", "null");
    ДанныеСообщения.Вставить("url_strip_qs", "null");
    ДанныеСообщения.Вставить("preserve_recipients", "null");
    ДанныеСообщения.Вставить("view_content_link", "null");
	
	//МассивКартинок = Новый Массив;
	//ПолноеИмяФайлаКартинки = "" + Путь + "logo.png";
	//Текст = Base64Строка(Новый ДвоичныеДанные(ПолноеИмяФайлаКартинки));
	//МассивФайлов.Добавить(Новый Структура("type,name,content","image/png", "logo", """" + Текст + """"));
	
	
	Данные = Новый Структура;
	КлючАПИ = Константы.Логс_КлючАпиСервисаПочтовыхРассылок.Получить();
	КлючАПИ = ?(ЗначениеЗаполнено(КлючАПИ), КлючАПИ, "jUibmIWtROAJMMScZZiwDA");
	Данные.Вставить("message",ДанныеСообщения);
	//Данные.Вставить("images",МассивКартинок);
	Данные.Вставить("async", "false");
    Данные.Вставить("ip_pool", "Main Pool");
    Данные.Вставить("send_at", "2019-08-20 20:20:20");
    
	ЗаписатьJSON(Запись, Данные, НастройкиСериализации);
    Запись.Закрыть();
	
	//POST запрос к мандрилу
	АдресСервера = "mandrillapp.com";
	HTTPСоединение = Новый HTTPСоединение(АдресСервера,443,,,,,Новый ЗащищенноеСоединениеOpenSSL);
	
	ЗаголовокЗапросаHTTP = Новый Соответствие();	
	ЗаголовокЗапросаHTTP.Вставить("Content-Type", "application/json; charset=utf-8");	
	
	запросPOST = Новый HTTPЗапрос("/api/1.0/messages/send.json", ЗаголовокЗапросаHTTP);
	запросPOST.УстановитьИмяФайлаТела("" + ПутьКJSON + "\" + "send.json");
	
	ФайлРезультата = ПолучитьИмяВременногоФайла();
	HTTPОтвет = HTTPСоединение.ОтправитьДляОбработки(запросPOST, ФайлРезультата);
	Если HTTPОтвет.КодСостояния = 200 Тогда
		РегистрыСведений.Логс_ПочтовыеРассылки.ЗарегистрироватьРассылку(Адрес, Тема, Текст, "Открытие ЛК");
	Иначе
		РегистрыСведений.Логс_ПочтовыеРассылки.ОтправитьРассылкуАсинхронно(Адрес, Тема, Текст, "Открытие ЛК");
	КонецЕсли;		
КонецПроцедуры

Процедура Логс_ОповещениеОбИстекающемДМС() Экспорт
	
	Если Константы.ПараметрыБлокировкиРаботыСВнешнимиРесурсами.Получить().Получить().РаботаСВнешнимиРесурсамиЗаблокирована Тогда
		//ВызватьИсключение "В копиях баз запрещен обмен с CRM";
		Возврат; 
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ДанныеДляПодбораСотрудников.Сотрудник КАК Сотрудник,
	               |	ДанныеДляПодбораСотрудников.ФизическоеЛицо КАК ФизическоеЛицо,
	               |	МАКСИМУМ(ДанныеДляПодбораСотрудников.Начало) КАК Начало
	               |ПОМЕСТИТЬ ВТ_МаксСтатусы
	               |ИЗ
	               |	РегистрСведений.ДанныеДляПодбораСотрудников КАК ДанныеДляПодбораСотрудников
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ДанныеДляПодбораСотрудников.Сотрудник,
	               |	ДанныеДляПодбораСотрудников.ФизическоеЛицо
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ  Различные
	               |	Логс_ПолисыДМСФизическихЛицСрезПоследних.ФизическоеЛицо КАК ФизическоеЛицо,
	               |	Логс_ПолисыДМСФизическихЛицСрезПоследних.ДатаОкончанияПолиса КАК ДатаОкончанияПолиса,
	               |	РАЗНОСТЬДАТ(Логс_ПолисыДМСФизическихЛицСрезПоследних.ДатаОкончанияПолиса, &ТекущаяДата, ДЕНЬ) КАК ОсталосьДней
	               |ИЗ
	               |	РегистрСведений.Логс_ПолисыДМСФизическихЛиц.СрезПоследних КАК Логс_ПолисыДМСФизическихЛицСрезПоследних
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ДанныеДляПодбораСотрудников КАК ДанныеДляПодбораСотрудников
	               |			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_МаксСтатусы КАК ВТ_МаксСтатусы
	               |			ПО ДанныеДляПодбораСотрудников.Сотрудник = ВТ_МаксСтатусы.Сотрудник
	               |				И (ВТ_МаксСтатусы.Начало = ДанныеДляПодбораСотрудников.Начало)
	               |		ПО Логс_ПолисыДМСФизическихЛицСрезПоследних.ФизическоеЛицо = ДанныеДляПодбораСотрудников.ФизическоеЛицо
	               |ГДЕ
	               |	(ДанныеДляПодбораСотрудников.Окончание >= &ТекущаяДата
	               |			ИЛИ ДанныеДляПодбораСотрудников.Окончание = ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0))
	               |	И ДанныеДляПодбораСотрудников.ВидСобытия <> &ВидСобытияУвольнение
	               |	И Логс_ПолисыДМСФизическихЛицСрезПоследних.ДатаОкончанияПолиса > ДАТАВРЕМЯ(2000, 1, 1, 0, 0, 0)
	               |	И (Логс_ПолисыДМСФизическихЛицСрезПоследних.ДатаОкончанияПолиса < &ТекущаяДата
	               |			ИЛИ РАЗНОСТЬДАТ(Логс_ПолисыДМСФизическихЛицСрезПоследних.ДатаОкончанияПолиса, &ТекущаяДата, ДЕНЬ) В (30, 20, 10, 5, 3, 2, 1, 0))
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	ДатаОкончанияПолиса";
	ТекДата = НачалоДня(ТекущаяДата());
	Запрос.УстановитьПараметр("ТекущаяДата", ТекДата);
	Запрос.УстановитьПараметр("ВидСобытияУвольнение", Перечисления.ВидыКадровыхСобытий.Увольнение);
	
	Выборка = Запрос.Выполнить().Выбрать();
	ТекстПисьма = "";
	Пока Выборка.Следующий() Цикл
		ТекстПисьма = ТекстПисьма + Выборка.ФизическоеЛицо + " : " + Формат(Выборка.ДатаОкончанияПолиса, "ДФ=dd.MM.yyyy")+ " ("+?(Выборка.ДатаОкончанияПолиса>ТекДата, Выборка.ОсталосьДней + " дн.)", "просрочен)") + Символы.ПС;
	КонецЦикла;
	
	Если НЕ ТекстПисьма="" Тогда
		ТекстПисьма = "Добрый день!"+ Символы.ПС+ "У следующих сотрудников заканчивается срок действия полиса ДМС:" + Символы.ПС+ТекстПисьма;
		
		Адреса = Константы.Логс_АдресаРассылкиПоИстекающимСрокамДМС.Получить();
		РегистрыСведений.Логс_ПочтовыеРассылки.ОтправитьРассылкуСинхронно(Адреса, "Истекающие сроки полисов ДМС сотрудников", ТекстПисьма);
		
	КонецЕсли;
	
КонецПроцедуры

Процедура Логс_ФоноваяОтправкаРассылок() Экспорт
	Если Константы.ПараметрыБлокировкиРаботыСВнешнимиРесурсами.Получить().Получить().РаботаСВнешнимиРесурсамиЗаблокирована Тогда
		//ВызватьИсключение "В копиях баз запрещен обмен с CRM";
		Возврат; 
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	Логс_ПочтовыеРассылки.ДатаРассылки КАК ДатаРассылки,
	               |	Логс_ПочтовыеРассылки.УИД КАК УИД,
	               |	Логс_ПочтовыеРассылки.Рассылка КАК Рассылка,
	               |	Логс_ПочтовыеРассылки.Получатели КАК Получатели,
	               |	Логс_ПочтовыеРассылки.ТемаПисьма КАК ТемаПисьма,
	               |	Логс_ПочтовыеРассылки.ТекстПисьма КАК ТекстПисьма,
	               |	Логс_ПочтовыеРассылки.ДополнительныеДанные КАК ДополнительныеДанные,
	               |	Логс_ПочтовыеРассылки.Отправлена КАК Отправлена
	               |ИЗ
	               |	РегистрСведений.Логс_ПочтовыеРассылки КАК Логс_ПочтовыеРассылки
	               |ГДЕ
	               |	НЕ Логс_ПочтовыеРассылки.Отправлена
	               |	И Логс_ПочтовыеРассылки.ДатаРассылки <= &ТекущаяДата";
	Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДата());
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Адреса = СтрРазделить(Выборка.Получатели, "; ", Ложь);
		РегистрыСведений.Логс_ПочтовыеРассылки.ОтправитьРассылку_В2(Адреса, Выборка.ТемаПисьма, Выборка.ТекстПисьма,Выборка.ДополнительныеДанные, Выборка.Рассылка, Выборка.УИД);
		
	КонецЦикла;
КонецПроцедуры

