	Запрос = новый Запрос;
	Запрос.Текст =  ( "ВЫБРАТЬ
	                  |	Логс_СводЗаявокНаДоставкуЗаявки.Ссылка.Дата КАК Дата,
	                  |	ЕСТЬNULL(ДоговорыКонтрагентов.Логс_ИдентификаторCRM, ""0"") КАК ИдентификаторКлиента,
