Функция ПолучитьХабПоИД(ИДХаба) Экспорт
	тИД = ?(ТипЗнч(ИДХаба) = Тип("Строка"), ИДХаба, Строка(ИДХаба));
	Хаб = Справочники.Логс_Хабы.НайтиПоРеквизиту("ИД", тИД);
	Если Не ЗначениеЗаполнено(Хаб) Тогда
		Хаб = Справочники.Логс_Хабы.Москва;
	КонецЕсли;
		
	Возврат Хаб;
КонецФункции

