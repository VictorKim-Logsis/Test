Функция КодРегионаПринадлежитХабам(КодРегиона) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	КодыРегиона.КодРегиона КАК КодРегиона
	               |ИЗ
	               |	Справочник.Логс_Хабы.КодыРегиона КАК КодыРегиона
	               |ГДЕ
	               |	КодыРегиона.КодРегиона = &КодРегиона";
	Запрос.УстановитьПараметр("КодРегиона", КодРегиона);
	
	Результат = Запрос.Выполнить();
	Возврат НЕ Результат.Пустой();	
КонецФункции

Функция ПолучитьОсновнуюКассуХаба(Хаб, Организация) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	Кассы.Касса КАК Касса
	               |ИЗ
	               |	Справочник.Логс_Хабы.Кассы КАК Кассы
	               |ГДЕ
	               |	Кассы.Ссылка = &Хаб
	               |	И Кассы.Касса.Владелец = &Организация";
	Запрос.УстановитьПараметр("Хаб", Хаб);
	Запрос.УстановитьПараметр("Организация", Организация);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Касса;
	Иначе
		Возврат Справочники.Кассы.ПустаяСсылка();
	КонецЕсли;
КонецФункции

Функция ПолучитьХабСотрудника(Сотрудник) Экспорт
	Если ТипЗнч(Сотрудник) = Тип("СправочникСсылка.Сотрудники") Тогда
		Подразделение = Сотрудник.Подразделение;
		
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
		               |	ДанныеДляПодбораСотрудников.Подразделение КАК Подразделение,
		               |	МАКСИМУМ(Логс_ХабыПодразделения.Ссылка) КАК Хаб,
		               |	ДанныеДляПодбораСотрудников.Сотрудник КАК Сотрудник
		               |ИЗ
		               |	РегистрСведений.ДанныеДляПодбораСотрудников КАК ДанныеДляПодбораСотрудников
		               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Логс_Хабы.Подразделения КАК Логс_ХабыПодразделения
		               |		ПО ДанныеДляПодбораСотрудников.Подразделение = Логс_ХабыПодразделения.Подразделение
		               |ГДЕ
		               |	ДанныеДляПодбораСотрудников.Сотрудник = &Сотрудник
		               |	И ДанныеДляПодбораСотрудников.Начало <= &ТекущаяДата
		               |	И ДанныеДляПодбораСотрудников.Окончание >= &ТекущаяДата
		               |
		               |СГРУППИРОВАТЬ ПО
		               |	ДанныеДляПодбораСотрудников.Сотрудник,
		               |	ДанныеДляПодбораСотрудников.Подразделение
		               |
		               |УПОРЯДОЧИТЬ ПО
		               |	Подразделение УБЫВ";
		Запрос.УстановитьПараметр("Сотрудник", Сотрудник);
		Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДата());
		
		//Запрос.Текст = "ВЫБРАТЬ
		//               |	Ссылка КАК Хаб
		//               |ИЗ
		//               |	Справочник.Логс_Хабы.Подразделения КАК Подразделения
		//               |ГДЕ
		//               |	Подразделения.Подразделение = &Подразделение";
		//Запрос.УстановитьПараметр("Подразделение", Подразделение);
		
		Выборка = Запрос.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда
			Возврат Выборка.Хаб;
		Иначе
		    Возврат Справочники.Логс_Хабы.Москва;
		КонецЕсли;
	ИначеЕсли ТипЗнч(Сотрудник) = Тип("СправочникСсылка.ДоговорыКонтрагентов") Тогда
		Возврат ?(ЗначениеЗаполнено(Сотрудник.Логс_ХабКурьера), Сотрудник.Логс_ХабКурьера, Справочники.Логс_Хабы.Москва);
	ИначеЕсли ТипЗнч(Сотрудник) = Тип("СправочникСсылка.Контрагенты") Тогда
		Запрос.Текст = "ВЫБРАТЬ
		               |	ДоговорыКонтрагентов.Логс_ХабКурьера КАК Хаб
		               |ИЗ
		               |	Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
		               |ГДЕ
		               |	ДоговорыКонтрагентов.Контрагент = &Контрагент
		               |	И ДоговорыКонтрагентов.ДатаНачалаДействия < &ТекущаяДата
		               |	И ДоговорыКонтрагентов.ДатаОкончанияДействия > &ТекущаяДата
		               |	И ДоговорыКонтрагентов.Логс_ОбменСCRM
		               |	И ДоговорыКонтрагентов.Логс_ВидКлиентаCRM = Значение(Перечисление.Логс_ВидыКлиентовCRM.СамозанятыйКурьер)
		               |	И ДоговорыКонтрагентов.Статус = Значение(Перечисление.СтатусыДоговоровКонтрагентов.Действует)";
		Запрос.УстановитьПараметр("Контрагент", Сотрудник);
		Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДата());
		Выборка = Запрос.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда
			Возврат Выборка.Хаб;
		Иначе
		    Возврат Справочники.Логс_Хабы.Москва;
		КонецЕсли;
	ИначеЕсли ТипЗнч(Сотрудник) = Тип("СправочникСсылка.Партнеры") Тогда
		Запрос.Текст = "ВЫБРАТЬ
		               |	ДоговорыКонтрагентов.Логс_ХабКурьера КАК Хаб
		               |ИЗ
		               |	Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
		               |ГДЕ
		               |	ДоговорыКонтрагентов.Партнер = &Партнер
		               |	И ДоговорыКонтрагентов.ДатаНачалаДействия < &ТекущаяДата
		               |	И ДоговорыКонтрагентов.ДатаОкончанияДействия > &ТекущаяДата
		               |	И ДоговорыКонтрагентов.Логс_ОбменСCRM
		               |	И ДоговорыКонтрагентов.Логс_ВидКлиентаCRM = Значение(Перечисление.Логс_ВидыКлиентовCRM.СамозанятыйКурьер)
		               |	И ДоговорыКонтрагентов.Статус = Значение(Перечисление.СтатусыДоговоровКонтрагентов.Действует)";
		Запрос.УстановитьПараметр("Партнер", Сотрудник);
		Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДата());
		Выборка = Запрос.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда
			Возврат Выборка.Хаб;
		Иначе
		    Возврат Справочники.Логс_Хабы.Москва;
		КонецЕсли;
	КонецЕсли;
	
КонецФункции
#КонецОбласти 


