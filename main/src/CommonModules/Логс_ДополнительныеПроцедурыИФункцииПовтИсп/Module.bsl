Функция ДобавитьРабочиеДни(ПроизводственныйКалендарь, Дата, КоличествоРабочихДней) Экспорт
	КДень = Дата; //текущий календарный день
	КРД = 0; //количество рабочих дней
	ТРД = Дата;  //текущий рабочий день
	Пока КРД<КоличествоРабочихДней Цикл
		// добавляем 10 календарных дней к дате
		НачальныеДаты = Новый Массив;
		Для сч = 1 по 10 Цикл
			КДень = КонецДня(КДень) + 1;
			НачальныеДаты.Добавить(КДень);
		КонецЦикла;	
		// определяем рабочие дни
		РабочиеДни = КалендарныеГрафики.ДатыБлижайшихРабочихДней(ПроизводственныйКалендарь, НачальныеДаты, Истина, Ложь, Истина);
		Для Каждого КД из НачальныеДаты Цикл
			Если РабочиеДни[КД]>ТРД Тогда
				ТРД = РабочиеДни[КД];
				КРД = КРД+1;
			КонецЕсли;
			Если КРД = КоличествоРабочихДней Тогда
				Прервать;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	Возврат ТРД;
КонецФункции

Функция РассчитатьДатуФормированияСвода(Договор, РегиональнаяЗаявка, Дата, Статус, ОплачиваемаяЗаявка) Экспорт
	
	ДатаФормированияСвода = Неопределено;
	
	Если ЗначениеЗаполнено(Договор) Тогда
		ДанныеДоговора = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Договор,
			"Логс_ВключатьВозвратыВПоследнийСводМесяца," +
			"Логс_ВключатьОтменыВПоследнийСводМесяца," +
			"Логс_ПериодФормированияСводовАгента,Логс_СрокВыставленияСчетаЗаУслугиАгента," +
			"Логс_ПериодФормированияСводовАгентаРег,Логс_СрокВыставленияСчетаЗаУслугиАгентаРег");
		
		Если ДанныеДоговора.Логс_ВключатьВозвратыВПоследнийСводМесяца И
			(Статус = "Полн. отказ" или (Статус="Отмена" и ОплачиваемаяЗаявка)) Тогда
			Возврат КонецМесяца(Дата);
		КонецЕсли;
		Если ДанныеДоговора.Логс_ВключатьОтменыВПоследнийСводМесяца И
			(Статус="Отмена") Тогда
			Возврат КонецМесяца(Дата);
		КонецЕсли;
		
		ПериодФормированияСводов = Логс_ДоговорыАгентов.ПериодФормированияСводов(ДанныеДоговора, РегиональнаяЗаявка);
		СрокВыставленияСчетаЗаУслугиАгента = Логс_ДоговорыАгентов.СрокВыставленияСчетаЗаУслугиАгента(ДанныеДоговора, РегиональнаяЗаявка);
		                                                               
		ДатаОкончанияПериода =
			?(СрокВыставленияСчетаЗаУслугиАгента = Перечисления.Логс_СрокиВыставленияСчетаЗаУслугиАгента.Число_15_30
					И День(Дата) <= 15,
				КонецДня(Дата(Год(Дата), Месяц(Дата), 15)),
				КонецМесяца(Дата));
		
		Если ПериодФормированияСводов = Перечисления.Логс_ПериодыФормированияСводовАгентов.ДваРазаВНеделю Тогда
			ДниНедели = Новый Массив;
			ДниНедели.Добавить(3); // Среда
			ДниНедели.Добавить(7); // Воскресенье
			ДатаКонецНедели = Логс_ДополнительныеПроцедурыИФункции.ПолучитьБлижайшийДеньНедели(Дата, ДниНедели);
			ДатаФормированияСвода = Мин(ДатаКонецНедели, ДатаОкончанияПериода);
		ИначеЕсли ПериодФормированияСводов = Перечисления.Логс_ПериодыФормированияСводовАгентов.Еженедельно Тогда
			ДниНедели = Новый Массив;
			ДниНедели.Добавить(7); // Воскресенье
			ДатаКонецНедели = Логс_ДополнительныеПроцедурыИФункции.ПолучитьБлижайшийДеньНедели(Дата, ДниНедели);
			ДатаФормированияСвода = Мин(ДатаКонецНедели, ДатаОкончанияПериода);
		ИначеЕсли ПериодФормированияСводов = Перечисления.Логс_ПериодыФормированияСводовАгентов.ДваРазаВМесяц Тогда
			ДатаФормированияСвода = ?(День(Дата) <= 15,
							Дата(Год(Дата), Месяц(Дата), 15),
							КонецМесяца(Дата));
		ИначеЕсли ПериодФормированияСводов = Перечисления.Логс_ПериодыФормированияСводовАгентов.Ежедневно Тогда
			ДатаФормированияСвода = Дата;
		ИначеЕсли ПериодФормированияСводов = Перечисления.Логс_ПериодыФормированияСводовАгентов.Ежемесячно Тогда
			ДатаФормированияСвода = КонецМесяца(Дата);
		ИначеЕсли ПериодФормированияСводов = перечисления.Логс_ПериодыФормированияСводовАгентов.Декадно Тогда
			Год =  Год(Дата);
			Месяц = Месяц(Дата);   			
			Если Дата <= КонецДня(Дата(Год, Месяц, 10)) Тогда
				ДатаФормированияСвода = Дата(Год, Месяц, 10);
			ИначеЕсли Дата <= КонецДня(Дата(Год, Месяц, 20)) Тогда
				ДатаФормированияСвода = Дата(Год, Месяц, 20);
			Иначе
				ДатаФормированияСвода = КонецМесяца(Дата);	
			КонецЕсли;
		ИначеЕсли ПериодФормированияСводов = Перечисления.Логс_ПериодыФормированияСводовАгентов.ПоПятницам Тогда
			ДниНедели = Новый Массив;
			ДниНедели.Добавить(7); // Воскресенье
			ДатаКонецНедели = Логс_ДополнительныеПроцедурыИФункции.ПолучитьБлижайшийДеньНедели(Дата, ДниНедели);
			//ДниНедели.Очистить();
			//ДниНедели.Добавить(5); //пятница (следующая)
			//ДатаФормированияСвода = Логс_ДополнительныеПроцедурыИФункции.ПолучитьБлижайшийДеньНедели(
			//		Мин(ДатаКонецНедели, КонецМесяца(Дата)), ДниНедели);  //минимум из воскресенья и конца месяца и ближайшая пятника к нему
			ДатаФормированияСвода = Мин(ДатаКонецНедели, КонецМесяца(Дата));  
		КонецЕсли; 
		
	КонецЕсли; 
	
	Если Не ЗначениеЗаполнено(ДатаФормированияСвода) Тогда
		ДатаФормированияСвода = ТекущаяДатаСеанса();
	КонецЕсли; 
	
	Возврат ДатаФормированияСвода;
КонецФункции

Функция РассчитатьПериодУслугиДляСчета(РасчетнаяДата, СрокВыставления) Экспорт
	//Логс_СрокВыставленияСчетаЗаУслугиАгента
	СтруктураПериода = Новый Структура("НачалоПериода, ОкончаниеПериода", Дата(1,1,1), дата(31,1,1));
	
	Если СрокВыставления = Перечисления.Логс_СрокиВыставленияСчетаЗаУслугиАгента.Число30 Тогда
		СтруктураПериода.НачалоПериода = НачалоМесяца(РасчетнаяДата);
		СтруктураПериода.ОкончаниеПериода = КонецМесяца(РасчетнаяДата);
	ИначеЕсли СрокВыставления = Перечисления.Логс_СрокиВыставленияСчетаЗаУслугиАгента.Число_15_30 Тогда
		Если День(РасчетнаяДата)<16 Тогда
			СтруктураПериода.НачалоПериода = НачалоМесяца(РасчетнаяДата);
			СтруктураПериода.ОкончаниеПериода = КонецДня(Дата(Год(РасчетнаяДата), Месяц(РасчетнаяДата), 15));
		Иначе
			СтруктураПериода.НачалоПериода = Дата(Год(РасчетнаяДата), Месяц(РасчетнаяДата), 16);
			СтруктураПериода.ОкончаниеПериода = КонецМесяца(РасчетнаяДата);
		КонецЕсли;     
	ИначеЕсли СрокВыставления = Перечисления.Логс_СрокиВыставленияСчетаЗаУслугиАгента.Декадно Тогда  
		Если День(РасчетнаяДата)<11 Тогда
			СтруктураПериода.НачалоПериода = НачалоМесяца(РасчетнаяДата);
			СтруктураПериода.ОкончаниеПериода = КонецДня(Дата(Год(РасчетнаяДата), Месяц(РасчетнаяДата), 10));
		ИначеЕсли День(РасчетнаяДата)<21 Тогда
			СтруктураПериода.НачалоПериода = Дата(Год(РасчетнаяДата), Месяц(РасчетнаяДата), 11);
			СтруктураПериода.ОкончаниеПериода = КонецДня(Дата(Год(РасчетнаяДата), Месяц(РасчетнаяДата), 20));
		Иначе
			СтруктураПериода.НачалоПериода = Дата(Год(РасчетнаяДата), Месяц(РасчетнаяДата), 21);
			СтруктураПериода.ОкончаниеПериода = КонецМесяца(РасчетнаяДата);
		КонецЕсли;     
	ИначеЕсли СрокВыставления = Перечисления.Логс_СрокиВыставленияСчетаЗаУслугиАгента.РазаВМесяц4 Тогда  
		СтруктураПериода.НачалоПериода = НачалоНедели(РасчетнаяДата);
		СтруктураПериода.ОкончаниеПериода = КонецНедели(РасчетнаяДата);
	Иначе        
		//исключительная ситуация
		СтруктураПериода.НачалоПериода = НачалоДня(РасчетнаяДата);
		СтруктураПериода.ОкончаниеПериода = НачалоДня(РасчетнаяДата);
	КонецЕсли; 
	
	Возврат СтруктураПериода
КонецФункции
