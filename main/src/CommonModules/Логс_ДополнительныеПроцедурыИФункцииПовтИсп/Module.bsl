Функция ПолучитьСтавкуНДС(СтавкаНДС) Экспорт
		//Возврат УчетНДСУПКлиентСервер.ПолучитьСтавкуНДС(СтавкаНДС)
	Если СтавкаНДС = Перечисления.СтавкиНДС.НДС20 Тогда
		Возврат 20;
	//++ Ким Виктор 22.12.2025
	//Новая ставка НДС 22
	ИначеЕсли СтавкаНДС = Перечисления.СтавкиНДС.НДС22 Тогда 
		Возврат 22;
	//-- Ким Виктор 22.12.2025
	ИначеЕсли СтавкаНДС = Перечисления.СтавкиНДС.БезНДС Тогда
		Возврат 0; 
	ИначеЕсли СтавкаНДС = Перечисления.СтавкиНДС.НДС5 Тогда
		Возврат 5;
	ИначеЕсли ТипЗнч(СтавкаНДС) = Тип("СправочникСсылка.СтавкиНДС") Тогда
		Возврат УчетНДСУПВызовСервера.ЗначениеСтавкиНДС(СтавкаНДС);
	КонецЕсли;


